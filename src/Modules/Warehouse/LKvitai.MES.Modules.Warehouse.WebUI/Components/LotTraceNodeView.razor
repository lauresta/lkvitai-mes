@using LKvitai.MES.Modules.Warehouse.WebUI.Models
@inherits ComponentBase

@if (Node is not null)
{
    <div class="lot-trace-node pl-2">
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
            <MudChip Color="Color.Default" Size="Size.Small">@Node.NodeType.ToUpperInvariant()</MudChip>
            <MudText Typo="Typo.subtitle2">@Node.NodeName</MudText>
            <MudText Typo="Typo.caption" Class="mud-secondary-text">(@Node.NodeId)</MudText>
            <MudText Typo="Typo.caption" Class="mud-secondary-text">@Node.Timestamp.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</MudText>
        </MudStack>

        @if (Node.Children?.Count > 0)
        {
            <div class="pl-3 mt-2 lot-trace-branch">
                @foreach (var child in Node.Children)
                {
                    <LotTraceNodeView Node="child" />
                }
            </div>
        }
    </div>
}

@code {
    [Parameter, EditorRequired] public LotTraceNodeDto Node { get; set; } = new();
}
