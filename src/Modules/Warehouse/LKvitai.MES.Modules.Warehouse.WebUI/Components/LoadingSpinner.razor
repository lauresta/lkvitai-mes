@if (IsLoading)
{
    <MudOverlay Visible="true" DarkBackground="false" ZIndex="1300" Class="loading-spinner-overlay" data-testid="shared-loading-overlay">
        <MudProgressCircular Indeterminate="true" Color="Color.Primary" Size="Size.Large" data-testid="shared-loading-spinner" />
    </MudOverlay>
}

@code {
    [Parameter]
    public bool IsLoading { get; set; }
}
