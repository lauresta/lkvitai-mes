<MudPaper Class="pa-6 text-center" Outlined="true" data-testid="shared-empty-state">
    <MudIcon Icon="@Icon" Size="Size.Large" Color="Color.Secondary" Class="mb-2" />
    <MudText Typo="Typo.h6" Class="mb-2">@Title</MudText>
    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-3">@Message</MudText>
    @if (ShowAction)
    {
        <MudButton Variant="Variant.Outlined" Color="Color.Primary" OnClick="OnAction">@ActionLabel</MudButton>
    }
</MudPaper>

@code {
    [Parameter] public string Title { get; set; } = "No data";
    [Parameter] public string Message { get; set; } = "No records available.";
    [Parameter] public string Icon { get; set; } = Icons.Material.Filled.Inbox;
    [Parameter] public string ActionLabel { get; set; } = "Refresh";
    [Parameter] public EventCallback OnAction { get; set; }

    private bool ShowAction => OnAction.HasDelegate;
}
