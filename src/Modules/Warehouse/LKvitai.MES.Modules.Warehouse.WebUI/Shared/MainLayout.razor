@inherits LayoutComponentBase
@inject IWebHostEnvironment Environment

<MudLayout>
    <MudDrawer Class="sidebar"
               Variant="DrawerVariant.Responsive"
               Breakpoint="Breakpoint.Md"
               Width="250px"
               Elevation="1"
               @bind-Open="_drawerOpen"
               ClipMode="DrawerClipMode.Never">
        <NavMenu />
    </MudDrawer>

    <MudMainContent>
        <MudAppBar Elevation="1" Dense="true" Class="app-shell-bar" data-testid="warehouse-shell-appbar">
            <MudIconButton Icon="@Icons.Material.Filled.Menu"
                           Color="Color.Inherit"
                           Edge="Edge.Start"
                           Class="app-shell-menu"
                           OnClick="ToggleDrawer"
                           aria-label="Toggle menu" />

            <MudAvatar Image="https://avatars.githubusercontent.com/u/233164040?s=40&v=4"
                       Alt="LKvitai"
                       Rounded="true"
                       Size="Size.Medium"
                       Class="app-shell-mark" />

            <MudText Typo="Typo.h6" Class="app-shell-title">LKvitai.MES Warehouse</MudText>
            <MudSpacer />
            <MudText Typo="Typo.caption" Class="app-shell-env">@Environment.EnvironmentName</MudText>
            <MudButton Variant="Variant.Outlined"
                       Color="Color.Default"
                       Size="Size.Small"
                       Disabled="true"
                       Class="app-shell-login">Login</MudButton>
        </MudAppBar>

        <main class="app-shell-main" data-testid="warehouse-shell-main">
            @Body
        </main>
    </MudMainContent>
</MudLayout>

@code {
    private bool _drawerOpen = true;

    private void ToggleDrawer()
    {
        _drawerOpen = !_drawerOpen;
    }
}
