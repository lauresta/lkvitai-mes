@inject NavigationManager Navigation
@implements IDisposable

<MudNavMenu Class="pa-2" data-testid="warehouse-navmenu">
    <MudNavLink Href="/dashboard" Match="NavLinkMatch.All">
        <span><i class="bi bi-speedometer2 me-2"></i>Dashboard</span>
    </MudNavLink>

    @foreach (var grp in _sections)
    {
        <MudNavGroup Title="@grp.Label"
                     Expanded="@(_openSection == grp.Key)"
                     ExpandedChanged="expanded => OnSectionExpandedChanged(grp.Key, expanded)">
            @foreach (var item in grp.Items)
            {
                <MudNavLink Href="@item.Href" Match="NavLinkMatch.Prefix">
                    <span><i class="bi @item.Icon me-2"></i>@item.Label</span>
                </MudNavLink>
            }
        </MudNavGroup>
    }
</MudNavMenu>

@code {
    private string? _openSection;
    private string _currentUri = string.Empty;

    private record NavItem(string Href, string Icon, string Label);
    private record NavSection(string Key, string Label, string Icon, NavItem[] Items);

    protected override void OnInitialized()
    {
        _currentUri = Navigation.Uri;
        Navigation.LocationChanged += OnLocationChanged;
        _openSection = FindSectionForUri(_currentUri);
    }

    private void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        _currentUri = e.Location;
        var active = FindSectionForUri(_currentUri);
        if (active is not null)
        {
            _openSection = active;
        }

        InvokeAsync(StateHasChanged);
    }

    private void OnSectionExpandedChanged(string key, bool expanded)
    {
        _openSection = expanded ? key : (_openSection == key ? null : _openSection);
    }

    private string? FindSectionForUri(string uri)
    {
        foreach (var section in _sections)
        {
            if (section.Items.Any(i => uri.Contains(i.Href, StringComparison.OrdinalIgnoreCase)))
            {
                return section.Key;
            }
        }

        return null;
    }

    public void Dispose()
    {
        Navigation.LocationChanged -= OnLocationChanged;
    }

