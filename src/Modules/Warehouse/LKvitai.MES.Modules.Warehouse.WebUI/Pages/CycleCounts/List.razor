@page "/warehouse/cycle-counts"
@inject CycleCountsClient CycleCountsClient
@inject NavigationManager NavigationManager
@inject ToastService ToastService

<PageTitle>Cycle Counts - LKvitai.MES</PageTitle>

<h1 data-testid="cycle-counts-title">Cycle Counts</h1>

@if (_apiError is not null)
{
    <SharedErrorAlert Message="@BuildErrorMessage(_apiError)"
                 TraceId="@_apiError.TraceId"
                 OnRetry="LoadAsync"
                 OnDismiss="@(() => _apiError = null)" />
}

<MudPaper Elevation="2" Class="pa-4 position-relative">
    @if (_isLoading)
    {
        <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-3" />
    }
    <MudStack Row="true" Justify="Justify.FlexEnd" Class="mb-3">
        <MudButton Variant="Variant.Filled" Color="Color.Primary" Href="/warehouse/cycle-counts/schedule">Schedule Cycle Count</MudButton>
    </MudStack>

    @if (_rows.Count == 0)
    {
        <EmptyState Title="No cycle counts scheduled."
                    Message="Create a schedule to start counting."
                    Icon="@Icons.Material.Filled.AssignmentTurnedIn"
                    OnAction="OpenScheduleAsync" />
    }
    else
    {
        <MudTable Items="_rows" Hover="true" Dense="true">
            <HeaderContent>
                <MudTh>Count Number</MudTh>
                <MudTh>Scheduled Date</MudTh>
                <MudTh>Status</MudTh>
                <MudTh>ABC</MudTh>
                <MudTh>Assigned Operator</MudTh>
                <MudTh>Actions</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Count Number">@context.CountNumber</MudTd>
                <MudTd DataLabel="Scheduled Date">@context.ScheduledDate.ToLocalTime().ToString("yyyy-MM-dd")</MudTd>
                <MudTd DataLabel="Status"><MudChip Color="@GetStatusColor(context.Status)" Size="Size.Small">@context.Status</MudChip></MudTd>
                <MudTd DataLabel="ABC">@context.AbcClass</MudTd>
                <MudTd DataLabel="Assigned Operator">@context.AssignedOperator</MudTd>
                <MudTd DataLabel="Actions">
                    <MudStack Row="true" Spacing="1">
                        <MudButton Variant="Variant.Outlined" Size="Size.Small" Color="Color.Default" OnClick="() => OpenView(context.Id)">View</MudButton>
                        <MudButton Variant="Variant.Outlined" Size="Size.Small" Color="Color.Default" OnClick="() => OpenExecute(context.Id)">Execute</MudButton>
                        <MudButton Variant="Variant.Outlined" Size="Size.Small" Color="Color.Primary" OnClick="() => OpenDiscrepancies(context.Id)">Review Discrepancies</MudButton>
                    </MudStack>
                </MudTd>
            </RowTemplate>
        </MudTable>
    }
</MudPaper>

@code {
    private readonly List<CycleCountDto> _rows = [];
    private bool _isLoading;
    private ApiException? _apiError;

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _isLoading = true;
        _apiError = null;

        try
        {
            var rows = await CycleCountsClient.GetCycleCountsAsync();
            _rows.Clear();
            _rows.AddRange(rows);
        }
        catch (ApiException ex)
        {
            _apiError = ex;
            ToastService.ShowError(BuildErrorMessage(ex));
        }
        finally
        {
            _isLoading = false;
        }
    }

    private Task OpenScheduleAsync()
    {
        NavigationManager.NavigateTo("/warehouse/cycle-counts/schedule");
        return Task.CompletedTask;
    }

    private void OpenView(Guid id) => NavigationManager.NavigateTo($"/warehouse/cycle-counts/{id}/execute");

    private void OpenExecute(Guid id) => NavigationManager.NavigateTo($"/warehouse/cycle-counts/{id}/execute");

    private void OpenDiscrepancies(Guid id) => NavigationManager.NavigateTo($"/warehouse/cycle-counts/{id}/discrepancies");

    private static Color GetStatusColor(string status) => status.ToUpperInvariant() switch
    {
        "SCHEDULED" => Color.Warning,
        "IN_PROGRESS" => Color.Primary,
        "COMPLETED" => Color.Success,
        "CANCELLED" => Color.Error,
        _ => Color.Default
    };

    private static string BuildErrorMessage(ApiException ex)
    {
        if (!string.IsNullOrWhiteSpace(ex.UserMessage))
        {
            return ex.UserMessage;
        }

        return ex.ProblemDetails?.Detail
               ?? ex.ProblemDetails?.Title
               ?? "Cycle count request failed.";
    }
}
