@page "/warehouse/transfers"
@inject TransfersClient TransfersClient
@inject NavigationManager NavigationManager
@inject ToastService ToastService

<PageTitle>Transfers - LKvitai.MES</PageTitle>

<div data-testid="transfers-list-page">
    <MudText Typo="Typo.h5" Class="mb-3">Stock Transfers</MudText>

    @if (_apiError is not null)
    {
        <div data-testid="transfers-list-error" class="mb-3">
            <SharedErrorAlert Message="@BuildErrorMessage(_apiError)"
                         TraceId="@_apiError.TraceId"
                         OnRetry="LoadAsync"
                         OnDismiss="DismissError" />
        </div>
    }

    <MudPaper Class="pa-4 mb-4">
        <MudGrid Spacing="2" AlignItems="AlignItems.End">
            <MudItem xs="12" md="4">
                <MudSelect T="string"
                           Label="Status"
                           @bind-Value="_status"
                           Dense="true"
                           Variant="Variant.Outlined"
                           @attributes="StatusAttributes">
                    <MudSelectItem T="string" Value="@string.Empty">All</MudSelectItem>
                    <MudSelectItem T="string" Value="@("DRAFT")">DRAFT</MudSelectItem>
                    <MudSelectItem T="string" Value="@("PENDING_APPROVAL")">PENDING_APPROVAL</MudSelectItem>
                    <MudSelectItem T="string" Value="@("APPROVED")">APPROVED</MudSelectItem>
                    <MudSelectItem T="string" Value="@("IN_TRANSIT")">IN_TRANSIT</MudSelectItem>
                    <MudSelectItem T="string" Value="@("COMPLETED")">COMPLETED</MudSelectItem>
                    <MudSelectItem T="string" Value="@("CANCELLED")">CANCELLED</MudSelectItem>
                </MudSelect>
            </MudItem>
            <MudItem xs="12" md="8">
                <MudStack Row="true" Spacing="2" Justify="Justify.FlexEnd" Class="flex-wrap">
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               Disabled="@_isLoading"
                               OnClick="ApplyFilterAsync"
                               data-testid="transfers-list-apply">
                        Apply
                    </MudButton>
                    <MudButton Variant="Variant.Outlined"
                               Color="Color.Default"
                               Disabled="@_isLoading"
                               OnClick="ResetFilterAsync"
                               data-testid="transfers-list-reset">
                        Reset
                    </MudButton>
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Success"
                               OnClick="OpenCreate"
                               data-testid="transfers-list-create">
                        + Create Transfer
                    </MudButton>
                </MudStack>
            </MudItem>
        </MudGrid>
    </MudPaper>

    <MudPaper Class="pa-4 position-relative">
        @if (_isLoading || _isSubmitting)
        {
            <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-3" />
        }

        @if (_rows.Count == 0)
        {
            <div data-testid="transfers-list-empty">
                <EmptyState Title="No transfers found."
                            Message="Create your first transfer request."
                            Icon="@Icons.Material.Filled.SwapHoriz"
                            OnAction="OpenCreateAsync" />
            </div>
        }
        else
        {
            <MudTable T="TransferDto"
                      Items="_rows"
                      Dense="true"
                      Hover="true"
                      data-testid="transfers-list-grid">
                <HeaderContent>
                    <MudTh>Transfer</MudTh>
                    <MudTh>From</MudTh>
                    <MudTh>To</MudTh>
                    <MudTh>Status</MudTh>
                    <MudTh>Requested By</MudTh>
                    <MudTh>Actions</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Transfer">@context.TransferNumber</MudTd>
                    <MudTd DataLabel="From">@context.FromWarehouse</MudTd>
                    <MudTd DataLabel="To">@context.ToWarehouse</MudTd>
                    <MudTd DataLabel="Status">
                        <MudChip Size="Size.Small" Color="@GetStatusColor(context.Status)">@context.Status</MudChip>
                    </MudTd>
                    <MudTd DataLabel="Requested By">@context.RequestedBy</MudTd>
                    <MudTd DataLabel="Actions">
                        <MudStack Row="true" Spacing="1" Class="flex-wrap">
                            <MudButton Variant="Variant.Outlined" Size="Size.Small" Color="Color.Default" OnClick="() => OpenExecute(context.Id)">View</MudButton>
                            <MudButton Variant="Variant.Outlined" Size="Size.Small" Color="Color.Primary" Disabled="@(!CanSubmit(context) || _isSubmitting)" OnClick="() => SubmitAsync(context.Id)">Submit</MudButton>
                            <MudButton Variant="Variant.Filled" Size="Size.Small" Color="Color.Warning" Disabled="@(!CanApprove(context) || _isSubmitting)" OnClick="() => OpenApprove(context)">Approve</MudButton>
                            <MudButton Variant="Variant.Filled" Size="Size.Small" Color="Color.Success" Disabled="@(!CanExecute(context) || _isSubmitting)" OnClick="() => OpenExecute(context.Id)">Execute</MudButton>
                            <MudButton Variant="Variant.Text" Size="Size.Small" Color="Color.Error" Disabled="@_isSubmitting" OnClick="() => CancelAsync(context.TransferNumber)">Cancel</MudButton>
                        </MudStack>
                    </MudTd>
                </RowTemplate>
            </MudTable>
        }
    </MudPaper>

    @if (_approveModalTarget is not null)
    {
        <MudOverlay Visible="true" DarkBackground="true" AutoClose="false" Class="d-flex align-center justify-center">
            <MudPaper Class="pa-4" Style="width: min(520px, 95vw);" data-testid="transfers-list-approve-dialog">
                <MudText Typo="Typo.h6" Class="mb-2">Approve Transfer</MudText>
                <MudText Typo="Typo.body2" Class="mb-3">Transfer: <strong>@_approveModalTarget.TransferNumber</strong></MudText>

                <MudTextField T="string"
                              Label="Reason (optional)"
                              @bind-Value="_approveReason"
                              Variant="Variant.Outlined"
                              Lines="3"
                              @attributes="ApproveReasonAttributes" />

                <MudStack Row="true" Spacing="2" Justify="Justify.FlexEnd" Class="mt-4">
                    <MudButton Variant="Variant.Outlined" Color="Color.Default" OnClick="CloseApprove" Disabled="@_isSubmitting">Cancel</MudButton>
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               OnClick="ApproveAsync"
                               Disabled="@_isSubmitting"
                               data-testid="transfers-list-approve-confirm">
                        Approve
                    </MudButton>
                </MudStack>
            </MudPaper>
        </MudOverlay>
    }
</div>

@code {
    private readonly List<TransferDto> _rows = [];
    private ApiException? _apiError;
    private bool _isLoading;
    private bool _isSubmitting;
    private string _status = string.Empty;
    private TransferDto? _approveModalTarget;
    private string _approveReason = string.Empty;

    private static readonly Dictionary<string, object> StatusAttributes = new() { ["data-testid"] = "transfers-list-status" };
    private static readonly Dictionary<string, object> ApproveReasonAttributes = new() { ["data-testid"] = "transfers-list-approve-reason" };

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task ApplyFilterAsync()
    {
        await LoadAsync();
    }

    private async Task ResetFilterAsync()
    {
        _status = string.Empty;
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _isLoading = true;
        _apiError = null;

        try
        {
            var response = await TransfersClient.GetTransfersAsync(
                _status,
                null,
                null,
                1,
                200);

            _rows.Clear();
            _rows.AddRange(response.Items);
        }
        catch (ApiException ex)
        {
            _apiError = ex;
            ToastService.ShowError(BuildErrorMessage(ex));
        }
        finally
        {
            _isLoading = false;
        }
    }

    private bool CanSubmit(TransferDto row) => string.Equals(row.Status, "DRAFT", StringComparison.OrdinalIgnoreCase);

    private bool CanApprove(TransferDto row) => string.Equals(row.Status, "PENDING_APPROVAL", StringComparison.OrdinalIgnoreCase);

    private bool CanExecute(TransferDto row) => string.Equals(row.Status, "APPROVED", StringComparison.OrdinalIgnoreCase);

    private async Task SubmitAsync(Guid id)
    {
        _isSubmitting = true;
        try
        {
            await TransfersClient.SubmitTransferAsync(id, new SubmitTransferRequestDto { CommandId = Guid.NewGuid() });
            ToastService.ShowSuccess("Transfer submitted for approval.");
            await LoadAsync();
        }
        catch (ApiException ex)
        {
            ToastService.ShowError(BuildErrorMessage(ex));
        }
        finally
        {
            _isSubmitting = false;
        }
    }

    private void OpenApprove(TransferDto row)
    {
        _approveModalTarget = row;
        _approveReason = string.Empty;
    }

    private void CloseApprove()
    {
        _approveModalTarget = null;
        _approveReason = string.Empty;
    }

    private async Task ApproveAsync()
    {
        if (_approveModalTarget is null)
        {
            return;
        }

        _isSubmitting = true;
        try
        {
            await TransfersClient.ApproveTransferAsync(_approveModalTarget.Id, new ApproveTransferRequestDto
            {
                CommandId = Guid.NewGuid(),
                Reason = string.IsNullOrWhiteSpace(_approveReason) ? null : _approveReason.Trim()
            });

            ToastService.ShowSuccess("Transfer approved.");
            CloseApprove();
            await LoadAsync();
        }
        catch (ApiException ex)
        {
            ToastService.ShowError(BuildErrorMessage(ex));
        }
        finally
        {
            _isSubmitting = false;
        }
    }

    private Task CancelAsync(string transferNumber)
    {
        ToastService.ShowError($"Cancel action is not available for {transferNumber}.");
        return Task.CompletedTask;
    }

    private void OpenCreate()
    {
        NavigationManager.NavigateTo("/warehouse/transfers/create");
    }

    private Task OpenCreateAsync()
    {
        OpenCreate();
        return Task.CompletedTask;
    }

    private void OpenExecute(Guid id)
    {
        NavigationManager.NavigateTo($"/warehouse/transfers/{id}/execute");
    }

    private void DismissError()
    {
        _apiError = null;
    }

    private static Color GetStatusColor(string status) => status.ToUpperInvariant() switch
    {
        "DRAFT" => Color.Default,
        "PENDING_APPROVAL" => Color.Warning,
        "APPROVED" => Color.Info,
        "IN_TRANSIT" => Color.Primary,
        "COMPLETED" => Color.Success,
        "CANCELLED" => Color.Error,
        _ => Color.Default
    };

    private static string BuildErrorMessage(ApiException ex)
    {
        if (!string.IsNullOrWhiteSpace(ex.UserMessage))
        {
            return ex.UserMessage;
        }

        return ex.ProblemDetails?.Detail
               ?? ex.ProblemDetails?.Title
               ?? "Transfer request failed.";
    }
}
