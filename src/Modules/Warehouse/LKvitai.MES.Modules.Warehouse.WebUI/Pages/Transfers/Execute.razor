@page "/warehouse/transfers/{Id:guid}/execute"
@inject TransfersClient TransfersClient
@inject MasterDataAdminClient MasterDataAdminClient
@inject NavigationManager NavigationManager
@inject ToastService ToastService

<PageTitle>Execute Transfer - LKvitai.MES</PageTitle>

<div data-testid="transfers-execute-page">
    <MudText Typo="Typo.h5" Class="mb-3">Execute Transfer</MudText>

    @if (_apiError is not null)
    {
        <div data-testid="transfers-execute-error" class="mb-3">
            <ErrorBanner Message="@BuildErrorMessage(_apiError)"
                         TraceId="@_apiError.TraceId"
                         ShowRetry="@_apiError.IsRetryable"
                         OnRetry="LoadAsync"
                         OnDismiss="DismissError" />
        </div>
    }

    <MudPaper Class="pa-4 position-relative">
        <LoadingSpinner IsLoading="_isLoading || _isSubmitting" />

        @if (_transfer is null)
        {
            <div data-testid="transfers-execute-empty">
                <EmptyState Title="Transfer not found"
                            Message="Transfer does not exist or is unavailable."
                            IconCss="bi bi-arrow-left-right"
                            OnAction="BackToListAsync" />
            </div>
        }
        else
        {
            <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-3 flex-wrap" data-testid="transfers-execute-details">
                <MudStack Spacing="0">
                    <MudText Typo="Typo.h6">@_transfer.TransferNumber</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">@_transfer.FromWarehouse -> @_transfer.ToWarehouse</MudText>
                    <MudChip Size="Size.Small" Class="mt-1" Color="@GetStatusColor(_transfer.Status)">@_transfer.Status</MudChip>
                </MudStack>

                <MudStack Row="true" Spacing="1" Class="flex-wrap">
                    <MudButton Variant="Variant.Outlined"
                               Color="Color.Default"
                               Size="Size.Small"
                               OnClick="BackToList"
                               data-testid="transfers-execute-back">
                        Back
                    </MudButton>
                    <MudButton Variant="Variant.Outlined"
                               Color="Color.Default"
                               Size="Size.Small"
                               OnClick="LoadAsync"
                               data-testid="transfers-execute-refresh">
                        Refresh
                    </MudButton>
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               Size="Size.Small"
                               OnClick="OpenConfirm"
                               Disabled="@(!CanExecute || _isSubmitting)"
                               data-testid="transfers-execute-submit">
                        Execute
                    </MudButton>
                </MudStack>
            </MudStack>

            <MudTable T="TransferLineDto"
                      Items="_transfer.Lines"
                      Dense="true"
                      Hover="true"
                      data-testid="transfers-execute-grid">
                <HeaderContent>
                    <MudTh>Item</MudTh>
                    <MudTh>Qty</MudTh>
                    <MudTh>From Location</MudTh>
                    <MudTh>To Location</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Item">@GetItemName(context.ItemId)</MudTd>
                    <MudTd DataLabel="Qty">@context.Qty.ToString("0.##")</MudTd>
                    <MudTd DataLabel="From Location">@GetLocationName(context.FromLocationId)</MudTd>
                    <MudTd DataLabel="To Location">@GetLocationName(context.ToLocationId)</MudTd>
                </RowTemplate>
            </MudTable>
        }
    </MudPaper>

    @if (_confirmExecute)
    {
        <MudOverlay Visible="true" DarkBackground="true" AutoClose="false" Class="d-flex align-center justify-center">
            <MudPaper Class="pa-4" Style="width: min(480px, 95vw);" data-testid="transfers-execute-confirm-dialog">
                <MudText Typo="Typo.h6" Class="mb-2">Confirm Execution</MudText>
                <MudText Typo="Typo.body2">Execute transfer? Stock will be moved.</MudText>

                <MudStack Row="true" Justify="Justify.FlexEnd" Spacing="2" Class="mt-4">
                    <MudButton Variant="Variant.Outlined" Color="Color.Default" OnClick="CloseConfirm" Disabled="@_isSubmitting">Cancel</MudButton>
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               OnClick="ConfirmExecuteAsync"
                               Disabled="@_isSubmitting"
                               data-testid="transfers-execute-confirm">
                        Confirm
                    </MudButton>
                </MudStack>
            </MudPaper>
        </MudOverlay>
    }
</div>

@code {
    [Parameter]
    public Guid Id { get; set; }

    private TransferDto? _transfer;
    private ApiException? _apiError;
    private bool _isLoading;
    private bool _isSubmitting;
    private bool _confirmExecute;
    private readonly List<AdminItemDto> _items = [];
    private readonly List<AdminLocationDto> _locations = [];

    private bool CanExecute => string.Equals(_transfer?.Status, "APPROVED", StringComparison.OrdinalIgnoreCase);

    protected override async Task OnParametersSetAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _isLoading = true;
        _apiError = null;

        try
        {
            _transfer = await TransfersClient.GetTransferByIdAsync(Id);

            var items = await MasterDataAdminClient.GetItemsAsync(null, null, "Active", 1, 500);
            _items.Clear();
            _items.AddRange(items.Items);

            var locations = await MasterDataAdminClient.GetLocationsAsync(null, "Active", true, 1, 500);
            _locations.Clear();
            _locations.AddRange(locations.Items);
        }
        catch (ApiException ex)
        {
            _apiError = ex;
            _transfer = null;
            ToastService.ShowError(BuildErrorMessage(ex));
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void OpenConfirm()
    {
        _confirmExecute = true;
    }

    private void CloseConfirm()
    {
        _confirmExecute = false;
    }

    private async Task ConfirmExecuteAsync()
    {
        _isSubmitting = true;
        _apiError = null;

        try
        {
            await TransfersClient.ExecuteTransferAsync(
                Id,
                new ExecuteTransferRequestDto
                {
                    CommandId = Guid.NewGuid()
                });

            _confirmExecute = false;
            ToastService.ShowSuccess("Transfer executed successfully.");
            await LoadAsync();
        }
        catch (ApiException ex)
        {
            _confirmExecute = false;
            _apiError = ex;
            ToastService.ShowError(BuildErrorMessage(ex));
        }
        finally
        {
            _isSubmitting = false;
        }
    }

    private void BackToList()
    {
        NavigationManager.NavigateTo("/warehouse/transfers");
    }

    private Task BackToListAsync()
    {
        BackToList();
        return Task.CompletedTask;
    }

    private void DismissError()
    {
        _apiError = null;
    }

    private string GetItemName(int itemId)
        => _items.FirstOrDefault(i => i.Id == itemId) is { } item
            ? $"{item.InternalSKU} - {item.Name}"
            : $"#{itemId}";

    private string GetLocationName(int locationId)
        => _locations.FirstOrDefault(l => l.Id == locationId)?.Code
            ?? $"#{locationId}";

    private static Color GetStatusColor(string status) => status.ToUpperInvariant() switch
    {
        "DRAFT" => Color.Default,
        "PENDING_APPROVAL" => Color.Warning,
        "APPROVED" => Color.Info,
        "IN_TRANSIT" => Color.Primary,
        "COMPLETED" => Color.Success,
        "CANCELLED" => Color.Error,
        _ => Color.Default
    };

    private static string BuildErrorMessage(ApiException ex)
    {
        if (ex.IsBusinessError && !string.IsNullOrWhiteSpace(ex.ProblemDetails?.Detail))
        {
            return ex.ProblemDetails.Detail;
        }

        if (!string.IsNullOrWhiteSpace(ex.UserMessage))
        {
            return ex.UserMessage;
        }

        return ex.ProblemDetails?.Detail
               ?? ex.ProblemDetails?.Title
               ?? "Transfer request failed.";
    }
}
