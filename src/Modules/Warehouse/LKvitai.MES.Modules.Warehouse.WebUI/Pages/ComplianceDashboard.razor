@page "/warehouse/compliance/dashboard"
@inject ReportsClient ReportsClient
@inject ToastService Toast

<PageTitle>Compliance Dashboard</PageTitle>

<MudStack Spacing="2" data-testid="compliance-dashboard-page">
    <MudText Typo="Typo.h4">Compliance Dashboard</MudText>

    @if (_apiError is not null)
    {
        <div data-testid="compliance-dashboard-error">
            <SharedErrorAlert Message="@_apiError.UserMessage" TraceId="@_apiError.TraceId" OnRetry="LoadAsync" OnDismiss="DismissError" />
        </div>
    }

    <MudGrid Spacing="2">
        <MudItem xs="12" md="4">
            <MudPaper Outlined="true" Class="pa-4 h-100">
                <MudText Typo="Typo.caption" Class="mud-secondary-text">Pending Exports</MudText>
                <MudText Typo="Typo.h4">@_summary.PendingExports</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" md="4">
            <MudPaper Outlined="true" Class="pa-4 h-100">
                <MudText Typo="Typo.caption" Class="mud-secondary-text">Recent Lot Traces</MudText>
                <MudText Typo="Typo.h4">@_summary.RecentTraces</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" md="4">
            <MudPaper Outlined="true" Class="pa-4 h-100">
                <MudText Typo="Typo.caption" Class="mud-secondary-text">Variance Alerts</MudText>
                <MudText Typo="Typo.h4" Color="Color.Error">@_summary.VarianceAlerts</MudText>
            </MudPaper>
        </MudItem>
    </MudGrid>

    <MudGrid Spacing="2">
        <MudItem xs="12" lg="6">
            <MudPaper Outlined="true" Class="pa-4" data-testid="compliance-dashboard-form">
                @if (_isSaving)
                {
                    <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-3" />
                }

                <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-2">
                    <MudText Typo="Typo.h6">Schedule Report</MudText>
                    <MudButton Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small" Class="ms-auto" OnClick="ResetForm" data-testid="compliance-dashboard-reset">Reset</MudButton>
                </MudStack>

                <EditForm Model="@_form" OnValidSubmit="SaveAsync">
                    <DataAnnotationsValidator />
                    <ValidationSummary />

                    <MudStack Spacing="2">
                        <MudSelect T="string" Label="Report Type" Variant="Variant.Outlined" @bind-Value="_form.ReportType" data-testid="compliance-dashboard-report-type">
                            <MudSelectItem T="string" Value="@("VARIANCEANALYSIS")">VARIANCE_ANALYSIS</MudSelectItem>
                            <MudSelectItem T="string" Value="@("TRANSACTIONEXPORT")">TRANSACTION_EXPORT</MudSelectItem>
                            <MudSelectItem T="string" Value="@("LOTTRACE")">LOT_TRACE</MudSelectItem>
                        </MudSelect>

                        <MudTextField T="string" Label="Cron (UTC)" Variant="Variant.Outlined" @bind-Value="_form.Schedule" data-testid="compliance-dashboard-schedule" />

                        <MudTextField T="string" Label="Email Recipients (comma)" Variant="Variant.Outlined" @bind-Value="_form.EmailRecipients" data-testid="compliance-dashboard-emails" />

                        <MudSelect T="string" Label="Format" Variant="Variant.Outlined" @bind-Value="_form.Format" data-testid="compliance-dashboard-format">
                            <MudSelectItem T="string" Value="@("PDF")">PDF</MudSelectItem>
                            <MudSelectItem T="string" Value="@("CSV")">CSV</MudSelectItem>
                        </MudSelect>

                        <MudCheckBox T="bool" Label="Active" @bind-Value="_form.Active" data-testid="compliance-dashboard-active" />

                        <MudButton Variant="Variant.Filled" Color="Color.Primary" ButtonType="ButtonType.Submit" Disabled="@_isSaving" data-testid="compliance-dashboard-save">Save</MudButton>
                    </MudStack>
                </EditForm>
            </MudPaper>
        </MudItem>

        <MudItem xs="12" lg="6">
            <MudPaper Outlined="true" Class="pa-4 h-100" data-testid="compliance-dashboard-recent-grid">
                @if (_isLoading)
                {
                    <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-3" />
                }

                <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-2">
                    <MudText Typo="Typo.h6">Recent Scheduled Reports</MudText>
                    <MudButton Variant="Variant.Outlined" Color="Color.Secondary" Size="Size.Small" Class="ms-auto" OnClick="LoadAsync" Disabled="@_isLoading" data-testid="compliance-dashboard-refresh">Refresh</MudButton>
                </MudStack>

                <MudTable Items="_summary.RecentReports" Dense="true" Hover="true" Elevation="0">
                    <HeaderContent>
                        <MudTh>Type</MudTh>
                        <MudTh>Status</MudTh>
                        <MudTh>Generated</MudTh>
                        <MudTh>Action</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="Type">@context.ReportType</MudTd>
                        <MudTd DataLabel="Status">@context.Status</MudTd>
                        <MudTd DataLabel="Generated">@context.GeneratedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</MudTd>
                        <MudTd DataLabel="Action">
                            <MudButton Variant="Variant.Outlined" Color="Color.Secondary" Size="Size.Small" Href="@context.FilePath" Target="_blank">Download</MudButton>
                        </MudTd>
                    </RowTemplate>
                    <NoRecordsContent>
                        <MudText Typo="Typo.body2" Class="pa-2 mud-secondary-text">No reports yet.</MudText>
                    </NoRecordsContent>
                </MudTable>
            </MudPaper>
        </MudItem>
    </MudGrid>

    <MudPaper Outlined="true" Class="pa-4" data-testid="compliance-dashboard-grid">
        <MudText Typo="Typo.h6" Class="mb-2">Scheduled Jobs</MudText>

        <MudTable Items="_schedules" Dense="true" Hover="true" Elevation="0">
            <HeaderContent>
                <MudTh>ID</MudTh>
                <MudTh>Type</MudTh>
                <MudTh>Cron</MudTh>
                <MudTh>Format</MudTh>
                <MudTh>Status</MudTh>
                <MudTh>Last Run</MudTh>
                <MudTh></MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="ID">@context.Id</MudTd>
                <MudTd DataLabel="Type">@context.ReportType</MudTd>
                <MudTd DataLabel="Cron"><code>@context.Schedule</code></MudTd>
                <MudTd DataLabel="Format">@context.Format</MudTd>
                <MudTd DataLabel="Status">@context.LastStatus</MudTd>
                <MudTd DataLabel="Last Run">@(context.LastRunAt?.ToLocalTime().ToString("yyyy-MM-dd HH:mm") ?? "-")</MudTd>
                <MudTd DataLabel="Actions" Class="text-end">
                    <MudStack Row="true" Spacing="1" Justify="Justify.FlexEnd">
                        <MudButton Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small" OnClick="() => RunAsync(context.Id)" Disabled="@_isLoading">Run</MudButton>
                        <MudButton Variant="Variant.Outlined" Color="Color.Error" Size="Size.Small" OnClick="() => DeleteAsync(context.Id)" Disabled="@_isLoading">Delete</MudButton>
                    </MudStack>
                </MudTd>
            </RowTemplate>
            <NoRecordsContent>
                <MudText Typo="Typo.body2" Class="pa-2 mud-secondary-text">No schedules configured.</MudText>
            </NoRecordsContent>
        </MudTable>
    </MudPaper>
</MudStack>

@code {
    private ComplianceDashboardDto _summary = new();
    private List<ScheduledReportDto> _schedules = new();
    private bool _isLoading;
    private bool _isSaving;
    private ApiException? _apiError;

    private ScheduledReportForm _form = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _isLoading = true;
        _apiError = null;

        try
        {
            _summary = await ReportsClient.GetComplianceDashboardAsync();
            _schedules = (await ReportsClient.GetScheduledReportsAsync()).ToList();
        }
        catch (ApiException ex)
        {
            _apiError = ex;
            Toast.ShowError(ex.UserMessage);
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task SaveAsync()
    {
        _isSaving = true;
        try
        {
            var recipients = _form.EmailRecipients.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
            if (_form.Id == null)
            {
                await ReportsClient.CreateScheduledReportAsync(
                    _form.ReportType,
                    _form.Schedule,
                    recipients,
                    _form.Format,
                    _form.Active);
            }
            else
            {
                await ReportsClient.UpdateScheduledReportAsync(
                    _form.Id.Value,
                    _form.ReportType,
                    _form.Schedule,
                    recipients,
                    _form.Format,
                    _form.Active);
            }

            Toast.ShowSuccess("Scheduled report saved.");
            ResetForm();
            await LoadAsync();
        }
        catch (ApiException ex)
        {
            _apiError = ex;
            Toast.ShowError(ex.UserMessage);
        }
        finally
        {
            _isSaving = false;
        }
    }

    private async Task RunAsync(int id)
    {
        _isLoading = true;
        try
        {
            await ReportsClient.RunScheduledReportAsync(id);
            Toast.ShowSuccess("Report triggered.");
            await LoadAsync();
        }
        catch (ApiException ex)
        {
            _apiError = ex;
            Toast.ShowError(ex.UserMessage);
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task DeleteAsync(int id)
    {
        _isLoading = true;
        try
        {
            await ReportsClient.DeleteScheduledReportAsync(id);
            Toast.ShowSuccess("Deleted.");
            await LoadAsync();
        }
        catch (ApiException ex)
        {
            _apiError = ex;
            Toast.ShowError(ex.UserMessage);
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void ResetForm()
    {
        _form = new ScheduledReportForm();
    }

    private void DismissError()
    {
        _apiError = null;
    }

    private sealed class ScheduledReportForm
    {
        public int? Id { get; set; }
        public string ReportType { get; set; } = "VARIANCEANALYSIS";
        public string Schedule { get; set; } = "0 8 * * 1";
        public string EmailRecipients { get; set; } = string.Empty;
        public string Format { get; set; } = "PDF";
        public bool Active { get; set; } = true;
    }
}
