@page "/admin/locations"
@using Microsoft.AspNetCore.WebUtilities
@inject MasterDataAdminClient AdminClient
@inject StockClient StockClient
@inject ToastService ToastService
@inject NavigationManager NavigationManager

<PageTitle>Admin Locations - LKvitai.MES</PageTitle>

<h3>Locations Management</h3>

@if (_apiError is not null)
{
    <ErrorBanner Message="@BuildErrorMessage(_apiError)"
                 TraceId="@_apiError.TraceId"
                 OnRetry="ReloadAsync"
                 OnDismiss="@(() => _apiError = null)" />
}

<div class="card shadow-sm mb-3">
    <div class="card-body">
        <div class="row g-2 align-items-end">
            <div class="col-md-4">
                <label class="form-label">Search</label>
                <input class="form-control" @bind="_search" placeholder="Code or barcode" />
            </div>
            <div class="col-md-3">
                <label class="form-label">Status</label>
                <select class="form-select" @bind="_status">
                    <option value="">All</option>
                    <option value="Active">Active</option>
                    <option value="Blocked">Blocked</option>
                    <option value="Maintenance">Maintenance</option>
                </select>
            </div>
            <div class="col-md-3 d-flex align-items-center">
                <div class="form-check mt-4">
                    <input class="form-check-input" type="checkbox" @bind="_includeVirtual" />
                    <label class="form-check-label">Include virtual locations</label>
                </div>
            </div>
            <div class="col-md-2">
                <label class="form-label">Placement Warehouse</label>
                <select class="form-select" @bind="_placementWarehouseCode">
                    @foreach (var warehouse in _warehouses)
                    {
                        <option value="@warehouse.Code">@warehouse.Code</option>
                    }
                </select>
            </div>
            <div class="col-md-2 d-grid">
                <button class="btn btn-primary" @onclick="ApplyFiltersAsync">Filter</button>
            </div>
        </div>
    </div>
</div>

<div class="card shadow-sm mb-3 position-relative">
    <LoadingSpinner IsLoading="@_isLoading" />
    <div class="card-body">
        <div class="d-flex justify-content-between align-items-center mb-2">
            <strong>Total: @_totalCount</strong>
            <button class="btn btn-sm btn-outline-primary" @onclick="@(() => _showCreate = !_showCreate)">
                @(_showCreate ? "Hide Create Form" : "Create Location")
            </button>
        </div>

        <div class="table-responsive">
            <table class="table table-sm table-hover align-middle">
                <thead>
                <tr>
                    <th>Code</th>
                    <th>Barcode</th>
                    <th>Type</th>
                    <th>Parent</th>
                    <th>Status</th>
                    <th>Coordinates</th>
                    <th>Dimensions (m)</th>
                    <th>Address</th>
                    <th>Placement</th>
                    <th>Role</th>
                    <th>Capacity</th>
                    <th>Virtual</th>
                    <th></th>
                </tr>
                </thead>
                <tbody>
                @if (_locations.Count == 0)
                {
                    <tr>
                        <td colspan="13" class="text-muted">No locations found.</td>
                    </tr>
                }
                else
                {
                    @foreach (var row in _locations)
                    {
                        <tr>
                            <td>@row.Code</td>
                            <td>@row.Barcode</td>
                            <td>@row.Type</td>
                            <td>@ResolveParentCode(row.ParentLocationId)</td>
                            <td>@row.Status</td>
                            <td>@FormatCoordinates(row)</td>
                            <td>@FormatDimensions(row)</td>
                            <td>@FormatAddress(row)</td>
                            <td>@FormatPlacement(row)</td>
                            <td>@(row.LocationRole ?? "-")</td>
                            <td>@FormatCapacity(row)</td>
                            <td>@(row.IsVirtual ? "Yes" : "No")</td>
                            <td class="text-end">
                                <a class="btn btn-sm btn-outline-info me-1" href="@($"/warehouse/locations/{row.Id}")">View Details</a>
                                <button class="btn btn-sm btn-outline-secondary" @onclick="@(() => BeginEdit(row))">Edit</button>
                            </td>
                        </tr>
                    }
                }
                </tbody>
            </table>
        </div>

        @if (_totalCount > 0)
        {
            <Pagination CurrentPage="@_pageNumber"
                        TotalPages="@TotalPages"
                        PageSize="@_pageSize"
                        OnPageChanged="OnPageChangedAsync"
                        OnPageSizeChanged="OnPageSizeChangedAsync" />
        }
    </div>
</div>

@if (_showCreate)
{
    <div class="card shadow-sm mb-3">
        <div class="card-header">Create Location</div>
        <div class="card-body">
            <div class="row g-2">
                <div class="col-md-3">
                    <label class="form-label">Code</label>
                    <input class="form-control" @bind="_create.Code" />
                </div>
                <div class="col-md-3">
                    <label class="form-label">Barcode</label>
                    <input class="form-control" @bind="_create.Barcode" />
                </div>
                <div class="col-md-2">
                    <label class="form-label">Type</label>
                    <input class="form-control" @bind="_create.Type" />
                </div>
                <div class="col-md-2">
                    <label class="form-label">Parent Id</label>
                    <input class="form-control" type="number" @bind="_create.ParentLocationId" />
                </div>
                <div class="col-md-2">
                    <label class="form-label">Status</label>
                    <select class="form-select" @bind="_create.Status">
                        <option value="Active">Active</option>
                        <option value="Blocked">Blocked</option>
                        <option value="Maintenance">Maintenance</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label">Max Weight</label>
                    <input class="form-control" type="number" step="0.001" @bind="_create.MaxWeight" />
                </div>
                <div class="col-md-2">
                    <label class="form-label">Max Volume</label>
                    <input class="form-control" type="number" step="0.001" @bind="_create.MaxVolume" />
                </div>
                <div class="col-md-2">
                    <label class="form-label">Zone Type</label>
                    <select class="form-select" @bind="_create.ZoneType">
                        <option value="">-</option>
                        <option value="General">General</option>
                        <option value="Refrigerated">Refrigerated</option>
                        <option value="Hazmat">Hazmat</option>
                        <option value="Quarantine">Quarantine</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label">Coordinate X</label>
                    <input class="form-control" type="number" step="0.01" @bind="_create.CoordinateX" />
                </div>
                <div class="col-md-2">
                    <label class="form-label">Coordinate Y</label>
                    <input class="form-control" type="number" step="0.01" @bind="_create.CoordinateY" />
                </div>
                <div class="col-md-2">
                    <label class="form-label">Coordinate Z</label>
                    <input class="form-control" type="number" step="0.01" @bind="_create.CoordinateZ" />
                </div>
                <div class="col-md-2">
                    <label class="form-label">Width (m)</label>
                    <input class="form-control" type="number" step="0.001" @bind="_create.WidthMeters" />
                </div>
                <div class="col-md-2">
                    <label class="form-label">Length (m)</label>
                    <input class="form-control" type="number" step="0.001" @bind="_create.LengthMeters" />
                </div>
                <div class="col-md-2">
                    <label class="form-label">Height (m)</label>
                    <input class="form-control" type="number" step="0.001" @bind="_create.HeightMeters" />
                </div>
                <div class="col-md-2">
                    <label class="form-label">Aisle</label>
                    <input class="form-control" @bind="_create.Aisle" />
                </div>
                <div class="col-md-2">
                    <label class="form-label">Rack</label>
                    <input class="form-control" @bind="_create.Rack" />
                </div>
                <div class="col-md-2">
                    <label class="form-label">Level</label>
                    <input class="form-control" @bind="_create.Level" />
                </div>
                <div class="col-md-2">
                    <label class="form-label">Bin</label>
                    <input class="form-control" @bind="_create.Bin" />
                </div>
                <div class="col-md-2">
                    <label class="form-label">Capacity Weight</label>
                    <input class="form-control" type="number" step="0.001" @bind="_create.CapacityWeight" />
                </div>
                <div class="col-md-2">
                    <label class="form-label">Capacity Volume</label>
                    <input class="form-control" type="number" step="0.001" @bind="_create.CapacityVolume" />
                </div>
                <div class="col-md-2 d-flex align-items-end">
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" @bind="_create.IsVirtual" />
                        <label class="form-check-label">Virtual</label>
                    </div>
                </div>
                <div class="col-md-2 d-flex align-items-end">
                    <button class="btn btn-primary px-4" @onclick="CreateAsync">Save</button>
                </div>
            </div>
        </div>
    </div>
}

@if (_editing is not null)
{
    <div class="card shadow-sm">
        <div class="card-header d-flex justify-content-between align-items-center">
            <span>Edit Location: @_editing.Code</span>
            <button class="btn btn-sm btn-outline-secondary" @onclick="@(() => _editing = null)">Close</button>
        </div>
        <div class="card-body">
            <div class="row g-2">
                <div class="col-md-3">
                    <label class="form-label">Code</label>
                    <input class="form-control" @bind="_editing.Code" disabled="@_editing.IsVirtual" />
                </div>
                <div class="col-md-3">
                    <label class="form-label">Barcode</label>
                    <input class="form-control" @bind="_editing.Barcode" disabled="@_editing.IsVirtual" />
                </div>
                <div class="col-md-2">
                    <label class="form-label">Type</label>
                    <input class="form-control" @bind="_editing.Type" />
                </div>
                <div class="col-md-2">
                    <label class="form-label">Parent Id</label>
                    <input class="form-control" type="number" @bind="_editing.ParentLocationId" />
                </div>
                <div class="col-md-2">
                    <label class="form-label">Status</label>
                    <select class="form-select" @bind="_editing.Status">
                        <option value="Active">Active</option>
                        <option value="Blocked">Blocked</option>
                        <option value="Maintenance">Maintenance</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label">Max Weight</label>
                    <input class="form-control" type="number" step="0.001" @bind="_editing.MaxWeight" />
                </div>
                <div class="col-md-2">
                    <label class="form-label">Max Volume</label>
                    <input class="form-control" type="number" step="0.001" @bind="_editing.MaxVolume" />
                </div>
                <div class="col-md-2">
                    <label class="form-label">Zone Type</label>
                    <select class="form-select" @bind="_editing.ZoneType">
                        <option value="">-</option>
                        <option value="General">General</option>
                        <option value="Refrigerated">Refrigerated</option>
                        <option value="Hazmat">Hazmat</option>
                        <option value="Quarantine">Quarantine</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label">Coordinate X</label>
                    <input class="form-control" type="number" step="0.01" @bind="_editing.CoordinateX" />
                </div>
                <div class="col-md-2">
                    <label class="form-label">Coordinate Y</label>
                    <input class="form-control" type="number" step="0.01" @bind="_editing.CoordinateY" />
                </div>
                <div class="col-md-2">
                    <label class="form-label">Coordinate Z</label>
                    <input class="form-control" type="number" step="0.01" @bind="_editing.CoordinateZ" />
                </div>
                <div class="col-md-2">
                    <label class="form-label">Width (m)</label>
                    <input class="form-control" type="number" step="0.001" @bind="_editing.WidthMeters" />
                </div>
                <div class="col-md-2">
                    <label class="form-label">Length (m)</label>
                    <input class="form-control" type="number" step="0.001" @bind="_editing.LengthMeters" />
                </div>
                <div class="col-md-2">
                    <label class="form-label">Height (m)</label>
                    <input class="form-control" type="number" step="0.001" @bind="_editing.HeightMeters" />
                </div>
                <div class="col-md-2">
                    <label class="form-label">Aisle</label>
                    <input class="form-control" @bind="_editing.Aisle" />
                </div>
                <div class="col-md-2">
                    <label class="form-label">Rack</label>
                    <input class="form-control" @bind="_editing.Rack" />
                </div>
                <div class="col-md-2">
                    <label class="form-label">Level</label>
                    <input class="form-control" @bind="_editing.Level" />
                </div>
