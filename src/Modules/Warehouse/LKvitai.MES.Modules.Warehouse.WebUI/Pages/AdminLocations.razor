                    <label class="form-label">Bin</label>
                    <input class="form-control" @bind="_editing.Bin" />
                </div>
                <div class="col-md-2">
                    <label class="form-label">Capacity Weight</label>
                    <input class="form-control" type="number" step="0.001" @bind="_editing.CapacityWeight" />
                </div>
                <div class="col-md-2">
                    <label class="form-label">Capacity Volume</label>
                    <input class="form-control" type="number" step="0.001" @bind="_editing.CapacityVolume" />
