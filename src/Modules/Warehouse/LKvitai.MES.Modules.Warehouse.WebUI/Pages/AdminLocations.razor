                            <option value="Bulk">Bulk</option>
                            <option value="EndCap">EndCap</option>
                            <option value="Overflow">Overflow</option>
                            <option value="GroundSlot">GroundSlot</option>
                        </select>
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">Computed Address</label>
