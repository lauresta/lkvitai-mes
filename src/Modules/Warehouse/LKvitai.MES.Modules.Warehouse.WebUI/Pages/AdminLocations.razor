@page "/admin/locations"
@inject MasterDataAdminClient AdminClient
@inject ToastService ToastService

<PageTitle>Admin Locations - LKvitai.MES</PageTitle>

<div data-testid="admin-locations-page">
<h3>Locations Management</h3>

@if (_apiError is not null)
{
    <SharedErrorAlert Message="@BuildErrorMessage(_apiError)"
                 TraceId="@_apiError.TraceId"
                 OnRetry="ReloadAsync"
                 OnDismiss="@(() => _apiError = null)" />
}

<div class="mud-surface shadow-sm mb-3">
    <div class="mud-surface-body">
        <div class="mud-grid-mrow g-2 align-items-end">
            <div class="mud-grid-col">
                <label class="form-label">Search</label>
                <input class="mud-input-base" @bind="_search" placeholder="Code or barcode" />
            </div>
            <div class="mud-grid-col">
                <label class="form-label">Status</label>
                <select class="mud-input-base" @bind="_status">
                    <option value="">All</option>
                    <option value="Active">Active</option>
                    <option value="Blocked">Blocked</option>
                    <option value="Maintenance">Maintenance</option>
                </select>
            </div>
            <div class="mud-grid-col d-flex align-items-center">
                <div class="form-check mt-4">
                    <input class="form-check-input" type="checkbox" @bind="_includeVirtual" />
                    <label class="form-check-label">Include virtual locations</label>
                </div>
            </div>
            <div class="mud-grid-col d-grid">
                <button class="mud-mbtn-base mud-mbtn-primary" @onclick="ApplyFiltersAsync">Filter</button>
            </div>
        </div>
    </div>
</div>

<div class="mud-surface shadow-sm mb-3 position-relative">
     (@_isLoading)
        {
            <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-3" />
        }
    <div class="mud-surface-body">
        <div class="d-flex justify-content-between align-items-center mb-2">
            <strong>Total: @_totalCount</strong>
            <button class="mud-mbtn-base mud-mbtn-sm mud-mbtn-outline-primary" @onclick="@(() => _showCreate = !_showCreate)">
                @(_showCreate ? "Hide Create Form" : "Create Location")
            </button>
        </div>

        <div class="overflow-auto" data-testid="admin-locations-grid">
            <table class="mud-mtbl-base mud-mtbl-dense mtbl-hover align-middle">
                <thead>
                <tr>
                    <th>Code</th>
                    <th>Barcode</th>
                    <th>Type</th>
                    <th>Parent</th>
                    <th>Status</th>
                    <th>Coordinates</th>
                    <th>Dimensions (m)</th>
                    <th>Address</th>
                    <th>Capacity</th>
                    <th>Virtual</th>
                    <th></th>
                </tr>
                </thead>
                <tbody>
                @if (_locations.Count == 0)
                {
                    <tr>
                        <td colspan="11" class="text-muted">No locations found.</td>
                    </tr>
                }
                else
                {
                    @foreach (var mrow in _locations)
                    {
                        <tr>
                            <td>@mrow.Code</td>
                            <td>@mrow.Barcode</td>
                            <td>@mrow.Type</td>
                            <td>@ResolveParentCode(mrow.ParentLocationId)</td>
                            <td>@mrow.Status</td>
                            <td>@FormatCoordinates(mrow)</td>
                            <td>@FormatDimensions(mrow)</td>
                            <td>@FormatAddress(mrow)</td>
                            <td>@FormatCapacity(mrow)</td>
                            <td>@(mrow.IsVirtual ? "Yes" : "No")</td>
                            <td class="text-end">
                                <a class="mud-mbtn-base mud-mbtn-sm mbtn-outline-info me-1" href="@($"/warehouse/locations/{mrow.Id}")">View Details</a>
                                <button class="mud-mbtn-base mud-mbtn-sm mud-mbtn-outline-secondary" @onclick="@(() => BeginEdit(mrow))">Edit</button>
                            </td>
                        </tr>
                    }
                }
                </tbody>
            </table>
        </div>

        @if (_totalCount > 0)
        {
            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.FlexEnd" Class="mt-3" data-testid="admin-locations-pager">
                <MudSelect T="int"
                           Label="Page size"
                           Value="_pageSize"
                           ValueChanged="OnPageSizeChangedAsync"
                           Variant="Variant.Outlined"
                           Dense="true"
                           Style="width: 120px;"
                           @attributes="PageSizeAttributes">
                    <MudSelectItem Value="25">25</MudSelectItem>
                    <MudSelectItem Value="50">50</MudSelectItem>
                    <MudSelectItem Value="100">100</MudSelectItem>
                </MudSelect>
                <MudPagination Count="@TotalPages"
                               Selected="@_pageNumber"
                               SelectedChanged="OnPageChangedAsync"
                               Variant="Variant.Outlined"
                               Color="Color.Primary"
                               Size="Size.Small"
                               Class="ml-2" />
            </MudStack>
        }
    </div>
</div>

@if (_showCreate)
{
    <div class="mud-surface shadow-sm mb-3">
        <div class="mud-surface-header">Create Location</div>
        <div class="mud-surface-body">
            <div class="mud-grid-mrow g-2">
                <div class="mud-grid-col">
                    <label class="form-label">Code</label>
                    <input class="mud-input-base" @bind="_create.Code" />
                </div>
                <div class="mud-grid-col">
                    <label class="form-label">Barcode</label>
                    <input class="mud-input-base" @bind="_create.Barcode" />
                </div>
                <div class="mud-grid-col">
                    <label class="form-label">Type</label>
                    <input class="mud-input-base" @bind="_create.Type" />
                </div>
                <div class="mud-grid-col">
                    <label class="form-label">Parent Id</label>
                    <input class="mud-input-base" type="number" @bind="_create.ParentLocationId" />
                </div>
                <div class="mud-grid-col">
                    <label class="form-label">Status</label>
                    <select class="mud-input-base" @bind="_create.Status">
                        <option value="Active">Active</option>
                        <option value="Blocked">Blocked</option>
                        <option value="Maintenance">Maintenance</option>
                    </select>
                </div>
                <div class="mud-grid-col">
                    <label class="form-label">Max Weight</label>
                    <input class="mud-input-base" type="number" step="0.001" @bind="_create.MaxWeight" />
                </div>
                <div class="mud-grid-col">
                    <label class="form-label">Max Volume</label>
                    <input class="mud-input-base" type="number" step="0.001" @bind="_create.MaxVolume" />
                </div>
                <div class="mud-grid-col">
                    <label class="form-label">Zone Type</label>
                    <select class="mud-input-base" @bind="_create.ZoneType">
                        <option value="">-</option>
                        <option value="General">General</option>
                        <option value="Refrigerated">Refrigerated</option>
                        <option value="Hazmat">Hazmat</option>
                        <option value="Quarantine">Quarantine</option>
                    </select>
                </div>
                <div class="mud-grid-col">
                    <label class="form-label">Coordinate X</label>
                    <input class="mud-input-base" type="number" step="0.01" @bind="_create.CoordinateX" />
                </div>
                <div class="mud-grid-col">
                    <label class="form-label">Coordinate Y</label>
                    <input class="mud-input-base" type="number" step="0.01" @bind="_create.CoordinateY" />
                </div>
                <div class="mud-grid-col">
                    <label class="form-label">Coordinate Z</label>
                    <input class="mud-input-base" type="number" step="0.01" @bind="_create.CoordinateZ" />
                </div>
                <div class="mud-grid-col">
                    <label class="form-label">Width (m)</label>
                    <input class="mud-input-base" type="number" step="0.001" @bind="_create.WidthMeters" />
                </div>
                <div class="mud-grid-col">
                    <label class="form-label">Length (m)</label>
                    <input class="mud-input-base" type="number" step="0.001" @bind="_create.LengthMeters" />
                </div>
                <div class="mud-grid-col">
                    <label class="form-label">Height (m)</label>
                    <input class="mud-input-base" type="number" step="0.001" @bind="_create.HeightMeters" />
                </div>
                <div class="mud-grid-col">
                    <label class="form-label">Aisle</label>
                    <input class="mud-input-base" @bind="_create.Aisle" />
                </div>
                <div class="mud-grid-col">
                    <label class="form-label">Rack</label>
                    <input class="mud-input-base" @bind="_create.Rack" />
                </div>
                <div class="mud-grid-col">
                    <label class="form-label">Level</label>
                    <input class="mud-input-base" @bind="_create.Level" />
                </div>
                <div class="mud-grid-col">
                    <label class="form-label">Bin</label>
                    <input class="mud-input-base" @bind="_create.Bin" />
                </div>
                <div class="mud-grid-col">
                    <label class="form-label">Capacity Weight</label>
                    <input class="mud-input-base" type="number" step="0.001" @bind="_create.CapacityWeight" />
                </div>
                <div class="mud-grid-col">
                    <label class="form-label">Capacity Volume</label>
                    <input class="mud-input-base" type="number" step="0.001" @bind="_create.CapacityVolume" />
                </div>
                <div class="mud-grid-col d-flex align-items-end">
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" @bind="_create.IsVirtual" />
                        <label class="form-check-label">Virtual</label>
                    </div>
                </div>
                <div class="mud-grid-col d-flex align-items-end">
                    <button class="mud-mbtn-base mud-mbtn-primary px-4" @onclick="CreateAsync">Save</button>
                </div>
            </div>
        </div>
    </div>
}
</div>

@if (_editing is not null)
{
    <div class="mud-surface shadow-sm">
        <div class="mud-surface-header d-flex justify-content-between align-items-center">
            <span>Edit Location: @_editing.Code</span>
            <button class="mud-mbtn-base mud-mbtn-sm mud-mbtn-outline-secondary" @onclick="@(() => _editing = null)">Close</button>
        </div>
        <div class="mud-surface-body">
            <div class="mud-grid-mrow g-2">
                <div class="mud-grid-col">
                    <label class="form-label">Code</label>
                    <input class="mud-input-base" @bind="_editing.Code" disabled="@_editing.IsVirtual" />
                </div>
                <div class="mud-grid-col">
                    <label class="form-label">Barcode</label>
                    <input class="mud-input-base" @bind="_editing.Barcode" disabled="@_editing.IsVirtual" />
                </div>
                <div class="mud-grid-col">
                    <label class="form-label">Type</label>
                    <input class="mud-input-base" @bind="_editing.Type" />
                </div>
                <div class="mud-grid-col">
                    <label class="form-label">Parent Id</label>
                    <input class="mud-input-base" type="number" @bind="_editing.ParentLocationId" />
                </div>
                <div class="mud-grid-col">
                    <label class="form-label">Status</label>
                    <select class="mud-input-base" @bind="_editing.Status">
                        <option value="Active">Active</option>
                        <option value="Blocked">Blocked</option>
                        <option value="Maintenance">Maintenance</option>
                    </select>
                </div>
                <div class="mud-grid-col">
                    <label class="form-label">Max Weight</label>
                    <input class="mud-input-base" type="number" step="0.001" @bind="_editing.MaxWeight" />
                </div>
                <div class="mud-grid-col">
                    <label class="form-label">Max Volume</label>
                    <input class="mud-input-base" type="number" step="0.001" @bind="_editing.MaxVolume" />
                </div>
                <div class="mud-grid-col">
                    <label class="form-label">Zone Type</label>
                    <select class="mud-input-base" @bind="_editing.ZoneType">
                        <option value="">-</option>
                        <option value="General">General</option>
                        <option value="Refrigerated">Refrigerated</option>
                        <option value="Hazmat">Hazmat</option>
                        <option value="Quarantine">Quarantine</option>
                    </select>
                </div>
                <div class="mud-grid-col">
                    <label class="form-label">Coordinate X</label>
                    <input class="mud-input-base" type="number" step="0.01" @bind="_editing.CoordinateX" />
                </div>
                <div class="mud-grid-col">
                    <label class="form-label">Coordinate Y</label>
                    <input class="mud-input-base" type="number" step="0.01" @bind="_editing.CoordinateY" />
                </div>
                <div class="mud-grid-col">
                    <label class="form-label">Coordinate Z</label>
                    <input class="mud-input-base" type="number" step="0.01" @bind="_editing.CoordinateZ" />
                </div>
                <div class="mud-grid-col">
                    <label class="form-label">Width (m)</label>
                    <input class="mud-input-base" type="number" step="0.001" @bind="_editing.WidthMeters" />
                </div>
                <div class="mud-grid-col">
                    <label class="form-label">Length (m)</label>
                    <input class="mud-input-base" type="number" step="0.001" @bind="_editing.LengthMeters" />
                </div>
                <div class="mud-grid-col">
                    <label class="form-label">Height (m)</label>
                    <input class="mud-input-base" type="number" step="0.001" @bind="_editing.HeightMeters" />
                </div>
                <div class="mud-grid-col">
                    <label class="form-label">Aisle</label>
                    <input class="mud-input-base" @bind="_editing.Aisle" />
                </div>
                <div class="mud-grid-col">
                    <label class="form-label">Rack</label>
                    <input class="mud-input-base" @bind="_editing.Rack" />
                </div>
                <div class="mud-grid-col">
                    <label class="form-label">Level</label>
                    <input class="mud-input-base" @bind="_editing.Level" />
                </div>
                <div class="mud-grid-col">
                    <label class="form-label">Bin</label>
                    <input class="mud-input-base" @bind="_editing.Bin" />
                </div>
                <div class="mud-grid-col">
                    <label class="form-label">Capacity Weight</label>
                    <input class="mud-input-base" type="number" step="0.001" @bind="_editing.CapacityWeight" />
                </div>
                <div class="mud-grid-col">
                    <label class="form-label">Capacity Volume</label>
                    <input class="mud-input-base" type="number" step="0.001" @bind="_editing.CapacityVolume" />
                </div>
                <div class="mud-grid-col d-flex align-items-end">
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" @bind="_editing.IsVirtual" disabled />
                        <label class="form-check-label">Virtual</label>
                    </div>
                </div>
                <div class="mud-grid-col d-flex align-items-end">
                    <button class="mud-mbtn-base mud-mbtn-primary px-4" @onclick="UpdateAsync">Save</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private readonly List<AdminLocationDto> _locations = [];

    private string? _search;
    private string? _status;
    private bool _includeVirtual = true;
    private int _pageNumber = 1;
    private int _pageSize = 50;
    private int _totalCount;
    private bool _isLoading;
    private bool _showCreate;
    private ApiException? _apiError;
    private static readonly Dictionary<string, object> PageSizeAttributes = new() { ["data-testid"] = "admin-locations-page-size" };

    private LocationFormModel _create = new();
    private LocationEditFormModel? _editing;

    private int TotalPages => Math.Max(1, (int)Math.Ceiling(_totalCount / (double)Math.Max(1, _pageSize)));

    protected override async Task OnInitializedAsync()
    {
        await ReloadAsync();
    }

    private async Task ReloadAsync()
    {
        _isLoading = true;
        _apiError = null;

        try
        {
            await LoadLocationsAsync();
        }
        catch (ApiException ex)
        {
            _apiError = ex;
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task ApplyFiltersAsync()
    {
        _pageNumber = 1;
        await LoadLocationsAsync();
    }

    private async Task LoadLocationsAsync()
    {
        var result = await AdminClient.GetLocationsAsync(
            _search,
            _status,
            _includeVirtual,
            _pageNumber,
            _pageSize);

        _locations.Clear();
        _locations.AddRange(result.Items);
        _totalCount = result.TotalCount;

        if (_create.ParentLocationId is null && _locations.Count > 0)
        {
            _create.ParentLocationId = _locations[0].Id;
        }
    }

    private string ResolveParentCode(int? parentId)
    {
        if (!parentId.HasValue)
        {
            return "-";
        }

        return _locations.FirstOrDefault(x => x.Id == parentId.Value)?.Code ?? parentId.Value.ToString();
    }

    private static string FormatCoordinates(AdminLocationDto mrow)
    {
        if (!mrow.CoordinateX.HasValue || !mrow.CoordinateY.HasValue || !mrow.CoordinateZ.HasValue)
        {
            return "-";
        }

        return $"{mrow.CoordinateX.Value:0.##}, {mrow.CoordinateY.Value:0.##}, {mrow.CoordinateZ.Value:0.##}";
    }

    private static string FormatDimensions(AdminLocationDto mrow)
    {
        if (!mrow.WidthMeters.HasValue || !mrow.LengthMeters.HasValue || !mrow.HeightMeters.HasValue)
        {
            return "-";
        }

        return $"{mrow.WidthMeters.Value:0.###} x {mrow.LengthMeters.Value:0.###} x {mrow.HeightMeters.Value:0.###}";
    }

    private static string FormatAddress(AdminLocationDto mrow)
    {
        var parts = new[] { mrow.Aisle, mrow.Rack, mrow.Level, mrow.Bin }
            .Where(static x => !string.IsNullOrWhiteSpace(x))
            .ToArray();

        return parts.Length == 0 ? "-" : string.Join("-", parts);
    }

    private static string FormatCapacity(AdminLocationDto mrow)
    {
        if (!mrow.CapacityWeight.HasValue && !mrow.CapacityVolume.HasValue)
        {
            return "-";
        }

        var weight = mrow.CapacityWeight?.ToString("0.###") ?? "-";
        var volume = mrow.CapacityVolume?.ToString("0.###") ?? "-";
        return $"W:{weight} / V:{volume}";
    }

    private async Task OnPageChangedAsync(int page)
    {
        _pageNumber = Math.Max(1, page);
        await LoadLocationsAsync();
    }

    private async Task OnPageSizeChangedAsync(int size)
    {
        _pageSize = Math.Clamp(size, 1, 500);
        _pageNumber = 1;
        await LoadLocationsAsync();
    }

    private async Task CreateAsync()
    {
        try
        {
            _apiError = null;
            await AdminClient.CreateLocationAsync(_create.ToRequest());
            ToastService.ShowSuccess("Location created.");
            _create = new LocationFormModel();
            await LoadLocationsAsync();
        }
        catch (ApiException ex)
        {
            _apiError = ex;
            ToastService.ShowError(BuildErrorMessage(ex));
        }
    }

    private void BeginEdit(AdminLocationDto mrow)
    {
        _editing = new LocationEditFormModel
        {
            Id = mrow.Id,
            Code = mrow.Code,
            Barcode = mrow.Barcode,
            Type = mrow.Type,
            ParentLocationId = mrow.ParentLocationId,
            IsVirtual = mrow.IsVirtual,
            MaxWeight = mrow.MaxWeight,
            MaxVolume = mrow.MaxVolume,
            Status = mrow.Status,
            ZoneType = mrow.ZoneType,
            CoordinateX = mrow.CoordinateX,
            CoordinateY = mrow.CoordinateY,
            CoordinateZ = mrow.CoordinateZ,
            WidthMeters = mrow.WidthMeters,
            LengthMeters = mrow.LengthMeters,
            HeightMeters = mrow.HeightMeters,
            Aisle = mrow.Aisle,
            Rack = mrow.Rack,
            Level = mrow.Level,
            Bin = mrow.Bin,
            CapacityWeight = mrow.CapacityWeight,
            CapacityVolume = mrow.CapacityVolume
        };
    }

    private async Task UpdateAsync()
    {
        if (_editing is null)
        {
            return;
        }

        try
        {
            _apiError = null;
            await AdminClient.UpdateLocationAsync(_editing.Id, _editing.ToRequest());
            ToastService.ShowSuccess("Location updated.");
            _editing = null;
            await LoadLocationsAsync();
        }
        catch (ApiException ex)
        {
            _apiError = ex;
            ToastService.ShowError(BuildErrorMessage(ex));
        }
    }

    private static string BuildErrorMessage(ApiException error)
    {
        if (!string.IsNullOrWhiteSpace(error.ProblemDetails?.Detail))
        {
            return $"{error.UserMessage} {error.ProblemDetails.Detail}";
        }

        return error.UserMessage;
    }

    private class LocationFormModel
    {
        public string Code { get; set; } = string.Empty;
        public string Barcode { get; set; } = string.Empty;
        public string Type { get; set; } = "Bin";
        public int? ParentLocationId { get; set; }
        public bool IsVirtual { get; set; }
        public decimal? MaxWeight { get; set; }
        public decimal? MaxVolume { get; set; }
        public string Status { get; set; } = "Active";
        public string? ZoneType { get; set; }
        public decimal? CoordinateX { get; set; }
        public decimal? CoordinateY { get; set; }
        public decimal? CoordinateZ { get; set; }
        public decimal? WidthMeters { get; set; }
        public decimal? LengthMeters { get; set; }
        public decimal? HeightMeters { get; set; }
        public string? Aisle { get; set; }
        public string? Rack { get; set; }
        public string? Level { get; set; }
        public string? Bin { get; set; }
        public decimal? CapacityWeight { get; set; }
        public decimal? CapacityVolume { get; set; }

        public CreateOrUpdateLocationRequest ToRequest() => new(
            Code,
            Barcode,
            Type,
            ParentLocationId,
            IsVirtual,
            MaxWeight,
            MaxVolume,
            Status,
            ZoneType,
            CoordinateX,
            CoordinateY,
            CoordinateZ,
            WidthMeters,
            LengthMeters,
            HeightMeters,
            Aisle,
            Rack,
            Level,
            Bin,
            CapacityWeight,
            CapacityVolume);
    }

    private sealed class LocationEditFormModel : LocationFormModel
    {
        public int Id { get; set; }
    }
}
