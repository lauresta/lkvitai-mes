                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" @bind="_editing.IsVirtual" disabled />
                        <label class="form-check-label">Virtual</label>
                    </div>
                </div>
                <div class="col-md-2 d-flex align-items-end">
                    <button class="btn btn-primary px-4" @onclick="UpdateAsync">Save</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private readonly List<AdminLocationDto> _locations = [];
    private IReadOnlyList<WarehouseDto> _warehouses = Array.Empty<WarehouseDto>();

    private string? _search;
    private string? _status;
    private bool _includeVirtual = true;
    private string _placementWarehouseCode = string.Empty;
    private int _pageNumber = 1;
    private int _pageSize = 50;
    private int _totalCount;
    private bool _isLoading;
    private bool _showCreate;
    private ApiException? _apiError;
    private string? _pendingEditCodeFromQuery;

    private LocationFormModel _create = new();
    private LocationEditFormModel? _editing;

    private int TotalPages => Math.Max(1, (int)Math.Ceiling(_totalCount / (double)Math.Max(1, _pageSize)));

    protected override async Task OnInitializedAsync()
    {
        ApplyQueryParameters();
        _warehouses = await StockClient.GetWarehousesAsync();
        if (_warehouses.Count > 0)
        {
            _placementWarehouseCode = _warehouses[0].Code;
        }

        await ReloadAsync();
    }

    private async Task ReloadAsync()
    {
        _isLoading = true;
        _apiError = null;

        try
        {
            await LoadLocationsAsync();
        }
        catch (ApiException ex)
        {
            _apiError = ex;
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task ApplyFiltersAsync()
    {
        _pageNumber = 1;
        await LoadLocationsAsync();
    }

    private async Task LoadLocationsAsync()
    {
        var result = await AdminClient.GetLocationsAsync(
            _search,
            _status,
            _includeVirtual,
            _pageNumber,
            _pageSize);

        _locations.Clear();
        _locations.AddRange(result.Items);
        _totalCount = result.TotalCount;

        if (_create.ParentLocationId is null && _locations.Count > 0)
        {
            _create.ParentLocationId = _locations[0].Id;
        }

        if (!string.IsNullOrWhiteSpace(_pendingEditCodeFromQuery))
        {
            var match = _locations.FirstOrDefault(x =>
                string.Equals(x.Code, _pendingEditCodeFromQuery, StringComparison.OrdinalIgnoreCase));
            if (match is not null)
            {
                BeginEdit(match);
                _pendingEditCodeFromQuery = null;
            }
        }
    }

    private void ApplyQueryParameters()
    {
        var uri = new Uri(NavigationManager.Uri);
        var query = QueryHelpers.ParseQuery(uri.Query);

        if (query.TryGetValue("search", out var searchValue))
        {
            var search = searchValue.ToString().Trim();
            _search = string.IsNullOrWhiteSpace(search) ? null : search;
        }

        if (query.TryGetValue("edit", out var editValue))
        {
            var editCode = editValue.ToString().Trim();
            _pendingEditCodeFromQuery = string.IsNullOrWhiteSpace(editCode) ? null : editCode;
        }
    }

    private string ResolveParentCode(int? parentId)
    {
        if (!parentId.HasValue)
        {
            return "-";
        }

        return _locations.FirstOrDefault(x => x.Id == parentId.Value)?.Code ?? parentId.Value.ToString();
    }

    private static string FormatCoordinates(AdminLocationDto row)
    {
        if (!row.CoordinateX.HasValue || !row.CoordinateY.HasValue || !row.CoordinateZ.HasValue)
        {
            return "-";
        }

        return $"{row.CoordinateX.Value:0.##}, {row.CoordinateY.Value:0.##}, {row.CoordinateZ.Value:0.##}";
    }

    private static string FormatDimensions(AdminLocationDto row)
    {
        if (!row.WidthMeters.HasValue || !row.LengthMeters.HasValue || !row.HeightMeters.HasValue)
        {
            return "-";
        }

        return $"{row.WidthMeters.Value:0.###} x {row.LengthMeters.Value:0.###} x {row.HeightMeters.Value:0.###}";
    }

    private string FormatAddress(AdminLocationDto row)
    {
        var placementAddress = BuildPlacementAddress(row);
        if (!string.IsNullOrWhiteSpace(placementAddress))
        {
            return placementAddress;
        }

        var parts = new[] { row.Aisle, row.Rack, row.Level, row.Bin }
            .Where(static x => !string.IsNullOrWhiteSpace(x))
            .ToArray();

        return parts.Length == 0 ? "-" : string.Join("-", parts);
    }

    private static string FormatPlacement(AdminLocationDto row)
    {
        if (string.IsNullOrWhiteSpace(row.RackRowId) || !row.ShelfLevelIndex.HasValue || !row.SlotStart.HasValue)
        {
            return "-";
        }

        var span = Math.Max(row.SlotSpan ?? 1, 1);
        return span > 1
            ? $"{row.RackRowId} / L{row.ShelfLevelIndex} / S{row.SlotStart}-{row.SlotStart + span - 1}"
            : $"{row.RackRowId} / L{row.ShelfLevelIndex} / S{row.SlotStart}";
    }

    private static string FormatCapacity(AdminLocationDto row)
    {
        if (!row.CapacityWeight.HasValue && !row.CapacityVolume.HasValue)
        {
            return "-";
        }

        var weight = row.CapacityWeight?.ToString("0.###") ?? "-";
        var volume = row.CapacityVolume?.ToString("0.###") ?? "-";
        return $"W:{weight} / V:{volume}";
    }

    private async Task OnPageChangedAsync(int page)
    {
        _pageNumber = Math.Max(1, page);
        await LoadLocationsAsync();
    }

    private async Task OnPageSizeChangedAsync(int size)
    {
        _pageSize = Math.Clamp(size, 1, 500);
        _pageNumber = 1;
        await LoadLocationsAsync();
    }

    private async Task CreateAsync()
    {
        try
        {
            _apiError = null;
            await AdminClient.CreateLocationAsync(_create.ToRequest());
            ToastService.ShowSuccess("Location created.");
            _create = new LocationFormModel();
            await LoadLocationsAsync();
        }
        catch (ApiException ex)
        {
            _apiError = ex;
            ToastService.ShowError(BuildErrorMessage(ex));
        }
    }

    private void BeginEdit(AdminLocationDto row)
    {
        _editing = new LocationEditFormModel
        {
            Id = row.Id,
            Code = row.Code,
            Barcode = row.Barcode,
            Type = row.Type,
            ParentLocationId = row.ParentLocationId,
            IsVirtual = row.IsVirtual,
            MaxWeight = row.MaxWeight,
            MaxVolume = row.MaxVolume,
            Status = row.Status,
            ZoneType = row.ZoneType,
            CoordinateX = row.CoordinateX,
            CoordinateY = row.CoordinateY,
            CoordinateZ = row.CoordinateZ,
            WidthMeters = row.WidthMeters,
            LengthMeters = row.LengthMeters,
            HeightMeters = row.HeightMeters,
            Aisle = row.Aisle,
            Rack = row.Rack,
            Level = row.Level,
            Bin = row.Bin,
            CapacityWeight = row.CapacityWeight,
            CapacityVolume = row.CapacityVolume,
            RackRowId = row.RackRowId,
            ShelfLevelIndex = row.ShelfLevelIndex,
            SlotStart = row.SlotStart,
            SlotSpan = row.SlotSpan,
            LocationRole = row.LocationRole
        };
    }

    private async Task UpdateAsync()
    {
        if (_editing is null)
        {
            return;
        }

        try
        {
            _apiError = null;
            await AdminClient.UpdateLocationAsync(_editing.Id, _editing.ToRequest());
            await SyncRackPlacementAsync(_editing);
            ToastService.ShowSuccess("Location updated.");
            _editing = null;
            await LoadLocationsAsync();
        }
        catch (InvalidOperationException ex)
        {
            ToastService.ShowError(ex.Message);
        }
        catch (ApiException ex)
        {
            _apiError = ex;
            ToastService.ShowError(BuildErrorMessage(ex));
        }
    }

    private static string BuildErrorMessage(ApiException error)
    {
        if (!string.IsNullOrWhiteSpace(error.ProblemDetails?.Detail))
        {
            return $"{error.UserMessage} {error.ProblemDetails.Detail}";
        }

        return error.UserMessage;
    }

    private async Task SyncRackPlacementAsync(LocationEditFormModel editing)
    {
        if (!CanEditRackPlacement(editing))
        {
            return;
        }

        var hasPlacementValues =
            !string.IsNullOrWhiteSpace(editing.RackRowId) ||
            editing.ShelfLevelIndex.HasValue ||
            editing.SlotStart.HasValue ||
            editing.SlotSpan.HasValue ||
            !string.IsNullOrWhiteSpace(editing.LocationRole);

        if (!hasPlacementValues)
        {
            await AdminClient.ClearLocationRackPlacementAsync(editing.Id);
            return;
        }

        if (string.IsNullOrWhiteSpace(_placementWarehouseCode))
        {
            throw new InvalidOperationException("Select a placement warehouse before saving rack placement.");
        }

        if (string.IsNullOrWhiteSpace(editing.RackRowId) ||
            !editing.ShelfLevelIndex.HasValue ||
            !editing.SlotStart.HasValue)
        {
            throw new InvalidOperationException("RackRowId, ShelfLevelIndex, and SlotStart are required for rack placement.");
        }

        await AdminClient.UpdateLocationRackPlacementAsync(
            editing.Id,
            new UpdateLocationRackPlacementRequest(
                _placementWarehouseCode,
                editing.RackRowId.Trim(),
                editing.ShelfLevelIndex.Value,
                editing.SlotStart.Value,
                editing.SlotSpan,
                string.IsNullOrWhiteSpace(editing.LocationRole) ? null : editing.LocationRole.Trim()));
    }

    private string BuildPlacementAddress(AdminLocationDto row)
        => BuildPlacementAddress(row.RackRowId, row.ShelfLevelIndex, row.SlotStart, row.SlotSpan);

    private string BuildPlacementAddress(LocationEditFormModel row)
        => BuildPlacementAddress(row.RackRowId, row.ShelfLevelIndex, row.SlotStart, row.SlotSpan);

    private static bool CanEditRackPlacement(LocationEditFormModel row)
        => !row.IsVirtual && string.Equals(row.Type, "Bin", StringComparison.OrdinalIgnoreCase);

    private string BuildPlacementAddress(string? rackRowId, int? shelfLevelIndex, int? slotStart, int? slotSpan)
    {
        if (string.IsNullOrWhiteSpace(_placementWarehouseCode) ||
            string.IsNullOrWhiteSpace(rackRowId) ||
            !shelfLevelIndex.HasValue ||
            !slotStart.HasValue)
        {
            return "-";
        }

        var baseAddress = $"{_placementWarehouseCode}-{rackRowId.Trim()}{shelfLevelIndex.Value}-{slotStart.Value:D2}";
        var span = Math.Max(slotSpan ?? 1, 1);
        return span > 1 ? $"{baseAddress}+{span}" : baseAddress;
    }

