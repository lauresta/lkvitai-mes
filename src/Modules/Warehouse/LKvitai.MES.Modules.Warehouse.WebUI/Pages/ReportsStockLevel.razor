@page "/reports/stock-level"
@inject ReportsClient ReportsClient
@inject IJSRuntime JavaScript
@inject ToastService ToastService

<PageTitle>Stock Level Report - LKvitai.MES</PageTitle>

<div data-testid="reports-stock-level-page">
    <MudText Typo="Typo.h5" Class="mb-3">Stock Level Report</MudText>

    @if (_apiError is not null)
    {
        <ErrorBanner Message="@BuildErrorMessage(_apiError)"
                     TraceId="@_apiError.TraceId"
                     OnRetry="LoadAsync"
                     OnDismiss="@(() => _apiError = null)" />
    }

    <MudPaper Class="pa-4 mb-3">
        <MudGrid Spacing="2" AlignItems="AlignItems.End">
            <MudItem xs="12" md="2">
                <MudNumericField T="int?" Label="Item Id" @bind-Value="_itemId" Variant="Variant.Outlined" Dense="true" />
            </MudItem>
            <MudItem xs="12" md="2">
                <MudNumericField T="int?" Label="Location Id" @bind-Value="_locationId" Variant="Variant.Outlined" Dense="true" />
            </MudItem>
            <MudItem xs="12" md="2">
                <MudNumericField T="int?" Label="Category Id" @bind-Value="_categoryId" Variant="Variant.Outlined" Dense="true" />
            </MudItem>
            <MudItem xs="12" md="3">
                <MudDatePicker Label="Expiring Before" @bind-Date="_expiringBefore" DateFormat="yyyy-MM-dd" Variant="Variant.Outlined" Dense="true" />
            </MudItem>
            <MudItem xs="12" md="3">
                <MudStack Spacing="1">
                    <MudCheckBox T="bool" Label="Include reserved" @bind-Value="_includeReserved" Dense="true" />
                    <MudCheckBox T="bool" Label="Include virtual" @bind-Value="_includeVirtualLocations" Dense="true" />
                </MudStack>
            </MudItem>
            <MudItem xs="12" md="2">
                <MudButton FullWidth="true" Variant="Variant.Filled" Color="Color.Primary" OnClick="ApplyFiltersAsync" @attributes="ApplyAttributes">Apply</MudButton>
            </MudItem>
            <MudItem xs="12" md="2">
                <MudButton FullWidth="true" Variant="Variant.Outlined" Color="Color.Default" OnClick="ExportCsvAsync" @attributes="ExportAttributes">Export CSV</MudButton>
            </MudItem>
        </MudGrid>
    </MudPaper>

    <MudPaper Class="pa-4 position-relative">
         (@_isLoading)
        {
            <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-3" />
        }

        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-2">
            <MudText Typo="Typo.subtitle2" data-testid="reports-stock-level-total">Total: @_totalCount</MudText>
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                <MudText Typo="Typo.caption">Stock as of @_projectionTimestamp.ToString("HH:mm:ss")</MudText>
                <StaleBadge LastUpdated="_projectionTimestamp" />
            </MudStack>
        </MudStack>

        <MudDataGrid T="StockLevelRowDto"
                     Items="_items"
                     Dense="true"
                     Hover="true"
                     Loading="@_isLoading"
                     SortMode="SortMode.None"
                     Filterable="false"
                     @attributes="GridAttributes">
            <NoRecordsContent>
                <MudText Typo="Typo.body2" Class="mud-secondary-text">No rows found.</MudText>
            </NoRecordsContent>
            <Columns>
                <PropertyColumn Property="x => x.InternalSku" Title="SKU" />
                <PropertyColumn Property="x => x.ItemName" Title="Item" />
                <PropertyColumn Property="x => x.LocationCode" Title="Location" />
                <PropertyColumn Property="x => x.LotNumber" Title="Lot" />
                <TemplateColumn Title="Expiry">
                    <CellTemplate>
                        @context.Item.ExpiryDate?.ToString("yyyy-MM-dd")
                    </CellTemplate>
                </TemplateColumn>
                <PropertyColumn Property="x => x.Qty" Title="Qty" />
                <PropertyColumn Property="x => x.ReservedQty" Title="Reserved" />
                <PropertyColumn Property="x => x.AvailableQty" Title="Available" />
            </Columns>
        </MudDataGrid>

        @if (_totalCount > 0)
        {
            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.FlexEnd" Class="mt-3" data-testid="reports-stock-level-pager">
                <MudSelect T="int"
                           Label="Page size"
                           Value="_pageSize"
                           ValueChanged="OnPageSizeChangedAsync"
                           Variant="Variant.Outlined"
                           Dense="true"
                           Style="width: 120px;"
                           @attributes="PageSizeAttributes">
                    <MudSelectItem Value="25">25</MudSelectItem>
                    <MudSelectItem Value="50">50</MudSelectItem>
                    <MudSelectItem Value="100">100</MudSelectItem>
                </MudSelect>
                <MudPagination Count="@TotalPages"
                               Selected="@_pageNumber"
                               SelectedChanged="OnPageChangedAsync"
                               Variant="Variant.Outlined"
                               Color="Color.Primary"
                               Size="Size.Small"
                               Class="ml-2" />
            </MudStack>
        }
    </MudPaper>
</div>

@code {
    private readonly List<StockLevelRowDto> _items = [];
    private ApiException? _apiError;
    private bool _isLoading;
    private int _pageNumber = 1;
    private int _pageSize = 50;
    private int _totalCount;
    private DateTime _projectionTimestamp = DateTime.UtcNow;

    private int? _itemId;
    private int? _locationId;
    private int? _categoryId;
    private DateTime? _expiringBefore;
    private bool _includeReserved;
    private bool _includeVirtualLocations;

    private static readonly Dictionary<string, object> GridAttributes = new() { ["data-testid"] = "reports-stock-level-grid" };
    private static readonly Dictionary<string, object> ApplyAttributes = new() { ["data-testid"] = "reports-stock-level-apply" };
    private static readonly Dictionary<string, object> ExportAttributes = new() { ["data-testid"] = "reports-stock-level-export" };
    private static readonly Dictionary<string, object> PageSizeAttributes = new() { ["data-testid"] = "reports-stock-level-page-size" };

    private int TotalPages => Math.Max(1, (int)Math.Ceiling(_totalCount / (double)Math.Max(1, _pageSize)));

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task ApplyFiltersAsync()
    {
        _pageNumber = 1;
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _isLoading = true;
        _apiError = null;

        try
        {
            DateOnly? expiringBefore = _expiringBefore.HasValue
                ? DateOnly.FromDateTime(_expiringBefore.Value.Date)
                : null;

            var response = await ReportsClient.GetStockLevelAsync(
                _itemId,
                _locationId,
                _categoryId,
                _includeReserved,
                _includeVirtualLocations,
                expiringBefore,
                _pageNumber,
                _pageSize);

            _items.Clear();
            _items.AddRange(response.Items);
            _totalCount = response.TotalCount;
            _projectionTimestamp = response.ProjectionTimestamp;
        }
        catch (ApiException ex)
        {
            _apiError = ex;
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task OnPageChangedAsync(int page)
    {
        _pageNumber = Math.Max(1, page);
        await LoadAsync();
    }

    private async Task OnPageSizeChangedAsync(int size)
    {
        _pageSize = Math.Clamp(size, 1, 1000);
        _pageNumber = 1;
        await LoadAsync();
    }

    private async Task ExportCsvAsync()
    {
        try
        {
            DateOnly? expiringBefore = _expiringBefore.HasValue
                ? DateOnly.FromDateTime(_expiringBefore.Value.Date)
                : null;

            var bytes = await ReportsClient.DownloadStockLevelCsvAsync(
                _itemId,
                _locationId,
                _categoryId,
                _includeReserved,
                _includeVirtualLocations,
                expiringBefore);

            await JavaScript.InvokeVoidAsync(
                "csvExport.downloadBytes",
                "stock-level-report.csv",
                "text/csv",
                Convert.ToBase64String(bytes));
        }
        catch (ApiException ex)
        {
            _apiError = ex;
            ToastService.ShowError(BuildErrorMessage(ex));
        }
    }

    private static string BuildErrorMessage(ApiException error)
    {
        if (!string.IsNullOrWhiteSpace(error.ProblemDetails?.Detail))
        {
            return $"{error.UserMessage} {error.ProblemDetails.Detail}";
        }

        return error.UserMessage;
    }
}
