@page "/reports/pick-history"
@inject ReportsClient ReportsClient
@inject IJSRuntime JavaScript
@inject ToastService ToastService

<PageTitle>Pick History - LKvitai.MES</PageTitle>

<div data-testid="reports-pick-history-page">
    <MudText Typo="Typo.h5" Class="mb-3">Pick History Report</MudText>

    @if (_apiError is not null)
    {
        <SharedErrorAlert Message="@BuildErrorMessage(_apiError)"
                     TraceId="@_apiError.TraceId"
                     OnRetry="LoadAsync"
                     OnDismiss="@(() => _apiError = null)" />
    }

    <MudPaper Class="pa-4 mb-3">
        <MudGrid Spacing="2" AlignItems="AlignItems.End">
            <MudItem xs="12" md="3">
                <MudTextField T="string" Label="Order Id" @bind-Value="_orderId" Variant="Variant.Outlined" Dense="true" />
            </MudItem>
            <MudItem xs="12" md="3">
                <MudTextField T="string" Label="Operator/User" @bind-Value="_userId" Variant="Variant.Outlined" Dense="true" />
            </MudItem>
            <MudItem xs="12" md="3">
                <MudDatePicker Label="Completed From" @bind-Date="_dateFrom" DateFormat="yyyy-MM-dd" Variant="Variant.Outlined" Dense="true" />
            </MudItem>
            <MudItem xs="12" md="3">
                <MudDatePicker Label="Completed To" @bind-Date="_dateTo" DateFormat="yyyy-MM-dd" Variant="Variant.Outlined" Dense="true" />
            </MudItem>
            <MudItem xs="12" md="2">
                <MudButton FullWidth="true" Variant="Variant.Filled" Color="Color.Primary" OnClick="ApplyFiltersAsync" @attributes="ApplyAttributes">Apply</MudButton>
            </MudItem>
            <MudItem xs="12" md="2">
                <MudButton FullWidth="true" Variant="Variant.Outlined" Color="Color.Default" OnClick="ExportCsvAsync" @attributes="ExportAttributes">Export CSV</MudButton>
            </MudItem>
        </MudGrid>
    </MudPaper>

    <MudPaper Class="pa-4 position-relative">
         (@_isLoading)
        {
            <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-3" />
        }

        <MudText Typo="Typo.subtitle2" Class="mb-2" data-testid="reports-pick-history-total">Total: @_totalCount</MudText>

        <MudDataGrid T="PickHistoryRowDto"
                     Items="_items"
                     Dense="true"
                     Hover="true"
                     Loading="@_isLoading"
                     SortMode="SortMode.None"
                     Filterable="false"
                     @attributes="GridAttributes">
            <NoRecordsContent>
                <MudText Typo="Typo.body2" Class="mud-secondary-text">No rows found.</MudText>
            </NoRecordsContent>
            <Columns>
                <PropertyColumn Property="x => x.TaskId" Title="Task" />
                <PropertyColumn Property="x => x.OrderId" Title="Order" />
                <PropertyColumn Property="x => x.InternalSku" Title="SKU" />
                <PropertyColumn Property="x => x.ItemName" Title="Item" />
                <PropertyColumn Property="x => x.Qty" Title="Qty" />
                <PropertyColumn Property="x => x.PickedQty" Title="Picked" />
                <TemplateColumn Title="Operator">
                    <CellTemplate>
                        @(context.Item.CompletedBy ?? context.Item.AssignedToUserId)
                    </CellTemplate>
                </TemplateColumn>
                <TemplateColumn Title="Completed">
                    <CellTemplate>
                        @context.Item.CompletedAt?.ToString("yyyy-MM-dd HH:mm")
                    </CellTemplate>
                </TemplateColumn>
            </Columns>
        </MudDataGrid>

        @if (_totalCount > 0)
        {
            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.FlexEnd" Class="mt-3" data-testid="reports-pick-history-pager">
                <MudSelect T="int"
                           Label="Page size"
                           Value="_pageSize"
                           ValueChanged="OnPageSizeChangedAsync"
                           Variant="Variant.Outlined"
                           Dense="true"
                           Style="width: 120px;"
                           @attributes="PageSizeAttributes">
                    <MudSelectItem Value="25">25</MudSelectItem>
                    <MudSelectItem Value="50">50</MudSelectItem>
                    <MudSelectItem Value="100">100</MudSelectItem>
                </MudSelect>
                <MudPagination Count="@TotalPages"
                               Selected="@_pageNumber"
                               SelectedChanged="OnPageChangedAsync"
                               Variant="Variant.Outlined"
                               Color="Color.Primary"
                               Size="Size.Small"
                               Class="ml-2" />
            </MudStack>
        }
    </MudPaper>
</div>

@code {
    private readonly List<PickHistoryRowDto> _items = [];
    private ApiException? _apiError;
    private bool _isLoading;
    private int _pageNumber = 1;
    private int _pageSize = 50;
    private int _totalCount;

    private string? _orderId;
    private string? _userId;
    private DateTime? _dateFrom;
    private DateTime? _dateTo;

    private static readonly Dictionary<string, object> GridAttributes = new() { ["data-testid"] = "reports-pick-history-grid" };
    private static readonly Dictionary<string, object> ApplyAttributes = new() { ["data-testid"] = "reports-pick-history-apply" };
    private static readonly Dictionary<string, object> ExportAttributes = new() { ["data-testid"] = "reports-pick-history-export" };
    private static readonly Dictionary<string, object> PageSizeAttributes = new() { ["data-testid"] = "reports-pick-history-page-size" };

    private int TotalPages => Math.Max(1, (int)Math.Ceiling(_totalCount / (double)Math.Max(1, _pageSize)));

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task ApplyFiltersAsync()
    {
        _pageNumber = 1;
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _isLoading = true;
        _apiError = null;

        try
        {
            var response = await ReportsClient.GetPickHistoryAsync(
                string.IsNullOrWhiteSpace(_orderId) ? null : _orderId,
                string.IsNullOrWhiteSpace(_userId) ? null : _userId,
                ParseDateTime(_dateFrom),
                ParseDateTime(_dateTo),
                _pageNumber,
                _pageSize);

            _items.Clear();
            _items.AddRange(response.Items);
            _totalCount = response.TotalCount;
        }
        catch (ApiException ex)
        {
            _apiError = ex;
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task OnPageChangedAsync(int page)
    {
        _pageNumber = Math.Max(1, page);
        await LoadAsync();
    }

    private async Task OnPageSizeChangedAsync(int size)
    {
        _pageSize = Math.Clamp(size, 1, 1000);
        _pageNumber = 1;
        await LoadAsync();
    }

    private async Task ExportCsvAsync()
    {
        try
        {
            var bytes = await ReportsClient.DownloadPickHistoryCsvAsync(
                string.IsNullOrWhiteSpace(_orderId) ? null : _orderId,
                string.IsNullOrWhiteSpace(_userId) ? null : _userId,
                ParseDateTime(_dateFrom),
                ParseDateTime(_dateTo));

            await JavaScript.InvokeVoidAsync(
                "csvExport.downloadBytes",
                "pick-history-report.csv",
                "text/csv",
                Convert.ToBase64String(bytes));
        }
        catch (ApiException ex)
        {
            _apiError = ex;
            ToastService.ShowError(BuildErrorMessage(ex));
        }
    }

    private static DateTimeOffset? ParseDateTime(DateTime? raw)
    {
        if (!raw.HasValue)
        {
            return null;
        }

        var value = raw.Value;
        return new DateTimeOffset(value, TimeZoneInfo.Local.GetUtcOffset(value));
    }

    private static string BuildErrorMessage(ApiException error)
    {
        if (!string.IsNullOrWhiteSpace(error.ProblemDetails?.Detail))
        {
            return $"{error.UserMessage} {error.ProblemDetails.Detail}";
        }

        return error.UserMessage;
    }
}
