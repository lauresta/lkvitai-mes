@page "/admin/items/{Id:int}"
@inject MasterDataAdminClient AdminClient
@inject ToastService ToastService
@inject NavigationManager NavigationManager

<PageTitle>Item Details - Cikada.MES</PageTitle>

<div data-testid="admin-item-detail-page">
    <div class="items-detail-title">
        <div>
            <h3>Item Details</h3>
            @if (_item is not null)
            {
                <div class="items-detail-title__meta">
                    <span class="mono">@_item.InternalSKU</span>
                    <span class="@StatusChipClass(_item.Status)">@_item.Status</span>
                </div>
            }
        </div>
        <MudButton Variant="Variant.Outlined"
                   Color="Color.Primary"
                   OnClick="BackToList"
                   data-testid="admin-item-detail-back">
            Back to list
        </MudButton>
    </div>

    @if (_apiError is not null)
    {
        <div data-testid="admin-item-detail-error">
            <SharedErrorAlert Message="@BuildErrorMessage(_apiError)"
                              TraceId="@_apiError.TraceId"
                              OnRetry="ReloadAsync"
                              OnDismiss="@(() => _apiError = null)" />
        </div>
    }

    <MudPaper Outlined="true" Elevation="0" Class="panel items-detail-panel" data-testid="admin-item-detail-fields">
        @if (_isLoading)
        {
            <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
        }

        @if (_item is null && !_isLoading)
        {
            <div class="lots-grid__empty">
                <span class="lots-grid__empty-title">Item not found</span>
                <span>The item could not be loaded.</span>
            </div>
        }
        else if (_item is not null)
        {
            <div class="panel__head">
                <span class="panel__title">@_item.Name</span>
                <span class="mono">@FormatDateTime(_item.UpdatedAt ?? _item.CreatedAt)</span>
            </div>
            <div class="items-detail-fields">
                <AdminItemFieldBlock Label="SKU" Value="@_item.InternalSKU" IsMono="true" />
                <AdminItemFieldBlock Label="Name" Value="@_item.Name" />
                <AdminItemFieldBlock Label="Category ID" Value="@_item.CategoryId.ToString()" IsMono="true" />
                <AdminItemFieldBlock Label="Base UoM" Value="@_item.BaseUoM" IsMono="true" />
                <AdminItemFieldBlock Label="Weight" Value="@FormatDecimal(_item.Weight)" IsMono="true" />
                <AdminItemFieldBlock Label="Volume" Value="@FormatDecimal(_item.Volume)" IsMono="true" />
                <AdminItemFieldBlock Label="Primary Barcode" Value="@FormatNullable(_item.PrimaryBarcode)" IsMono="true" />
                <AdminItemFieldBlock Label="Product Config" Value="@FormatNullable(_item.ProductConfigId)" IsMono="true" />
                <AdminItemFieldBlock Label="Lot Tracking" Value="@(_item.RequiresLotTracking ? "Required" : "Not required")" />
                <AdminItemFieldBlock Label="QC" Value="@(_item.RequiresQC ? "Required" : "Not required")" />
                <AdminItemFieldBlock Label="Created" Value="@FormatDateTime(_item.CreatedAt)" IsMono="true" />
                <AdminItemFieldBlock Label="Updated" Value="@(_item.UpdatedAt.HasValue ? FormatDateTime(_item.UpdatedAt.Value) : "-")" IsMono="true" />
                <div class="items-detail-field items-detail-field--wide">
                    <span>Description</span>
                    <strong>@FormatNullable(_item.Description)</strong>
                </div>
            </div>
        }
    </MudPaper>

    <MudPaper Outlined="true" Elevation="0" Class="panel items-detail-panel items-photo-panel" data-testid="admin-item-detail-photos">
        @if (_isLoading)
        {
            <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
        }

        <div class="panel__head">
            <span class="panel__title">Photos <small>@_photos.Count total</small></span>
            <div class="panel__actions items-photo-actions">
                <InputFile OnChange="HandleFileSelectedAsync" accept="image/jpeg,image/png,image/webp" />
                <MudButton Variant="Variant.Outlined"
                           Color="Color.Primary"
                           Size="Size.Small"
                           Disabled="@(_photos.Count == 0 || _isLoading)"
                           OnClick="RecomputeEmbeddingsAsync">
                    Recompute
                </MudButton>
            </div>
        </div>

        @if (!_isLoading && _photos.Count == 0)
        {
            <div class="lots-grid__empty">
                <span class="lots-grid__empty-title">No photos</span>
                <span>Upload a photo to show thumbnails in item and stock lists.</span>
            </div>
        }
        else
        {
            <div class="admin-item-photos-dialog__grid">
                @foreach (var photo in _photos)
                {
                    <div class="admin-item-photo">
                        <img src="@photo.ThumbUrl" alt="@($"{_item?.Name ?? "Item"} photo")" loading="lazy" />
                        <div class="admin-item-photo__body">
                            <div class="admin-item-photo__meta">
                                @if (photo.IsPrimary)
                                {
                                    <span class="chip chip--reserved">Primary</span>
                                }
                                else
                                {
                                    <span class="chip chip--locked">Photo</span>
                                }
                                <span class="mono">@FormatBytes(photo.SizeBytes)</span>
                            </div>
                            <div class="admin-item-photo__buttons">
                                <MudButton Href="@photo.OriginalUrl"
                                           Target="_blank"
                                           Rel="noopener"
                                           Variant="Variant.Outlined"
                                           Color="Color.Primary"
                                           Size="Size.Small">
                                    Open
                                </MudButton>
                                <MudButton Variant="Variant.Outlined"
                                           Color="Color.Primary"
                                           Size="Size.Small"
                                           Disabled="@(photo.IsPrimary || _isLoading)"
                                           OnClick="@(() => MakePrimaryAsync(photo.Id))">
                                    Primary
                                </MudButton>
                                <MudButton Variant="Variant.Outlined"
                                           Color="Color.Error"
                                           Size="Size.Small"
                                           Disabled="@_isLoading"
                                           OnClick="@(() => DeletePhotoAsync(photo.Id))">
                                    Delete
                                </MudButton>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </MudPaper>
</div>

@code {
    private const long MaxPhotoBytes = 5L * 1024 * 1024;

    [Parameter] public int Id { get; set; }

    private ItemDetailsDto? _item;
    private readonly List<ItemPhotoDto> _photos = [];
    private bool _isLoading;
    private ApiException? _apiError;

    protected override async Task OnParametersSetAsync()
    {
        await ReloadAsync();
    }

    private async Task ReloadAsync()
    {
        _isLoading = true;
        _apiError = null;

        try
        {
            _item = await AdminClient.GetItemByIdAsync(Id);
            _photos.Clear();
            _photos.AddRange(_item.Photos.OrderByDescending(x => x.IsPrimary).ThenByDescending(x => x.CreatedAt));
        }
        catch (ApiException ex)
        {
            _apiError = ex;
            _item = null;
            _photos.Clear();
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task HandleFileSelectedAsync(InputFileChangeEventArgs args)
    {
        var file = args.File;
        if (file is null)
        {
            return;
        }

        _isLoading = true;
        _apiError = null;

        try
        {
            await using var stream = file.OpenReadStream(MaxPhotoBytes);
            using var ms = new MemoryStream();
            await stream.CopyToAsync(ms);
            await AdminClient.UploadPhotoAsync(Id, file.Name, ms.ToArray(), file.ContentType);
            ToastService.ShowSuccess("Photo uploaded.");
            await ReloadAsync();
        }
        catch (ApiException ex)
        {
            _apiError = ex;
            ToastService.ShowError(BuildErrorMessage(ex));
        }
        catch (IOException ex)
        {
            ToastService.ShowError(ex.Message);
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task MakePrimaryAsync(Guid photoId)
    {
        _isLoading = true;
        _apiError = null;

        try
        {
            await AdminClient.MakePrimaryPhotoAsync(Id, photoId);
            ToastService.ShowSuccess("Primary photo updated.");
            await ReloadAsync();
        }
        catch (ApiException ex)
        {
            _apiError = ex;
            ToastService.ShowError(BuildErrorMessage(ex));
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task DeletePhotoAsync(Guid photoId)
    {
        _isLoading = true;
        _apiError = null;

        try
        {
            await AdminClient.DeletePhotoAsync(Id, photoId);
            ToastService.ShowWarning("Photo deleted.");
            await ReloadAsync();
        }
        catch (ApiException ex)
        {
            _apiError = ex;
            ToastService.ShowError(BuildErrorMessage(ex));
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task RecomputeEmbeddingsAsync()
    {
        _isLoading = true;
        _apiError = null;

        try
        {
            var count = await AdminClient.RecomputeEmbeddingsAsync(Id);
            ToastService.ShowSuccess($"Embeddings recomputed for {count} photo(s).");
        }
        catch (ApiException ex)
        {
            _apiError = ex;
            ToastService.ShowError(BuildErrorMessage(ex));
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void BackToList()
    {
        NavigationManager.NavigateTo("/admin/items");
    }

    private static string StatusChipClass(string status) => status switch
    {
        "Active" => "chip chip--ok",
        "Obsolete" => "chip chip--low",
        "Discontinued" => "chip chip--locked",
        _ => "chip chip--reserved"
    };

    private static string FormatDecimal(decimal? value)
        => value?.ToString("0.###") ?? "-";

    private static string FormatNullable(string? value)
        => string.IsNullOrWhiteSpace(value) ? "-" : value;

    private static string FormatDateTime(DateTimeOffset value)
        => value.ToLocalTime().ToString("yyyy-MM-dd HH:mm");

    private static string FormatBytes(long bytes)
        => bytes >= 1024 * 1024
            ? $"{bytes / 1024m / 1024m:0.#} MB"
            : $"{Math.Max(1, bytes / 1024m):0.#} KB";

    private static string BuildErrorMessage(ApiException error)
    {
        if (!string.IsNullOrWhiteSpace(error.ProblemDetails?.Detail))
        {
            return $"{error.UserMessage} {error.ProblemDetails.Detail}";
        }

        return error.UserMessage;
    }
}
