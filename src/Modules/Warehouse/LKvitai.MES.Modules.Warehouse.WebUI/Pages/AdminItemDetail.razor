@page "/admin/items/{Id:int}"
@inject MasterDataAdminClient AdminClient
@inject ValuationClient ValuationClient
@inject ToastService ToastService
@inject NavigationManager NavigationManager

<PageTitle>Item Details - Cikada.MES</PageTitle>

<div data-testid="admin-item-detail-page">
    <div class="items-detail-title">
        <div>
            <h3>Item Details</h3>
            @if (_item is not null)
            {
                <div class="items-detail-title__meta">
                    <span class="mono">@_item.InternalSKU</span>
                    <span class="@StatusChipClass(_item.Status)">@_item.Status</span>
                </div>
            }
        </div>
        <MudButton Variant="Variant.Outlined"
                   Color="Color.Primary"
                   OnClick="BackToList"
                   data-testid="admin-item-detail-back">
            Back to list
        </MudButton>
    </div>

    @if (_apiError is not null)
    {
        <div data-testid="admin-item-detail-error">
            <SharedErrorAlert Message="@BuildErrorMessage(_apiError)"
                              TraceId="@_apiError.TraceId"
                              OnRetry="ReloadAsync"
                              OnDismiss="@(() => _apiError = null)" />
        </div>
    }

    <MudPaper Outlined="true" Elevation="0" Class="panel items-detail-panel" data-testid="admin-item-detail-fields">
        @if (_isLoading)
        {
            <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
        }

        @if (_item is null && !_isLoading)
        {
            <div class="lots-grid__empty">
                <span class="lots-grid__empty-title">Item not found</span>
                <span>The item could not be loaded.</span>
            </div>
        }
        else if (_item is not null)
        {
            <div class="panel__head">
                <span class="panel__title">@_item.Name</span>
                <span class="mono">@FormatDateTime(_item.UpdatedAt ?? _item.CreatedAt)</span>
            </div>
            <div class="items-detail-fields">
                <AdminItemFieldBlock Label="SKU" Value="@_item.InternalSKU" IsMono="true" />
                <AdminItemFieldBlock Label="Name" Value="@_item.Name" />
                <AdminItemFieldBlock Label="Category ID" Value="@_item.CategoryId.ToString()" IsMono="true" />
                <AdminItemFieldBlock Label="Base UoM" Value="@_item.BaseUoM" IsMono="true" />
                <AdminItemFieldBlock Label="Weight" Value="@FormatDecimal(_item.Weight)" IsMono="true" />
                <AdminItemFieldBlock Label="Volume" Value="@FormatDecimal(_item.Volume)" IsMono="true" />
                <AdminItemFieldBlock Label="Base Price" Value="@FormatMoney(_item.BasePrice)" IsMono="true" />
                <AdminItemFieldBlock Label="Purchase Price" Value="@FormatMoney(_item.PurchasePrice)" IsMono="true" />
                <AdminItemFieldBlock Label="Primary Barcode" Value="@FormatNullable(_item.PrimaryBarcode)" IsMono="true" />
                <AdminItemFieldBlock Label="Product Config" Value="@FormatNullable(_item.ProductConfigId)" IsMono="true" />
                <div class="items-detail-field">
                    <span>Tags</span>
                    <div class="item-tags item-tags--detail">
                        @if (_item.Tags.Count == 0)
                        {
                            <strong>-</strong>
                        }
                        else
                        {
                            @foreach (var tag in _item.Tags)
                            {
                                <span class="chip chip--reserved item-tag-chip">#@tag</span>
                            }
                        }
                    </div>
                </div>
                <AdminItemFieldBlock Label="Lot Tracking" Value="@(_item.RequiresLotTracking ? "Required" : "Not required")" />
                <AdminItemFieldBlock Label="QC" Value="@(_item.RequiresQC ? "Required" : "Not required")" />
                <AdminItemFieldBlock Label="Created" Value="@FormatDateTime(_item.CreatedAt)" IsMono="true" />
                <AdminItemFieldBlock Label="Updated" Value="@(_item.UpdatedAt.HasValue ? FormatDateTime(_item.UpdatedAt.Value) : "-")" IsMono="true" />
                <div class="items-detail-field items-detail-field--wide">
                    <span>Description</span>
                    <strong>@FormatNullable(_item.Description)</strong>
                </div>
            </div>
        }
    </MudPaper>

    <MudPaper Outlined="true" Elevation="0" Class="panel items-detail-panel items-photo-panel" data-testid="admin-item-detail-photos">
        @if (_isLoading)
        {
            <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
        }

        <div class="panel__head">
            <span class="panel__title">Photos <small>@_photos.Count total</small></span>
            <div class="panel__actions items-photo-actions">
                <InputFile OnChange="HandleFileSelectedAsync" accept="image/jpeg,image/png,image/webp" />
                <MudButton Variant="Variant.Outlined"
                           Color="Color.Primary"
                           Size="Size.Small"
                           Disabled="@(_photos.Count == 0 || _isLoading)"
                           OnClick="RecomputeEmbeddingsAsync">
                    Recompute
                </MudButton>
            </div>
        </div>

        @if (!_isLoading && _photos.Count == 0)
        {
            <div class="lots-grid__empty">
                <span class="lots-grid__empty-title">No photos</span>
                <span>Upload a photo to show thumbnails in item and stock lists.</span>
            </div>
        }
        else
        {
            <div class="admin-item-photos-dialog__grid">
                @foreach (var photo in _photos)
                {
                    <div class="admin-item-photo">
                        <img src="@photo.ThumbUrl" alt="@($"{_item?.Name ?? "Item"} photo")" loading="lazy" />
                        <div class="admin-item-photo__body">
                            <div class="admin-item-photo__meta">
                                @if (photo.IsPrimary)
                                {
                                    <span class="chip chip--reserved">Primary</span>
                                }
                                else
                                {
                                    <span class="chip chip--locked">Photo</span>
                                }
                                <span class="mono">@FormatBytes(photo.SizeBytes)</span>
                            </div>
                            <div class="admin-item-photo__buttons">
                                <MudButton Href="@photo.OriginalUrl"
                                           Target="_blank"
                                           Rel="noopener"
                                           Variant="Variant.Outlined"
                                           Color="Color.Primary"
                                           Size="Size.Small">
                                    Open
                                </MudButton>
                                <MudButton Variant="Variant.Outlined"
                                           Color="Color.Primary"
                                           Size="Size.Small"
                                           Disabled="@(photo.IsPrimary || _isLoading)"
                                           OnClick="@(() => MakePrimaryAsync(photo.Id))">
                                    Primary
                                </MudButton>
                                <MudButton Variant="Variant.Outlined"
                                           Color="Color.Error"
                                           Size="Size.Small"
                                           Disabled="@_isLoading"
                                           OnClick="@(() => DeletePhotoAsync(photo.Id))">
                                    Delete
                                </MudButton>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </MudPaper>

    <MudPaper Outlined="true" Elevation="0" Class="panel items-detail-panel" data-testid="admin-item-detail-prices">
        @if (_isLoading)
        {
            <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
        }

        <div class="panel__head">
            <span class="panel__title">Prices by group</span>
        </div>

        @if (_priceOverrides.Count == 0)
        {
            <div class="lots-grid__empty">
                <span class="lots-grid__empty-title">No price groups</span>
                <span>Create a price group under Admin &gt; Price Groups to set group-specific prices.</span>
            </div>
        }
        else
        {
            <table class="lk-table">
                <thead>
                <tr>
                    <th>Group</th>
                    <th class="is-num">Override</th>
                    <th class="is-num">Effective Price</th>
                    <th></th>
                </tr>
                </thead>
                <tbody>
                @foreach (var row in _priceOverrides)
                {
                    <tr>
                        <td>@row.PriceGroupCode - @row.PriceGroupName</td>
                        @if (_editingGroupId == row.PriceGroupId)
                        {
                            <td class="is-num">
                                <MudNumericField T="decimal?" Variant="Variant.Outlined" Margin="Margin.Dense" Format="0.00" @bind-Value="_editingAmount" />
                            </td>
                            <td class="is-num">-</td>
                            <td class="text-end">
                                <MudButton Size="Size.Small" Variant="Variant.Filled" Color="Color.Primary" OnClick="SavePriceOverrideAsync">Save</MudButton>
                                <MudButton Size="Size.Small" Variant="Variant.Outlined" OnClick="CancelEditOverride">Cancel</MudButton>
                            </td>
                        }
                        else
                        {
                            <td class="is-money is-num">@(row.OverrideAmount.HasValue ? FormatMoney(row.OverrideAmount) : "-")</td>
                            <td class="is-money is-num">@FormatMoney(row.EffectivePrice)</td>
                            <td class="text-end">
                                <MudButton Size="Size.Small" Variant="Variant.Outlined" OnClick="@(() => BeginEditOverride(row))">Edit</MudButton>
                            </td>
                        }
                    </tr>
                }
                </tbody>
            </table>
        }
    </MudPaper>

    <MudPaper Outlined="true" Elevation="0" Class="panel items-detail-panel" data-testid="admin-item-detail-price-history">
        <div class="panel__head">
            <span class="panel__title">Price History</span>
        </div>

        @if (_priceHistory.Count == 0)
        {
            <div class="lots-grid__empty">
                <span class="lots-grid__empty-title">No price changes yet</span>
            </div>
        }
        else
        {
            <table class="lk-table">
                <thead>
                <tr>
                    <th>When</th>
                    <th>Type</th>
                    <th class="is-num">Old</th>
                    <th class="is-num">New</th>
                    <th>Changed By</th>
                    <th>Reason</th>
                </tr>
                </thead>
                <tbody>
                @foreach (var row in _priceHistory)
                {
                    <tr>
                        <td class="mono">@row.ChangedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td>
                        <td>@DescribePriceType(row)</td>
                        <td class="is-money is-num">@(row.OldAmount.HasValue ? FormatMoney(row.OldAmount) : "-")</td>
                        <td class="is-money is-num">@FormatMoney(row.NewAmount)</td>
                        <td>@row.ChangedBy</td>
                        <td>@FormatNullable(row.Reason)</td>
                    </tr>
                }
                </tbody>
            </table>
        }
    </MudPaper>

    <MudPaper Outlined="true" Elevation="0" Class="panel items-detail-panel" data-testid="admin-item-detail-purchase-history">
        <div class="panel__head">
            <span class="panel__title">Purchase / cost history</span>
        </div>

        @if (_purchaseHistory.Count == 0)
        {
            <div class="lots-grid__empty">
                <span class="lots-grid__empty-title">No purchase receipts or cost changes yet</span>
            </div>
        }
        else
        {
            <table class="lk-table">
                <thead>
                <tr>
                    <th>When</th>
                    <th>Type</th>
                    <th class="is-num">Old cost</th>
                    <th class="is-num">New cost</th>
                    <th>By</th>
                    <th>Reason</th>
                </tr>
                </thead>
                <tbody>
                @foreach (var row in _purchaseHistory)
                {
                    <tr>
                        <td class="mono">@row.ChangedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td>
                        <td>@row.ActionType</td>
                        <td class="is-money is-num">@(row.OldCost.HasValue ? row.OldCost.Value.ToString("0.####") : "-")</td>
                        <td class="is-money is-num">@(row.NewCost.HasValue ? row.NewCost.Value.ToString("0.####") : "-")</td>
                        <td>@(row.ApprovedBy ?? "-")</td>
                        <td>@row.Reason</td>
                    </tr>
                }
                </tbody>
            </table>
        }
    </MudPaper>
</div>

@code {
    private const long MaxPhotoBytes = 5L * 1024 * 1024;

    [Parameter] public int Id { get; set; }

    private ItemDetailsDto? _item;
    private readonly List<ItemPhotoDto> _photos = [];
    private readonly List<ItemPriceOverrideDto> _priceOverrides = [];
    private readonly List<ItemPriceHistoryDto> _priceHistory = [];
    private readonly List<CostHistoryRowDto> _purchaseHistory = [];
    private bool _isLoading;
    private ApiException? _apiError;
    private int? _editingGroupId;
    private decimal? _editingAmount;

    protected override async Task OnParametersSetAsync()
    {
        await ReloadAsync();
    }

    private async Task ReloadAsync()
    {
        _isLoading = true;
        _apiError = null;

        try
        {
            _item = await AdminClient.GetItemByIdAsync(Id);
            _photos.Clear();
            _photos.AddRange(_item.Photos.OrderByDescending(x => x.IsPrimary).ThenByDescending(x => x.CreatedAt));

            var overrides = await AdminClient.GetItemPriceOverridesAsync(Id);
            _priceOverrides.Clear();
            _priceOverrides.AddRange(overrides);

            var history = await AdminClient.GetItemPriceHistoryAsync(Id);
            _priceHistory.Clear();
            _priceHistory.AddRange(history);

            var purchaseHistory = await ValuationClient.GetCostHistoryAsync(itemId: Id);
            _purchaseHistory.Clear();
            _purchaseHistory.AddRange(purchaseHistory.OrderByDescending(x => x.ChangedAt));
        }
        catch (ApiException ex)
        {
            _apiError = ex;
            _item = null;
            _photos.Clear();
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void BeginEditOverride(ItemPriceOverrideDto row)
    {
        _editingGroupId = row.PriceGroupId;
        _editingAmount = row.OverrideAmount;
    }

    private void CancelEditOverride()
    {
        _editingGroupId = null;
        _editingAmount = null;
    }

    private async Task SavePriceOverrideAsync()
    {
        if (_editingGroupId is null)
        {
            return;
        }

        try
        {
            await AdminClient.SetItemPriceOverrideAsync(Id, _editingGroupId.Value, _editingAmount);
            ToastService.ShowSuccess("Price override updated.");
            _editingGroupId = null;
            _editingAmount = null;
            await ReloadAsync();
        }
        catch (ApiException ex)
        {
            ToastService.ShowError(BuildErrorMessage(ex));
        }
    }

    private static string DescribePriceType(ItemPriceHistoryDto row) => row.PriceType switch
    {
        "Base" => "Base price",
        "Purchase" => "Purchase price",
        "GroupOverride" => "Group override",
        _ => row.PriceType
    };

    private async Task HandleFileSelectedAsync(InputFileChangeEventArgs args)
    {
        var file = args.File;
        if (file is null)
        {
            return;
        }

        _isLoading = true;
        _apiError = null;

        try
        {
            await using var stream = file.OpenReadStream(MaxPhotoBytes);
            using var ms = new MemoryStream();
            await stream.CopyToAsync(ms);
            await AdminClient.UploadPhotoAsync(Id, file.Name, ms.ToArray(), file.ContentType);
            ToastService.ShowSuccess("Photo uploaded.");
            await ReloadAsync();
        }
        catch (ApiException ex)
        {
            _apiError = ex;
            ToastService.ShowError(BuildErrorMessage(ex));
        }
        catch (IOException ex)
        {
            ToastService.ShowError(ex.Message);
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task MakePrimaryAsync(Guid photoId)
    {
        _isLoading = true;
        _apiError = null;

        try
        {
            await AdminClient.MakePrimaryPhotoAsync(Id, photoId);
            ToastService.ShowSuccess("Primary photo updated.");
            await ReloadAsync();
        }
        catch (ApiException ex)
        {
            _apiError = ex;
            ToastService.ShowError(BuildErrorMessage(ex));
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task DeletePhotoAsync(Guid photoId)
    {
        _isLoading = true;
        _apiError = null;

        try
        {
            await AdminClient.DeletePhotoAsync(Id, photoId);
            ToastService.ShowWarning("Photo deleted.");
            await ReloadAsync();
        }
        catch (ApiException ex)
        {
            _apiError = ex;
            ToastService.ShowError(BuildErrorMessage(ex));
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task RecomputeEmbeddingsAsync()
    {
        _isLoading = true;
        _apiError = null;

        try
        {
            var count = await AdminClient.RecomputeEmbeddingsAsync(Id);
            ToastService.ShowSuccess($"Embeddings recomputed for {count} photo(s).");
        }
        catch (ApiException ex)
        {
            _apiError = ex;
            ToastService.ShowError(BuildErrorMessage(ex));
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void BackToList()
    {
        NavigationManager.NavigateTo("admin/items");
    }

    private static string StatusChipClass(string status) => status switch
    {
        "Active" => "chip chip--ok",
        "Obsolete" => "chip chip--low",
        "Discontinued" => "chip chip--locked",
        _ => "chip chip--reserved"
    };

    private static string FormatDecimal(decimal? value)
        => value?.ToString("0.###") ?? "-";

    private static string FormatMoney(decimal? value)
        => value.HasValue ? $"{value.Value:0.00} €" : "-";

    private static string FormatNullable(string? value)
        => string.IsNullOrWhiteSpace(value) ? "-" : value;

    private static string FormatDateTime(DateTimeOffset value)
        => value.ToLocalTime().ToString("yyyy-MM-dd HH:mm");

    private static string FormatBytes(long bytes)
        => bytes >= 1024 * 1024
            ? $"{bytes / 1024m / 1024m:0.#} MB"
            : $"{Math.Max(1, bytes / 1024m):0.#} KB";

    private static string BuildErrorMessage(ApiException error)
    {
        if (!string.IsNullOrWhiteSpace(error.ProblemDetails?.Detail))
        {
            return $"{error.UserMessage} {error.ProblemDetails.Detail}";
        }

        return error.UserMessage;
    }
}
