@inject MasterDataAdminClient AdminClient

<MudDialog Class="admin-item-dialog">
    <TitleContent>
        <div class="admin-item-dialog__title">
            <span>@(IsEdit ? "Edit Item" : "Create Item")</span>
            @if (IsEdit && !string.IsNullOrWhiteSpace(Item?.InternalSKU))
            {
                <span class="mono">@Item.InternalSKU</span>
            }
        </div>
    </TitleContent>
    <DialogContent>
        @if (!string.IsNullOrWhiteSpace(_validationMessage))
        {
            <div class="lk-state lk-state--warn admin-item-dialog__validation">@_validationMessage</div>
        }

        <div class="admin-item-dialog__grid">
            @if (!IsEdit)
            {
                <MudTextField T="string"
                              Label="Internal SKU"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense"
                              @bind-Value="_model.InternalSKU"
                              Placeholder="Auto-generated if empty" />
            }

            <MudTextField T="string"
                          Label="Name"
                          Variant="Variant.Outlined"
                          Margin="Margin.Dense"
                          @bind-Value="_model.Name"
                          Required="true" />

            <MudSelect T="int"
                       Label="Category"
                       Variant="Variant.Outlined"
                       Margin="Margin.Dense"
                       @bind-Value="_model.CategoryId"
                       Required="true">
                @foreach (var category in Categories)
                {
                    <MudSelectItem T="int" Value="@category.Id">@($"{category.Code} - {category.Name}")</MudSelectItem>
                }
            </MudSelect>

            <MudSelect T="string"
                       Label="Base UoM"
                       Variant="Variant.Outlined"
                       Margin="Margin.Dense"
                       @bind-Value="_model.BaseUoM"
                       Required="true">
                @foreach (var unit in Units)
                {
                    <MudSelectItem T="string" Value="@unit.Code">@($"{unit.Code} - {unit.Name}")</MudSelectItem>
                }
            </MudSelect>

            <MudSelect T="string"
                       Label="Status"
                       Variant="Variant.Outlined"
                       Margin="Margin.Dense"
                       @bind-Value="_model.Status">
                <MudSelectItem T="string" Value="@("Active")">Active</MudSelectItem>
                <MudSelectItem T="string" Value="@("Discontinued")">Discontinued</MudSelectItem>
                <MudSelectItem T="string" Value="@("Obsolete")">Obsolete</MudSelectItem>
            </MudSelect>

            <MudSelect T="string"
                       Label="Item Type"
                       Variant="Variant.Outlined"
                       Margin="Margin.Dense"
                       @bind-Value="_model.ItemType"
                       HelperText="Service items (e.g. Transport, Delivery) never receive physical stock.">
                <MudSelectItem T="string" Value="@("Stock")">Stock</MudSelectItem>
                <MudSelectItem T="string" Value="@("Service")">Service</MudSelectItem>
            </MudSelect>

            @if (string.Equals(_model.ItemType, "Service", StringComparison.OrdinalIgnoreCase))
            {
                <MudAutocomplete T="string"
                                 Label="Cost Type"
                                 Variant="Variant.Outlined"
                                 Margin="Margin.Dense"
                                 @bind-Value="_model.CostType"
                                 SearchFunc="SearchCostTypesAsync"
                                 CoerceText="true"
                                 CoerceValue="true"
                                 ResetValueOnEmptyText="true"
                                 HelperText="Which additional-cost bucket this service's amount folds into on inbound shipments. Pick a preset or type a custom value." />
            }

            <MudTextField T="string"
                          Label="Primary Barcode"
                          Variant="Variant.Outlined"
                          Margin="Margin.Dense"
                          @bind-Value="_model.PrimaryBarcode" />

            <MudNumericField T="decimal?"
                             Label="Weight"
                             Variant="Variant.Outlined"
                             Margin="Margin.Dense"
                             Min="0.001m"
                             @bind-Value="_model.Weight" />

            <MudNumericField T="decimal?"
                             Label="Volume"
                             Variant="Variant.Outlined"
                             Margin="Margin.Dense"
                             Min="0.001m"
                             @bind-Value="_model.Volume" />

            <MudNumericField T="decimal?"
                             Label="Base Price"
                             Variant="Variant.Outlined"
                             Margin="Margin.Dense"
                             Min="0m"
                             Format="0.00"
                             Adornment="Adornment.End"
                             AdornmentText="€"
                             @bind-Value="_model.BasePrice" />

            <MudNumericField T="decimal?"
                             Label="Purchase Price"
                             Variant="Variant.Outlined"
                             Margin="Margin.Dense"
                             Min="0m"
                             Format="0.00"
                             Adornment="Adornment.End"
                             AdornmentText="€"
                             @bind-Value="_model.PurchasePrice" />

            <MudTextField T="string"
                          Label="Product Config"
                          Variant="Variant.Outlined"
                          Margin="Margin.Dense"
                          @bind-Value="_model.ProductConfigId" />

            <div class="admin-item-dialog__tags">
                <div class="admin-item-tag-entry">
                    <MudAutocomplete T="string"
                                     Label="Tags"
                                     Variant="Variant.Outlined"
                                     Margin="Margin.Dense"
                                     Value="@_selectedTag"
                                     ValueChanged="OnTagSelectedAsync"
                                     Text="@_tagInput"
                                     TextChanged="OnTagTextChanged"
                                     SearchFunc="SearchTagsAsync"
                                     ToStringFunc="FormatTagOption"
                                     CoerceText="false"
                                     CoerceValue="false"
                                     ResetValueOnEmptyText="true"
                                     MinCharacters="0"
                                     MaxItems="12"
                                     Placeholder="#tag" />
                    <MudButton Variant="Variant.Outlined"
                               Color="Color.Primary"
                               Disabled="@string.IsNullOrWhiteSpace(_tagInput)"
                               OnClick="AddTagAsync">
                        Add
                    </MudButton>
                </div>

                <div class="item-tags" data-testid="admin-item-tags">
                    @if (_model.Tags.Count == 0)
                    {
                        <span class="item-tags__empty">No tags</span>
                    }
                    else
                    {
                        @foreach (var tag in _model.Tags)
                        {
                            <span class="chip chip--reserved item-tag-chip">
                                #@tag
                                <button type="button"
                                        class="item-tag-chip__remove"
                                        aria-label="@($"Remove tag {tag}")"
                                        @onclick="@(() => RemoveTag(tag))">
                                    x
                                </button>
                            </span>
                        }
                    }
                </div>
            </div>

            <div class="admin-item-dialog__checks">
                <MudCheckBox T="bool" @bind-Checked="_model.RequiresLotTracking" Label="Requires lot tracking" />
                <MudCheckBox T="bool" @bind-Checked="_model.RequiresQC" Label="Requires QC" />
            </div>

            <MudTextField T="string"
                          Label="Description"
                          Variant="Variant.Outlined"
                          Margin="Margin.Dense"
                          Lines="3"
                          Class="admin-item-dialog__description"
                          @bind-Value="_model.Description" />
        </div>
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Outlined" Color="Color.Primary" OnClick="Cancel">Cancel</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveAsync">@(IsEdit ? "Save Changes" : "Create Item")</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private MudDialogInstance MudDialog { get; set; } = default!;

    [Parameter] public bool IsEdit { get; set; }
    [Parameter] public ItemDetailsDto? Item { get; set; }
    [Parameter] public IReadOnlyList<AdminCategoryDto> Categories { get; set; } = Array.Empty<AdminCategoryDto>();
    [Parameter] public IReadOnlyList<UnitOfMeasureDto> Units { get; set; } = Array.Empty<UnitOfMeasureDto>();
    [Parameter] public IReadOnlyList<string> ExistingTags { get; set; } = Array.Empty<string>();

    private static readonly string[] CostTypePresets = ["Freight", "Duty", "Insurance", "VAT", "Other"];

    private readonly ItemFormModel _model = new();
    private string? _validationMessage;
    private string? _tagInput;
    private string? _selectedTag;

    protected override void OnInitialized()
    {
        if (Item is not null)
        {
            _model.InternalSKU = Item.InternalSKU;
            _model.Name = Item.Name;
            _model.Description = Item.Description;
            _model.CategoryId = Item.CategoryId;
            _model.BaseUoM = Item.BaseUoM;
            _model.Weight = Item.Weight;
            _model.Volume = Item.Volume;
            _model.BasePrice = Item.BasePrice;
            _model.PurchasePrice = Item.PurchasePrice;
            _model.RequiresLotTracking = Item.RequiresLotTracking;
            _model.RequiresQC = Item.RequiresQC;
            _model.Status = Item.Status;
            _model.PrimaryBarcode = Item.PrimaryBarcode;
            _model.ProductConfigId = Item.ProductConfigId;
            _model.ItemType = Item.ItemType;
            _model.CostType = Item.CostType;
            _model.Tags.Clear();
            _model.Tags.AddRange(Item.Tags.Select(NormalizeTag).Where(x => !string.IsNullOrWhiteSpace(x)));
            return;
        }

        _model.CategoryId = Categories.FirstOrDefault()?.Id ?? 0;
        _model.BaseUoM = Units.FirstOrDefault(x => string.Equals(x.Code, "PCS", StringComparison.OrdinalIgnoreCase))?.Code
                         ?? Units.FirstOrDefault()?.Code
                         ?? "PCS";
    }

    private Task SaveAsync()
    {
        _validationMessage = Validate();
        if (!string.IsNullOrWhiteSpace(_validationMessage))
        {
            return Task.CompletedTask;
        }

        MudDialog.Close(DialogResult.Ok(_model.ToRequest(IsEdit)));
        return Task.CompletedTask;
    }

    private string? Validate()
    {
        if (string.IsNullOrWhiteSpace(_model.Name))
        {
            return "Name is required.";
        }

        if (_model.CategoryId <= 0)
        {
            return "Category is required.";
        }

        if (string.IsNullOrWhiteSpace(_model.BaseUoM))
        {
            return "Base UoM is required.";
        }

        if (_model.Weight is <= 0)
        {
            return "Weight must be greater than zero.";
        }

        if (_model.Volume is <= 0)
        {
            return "Volume must be greater than zero.";
        }

        if (_model.BasePrice is < 0)
        {
            return "Base price must be greater than or equal to zero.";
        }

        if (_model.PurchasePrice is < 0)
        {
            return "Purchase price must be greater than or equal to zero.";
        }

        return null;
    }

    private void Cancel() => MudDialog.Cancel();

    private Task<IEnumerable<string>> SearchCostTypesAsync(string value)
    {
        IEnumerable<string> results = string.IsNullOrWhiteSpace(value)
            ? CostTypePresets
            : CostTypePresets
                .Where(x => x.Contains(value, StringComparison.OrdinalIgnoreCase))
                .Append(value.Trim())
                .Distinct(StringComparer.OrdinalIgnoreCase);

        return Task.FromResult(results);
    }

    private async Task<IEnumerable<string>> SearchTagsAsync(string value)
    {
        var normalized = NormalizeTag(value);
        var selected = _model.Tags.ToHashSet(StringComparer.OrdinalIgnoreCase);

        var candidates = new List<string>();
        try
        {
            candidates.AddRange(await AdminClient.GetItemTagsAsync(normalized, limit: 30));
        }
        catch (ApiException)
        {
            // Keep autocomplete usable even if the suggestions endpoint is temporarily unavailable.
        }

        candidates.AddRange(ExistingTags);
        if (!string.IsNullOrWhiteSpace(normalized))
        {
            candidates.Add(normalized);
        }

        return candidates
            .Select(NormalizeTag)
            .Where(x => !string.IsNullOrWhiteSpace(x))
            .Where(x => !selected.Contains(x))
            .Where(x => string.IsNullOrWhiteSpace(normalized) ||
                        x.Contains(normalized, StringComparison.OrdinalIgnoreCase))
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .OrderByDescending(x => string.Equals(x, normalized, StringComparison.OrdinalIgnoreCase))
            .ThenByDescending(x => x.StartsWith(normalized, StringComparison.OrdinalIgnoreCase))
            .ThenBy(x => x, StringComparer.OrdinalIgnoreCase)
            .Take(12)
            .ToList();
    }

    private Task OnTagTextChanged(string value)
    {
        _tagInput = value;
        return Task.CompletedTask;
    }

    private Task OnTagSelectedAsync(string value)
    {
        AddTags(value);
        _selectedTag = null;
        _tagInput = string.Empty;
        return Task.CompletedTask;
    }

    private Task AddTagAsync()
    {
        AddTags(_tagInput);
        _selectedTag = null;
        _tagInput = string.Empty;
        return Task.CompletedTask;
    }

    private void AddTags(string? value)
    {
        foreach (var tag in SplitTags(value))
        {
            if (!_model.Tags.Contains(tag, StringComparer.OrdinalIgnoreCase))
            {
                _model.Tags.Add(tag);
            }
        }

        _model.Tags.Sort(StringComparer.OrdinalIgnoreCase);
    }

    private void RemoveTag(string tag)
    {
        _model.Tags.RemoveAll(x => string.Equals(x, tag, StringComparison.OrdinalIgnoreCase));
    }

    private static IEnumerable<string> SplitTags(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return Array.Empty<string>();
        }

        return value
            .Split([',', ';', '|', ' ', '\t', '\r', '\n'], StringSplitOptions.RemoveEmptyEntries)
            .Select(NormalizeTag)
            .Where(x => !string.IsNullOrWhiteSpace(x));
    }

    private static string NormalizeTag(string? value)
        => value?.Trim().TrimStart('#').Trim() ?? string.Empty;

    private static string FormatTagOption(string tag)
    {
        var normalized = NormalizeTag(tag);
        return string.IsNullOrWhiteSpace(normalized) ? string.Empty : "#" + normalized;
    }

    private sealed class ItemFormModel
    {
        public string? InternalSKU { get; set; }
        public string Name { get; set; } = string.Empty;
        public string? Description { get; set; }
        public int CategoryId { get; set; }
        public string BaseUoM { get; set; } = "PCS";
        public decimal? Weight { get; set; }
        public decimal? Volume { get; set; }
        public decimal? BasePrice { get; set; }
        public decimal? PurchasePrice { get; set; }
        public bool RequiresLotTracking { get; set; }
        public bool RequiresQC { get; set; }
        public string Status { get; set; } = "Active";
        public string? PrimaryBarcode { get; set; }
        public string? ProductConfigId { get; set; }
        public string ItemType { get; set; } = "Stock";
        public string? CostType { get; set; }
        public List<string> Tags { get; } = [];

        public CreateOrUpdateItemRequest ToRequest(bool isEdit) => new()
        {
            InternalSKU = isEdit ? null : Normalize(InternalSKU),
            Name = Name.Trim(),
            Description = Normalize(Description),
            CategoryId = CategoryId,
            BaseUoM = BaseUoM.Trim(),
            Weight = Weight,
            Volume = Volume,
            BasePrice = BasePrice,
            PurchasePrice = PurchasePrice,
            RequiresLotTracking = RequiresLotTracking,
            RequiresQC = RequiresQC,
            Status = string.IsNullOrWhiteSpace(Status) ? "Active" : Status.Trim(),
            PrimaryBarcode = Normalize(PrimaryBarcode),
            ProductConfigId = Normalize(ProductConfigId),
            Tags = Tags.ToArray(),
            ItemType = string.IsNullOrWhiteSpace(ItemType) ? "Stock" : ItemType.Trim(),
            CostType = string.Equals(ItemType, "Service", StringComparison.OrdinalIgnoreCase)
                ? Normalize(CostType)
                : null
        };

        private static string? Normalize(string? value)
            => string.IsNullOrWhiteSpace(value) ? null : value.Trim();
    }
}
