@page "/warehouse/sales/orders/create"
@inject SalesOrdersClient SalesOrdersClient
@inject NavigationManager NavigationManager
@inject ToastService ToastService

<PageTitle>Create Sales Order - LKvitai.MES</PageTitle>

<div data-testid="sales-order-create-page">
    <MudText Typo="Typo.h5" Class="mb-3">Create Sales Order</MudText>

    @if (_apiError is not null)
    {
        <div data-testid="sales-order-create-error">
            <ErrorBanner Message="@BuildErrorMessage(_apiError)"
                         TraceId="@_apiError.TraceId"
                         OnRetry="LoadLookupDataAsync"
                         OnDismiss="DismissError" />
        </div>
    }

    <MudPaper Class="pa-4 position-relative" data-testid="sales-order-create-form">
        @if (_isLoading || _isSubmitting)
        {
            <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-3" data-testid="sales-order-create-loading" />
        }

        <MudGrid Spacing="3" AlignItems="AlignItems.End">
            <MudItem xs="12" md="6">
                <MudSelect T="Guid?"
                           Label="Customer"
                           @bind-Value="_selectedCustomerId"
                           @bind-Value:after="OnCustomerChangedAsync"
                           Variant="Variant.Outlined"
                           Dense="true"
                           @attributes="CustomerAttributes">
                    <MudSelectItem T="Guid?" Value="@((Guid?)null)">Select customer</MudSelectItem>
                    @foreach (var customer in _customers)
                    {
                        <MudSelectItem T="Guid?" Value="@((Guid?)customer.Id)">@customer.CustomerCode - @customer.Name</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" md="3">
                <MudDatePicker Label="Requested Delivery Date"
                               @bind-Date="_requestedDeliveryDate"
                               DateFormat="yyyy-MM-dd"
                               Variant="Variant.Outlined"
                               Dense="true"
                               @attributes="DeliveryDateAttributes" />
            </MudItem>
            <MudItem xs="12" md="3">
                <MudButton Variant="Variant.Outlined"
                           Color="Color.Default"
                           Disabled="@_isSubmitting"
                           OnClick="BackToList"
                           FullWidth="true">
                    Back to List
                </MudButton>
            </MudItem>
        </MudGrid>

        <MudDivider Class="my-4" />

        <MudText Typo="Typo.h6" Class="mb-2">Shipping Address</MudText>
        <MudGrid Spacing="2">
            <MudItem xs="12" md="6"><MudTextField T="string" Label="Street" @bind-Value="_shippingStreet" Variant="Variant.Outlined" Dense="true" @attributes="ShippingStreetAttributes" /></MudItem>
            <MudItem xs="12" md="3"><MudTextField T="string" Label="City" @bind-Value="_shippingCity" Variant="Variant.Outlined" Dense="true" @attributes="ShippingCityAttributes" /></MudItem>
            <MudItem xs="12" md="3"><MudTextField T="string" Label="State" @bind-Value="_shippingState" Variant="Variant.Outlined" Dense="true" @attributes="ShippingStateAttributes" /></MudItem>
            <MudItem xs="12" md="3"><MudTextField T="string" Label="Zip" @bind-Value="_shippingZipCode" Variant="Variant.Outlined" Dense="true" @attributes="ShippingZipAttributes" /></MudItem>
            <MudItem xs="12" md="3"><MudTextField T="string" Label="Country" @bind-Value="_shippingCountry" Variant="Variant.Outlined" Dense="true" @attributes="ShippingCountryAttributes" /></MudItem>
        </MudGrid>

        <MudDivider Class="my-4" />

        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-2">
            <MudText Typo="Typo.h6">Order Lines</MudText>
            <MudButton Variant="Variant.Outlined" Color="Color.Primary" OnClick="AddLine" Disabled="@_isSubmitting" data-testid="sales-order-create-add-line">+ Add Line</MudButton>
        </MudStack>

        @if (_lines.Count == 0)
        {
            <EmptyState Title="No lines added"
                        Message="Add at least one line item."
                        Icon="@Icons.Material.Filled.FormatListBulleted"
                        OnAction="AddLineAsync" />
        }
        else
        {
            <MudTable Items="_lines" Dense="true" Hover="true">
                <HeaderContent>
                    <MudTh style="width: 50%;">Item</MudTh>
                    <MudTh style="width: 15%;">Qty</MudTh>
                    <MudTh style="width: 20%;">Unit Price</MudTh>
                    <MudTh style="width: 15%;">Actions</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd>
                        <MudSelect T="int?" @bind-Value="context.ItemId" Variant="Variant.Outlined" Dense="true" data-testid="sales-order-create-line-item">
                            <MudSelectItem T="int?" Value="@((int?)null)">Select item</MudSelectItem>
                            @foreach (var item in _items)
                            {
                                <MudSelectItem T="int?" Value="@((int?)item.Id)">@item.InternalSKU - @item.Name</MudSelectItem>
                            }
                        </MudSelect>
                    </MudTd>
                    <MudTd>
                        <MudNumericField T="decimal" Min="0.01m" Step="0.01m" @bind-Value="context.Qty" Variant="Variant.Outlined" Dense="true" data-testid="sales-order-create-line-qty" />
                    </MudTd>
                    <MudTd>
                        <MudNumericField T="decimal" Min="0m" Step="0.01m" @bind-Value="context.UnitPrice" Variant="Variant.Outlined" Dense="true" data-testid="sales-order-create-line-price" />
                    </MudTd>
                    <MudTd>
                        <MudButton Variant="Variant.Outlined"
                                   Size="Size.Small"
                                   Color="Color.Error"
                                   Disabled="@(_isSubmitting || _lines.Count == 1)"
                                   OnClick="() => RemoveLine(_lines.IndexOf(context))">
                            Remove
                        </MudButton>
                    </MudTd>
                </RowTemplate>
            </MudTable>
        }

        <MudStack Row="true" Justify="Justify.FlexEnd" Class="mt-3">
            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       Disabled="@_isSubmitting"
                       OnClick="CreateAsync"
                       @attributes="SubmitAttributes">
                Create Sales Order
            </MudButton>
        </MudStack>
    </MudPaper>
</div>

@code {
    private readonly List<SalesOrderCustomerLookupDto> _customers = [];
    private readonly List<AdminItemDto> _items = [];
    private readonly List<LineFormModel> _lines = [];
    private bool _isLoading;
    private bool _isSubmitting;
    private ApiException? _apiError;

    private Guid? _selectedCustomerId;
    private DateTime? _requestedDeliveryDate;

    private string _shippingStreet = string.Empty;
    private string _shippingCity = string.Empty;
    private string _shippingState = string.Empty;
    private string _shippingZipCode = string.Empty;
    private string _shippingCountry = string.Empty;

    private static readonly Dictionary<string, object> CustomerAttributes = new() { ["data-testid"] = "sales-order-create-customer" };
    private static readonly Dictionary<string, object> DeliveryDateAttributes = new() { ["data-testid"] = "sales-order-create-date" };
    private static readonly Dictionary<string, object> SubmitAttributes = new() { ["data-testid"] = "sales-order-create-submit" };
    private static readonly Dictionary<string, object> ShippingStreetAttributes = new() { ["data-testid"] = "sales-order-create-shipping-street" };
    private static readonly Dictionary<string, object> ShippingCityAttributes = new() { ["data-testid"] = "sales-order-create-shipping-city" };
    private static readonly Dictionary<string, object> ShippingStateAttributes = new() { ["data-testid"] = "sales-order-create-shipping-state" };
    private static readonly Dictionary<string, object> ShippingZipAttributes = new() { ["data-testid"] = "sales-order-create-shipping-zip" };
    private static readonly Dictionary<string, object> ShippingCountryAttributes = new() { ["data-testid"] = "sales-order-create-shipping-country" };

    protected override async Task OnInitializedAsync()
    {
        _lines.Add(new LineFormModel());
        await LoadLookupDataAsync();
    }

    private async Task LoadLookupDataAsync()
    {
        _isLoading = true;
        _apiError = null;

        try
        {
            var customers = await SalesOrdersClient.GetCustomersAsync();
            _customers.Clear();
            _customers.AddRange(customers);

            var items = await SalesOrdersClient.GetItemsAsync();
            _items.Clear();
            _items.AddRange(items.Items);
        }
        catch (ApiException ex)
        {
            _apiError = ex;
            ToastService.ShowError(BuildErrorMessage(ex));
        }
        finally
        {
            _isLoading = false;
        }
    }

    private Task OnCustomerChangedAsync()
    {
        if (!_selectedCustomerId.HasValue)
        {
            return Task.CompletedTask;
        }

        var customer = _customers.FirstOrDefault(x => x.Id == _selectedCustomerId.Value);
        if (customer?.DefaultShippingAddress is null)
        {
            return Task.CompletedTask;
        }

        _shippingStreet = customer.DefaultShippingAddress.Street;
        _shippingCity = customer.DefaultShippingAddress.City;
        _shippingState = customer.DefaultShippingAddress.State;
        _shippingZipCode = customer.DefaultShippingAddress.ZipCode;
        _shippingCountry = customer.DefaultShippingAddress.Country;
        return Task.CompletedTask;
    }

    private void AddLine()
    {
        _lines.Add(new LineFormModel());
    }

    private Task AddLineAsync()
    {
        AddLine();
        return Task.CompletedTask;
    }

    private void RemoveLine(int index)
    {
        if (index < 0 || index >= _lines.Count || _lines.Count == 1)
        {
            return;
        }

        _lines.RemoveAt(index);
    }

    private async Task CreateAsync()
    {
        if (!_selectedCustomerId.HasValue)
        {
            ToastService.ShowError("Select a customer.");
            return;
        }

        var normalizedLines = _lines
            .Where(x => x.ItemId.HasValue && x.Qty > 0 && x.UnitPrice >= 0)
            .Select(x => new SalesOrderLineCreateRequestDto
            {
                ItemId = x.ItemId!.Value,
                Qty = x.Qty,
                UnitPrice = x.UnitPrice
            })
            .ToList();

        if (normalizedLines.Count == 0)
        {
            ToastService.ShowError("Add at least one valid line (item, qty > 0).");
            return;
        }

        _isSubmitting = true;
        _apiError = null;

        try
        {
            var request = new SalesOrderCreateRequestDto
            {
                CommandId = Guid.NewGuid(),
                CustomerId = _selectedCustomerId.Value,
                RequestedDeliveryDate = _requestedDeliveryDate,
                ShippingAddress = BuildShippingAddress(),
                Lines = normalizedLines
            };

            var created = await SalesOrdersClient.CreateSalesOrderAsync(request);
            ToastService.ShowSuccess($"Sales order {created.OrderNumber} created.");
            NavigationManager.NavigateTo($"/warehouse/sales/orders/{created.Id}");
        }
        catch (ApiException ex)
        {
            _apiError = ex;
            ToastService.ShowError(BuildErrorMessage(ex));
        }
        finally
        {
            _isSubmitting = false;
        }
    }

    private SalesOrderAddressDto? BuildShippingAddress()
    {
        if (string.IsNullOrWhiteSpace(_shippingStreet) &&
            string.IsNullOrWhiteSpace(_shippingCity) &&
            string.IsNullOrWhiteSpace(_shippingState) &&
            string.IsNullOrWhiteSpace(_shippingZipCode) &&
            string.IsNullOrWhiteSpace(_shippingCountry))
        {
            return null;
        }

        return new SalesOrderAddressDto
        {
            Street = _shippingStreet.Trim(),
            City = _shippingCity.Trim(),
            State = _shippingState.Trim(),
            ZipCode = _shippingZipCode.Trim(),
            Country = _shippingCountry.Trim()
        };
    }

    private void BackToList()
    {
        NavigationManager.NavigateTo("/warehouse/sales/orders");
    }

    private void DismissError()
    {
        _apiError = null;
    }

    private static string BuildErrorMessage(ApiException ex)
    {
        if (!string.IsNullOrWhiteSpace(ex.UserMessage))
        {
            return ex.UserMessage;
        }

        return ex.ProblemDetails?.Detail
               ?? ex.ProblemDetails?.Title
               ?? "Sales order request failed.";
    }

    private sealed class LineFormModel
    {
        public int? ItemId { get; set; }
        public decimal Qty { get; set; } = 1m;
        public decimal UnitPrice { get; set; }
    }
}
