@page "/warehouse/cross-dock"
@inject AdvancedWarehouseClient AdvancedClient
@inject ToastService ToastService
@using LKvitai.MES.Modules.Warehouse.WebUI.Infrastructure

<PageTitle>Cross-Dock - LKvitai.MES</PageTitle>

<h3>Cross-Dock Tracking</h3>

@if (_error is not null)
{
    <SharedErrorAlert Message="@_error.UserMessage"
                 TraceId="@_error.TraceId"
                 OnRetry="LoadAsync"
                 OnDismiss="DismissError" />
}

<div class="mud-surface shadow-sm mb-3">
    <div class="mud-surface-body">
        <h5>Create Cross-Dock Match</h5>
        <div class="mud-grid-mrow g-2 align-items-end">
            <div class="mud-grid-col">
                <label class="form-label">Inbound Shipment Id</label>
                <input class="mud-input-base" @bind="_inboundId" placeholder="GUID" />
            </div>
            <div class="mud-grid-col">
                <label class="form-label">Outbound Order Id</label>
                <input class="mud-input-base" @bind="_outboundId" placeholder="GUID" />
            </div>
            <div class="mud-grid-col">
                <label class="form-label">Item Id</label>
                <input class="mud-input-base" type="number" @bind="_itemId" />
            </div>
            <div class="mud-grid-col">
                <label class="form-label">Qty</label>
                <input class="mud-input-base" type="number" step="0.01" @bind="_qty" />
            </div>
            <div class="mud-grid-col">
                <button class="mud-mbtn-base mud-mbtn-primary w-100" @onclick="CreateAsync" disabled="@_isBusy">Create</button>
            </div>
        </div>
    </div>
</div>

<div class="mud-surface shadow-sm">
    <div class="mud-surface-body">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h5 class="mb-0">Cross-Dock Queue</h5>
            <button class="mud-mbtn-base mud-mbtn-outline-secondary mud-mbtn-sm" @onclick="LoadAsync" disabled="@_isBusy">Refresh</button>
        </div>

        @if (_rows.Count == 0)
        {
            <EmptyState Title="No cross-dock records"
                        Message="Create a match to route inbound stock directly to outbound shipping."
                        Icon="@Icons.Material.Filled.SwapHoriz"
                        OnAction="LoadAsync" />
        }
        else
        {
            <div class="overflow-auto">
                <table class="mud-mtbl-base mud-mtbl-dense align-middle">
                    <thead>
                        <tr>
                            <th>Number</th>
                            <th>Item</th>
                            <th>Qty</th>
                            <th>Status</th>
                            <th>Created</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var mrow in _rows)
                        {
                            <tr>
                                <td>@mrow.CrossDockNumber</td>
                                <td>@mrow.ItemId</td>
                                <td>@mrow.Qty</td>
                                <td><span class="mud-pill bg-secondary">@mrow.Status</span></td>
                                <td>@mrow.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td>
                                <td class="d-flex gap-1">
                                    <button class="mud-mbtn-base mud-mbtn-sm mbtn-outline-success" @onclick='() => SetStatusAsync(mrow.Id, "MATCHED")'>Match</button>
                                    <button class="mud-mbtn-base mud-mbtn-sm mud-mbtn-outline-primary" @onclick='() => SetStatusAsync(mrow.Id, "COMPLETED")'>Complete</button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

@code {
    private readonly List<CrossDockDto> _rows = [];
    private string _inboundId = string.Empty;
    private string _outboundId = string.Empty;
    private int _itemId = 1;
    private decimal _qty = 1;
    private ApiException? _error;
    private bool _isBusy;

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        await ExecuteAsync(async () =>
        {
            var rows = await AdvancedClient.GetCrossDocksAsync();
            _rows.Clear();
            _rows.AddRange(rows);
        });
    }

    private async Task CreateAsync()
    {
        if (!Guid.TryParse(_inboundId, out var inboundId) || !Guid.TryParse(_outboundId, out var outboundId))
        {
            ToastService.ShowError("Inbound and outbound IDs must be valid GUID values.");
            return;
        }

        await ExecuteAsync(async () =>
        {
            await AdvancedClient.CreateCrossDockAsync(new CrossDockCreateRequestDto(inboundId, outboundId, _itemId, _qty));
            ToastService.ShowSuccess("Cross-dock record created.");
            _inboundId = string.Empty;
            _outboundId = string.Empty;
            await LoadAsync();
        });
    }

    private async Task SetStatusAsync(Guid id, string status)
    {
        await ExecuteAsync(async () =>
        {
            await AdvancedClient.UpdateCrossDockStatusAsync(id, status);
            await LoadAsync();
        });
    }

    private async Task ExecuteAsync(Func<Task> action)
    {
        _isBusy = true;
        _error = null;

        try
        {
            await action();
        }
        catch (ApiException ex)
        {
            _error = ex;
            ToastService.ShowError(ex.UserMessage);
        }
        finally
        {
            _isBusy = false;
        }
    }

    private void DismissError()
    {
        _error = null;
    }
}
