@inject MasterDataAdminClient AdminClient
@inject ToastService ToastService

<MudDialog Class="admin-item-photos-dialog">
    <TitleContent>
        <div class="admin-item-dialog__title">
            <span>Item Photos</span>
            <span class="mono">@InternalSKU</span>
        </div>
    </TitleContent>
    <DialogContent>
        @if (_apiError is not null)
        {
            <SharedErrorAlert Message="@BuildErrorMessage(_apiError)"
                              TraceId="@_apiError.TraceId"
                              OnRetry="LoadPhotosAsync"
                              OnDismiss="@(() => _apiError = null)" />
        }

        @if (_isLoading)
        {
            <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
        }

        <div class="admin-item-photos-dialog__toolbar">
            <div>
                <strong>@Name</strong>
                <span class="mono">@_photos.Count photo(s)</span>
            </div>
            <div class="admin-item-photos-dialog__actions">
                <InputFile OnChange="HandleFileSelectedAsync" accept="image/jpeg,image/png,image/webp" />
                <MudButton Variant="Variant.Outlined"
                           Color="Color.Primary"
                           Size="Size.Small"
                           Disabled="@(_photos.Count == 0 || _isLoading)"
                           OnClick="RecomputeEmbeddingsAsync">
                    Recompute
                </MudButton>
            </div>
        </div>

        @if (!_isLoading && _photos.Count == 0)
        {
            <div class="admin-item-photos-dialog__empty">
                <span class="lots-grid__empty-title">No photos</span>
                <span>Upload a product image to make it visible in the items grid.</span>
            </div>
        }
        else
        {
            <div class="admin-item-photos-dialog__grid">
                @foreach (var photo in _photos)
                {
                    <div class="admin-item-photo">
                        <img src="@photo.ThumbUrl" alt="@($"{Name} photo")" loading="lazy" />
                        <div class="admin-item-photo__body">
                            <div class="admin-item-photo__meta">
                                @if (photo.IsPrimary)
                                {
                                    <span class="chip chip--info">Primary</span>
                                }
                                else
                                {
                                    <span class="chip chip--slate">Photo</span>
                                }
                                <span class="mono">@FormatBytes(photo.SizeBytes)</span>
                            </div>
                            <div class="admin-item-photo__buttons">
                                <MudButton Href="@photo.OriginalUrl"
                                           Target="_blank"
                                           Rel="noopener"
                                           Variant="Variant.Outlined"
                                           Color="Color.Primary"
                                           Size="Size.Small">
                                    Open
                                </MudButton>
                                <MudButton Variant="Variant.Outlined"
                                           Color="Color.Primary"
                                           Size="Size.Small"
                                           Disabled="@(photo.IsPrimary || _isLoading)"
                                           OnClick="@(() => MakePrimaryAsync(photo.Id))">
                                    Primary
                                </MudButton>
                                <MudButton Variant="Variant.Outlined"
                                           Color="Color.Error"
                                           Size="Size.Small"
                                           Disabled="@_isLoading"
                                           OnClick="@(() => DeletePhotoAsync(photo.Id))">
                                    Delete
                                </MudButton>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Close">Close</MudButton>
    </DialogActions>
</MudDialog>

@code {
    private const long MaxPhotoBytes = 5L * 1024 * 1024;

    [CascadingParameter] private MudDialogInstance MudDialog { get; set; } = default!;

    [Parameter] public int ItemId { get; set; }
    [Parameter] public string InternalSKU { get; set; } = string.Empty;
    [Parameter] public string Name { get; set; } = string.Empty;

    private readonly List<ItemPhotoDto> _photos = [];
    private bool _isLoading;
    private bool _changed;
    private ApiException? _apiError;

    protected override async Task OnInitializedAsync()
    {
        await LoadPhotosAsync();
    }

    private async Task LoadPhotosAsync()
    {
        _isLoading = true;
        _apiError = null;

        try
        {
            var response = await AdminClient.GetItemPhotosAsync(ItemId);
            _photos.Clear();
            _photos.AddRange(response.Photos.OrderByDescending(x => x.IsPrimary).ThenByDescending(x => x.CreatedAt));
        }
        catch (ApiException ex)
        {
            _apiError = ex;
            ToastService.ShowError(BuildErrorMessage(ex));
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task HandleFileSelectedAsync(InputFileChangeEventArgs args)
    {
        var file = args.File;
        if (file is null)
        {
            return;
        }

        _isLoading = true;
        _apiError = null;

        try
        {
            await using var stream = file.OpenReadStream(MaxPhotoBytes);
            using var ms = new MemoryStream();
            await stream.CopyToAsync(ms);
            await AdminClient.UploadPhotoAsync(ItemId, file.Name, ms.ToArray(), file.ContentType);
            _changed = true;
            ToastService.ShowSuccess("Photo uploaded.");
            await LoadPhotosAsync();
        }
        catch (ApiException ex)
        {
            _apiError = ex;
            ToastService.ShowError(BuildErrorMessage(ex));
        }
        catch (IOException ex)
        {
            ToastService.ShowError(ex.Message);
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task MakePrimaryAsync(Guid photoId)
    {
        _isLoading = true;
        _apiError = null;

        try
        {
            await AdminClient.MakePrimaryPhotoAsync(ItemId, photoId);
            _changed = true;
            ToastService.ShowSuccess("Primary photo updated.");
            await LoadPhotosAsync();
        }
        catch (ApiException ex)
        {
            _apiError = ex;
            ToastService.ShowError(BuildErrorMessage(ex));
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task DeletePhotoAsync(Guid photoId)
    {
        _isLoading = true;
        _apiError = null;

        try
        {
            await AdminClient.DeletePhotoAsync(ItemId, photoId);
            _changed = true;
            ToastService.ShowWarning("Photo deleted.");
            await LoadPhotosAsync();
        }
        catch (ApiException ex)
        {
            _apiError = ex;
            ToastService.ShowError(BuildErrorMessage(ex));
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task RecomputeEmbeddingsAsync()
    {
        _isLoading = true;
        _apiError = null;

        try
        {
            var count = await AdminClient.RecomputeEmbeddingsAsync(ItemId);
            ToastService.ShowSuccess($"Embeddings recomputed for {count} photo(s).");
        }
        catch (ApiException ex)
        {
            _apiError = ex;
            ToastService.ShowError(BuildErrorMessage(ex));
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void Close() => MudDialog.Close(DialogResult.Ok(_changed));

    private static string FormatBytes(long bytes)
        => bytes >= 1024 * 1024
            ? $"{bytes / 1024m / 1024m:0.#} MB"
            : $"{Math.Max(1, bytes / 1024m):0.#} KB";

    private static string BuildErrorMessage(ApiException error)
    {
        if (!string.IsNullOrWhiteSpace(error.ProblemDetails?.Detail))
        {
            return $"{error.UserMessage} {error.ProblemDetails.Detail}";
        }

        return error.UserMessage;
    }
}
