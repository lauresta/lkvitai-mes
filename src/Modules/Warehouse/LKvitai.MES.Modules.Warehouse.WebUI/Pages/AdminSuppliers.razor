@page "/admin/suppliers"
@inject MasterDataAdminClient AdminClient
@inject ToastService ToastService

<PageTitle>Admin Suppliers - LKvitai.MES</PageTitle>

<div data-testid="admin-suppliers-page">
    <MudText Typo="Typo.h5" Class="mb-3">Suppliers Management</MudText>

    @if (_apiError is not null)
    {
        <div data-testid="admin-suppliers-error" class="mb-3">
            <SharedErrorAlert Message="@BuildErrorMessage(_apiError)"
                         TraceId="@_apiError.TraceId"
                         OnRetry="ReloadAsync"
                         OnDismiss="@(() => _apiError = null)" />
        </div>
    }

    <MudPaper Class="pa-4 mb-4">
        <MudGrid Spacing="2" AlignItems="AlignItems.End">
            <MudItem xs="12" md="6">
                <MudTextField T="string"
                              Label="Search"
                              Placeholder="Code or name"
                              @bind-Value="_search"
                              Variant="Variant.Outlined"
                              Dense="true"
                              @attributes="SearchAttributes" />
            </MudItem>
            <MudItem xs="12" md="6">
                <MudStack Row="true" Spacing="2" Justify="Justify.FlexEnd" Class="flex-wrap">
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="ApplyFiltersAsync" Disabled="@_isLoading">Filter</MudButton>
                    <MudButton Variant="Variant.Outlined" Color="Color.Default" Href="/admin/supplier-mappings">View Mappings</MudButton>
                    <MudButton Variant="Variant.Outlined" Color="Color.Primary" OnClick="ToggleCreate">
                        @(_showCreate ? "Hide Create Form" : "Create Supplier")
                    </MudButton>
                </MudStack>
            </MudItem>
        </MudGrid>
    </MudPaper>

    <MudPaper Class="pa-4 mb-4 position-relative">
         (@(_isLoading || _isSubmitting))
        {
            <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-3" />
        }

        <MudTable T="AdminSupplierDto"
                  Items="_suppliers"
                  Dense="true"
                  Hover="true"
                  data-testid="admin-suppliers-grid">
            <HeaderContent>
                <MudTh>Code</MudTh>
                <MudTh>Name</MudTh>
                <MudTh>Contact Info</MudTh>
                <MudTh></MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Code">@context.Code</MudTd>
                <MudTd DataLabel="Name">@context.Name</MudTd>
                <MudTd DataLabel="Contact Info">@context.ContactInfo</MudTd>
                <MudTd DataLabel="Actions" Align="Align.Right">
                    <MudButton Variant="Variant.Outlined" Size="Size.Small" Color="Color.Default" OnClick="() => BeginEdit(context)">Edit</MudButton>
                </MudTd>
            </RowTemplate>
            <NoRecordsContent>
                <MudText Typo="Typo.body2" Color="Color.Secondary">No suppliers found.</MudText>
            </NoRecordsContent>
        </MudTable>

        @if (_totalCount > 0)
        {
            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.FlexEnd" Class="mt-3" data-testid="admin-suppliers-pager">
                <MudSelect T="int"
                           Label="Page size"
                           Value="_pageSize"
                           ValueChanged="OnPageSizeChangedAsync"
                           Variant="Variant.Outlined"
                           Dense="true"
                           Style="width: 120px;"
                           @attributes="PageSizeAttributes">
                    <MudSelectItem Value="25">25</MudSelectItem>
                    <MudSelectItem Value="50">50</MudSelectItem>
                    <MudSelectItem Value="100">100</MudSelectItem>
                </MudSelect>
                <MudPagination Count="@TotalPages"
                               Selected="@_pageNumber"
                               SelectedChanged="OnPageChangedAsync"
                               Variant="Variant.Outlined"
                               Color="Color.Primary"
                               Size="Size.Small"
                               Class="ml-2" />
            </MudStack>
        }
    </MudPaper>

    @if (_showCreate)
    {
        <MudPaper Class="pa-4 mb-4" data-testid="admin-suppliers-create-form">
            <MudText Typo="Typo.h6" Class="mb-3">Create Supplier</MudText>
            <MudGrid Spacing="2" AlignItems="AlignItems.End">
                <MudItem xs="12" md="3">
                    <MudTextField T="string" Label="Code" @bind-Value="_create.Code" Variant="Variant.Outlined" Dense="true" />
                </MudItem>
                <MudItem xs="12" md="5">
                    <MudTextField T="string" Label="Name" @bind-Value="_create.Name" Variant="Variant.Outlined" Dense="true" />
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudTextField T="string" Label="Contact Info" @bind-Value="_create.ContactInfo" Variant="Variant.Outlined" Dense="true" />
                </MudItem>
                <MudItem xs="12" md="3">
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               FullWidth="true"
                               OnClick="CreateAsync"
                               Disabled="@_isSubmitting"
                               data-testid="admin-suppliers-submit">
                        Save Supplier
                    </MudButton>
                </MudItem>
            </MudGrid>
        </MudPaper>
    }

    @if (_editing is not null)
    {
        <MudPaper Class="pa-4" data-testid="admin-suppliers-edit-form">
            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-3">
                <MudText Typo="Typo.h6">Edit Supplier: @_editing.Code</MudText>
                <MudButton Variant="Variant.Text" Color="Color.Default" Size="Size.Small" OnClick="CloseEdit">Close</MudButton>
            </MudStack>

            <MudGrid Spacing="2" AlignItems="AlignItems.End">
                <MudItem xs="12" md="3">
                    <MudTextField T="string" Label="Code" @bind-Value="_editing.Code" Variant="Variant.Outlined" Dense="true" />
                </MudItem>
                <MudItem xs="12" md="5">
                    <MudTextField T="string" Label="Name" @bind-Value="_editing.Name" Variant="Variant.Outlined" Dense="true" />
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudTextField T="string" Label="Contact Info" @bind-Value="_editing.ContactInfo" Variant="Variant.Outlined" Dense="true" />
                </MudItem>
                <MudItem xs="12" md="3">
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               FullWidth="true"
                               OnClick="UpdateAsync"
                               Disabled="@_isSubmitting"
                               data-testid="admin-suppliers-update-submit">
                        Save Changes
                    </MudButton>
                </MudItem>
            </MudGrid>
        </MudPaper>
    }
</div>

@code {
    private readonly List<AdminSupplierDto> _suppliers = [];

    private string? _search;
    private int _pageNumber = 1;
    private int _pageSize = 50;
    private int _totalCount;
    private bool _isLoading;
    private bool _isSubmitting;
    private bool _showCreate;
    private ApiException? _apiError;

    private SupplierForm _create = new();
    private SupplierEditForm? _editing;

    private static readonly Dictionary<string, object> SearchAttributes = new() { ["data-testid"] = "admin-suppliers-search" };
    private static readonly Dictionary<string, object> PageSizeAttributes = new() { ["data-testid"] = "admin-suppliers-page-size" };

    private int TotalPages => Math.Max(1, (int)Math.Ceiling(_totalCount / (double)Math.Max(1, _pageSize)));

    protected override async Task OnInitializedAsync()
    {
        await ReloadAsync();
    }

    private async Task ReloadAsync()
    {
        _isLoading = true;
        _apiError = null;

        try
        {
            await LoadSuppliersAsync();
        }
        catch (ApiException ex)
        {
            _apiError = ex;
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void ToggleCreate()
    {
        _showCreate = !_showCreate;
    }

    private void CloseEdit()
    {
        _editing = null;
    }

    private async Task ApplyFiltersAsync()
    {
        _pageNumber = 1;
        await LoadSuppliersAsync();
    }

    private async Task LoadSuppliersAsync()
    {
        var result = await AdminClient.GetSuppliersAsync(_search, _pageNumber, _pageSize);
        _suppliers.Clear();
        _suppliers.AddRange(result.Items);
        _totalCount = result.TotalCount;
    }

    private async Task OnPageChangedAsync(int page)
    {
        _pageNumber = Math.Max(1, page);
        await LoadSuppliersAsync();
    }

    private async Task OnPageSizeChangedAsync(int size)
    {
        _pageSize = Math.Clamp(size, 1, 500);
        _pageNumber = 1;
        await LoadSuppliersAsync();
    }

    private async Task CreateAsync()
    {
        _isSubmitting = true;

        try
        {
            _apiError = null;
            await AdminClient.CreateSupplierAsync(new CreateOrUpdateSupplierRequest(
                _create.Code,
                _create.Name,
                _create.ContactInfo));
            ToastService.ShowSuccess("Supplier created.");
            _create = new SupplierForm();
            await LoadSuppliersAsync();
        }
        catch (ApiException ex)
        {
            _apiError = ex;
            ToastService.ShowError(BuildErrorMessage(ex));
        }
        finally
        {
            _isSubmitting = false;
        }
    }

    private void BeginEdit(AdminSupplierDto row)
    {
        _editing = new SupplierEditForm
        {
            Id = row.Id,
            Code = row.Code,
            Name = row.Name,
            ContactInfo = row.ContactInfo
        };
    }

    private async Task UpdateAsync()
    {
        if (_editing is null)
        {
            return;
        }

        _isSubmitting = true;

        try
        {
            _apiError = null;
            await AdminClient.UpdateSupplierAsync(
                _editing.Id,
                new CreateOrUpdateSupplierRequest(_editing.Code, _editing.Name, _editing.ContactInfo));
            ToastService.ShowSuccess("Supplier updated.");
            _editing = null;
            await LoadSuppliersAsync();
        }
        catch (ApiException ex)
        {
            _apiError = ex;
            ToastService.ShowError(BuildErrorMessage(ex));
        }
        finally
        {
            _isSubmitting = false;
        }
    }

    private static string BuildErrorMessage(ApiException error)
    {
        if (!string.IsNullOrWhiteSpace(error.ProblemDetails?.Detail))
        {
            return $"{error.UserMessage} {error.ProblemDetails.Detail}";
        }

        return error.UserMessage;
    }

    private class SupplierForm
    {
        public string Code { get; set; } = string.Empty;
        public string Name { get; set; } = string.Empty;
        public string? ContactInfo { get; set; }
    }

    private sealed class SupplierEditForm : SupplierForm
    {
        public int Id { get; set; }
    }
}
