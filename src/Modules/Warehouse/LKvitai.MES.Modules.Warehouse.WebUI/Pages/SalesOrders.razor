@page "/warehouse/sales/orders"
@inject SalesOrdersClient SalesOrdersClient
@inject NavigationManager NavigationManager
@inject ToastService ToastService

<PageTitle>Sales Orders - LKvitai.MES</PageTitle>

<div data-testid="sales-orders-page">
    <MudText Typo="Typo.h5" Class="mb-3">Sales Orders</MudText>

    @if (_apiError is not null)
    {
        <div data-testid="sales-orders-error" class="mb-3">
            <SharedErrorAlert Message="@BuildErrorMessage(_apiError)"
                         TraceId="@_apiError.TraceId"
                         OnRetry="RetryAsync"
                         OnDismiss="DismissError" />
        </div>
    }

    <MudPaper Class="pa-4 position-relative">
        @if (_isLoading)
        {
            <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-3" />
        }

        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-3 flex-wrap">
            <MudText Typo="Typo.subtitle1">Total: @_totalCount</MudText>
            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       OnClick="OpenCreate"
                       data-testid="sales-orders-create">
                + Create
            </MudButton>
        </MudStack>

        <MudGrid Spacing="2" AlignItems="AlignItems.End" Class="mb-3" data-testid="sales-orders-filters">
            <MudItem xs="12" md="3">
                <MudSelect T="string"
                           Label="Status"
                           @bind-Value="_statusFilter"
                           Variant="Variant.Outlined"
                           Dense="true"
                           @attributes="StatusFilterAttributes">
                    <MudSelectItem T="string" Value="@string.Empty">All</MudSelectItem>
                    <MudSelectItem T="string" Value="@("DRAFT")">DRAFT</MudSelectItem>
                    <MudSelectItem T="string" Value="@("PENDING_APPROVAL")">PENDING_APPROVAL</MudSelectItem>
                    <MudSelectItem T="string" Value="@("ALLOCATED")">ALLOCATED</MudSelectItem>
                    <MudSelectItem T="string" Value="@("PENDING_STOCK")">PENDING_STOCK</MudSelectItem>
                    <MudSelectItem T="string" Value="@("PICKING")">PICKING</MudSelectItem>
                    <MudSelectItem T="string" Value="@("PACKED")">PACKED</MudSelectItem>
                    <MudSelectItem T="string" Value="@("SHIPPED")">SHIPPED</MudSelectItem>
                    <MudSelectItem T="string" Value="@("DELIVERED")">DELIVERED</MudSelectItem>
                    <MudSelectItem T="string" Value="@("INVOICED")">INVOICED</MudSelectItem>
                    <MudSelectItem T="string" Value="@("CANCELLED")">CANCELLED</MudSelectItem>
                </MudSelect>
            </MudItem>
            <MudItem xs="12" md="3">
                <MudSelect T="string"
                           Label="Customer"
                           @bind-Value="_customerFilter"
                           Variant="Variant.Outlined"
                           Dense="true"
                           @attributes="CustomerFilterAttributes">
                    <MudSelectItem T="string" Value="@string.Empty">All</MudSelectItem>
                    @foreach (var customer in _customers)
                    {
                        <MudSelectItem T="string" Value="@customer.Id.ToString()">@customer.CustomerCode - @customer.Name</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" md="2">
                <MudDatePicker Label="Date from"
                               Date="@_dateFrom"
                               DateChanged="OnDateFromChanged"
                               Variant="Variant.Outlined"
                               PickerVariant="PickerVariant.Inline"
                               Dense="true"
                               @attributes="DateFromAttributes" />
            </MudItem>
            <MudItem xs="12" md="2">
                <MudDatePicker Label="Date to"
                               Date="@_dateTo"
                               DateChanged="OnDateToChanged"
                               Variant="Variant.Outlined"
                               PickerVariant="PickerVariant.Inline"
                               Dense="true"
                               @attributes="DateToAttributes" />
            </MudItem>
            <MudItem xs="12" md="2">
                <MudStack Row="true" Spacing="1">
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               OnClick="ApplyFiltersAsync"
                               Disabled="@_isLoading"
                               data-testid="sales-orders-apply">
                        Apply
                    </MudButton>
                    <MudButton Variant="Variant.Outlined"
                               Color="Color.Default"
                               OnClick="ResetFiltersAsync"
                               Disabled="@_isLoading"
                               data-testid="sales-orders-reset">
                        Reset
                    </MudButton>
                </MudStack>
            </MudItem>
        </MudGrid>

        <MudTable T="SalesOrderDto"
                  Items="_orders"
                  Dense="true"
                  Hover="true"
                  data-testid="sales-orders-grid">
            <HeaderContent>
                <MudTh>Order Number</MudTh>
                <MudTh>Customer</MudTh>
                <MudTh>Status</MudTh>
                <MudTh>Lines</MudTh>
                <MudTh>Total</MudTh>
                <MudTh>Order Date</MudTh>
                <MudTh>Requested Date</MudTh>
                <MudTh>Actions</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Order Number">@context.OrderNumber</MudTd>
                <MudTd DataLabel="Customer">@context.CustomerName</MudTd>
                <MudTd DataLabel="Status">
                    <MudChip Size="Size.Small" Color="@GetStatusColor(context.Status)">@context.Status</MudChip>
                </MudTd>
                <MudTd DataLabel="Lines">@context.Lines.Count</MudTd>
                <MudTd DataLabel="Total">@context.TotalAmount.ToString("0.00")</MudTd>
                <MudTd DataLabel="Order Date">@FormatDate(context.OrderDate)</MudTd>
                <MudTd DataLabel="Requested Date">@FormatDate(context.RequestedDeliveryDate)</MudTd>
                <MudTd DataLabel="Actions">
                    <MudButton Variant="Variant.Outlined"
                               Size="Size.Small"
                               Color="Color.Primary"
                               OnClick="() => OpenDetails(context.Id)">
                        View
                    </MudButton>
                </MudTd>
            </RowTemplate>
            <NoRecordsContent>
                <EmptyState Title="No sales orders found"
                            Message="Create a sales order to start outbound workflow."
                            Icon="@Icons.Material.Filled.NoteAdd"
                            OnAction="OpenCreateAsync" />
            </NoRecordsContent>
        </MudTable>

        @if (TotalPages > 1)
        {
            <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mt-3" data-testid="sales-orders-pager">
                <MudText Typo="Typo.body2" Color="Color.Secondary">Page @_page of @TotalPages</MudText>
                <MudPagination Count="@TotalPages"
                               Selected="@_page"
                               SelectedChanged="OnPageChangedAsync"
                               Variant="Variant.Outlined"
                               Color="Color.Primary"
                               Size="Size.Small" />
            </MudStack>
        }
    </MudPaper>
</div>

@code {
    private readonly List<SalesOrderDto> _orders = [];
    private readonly List<SalesOrderCustomerLookupDto> _customers = [];
    private bool _isLoading;
    private ApiException? _apiError;
    private string _statusFilter = string.Empty;
    private string _customerFilter = string.Empty;
    private DateTime? _dateFrom;
    private DateTime? _dateTo;
    private int _page = 1;
    private const int PageSize = 20;
    private int _totalCount;

    private static readonly Dictionary<string, object> StatusFilterAttributes = new() { ["data-testid"] = "sales-orders-status" };
    private static readonly Dictionary<string, object> CustomerFilterAttributes = new() { ["data-testid"] = "sales-orders-customer" };
    private static readonly Dictionary<string, object> DateFromAttributes = new() { ["data-testid"] = "sales-orders-date-from" };
    private static readonly Dictionary<string, object> DateToAttributes = new() { ["data-testid"] = "sales-orders-date-to" };

    private int TotalPages => Math.Max(1, (int)Math.Ceiling(_totalCount / (double)Math.Max(1, PageSize)));

    protected override async Task OnInitializedAsync()
    {
        await LoadCustomersAsync();
        await ReloadAsync();
    }

    private async Task LoadCustomersAsync()
    {
        try
        {
            var rows = await SalesOrdersClient.GetCustomersAsync();
            _customers.Clear();
            _customers.AddRange(rows);
        }
        catch (ApiException ex)
        {
            _apiError = ex;
            ToastService.ShowError(BuildErrorMessage(ex));
        }
    }

    private Task OnDateFromChanged(DateTime? value)
    {
        _dateFrom = value;
        return Task.CompletedTask;
    }

    private Task OnDateToChanged(DateTime? value)
    {
        _dateTo = value;
        return Task.CompletedTask;
    }

    private async Task ApplyFiltersAsync()
    {
        _page = 1;
        await ReloadAsync();
    }

    private async Task ResetFiltersAsync()
    {
        _statusFilter = string.Empty;
        _customerFilter = string.Empty;
        _dateFrom = null;
        _dateTo = null;
        _page = 1;
        await ReloadAsync();
    }

    private Task RetryAsync() => ReloadAsync();

    private async Task ReloadAsync()
    {
        _isLoading = true;
        _apiError = null;

        try
        {
            Guid? customerId = null;
            if (!string.IsNullOrWhiteSpace(_customerFilter) && Guid.TryParse(_customerFilter, out var parsed))
            {
                customerId = parsed;
            }

            var response = await SalesOrdersClient.GetSalesOrdersAsync(
                _statusFilter,
                customerId,
                _dateFrom,
                _dateTo,
                _page,
                PageSize);

            _orders.Clear();
            _orders.AddRange(response.Items);
            _totalCount = response.TotalCount;
            _page = Math.Min(Math.Max(1, _page), TotalPages);
        }
        catch (ApiException ex)
        {
            _apiError = ex;
            ToastService.ShowError(BuildErrorMessage(ex));
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task OnPageChangedAsync(int page)
    {
        _page = Math.Max(1, page);
        await ReloadAsync();
    }

    private void DismissError()
    {
        _apiError = null;
    }

    private void OpenCreate()
    {
        NavigationManager.NavigateTo("/warehouse/sales/orders/create");
    }

    private Task OpenCreateAsync()
    {
        OpenCreate();
        return Task.CompletedTask;
    }

    private void OpenDetails(Guid id)
    {
        NavigationManager.NavigateTo($"/warehouse/sales/orders/{id}");
    }

    private static string FormatDate(DateTime? date)
    {
        return date?.ToString("yyyy-MM-dd") ?? "-";
    }

    private static Color GetStatusColor(string status) => status.ToUpperInvariant() switch
    {
        "DRAFT" => Color.Default,
        "PENDING_APPROVAL" => Color.Warning,
        "ALLOCATED" => Color.Info,
        "PENDING_STOCK" => Color.Warning,
        "PICKING" => Color.Primary,
        "PACKED" => Color.Primary,
        "SHIPPED" => Color.Success,
        "DELIVERED" => Color.Success,
        "INVOICED" => Color.Dark,
        "CANCELLED" => Color.Error,
        _ => Color.Default
    };

    private static string BuildErrorMessage(ApiException ex)
    {
        if (!string.IsNullOrWhiteSpace(ex.UserMessage))
        {
            return ex.UserMessage;
        }

        return ex.ProblemDetails?.Detail
               ?? ex.ProblemDetails?.Title
               ?? "Sales order request failed.";
    }
}
