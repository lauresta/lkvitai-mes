@page "/admin/users"
@inject AdminUsersClient AdminUsersClient
@inject ToastService ToastService

<PageTitle>Admin Users - LKvitai.MES</PageTitle>

<div data-testid="admin-users-page">
    <MudText Typo="Typo.h5" Class="mb-3">Admin Users</MudText>

    @if (_apiError is not null)
    {
        <div data-testid="admin-users-error" class="mb-3">
            <SharedErrorAlert Message="@BuildErrorMessage(_apiError)"
                         TraceId="@_apiError.TraceId"
                         OnRetry="LoadAsync"
                         OnDismiss="DismissError" />
        </div>
    }

    <MudGrid Spacing="3">
        <MudItem xs="12" lg="4">
            <MudPaper Class="pa-4 position-relative" data-testid="admin-users-form">
                 (_isLoading || _isSubmittingCreate)
        {
            <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-3" />
        }

                <MudText Typo="Typo.h6" Class="mb-3">Create User</MudText>

                <MudTextField T="string"
                              Label="Username"
                              @bind-Value="_createUsername"
                              Variant="Variant.Outlined"
                              Dense="true"
                              Class="mb-2"
                              data-testid="admin-users-create-username" />
                <MudTextField T="string"
                              Label="Email"
                              @bind-Value="_createEmail"
                              Variant="Variant.Outlined"
                              Dense="true"
                              Class="mb-2"
                              data-testid="admin-users-create-email" />
                <MudTextField T="string"
                              Label="Password"
                              InputType="InputType.Password"
                              @bind-Value="_createPassword"
                              Variant="Variant.Outlined"
                              Dense="true"
                              Class="mb-2"
                              data-testid="admin-users-create-password" />
                <MudSelect T="string"
                           Label="Status"
                           @bind-Value="_createStatus"
                           Variant="Variant.Outlined"
                           Dense="true"
                           Class="mb-2"
                           data-testid="admin-users-create-status">
                    <MudSelectItem T="string" Value="@("Active")">Active</MudSelectItem>
                    <MudSelectItem T="string" Value="@("Inactive")">Inactive</MudSelectItem>
                </MudSelect>

                <MudText Typo="Typo.subtitle2" Class="mt-3 mb-1">Roles</MudText>
                <MudStack Spacing="0" Class="mb-3">
                    @foreach (var role in AllRoles)
                    {
                        <MudCheckBox T="bool"
                                     Label="@role"
                                     Checked="@_createRoles.Contains(role)"
                                     CheckedChanged="value => ToggleCreateRole(role, value)"
                                     Dense="true" />
                    }
                </MudStack>

                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           FullWidth="true"
                           OnClick="CreateAsync"
                           Disabled="@_isSubmittingCreate"
                           data-testid="admin-users-create-submit">
                    Create User
                </MudButton>
            </MudPaper>
        </MudItem>

        <MudItem xs="12" lg="8">
            <MudPaper Class="pa-4 position-relative">
                 (_isLoading || _isSubmittingUpdate)
        {
            <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-3" />
        }

                <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-3">
                    <MudText Typo="Typo.h6">Users (@_users.Count)</MudText>
                    <MudButton Variant="Variant.Outlined"
                               Color="Color.Default"
                               Size="Size.Small"
                               OnClick="LoadAsync"
                               Disabled="@_isLoading"
                               data-testid="admin-users-refresh">
                        Refresh
                    </MudButton>
                </MudStack>

                <MudTable T="AdminUserDto"
                          Items="_users"
                          Dense="true"
                          Hover="true"
                          data-testid="admin-users-grid">
                    <HeaderContent>
                        <MudTh>Username</MudTh>
                        <MudTh>Email</MudTh>
                        <MudTh>Roles</MudTh>
                        <MudTh>Status</MudTh>
                        <MudTh>Created</MudTh>
                        <MudTh>Actions</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="Username">@context.Username</MudTd>
                        <MudTd DataLabel="Email">@context.Email</MudTd>
                        <MudTd DataLabel="Roles">
                            <MudStack Row="true" Spacing="1" Class="flex-wrap">
                                @foreach (var role in context.Roles)
                                {
                                    <MudChip Size="Size.Small" Variant="Variant.Outlined" Color="Color.Default">@role</MudChip>
                                }
                            </MudStack>
                        </MudTd>
                        <MudTd DataLabel="Status">
                            <MudChip Size="Size.Small" Color="@(context.Status.Equals("Active", StringComparison.OrdinalIgnoreCase) ? Color.Success : Color.Default)">
                                @context.Status
                            </MudChip>
                        </MudTd>
                        <MudTd DataLabel="Created">@context.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</MudTd>
                        <MudTd DataLabel="Actions">
                            <MudButton Variant="Variant.Outlined"
                                       Size="Size.Small"
                                       Color="Color.Primary"
                                       OnClick="() => StartEdit(context)">
                                Edit
                            </MudButton>
                        </MudTd>
                    </RowTemplate>
                    <NoRecordsContent>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">No users found.</MudText>
                    </NoRecordsContent>
                </MudTable>

                @if (_editUser is not null)
                {
                    <MudPaper Class="pa-3 mt-4" Outlined="true" data-testid="admin-users-edit-form">
                        <MudText Typo="Typo.subtitle1" Class="mb-2">Edit @_editUser.Username</MudText>

                        <MudGrid Spacing="2">
                            <MudItem xs="12" md="6">
                                <MudTextField T="string"
                                              Label="Email"
                                              @bind-Value="_editEmail"
                                              Variant="Variant.Outlined"
                                              Dense="true"
                                              data-testid="admin-users-edit-email" />
                            </MudItem>
                            <MudItem xs="12" md="3">
                                <MudSelect T="string"
                                           Label="Status"
                                           @bind-Value="_editStatus"
                                           Variant="Variant.Outlined"
                                           Dense="true"
                                           data-testid="admin-users-edit-status">
                                    <MudSelectItem T="string" Value="@("Active")">Active</MudSelectItem>
                                    <MudSelectItem T="string" Value="@("Inactive")">Inactive</MudSelectItem>
                                </MudSelect>
                            </MudItem>
                        </MudGrid>

                        <MudText Typo="Typo.subtitle2" Class="mt-3 mb-1">Roles</MudText>
                        <MudGrid Spacing="1" Class="mb-2">
                            @foreach (var role in AllRoles)
                            {
                                <MudItem xs="12" md="6">
                                    <MudCheckBox T="bool"
                                                 Label="@role"
                                                 Checked="@_editRoles.Contains(role)"
                                                 CheckedChanged="value => ToggleEditRole(role, value)"
                                                 Dense="true" />
                                </MudItem>
                            }
                        </MudGrid>

                        <MudStack Row="true" Spacing="2" Class="mt-3">
                            <MudButton Variant="Variant.Filled"
                                       Color="Color.Primary"
                                       OnClick="SaveEditAsync"
                                       Disabled="@_isSubmittingUpdate"
                                       data-testid="admin-users-edit-submit">
                                Save
                            </MudButton>
                            <MudButton Variant="Variant.Outlined"
                                       Color="Color.Default"
                                       OnClick="CancelEdit"
                                       Disabled="@_isSubmittingUpdate">
                                Cancel
                            </MudButton>
                        </MudStack>
                    </MudPaper>
                }
            </MudPaper>
        </MudItem>
    </MudGrid>
</div>

@code {
    private static readonly string[] AllRoles =
    [
        "WarehouseAdmin",
        "WarehouseManager",
        "Operator",
        "QCInspector",
        "SalesAdmin",
        "PackingOperator",
        "DispatchClerk",
        "InventoryAccountant",
        "CFO"
    ];

    private readonly List<AdminUserDto> _users = [];
    private ApiException? _apiError;
    private bool _isLoading;
    private bool _isSubmittingCreate;
    private bool _isSubmittingUpdate;

    private string _createUsername = string.Empty;
    private string _createEmail = string.Empty;
    private string _createPassword = string.Empty;
    private string _createStatus = "Active";
    private readonly HashSet<string> _createRoles = ["WarehouseAdmin"];

    private AdminUserDto? _editUser;
    private string _editEmail = string.Empty;
    private string _editStatus = "Active";
    private HashSet<string> _editRoles = [];

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _isLoading = true;
        _apiError = null;

        try
        {
            var users = await AdminUsersClient.GetUsersAsync();
            _users.Clear();
            _users.AddRange(users.OrderBy(x => x.Username, StringComparer.OrdinalIgnoreCase));
        }
        catch (ApiException ex)
        {
            _apiError = ex;
            ToastService.ShowError(BuildErrorMessage(ex));
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task CreateAsync()
    {
        if (string.IsNullOrWhiteSpace(_createUsername) || string.IsNullOrWhiteSpace(_createEmail) || string.IsNullOrWhiteSpace(_createPassword))
        {
            ToastService.ShowError("Username, email, and password are required.");
            return;
        }

        if (_createRoles.Count == 0)
        {
            ToastService.ShowError("Select at least one role.");
            return;
        }

        _isSubmittingCreate = true;
        _apiError = null;

        try
        {
            var created = await AdminUsersClient.CreateUserAsync(new CreateAdminUserRequestDto
            {
                Username = _createUsername.Trim(),
                Email = _createEmail.Trim(),
                Password = _createPassword,
                Status = _createStatus,
                Roles = _createRoles.OrderBy(x => x, StringComparer.OrdinalIgnoreCase).ToList()
            });

            ToastService.ShowSuccess($"User {created.Username} created.");
            _createUsername = string.Empty;
            _createEmail = string.Empty;
            _createPassword = string.Empty;
            _createStatus = "Active";
            _createRoles.Clear();
            _createRoles.Add("WarehouseAdmin");
            await LoadAsync();
        }
        catch (ApiException ex)
        {
            _apiError = ex;
            ToastService.ShowError(BuildErrorMessage(ex));
        }
        finally
        {
            _isSubmittingCreate = false;
        }
    }

    private void StartEdit(AdminUserDto user)
    {
        _editUser = user;
        _editEmail = user.Email;
        _editStatus = user.Status;
        _editRoles = user.Roles.ToHashSet(StringComparer.OrdinalIgnoreCase);
    }

    private void CancelEdit()
    {
        _editUser = null;
        _editEmail = string.Empty;
        _editStatus = "Active";
        _editRoles = [];
    }

    private async Task SaveEditAsync()
    {
        if (_editUser is null)
        {
            return;
        }

        if (_editRoles.Count == 0)
        {
            ToastService.ShowError("Select at least one role.");
            return;
        }

        _isSubmittingUpdate = true;
        _apiError = null;

        try
        {
            var updated = await AdminUsersClient.UpdateUserAsync(_editUser.Id, new UpdateAdminUserRequestDto
            {
                Email = _editEmail.Trim(),
                Status = _editStatus,
                Roles = _editRoles.OrderBy(x => x, StringComparer.OrdinalIgnoreCase).ToList()
            });

            ToastService.ShowSuccess($"User {updated.Username} updated.");
            CancelEdit();
            await LoadAsync();
        }
        catch (ApiException ex)
        {
            _apiError = ex;
            ToastService.ShowError(BuildErrorMessage(ex));
        }
        finally
        {
            _isSubmittingUpdate = false;
        }
    }

    private void ToggleCreateRole(string role, bool enabled)
    {
        if (enabled)
        {
            _createRoles.Add(role);
        }
        else
        {
            _createRoles.Remove(role);
        }
    }

    private void ToggleEditRole(string role, bool enabled)
    {
        if (enabled)
        {
            _editRoles.Add(role);
        }
        else
        {
            _editRoles.Remove(role);
        }
    }

    private void DismissError()
    {
        _apiError = null;
    }

    private static string BuildErrorMessage(ApiException ex)
    {
        if (!string.IsNullOrWhiteSpace(ex.UserMessage))
        {
            return ex.UserMessage;
        }

        return ex.ProblemDetails?.Detail
               ?? ex.ProblemDetails?.Title
               ?? "Admin user request failed.";
    }
}
