@page "/warehouse/outbound/dispatch"
@inject OutboundClient OutboundClient
@inject ToastService ToastService
@using LKvitai.MES.Modules.Warehouse.WebUI.Infrastructure

<PageTitle>Dispatch Confirmation - LKvitai.MES</PageTitle>

<div data-testid="outbound-dispatch-page">
    <MudText Typo="Typo.h5" Class="mb-3">Dispatch Confirmation</MudText>

    @if (_apiError is not null)
    {
        <div data-testid="outbound-dispatch-error" class="mb-3">
            <ErrorBanner Message="@BuildErrorMessage(_apiError)"
                         TraceId="@_apiError.TraceId"
                         OnRetry="ReloadAsync"
                         OnDismiss="DismissError" />
        </div>
    }

    <MudPaper Class="pa-4 position-relative mb-4">
        <LoadingSpinner IsLoading="@(_isLoading || _isSubmitting)" />

        <MudStack Row="true" Class="mb-3">
            <MudButton Variant="Variant.Outlined"
                       Color="Color.Default"
                       OnClick="ReloadAsync"
                       Disabled="@(_isLoading || _isSubmitting)"
                       data-testid="outbound-dispatch-refresh">
                Refresh
            </MudButton>
        </MudStack>

        @if (_shipments.Count == 0)
        {
            <div data-testid="outbound-dispatch-empty">
                <EmptyState Title="No packed shipments"
                            Message="No packed shipments available."
                            IconCss="bi bi-box-seam"
                            OnAction="ReloadAsync" />
            </div>
        }
        else
        {
            <MudTable T="ShipmentSummaryDto"
                      Items="_shipments"
                      Dense="true"
                      Hover="true"
                      data-testid="outbound-dispatch-grid">
                <HeaderContent>
                    <MudTh>Shipment Number</MudTh>
                    <MudTh>Order Number</MudTh>
                    <MudTh>Customer</MudTh>
                    <MudTh>Packed At</MudTh>
                    <MudTh>Actions</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Shipment Number">@context.ShipmentNumber</MudTd>
                    <MudTd DataLabel="Order Number">@context.OutboundOrderNumber</MudTd>
                    <MudTd DataLabel="Customer">@(context.CustomerName ?? "-")</MudTd>
                    <MudTd DataLabel="Packed At">@FormatDate(context.PackedAt)</MudTd>
                    <MudTd DataLabel="Actions">
                        <MudButton Variant="Variant.Filled"
                                   Size="Size.Small"
                                   Color="Color.Primary"
                                   OnClick="() => OpenDispatchModal(context)"
                                   Disabled="@_isSubmitting">
                            Dispatch
                        </MudButton>
                    </MudTd>
                </RowTemplate>
            </MudTable>
        }
    </MudPaper>

    @if (_showModal && _selectedShipment is not null)
    {
        <MudPaper Class="pa-4" data-testid="outbound-dispatch-form">
            <MudText Typo="Typo.h6" Class="mb-3">Dispatch @_selectedShipment.ShipmentNumber</MudText>

            <MudGrid Spacing="2" Class="mb-3">
                <MudItem xs="12" md="4">
                    <MudSelect T="string"
                               Label="Carrier"
                               @bind-Value="_carrier"
                               Variant="Variant.Outlined"
                               Dense="true"
                               @attributes="CarrierAttributes">
                        <MudSelectItem T="string" Value="@("FEDEX")">FEDEX</MudSelectItem>
                        <MudSelectItem T="string" Value="@("UPS")">UPS</MudSelectItem>
                        <MudSelectItem T="string" Value="@("DHL")">DHL</MudSelectItem>
                        <MudSelectItem T="string" Value="@("USPS")">USPS</MudSelectItem>
                        <MudSelectItem T="string" Value="@("OTHER")">OTHER</MudSelectItem>
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudTextField T="string"
                                  Label="Vehicle ID"
                                  @bind-Value="_vehicleId"
                                  Variant="Variant.Outlined"
                                  Dense="true"
                                  @attributes="VehicleAttributes" />
                </MudItem>
            </MudGrid>

            <MudStack Row="true" Spacing="2">
                <MudButton Variant="Variant.Outlined"
                           Color="Color.Default"
                           OnClick="CloseModal"
                           Disabled="@_isSubmitting">
                    Cancel
                </MudButton>
                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           OnClick="ConfirmDispatchAsync"
                           Disabled="@_isSubmitting"
                           @attributes="SubmitAttributes">
                    Confirm Dispatch
                </MudButton>
            </MudStack>
        </MudPaper>
    }
</div>

@code {
    private readonly List<ShipmentSummaryDto> _shipments = [];
    private bool _isLoading;
    private bool _isSubmitting;
    private ApiException? _apiError;
    private bool _showModal;
    private ShipmentSummaryDto? _selectedShipment;
    private string _carrier = "FEDEX";
    private string _vehicleId = string.Empty;

    private static readonly Dictionary<string, object> CarrierAttributes = new() { ["data-testid"] = "outbound-dispatch-carrier" };
    private static readonly Dictionary<string, object> VehicleAttributes = new() { ["data-testid"] = "outbound-dispatch-vehicle" };
    private static readonly Dictionary<string, object> SubmitAttributes = new() { ["data-testid"] = "outbound-dispatch-submit" };

    protected override async Task OnInitializedAsync()
    {
        await ReloadAsync();
    }

    private async Task ReloadAsync()
    {
        _isLoading = true;
        _apiError = null;

        try
        {
            var rows = await OutboundClient.GetShipmentSummariesAsync("PACKED", null, null, null);
            _shipments.Clear();
            _shipments.AddRange(rows.OrderByDescending(x => x.PackedAt));
        }
        catch (ApiException ex)
        {
            _apiError = ex;
            ToastService.ShowError(BuildErrorMessage(ex));
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void DismissError()
    {
        _apiError = null;
    }

    private void OpenDispatchModal(ShipmentSummaryDto shipment)
    {
        _selectedShipment = shipment;
        _carrier = "FEDEX";
        _vehicleId = string.Empty;
        _showModal = true;
    }

    private void CloseModal()
    {
        _showModal = false;
        _selectedShipment = null;
    }

    private async Task ConfirmDispatchAsync()
    {
        if (_selectedShipment is null)
        {
            return;
        }

        _isSubmitting = true;

        try
        {
            await OutboundClient.DispatchShipmentAsync(_selectedShipment.Id, new DispatchShipmentRequestDto
            {
                CommandId = Guid.NewGuid(),
                Carrier = _carrier,
                VehicleId = string.IsNullOrWhiteSpace(_vehicleId) ? null : _vehicleId.Trim()
            });

            ToastService.ShowSuccess("Shipment dispatched successfully.");
            CloseModal();
            await ReloadAsync();
        }
        catch (ApiException ex)
        {
            _apiError = ex;
            ToastService.ShowError(BuildErrorMessage(ex));
        }
        finally
        {
            _isSubmitting = false;
        }
    }

    private static string BuildErrorMessage(ApiException ex)
        => !string.IsNullOrWhiteSpace(ex.UserMessage)
            ? ex.UserMessage
            : "Dispatch request failed.";

    private static string FormatDate(DateTimeOffset? value)
        => value.HasValue ? value.Value.ToLocalTime().ToString("yyyy-MM-dd HH:mm") : "-";
}
