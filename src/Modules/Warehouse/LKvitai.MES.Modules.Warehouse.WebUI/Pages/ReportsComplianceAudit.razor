@page "/reports/compliance-audit"
@inject ReportsClient ReportsClient
@inject IJSRuntime JavaScript
@inject ToastService ToastService

<PageTitle>Compliance Audit - LKvitai.MES</PageTitle>

<div data-testid="reports-compliance-audit-page">
    <MudText Typo="Typo.h5" Class="mb-3">Compliance Audit Report</MudText>

    @if (_apiError is not null)
    {
        <ErrorBanner Message="@BuildErrorMessage(_apiError)"
                     TraceId="@_apiError.TraceId"
                     OnRetry="LoadAsync"
                     OnDismiss="DismissError" />
    }

    <MudPaper Class="pa-4 mb-3">
        <MudGrid Spacing="2" AlignItems="AlignItems.End">
            <MudItem xs="12" md="2">
                <MudDatePicker Label="Start" @bind-Date="_startDate" DateFormat="yyyy-MM-dd" Variant="Variant.Outlined" Dense="true" />
            </MudItem>
            <MudItem xs="12" md="2">
                <MudDatePicker Label="End" @bind-Date="_endDate" DateFormat="yyyy-MM-dd" Variant="Variant.Outlined" Dense="true" />
            </MudItem>
            <MudItem xs="12" md="3">
                <MudSelect T="string" Label="Report Type" @bind-Value="_reportType" Variant="Variant.Outlined" Dense="true">
                    <MudSelectItem Value="@("STOCK_MOVEMENTS")">STOCK_MOVEMENTS</MudSelectItem>
                    <MudSelectItem Value="@("ADJUSTMENTS")">ADJUSTMENTS</MudSelectItem>
                    <MudSelectItem Value="@("VALUATIONS")">VALUATIONS</MudSelectItem>
                    <MudSelectItem Value="@("USER_ACTIONS")">USER_ACTIONS</MudSelectItem>
                </MudSelect>
            </MudItem>
            <MudItem xs="12" md="5">
                <MudStack Row="true" Spacing="1">
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" Disabled="@_isLoading" OnClick="ApplyFiltersAsync" @attributes="ApplyAttributes">Apply</MudButton>
                    <MudButton Variant="Variant.Outlined" Color="Color.Default" Disabled="@_isLoading" OnClick="LoadAsync" @attributes="RefreshAttributes">Refresh</MudButton>
                    <MudSpacer />
                    <MudButton Variant="Variant.Outlined" Color="Color.Success" Disabled="@_isLoading" OnClick="ExportCsvAsync" @attributes="ExportCsvAttributes">Export CSV</MudButton>
                    <MudButton Variant="Variant.Outlined" Color="Color.Error" Disabled="@_isLoading" OnClick="ExportPdfAsync" @attributes="ExportPdfAttributes">Export PDF</MudButton>
                </MudStack>
            </MudItem>
        </MudGrid>
    </MudPaper>

    <MudPaper Class="pa-4 position-relative">
         (_isLoading)
        {
            <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-3" />
        }

        <MudText Typo="Typo.subtitle2" Class="mb-2" data-testid="reports-compliance-audit-total">Total: @_totalCount</MudText>

        <MudDataGrid T="ComplianceAuditRowDto"
                     Items="_rows"
                     Dense="true"
                     Hover="true"
                     Loading="@_isLoading"
                     SortMode="SortMode.None"
                     Filterable="false"
                     @attributes="GridAttributes">
            <NoRecordsContent>
                <MudText Typo="Typo.body2" Class="mud-secondary-text">No compliance rows found.</MudText>
            </NoRecordsContent>
            <Columns>
                <TemplateColumn Title="Timestamp">
                    <CellTemplate>
                        @context.Item.Timestamp.ToLocalTime().ToString("yyyy-MM-dd HH:mm")
                    </CellTemplate>
                </TemplateColumn>
                <PropertyColumn Property="x => x.ReportType" Title="Type" />
                <PropertyColumn Property="x => x.Actor" Title="Actor" />
                <PropertyColumn Property="x => x.Reference" Title="Reference" />
                <PropertyColumn Property="x => x.Category" Title="Category" />
                <PropertyColumn Property="x => x.Details" Title="Details" />
                <TemplateColumn Title="Notes">
                    <CellTemplate>
                        @(context.Item.Notes ?? "-")
                    </CellTemplate>
                </TemplateColumn>
            </Columns>
        </MudDataGrid>

        @if (_totalCount > 0)
        {
            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.FlexEnd" Class="mt-3" data-testid="reports-compliance-audit-pager">
                <MudSelect T="int"
                           Label="Page size"
                           Value="_pageSize"
                           ValueChanged="OnPageSizeChangedAsync"
                           Variant="Variant.Outlined"
                           Dense="true"
                           Style="width: 120px;"
                           @attributes="PageSizeAttributes">
                    <MudSelectItem Value="25">25</MudSelectItem>
                    <MudSelectItem Value="50">50</MudSelectItem>
                    <MudSelectItem Value="100">100</MudSelectItem>
                </MudSelect>
                <MudPagination Count="@TotalPages"
                               Selected="@_page"
                               SelectedChanged="OnPageChangedAsync"
                               Variant="Variant.Outlined"
                               Color="Color.Primary"
                               Size="Size.Small"
                               Class="ml-2" />
            </MudStack>
        }
    </MudPaper>
</div>

@code {
    private readonly List<ComplianceAuditRowDto> _rows = [];
    private ApiException? _apiError;
    private bool _isLoading;

    private DateTime? _startDate = DateTime.UtcNow.AddDays(-30);
    private DateTime? _endDate = DateTime.UtcNow;
    private string _reportType = "STOCK_MOVEMENTS";
    private int _page = 1;
    private int _pageSize = 50;
    private int _totalCount;

    private static readonly Dictionary<string, object> GridAttributes = new() { ["data-testid"] = "reports-compliance-audit-grid" };
    private static readonly Dictionary<string, object> ApplyAttributes = new() { ["data-testid"] = "reports-compliance-audit-apply" };
    private static readonly Dictionary<string, object> RefreshAttributes = new() { ["data-testid"] = "reports-compliance-audit-refresh" };
    private static readonly Dictionary<string, object> ExportCsvAttributes = new() { ["data-testid"] = "reports-compliance-audit-export-csv" };
    private static readonly Dictionary<string, object> ExportPdfAttributes = new() { ["data-testid"] = "reports-compliance-audit-export-pdf" };
    private static readonly Dictionary<string, object> PageSizeAttributes = new() { ["data-testid"] = "reports-compliance-audit-page-size" };

    private int TotalPages => Math.Max(1, (int)Math.Ceiling(_totalCount / (double)Math.Max(1, _pageSize)));

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task ApplyFiltersAsync()
    {
        _page = 1;
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _isLoading = true;
        _apiError = null;

        try
        {
            var result = await ReportsClient.GetComplianceAuditAsync(
                ParseDateOffset(_startDate, true),
                ParseDateOffset(_endDate, false),
                _reportType,
                _page,
                _pageSize);

            _rows.Clear();
            _rows.AddRange(result.Rows);
            _totalCount = result.TotalCount;
        }
        catch (ApiException ex)
        {
            _apiError = ex;
            ToastService.ShowError(BuildErrorMessage(ex));
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task ExportCsvAsync()
    {
        try
        {
            var bytes = await ReportsClient.DownloadComplianceAuditCsvAsync(
                ParseDateOffset(_startDate, true),
                ParseDateOffset(_endDate, false),
                _reportType);

            await JavaScript.InvokeVoidAsync(
                "csvExport.downloadBytes",
                $"compliance-audit-{DateTime.UtcNow:yyyyMMdd}.csv",
                "text/csv",
                Convert.ToBase64String(bytes));
        }
        catch (ApiException ex)
        {
            _apiError = ex;
            ToastService.ShowError(BuildErrorMessage(ex));
        }
    }

    private async Task ExportPdfAsync()
    {
        try
        {
            var bytes = await ReportsClient.DownloadComplianceAuditPdfAsync(
                ParseDateOffset(_startDate, true),
                ParseDateOffset(_endDate, false),
                _reportType);

            await JavaScript.InvokeVoidAsync(
                "csvExport.downloadBytes",
                $"compliance-audit-{DateTime.UtcNow:yyyyMMdd}.pdf",
                "application/pdf",
                Convert.ToBase64String(bytes));
        }
        catch (ApiException ex)
        {
            _apiError = ex;
            ToastService.ShowError(BuildErrorMessage(ex));
        }
    }

    private async Task OnPageChangedAsync(int page)
    {
        _page = Math.Max(1, page);
        await LoadAsync();
    }

    private async Task OnPageSizeChangedAsync(int size)
    {
        _pageSize = Math.Clamp(size, 1, 500);
        _page = 1;
        await LoadAsync();
    }

    private static DateTimeOffset? ParseDateOffset(DateTime? input, bool startOfDay)
    {
        if (!input.HasValue)
        {
            return null;
        }

        var date = input.Value.Date;
        var value = startOfDay
            ? new DateTimeOffset(date, TimeSpan.Zero)
            : new DateTimeOffset(date.AddDays(1).AddTicks(-1), TimeSpan.Zero);

        return value;
    }

    private void DismissError()
    {
        _apiError = null;
    }

    private static string BuildErrorMessage(ApiException ex)
    {
        if (!string.IsNullOrWhiteSpace(ex.UserMessage))
        {
            return ex.UserMessage;
        }

        return ex.ProblemDetails?.Detail
               ?? ex.ProblemDetails?.Title
               ?? "Compliance report request failed.";
    }
}
