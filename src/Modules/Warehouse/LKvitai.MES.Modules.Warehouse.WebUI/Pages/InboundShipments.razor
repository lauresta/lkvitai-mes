@page "/warehouse/inbound/shipments"
@inject ReceivingClient ReceivingClient
@inject NavigationManager NavigationManager
@inject ToastService ToastService

<PageTitle>Inbound Shipments - LKvitai.MES</PageTitle>

<div data-testid="inbound-shipments-page">
    <MudText Typo="Typo.h5" Class="mb-3">Inbound Shipments</MudText>

    @if (_apiError is not null)
    {
        <SharedErrorAlert Message="@BuildErrorMessage(_apiError)"
                     TraceId="@_apiError.TraceId"
                     OnRetry="LoadAsync"
                     OnDismiss="DismissError" />
    }

    <MudPaper Class="pa-4 mb-3">
        <MudGrid Spacing="2" AlignItems="AlignItems.End">
            <MudItem xs="12" md="2">
                <MudNumericField T="int?" Label="Supplier Id" @bind-Value="_supplierId" Variant="Variant.Outlined" Dense="true" />
            </MudItem>
            <MudItem xs="12" md="2">
                <MudSelect T="string" Label="Status" @bind-Value="_status" Variant="Variant.Outlined" Dense="true">
                    <MudSelectItem Value="@string.Empty">All</MudSelectItem>
                    <MudSelectItem Value="@("Draft")">Draft</MudSelectItem>
                    <MudSelectItem Value="@("Partial")">Partial</MudSelectItem>
                    <MudSelectItem Value="@("Complete")">Complete</MudSelectItem>
                </MudSelect>
            </MudItem>
            <MudItem xs="12" md="2">
                <MudDatePicker Label="Expected From" @bind-Date="_expectedFrom" DateFormat="yyyy-MM-dd" Variant="Variant.Outlined" Dense="true" />
            </MudItem>
            <MudItem xs="12" md="2">
                <MudDatePicker Label="Expected To" @bind-Date="_expectedTo" DateFormat="yyyy-MM-dd" Variant="Variant.Outlined" Dense="true" />
            </MudItem>
            <MudItem xs="12" md="4">
                <MudStack Row="true" Spacing="1">
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" Disabled="@_isLoading" OnClick="ApplyFiltersAsync" @attributes="ApplyAttributes">Apply</MudButton>
                    <MudButton Variant="Variant.Outlined" Color="Color.Default" Disabled="@_isLoading" OnClick="ResetFiltersAsync" @attributes="ResetAttributes">Reset</MudButton>
                    <MudButton Variant="Variant.Outlined" Color="Color.Default" Disabled="@_isLoading" OnClick="LoadAsync" @attributes="RefreshAttributes">Refresh</MudButton>
                    <MudSpacer />
                    <MudButton Variant="Variant.Filled" Color="Color.Success" OnClick="OpenCreate" @attributes="CreateAttributes">+ Create Inbound</MudButton>
                </MudStack>
            </MudItem>
        </MudGrid>
    </MudPaper>

    <MudPaper Class="pa-4 position-relative">
         (_isLoading)
        {
            <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-3" />
        }

        <MudText Typo="Typo.subtitle2" Class="mb-2" data-testid="inbound-shipments-total">Total: @_totalCount</MudText>

        <MudDataGrid T="InboundShipmentSummaryDto"
                     Items="_rows"
                     Dense="true"
                     Hover="true"
                     Loading="@_isLoading"
                     SortMode="SortMode.None"
                     Filterable="false"
                     @attributes="GridAttributes">
            <NoRecordsContent>
                <EmptyState Title="No inbound shipments"
                            Message="Create inbound shipment to start receiving workflow."
                            Icon="@Icons.Material.Filled.MoveToInbox"
                            OnAction="OpenCreateAsync" />
            </NoRecordsContent>
            <Columns>
                <TemplateColumn Title="Shipment">
                    <CellTemplate>
                        ISH-@context.Item.Id
                    </CellTemplate>
                </TemplateColumn>
                <PropertyColumn Property="x => x.ReferenceNumber" Title="Reference" />
                <TemplateColumn Title="Supplier">
                    <CellTemplate>
                        @context.Item.SupplierName (@context.Item.SupplierId)
                    </CellTemplate>
                </TemplateColumn>
                <TemplateColumn Title="Status">
                    <CellTemplate>
                        <MudChip T="string"
                                 Size="Size.Small"
                                 Variant="Variant.Filled"
                                 Color="@GetStatusColor(context.Item.Status)">
                            @context.Item.Status
                        </MudChip>
                    </CellTemplate>
                </TemplateColumn>
                <TemplateColumn Title="Expected Date">
                    <CellTemplate>
                        @context.Item.ExpectedDate?.ToString("yyyy-MM-dd")
                    </CellTemplate>
                </TemplateColumn>
                <PropertyColumn Property="x => x.TotalLines" Title="Lines" />
                <TemplateColumn Title="Received / Expected">
                    <CellTemplate>
                        @context.Item.TotalReceivedQty.ToString("0.##") / @context.Item.TotalExpectedQty.ToString("0.##")
                    </CellTemplate>
                </TemplateColumn>
                <TemplateColumn Title="Actions">
                    <CellTemplate>
                        <MudButton Variant="Variant.Outlined" Size="Size.Small" Color="Color.Primary" OnClick="@(() => OpenDetails(context.Item.Id))">View</MudButton>
                    </CellTemplate>
                </TemplateColumn>
            </Columns>
        </MudDataGrid>

        @if (_totalCount > 0)
        {
            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.FlexEnd" Class="mt-3" data-testid="inbound-shipments-pager">
                <MudSelect T="int"
                           Label="Page size"
                           Value="_pageSize"
                           ValueChanged="OnPageSizeChangedAsync"
                           Variant="Variant.Outlined"
                           Dense="true"
                           Style="width: 120px;"
                           @attributes="PageSizeAttributes">
                    <MudSelectItem Value="25">25</MudSelectItem>
                    <MudSelectItem Value="50">50</MudSelectItem>
                    <MudSelectItem Value="100">100</MudSelectItem>
                </MudSelect>
                <MudPagination Count="@TotalPages"
                               Selected="@_pageNumber"
                               SelectedChanged="OnPageChangedAsync"
                               Variant="Variant.Outlined"
                               Color="Color.Primary"
                               Size="Size.Small"
                               Class="ml-2" />
            </MudStack>
        }
    </MudPaper>
</div>

@code {
    private readonly List<InboundShipmentSummaryDto> _rows = [];
    private ApiException? _apiError;
    private bool _isLoading;
    private int? _supplierId;
    private string _status = string.Empty;
    private DateTime? _expectedFrom;
    private DateTime? _expectedTo;
    private int _pageNumber = 1;
    private int _pageSize = 50;
    private int _totalCount;

    private static readonly Dictionary<string, object> GridAttributes = new() { ["data-testid"] = "inbound-shipments-grid" };
    private static readonly Dictionary<string, object> ApplyAttributes = new() { ["data-testid"] = "inbound-shipments-apply" };
    private static readonly Dictionary<string, object> ResetAttributes = new() { ["data-testid"] = "inbound-shipments-reset" };
    private static readonly Dictionary<string, object> RefreshAttributes = new() { ["data-testid"] = "inbound-shipments-refresh" };
    private static readonly Dictionary<string, object> CreateAttributes = new() { ["data-testid"] = "inbound-shipments-create" };
    private static readonly Dictionary<string, object> PageSizeAttributes = new() { ["data-testid"] = "inbound-shipments-page-size" };

    private int TotalPages => Math.Max(1, (int)Math.Ceiling(_totalCount / (double)Math.Max(1, _pageSize)));

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task ApplyFiltersAsync()
    {
        _pageNumber = 1;
        await LoadAsync();
    }

    private async Task ResetFiltersAsync()
    {
        _supplierId = null;
        _status = string.Empty;
        _expectedFrom = null;
        _expectedTo = null;
        _pageNumber = 1;
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _isLoading = true;
        _apiError = null;

        try
        {
            var response = await ReceivingClient.GetShipmentsAsync(
                _supplierId,
                _status,
                ParseDate(_expectedFrom),
                ParseDate(_expectedTo),
                _pageNumber,
                _pageSize);

            _rows.Clear();
            _rows.AddRange(response.Items);
            _totalCount = response.TotalCount;
        }
        catch (ApiException ex)
        {
            _apiError = ex;
            ToastService.ShowError(BuildErrorMessage(ex));
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task OnPageChangedAsync(int page)
    {
        _pageNumber = Math.Max(1, page);
        await LoadAsync();
    }

    private async Task OnPageSizeChangedAsync(int size)
    {
        _pageSize = Math.Clamp(size, 1, 500);
        _pageNumber = 1;
        await LoadAsync();
    }

    private void OpenDetails(int id)
    {
        NavigationManager.NavigateTo($"/warehouse/inbound/shipments/{id}");
    }

    private void OpenCreate()
    {
        NavigationManager.NavigateTo("/warehouse/inbound/shipments/create");
    }

    private Task OpenCreateAsync()
    {
        OpenCreate();
        return Task.CompletedTask;
    }

    private void DismissError()
    {
        _apiError = null;
    }

    private static DateOnly? ParseDate(DateTime? date)
    {
        return date.HasValue ? DateOnly.FromDateTime(date.Value.Date) : null;
    }

    private static Color GetStatusColor(string status) => status.ToUpperInvariant() switch
    {
        "DRAFT" => Color.Default,
        "PARTIAL" => Color.Warning,
        "COMPLETE" => Color.Success,
        _ => Color.Default
    };

    private static string BuildErrorMessage(ApiException ex)
    {
        if (!string.IsNullOrWhiteSpace(ex.UserMessage))
        {
            return ex.UserMessage;
        }

        return ex.ProblemDetails?.Detail
               ?? ex.ProblemDetails?.Title
               ?? "Inbound shipment request failed.";
    }
}
