@page "/warehouse/rmas"
@inject AdvancedWarehouseClient AdvancedClient
@inject ToastService ToastService
@using LKvitai.MES.Modules.Warehouse.WebUI.Infrastructure

<PageTitle>RMAs - LKvitai.MES</PageTitle>

<div data-testid="rmas-page">
    <MudText Typo="Typo.h5" Class="mb-3">Returns / RMA</MudText>

    @if (_error is not null)
    {
        <div data-testid="rmas-error" class="mb-3">
            <ErrorBanner Message="@_error.UserMessage"
                         TraceId="@_error.TraceId"
                         OnRetry="LoadAsync"
                         OnDismiss="DismissError" />
        </div>
    }

    <MudPaper Class="pa-4 mb-3" data-testid="rmas-form">
        <MudText Typo="Typo.h6" Class="mb-2">Create RMA</MudText>

        <MudGrid Spacing="2" AlignItems="AlignItems.End">
            <MudItem xs="12" md="4">
                <MudTextField T="string"
                              Label="Sales Order Id"
                              @bind-Value="_salesOrderIdInput"
                              Placeholder="GUID"
                              Variant="Variant.Outlined"
                              Dense="true"
                              data-testid="rmas-sales-order-id" />
            </MudItem>
            <MudItem xs="12" md="3">
                <MudNumericField T="int"
                                 Label="Item Id"
                                 @bind-Value="_itemId"
                                 Min="1"
                                 Variant="Variant.Outlined"
                                 Dense="true"
                                 data-testid="rmas-item-id" />
            </MudItem>
            <MudItem xs="12" md="2">
                <MudNumericField T="decimal"
                                 Label="Qty"
                                 @bind-Value="_qty"
                                 Min="0.01m"
                                 Step="0.01m"
                                 Variant="Variant.Outlined"
                                 Dense="true"
                                 data-testid="rmas-qty" />
            </MudItem>
            <MudItem xs="12" md="3">
                <MudTextField T="string"
                              Label="Reason"
                              @bind-Value="_reason"
                              Placeholder="Damaged"
                              Variant="Variant.Outlined"
                              Dense="true"
                              data-testid="rmas-reason" />
            </MudItem>
            <MudItem xs="12">
                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           OnClick="CreateAsync"
                           Disabled="@_isBusy"
                           data-testid="rmas-submit">
                    Create RMA
                </MudButton>
            </MudItem>
        </MudGrid>
    </MudPaper>

    <MudPaper Class="pa-4">
        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-3">
            <MudText Typo="Typo.h6">RMA Queue</MudText>
            <MudButton Variant="Variant.Outlined" Size="Size.Small" OnClick="LoadAsync" Disabled="@_isBusy">Refresh</MudButton>
        </MudStack>

        @if (_rows.Count == 0)
        {
            <div data-testid="rmas-empty">
                <EmptyState Title="No RMAs"
                            Message="Create an RMA for customer returns and disposition workflow."
                            Icon="@Icons.Material.Filled.RotateLeft"
                            OnAction="LoadAsync" />
            </div>
        }
        else
        {
            <MudTable T="RmaDto"
                      Items="_rows"
                      Dense="true"
                      Hover="true"
                      data-testid="rmas-grid">
                <HeaderContent>
                    <MudTh>RMA</MudTh>
                    <MudTh>Status</MudTh>
                    <MudTh>Reason</MudTh>
                    <MudTh>Credit</MudTh>
                    <MudTh>Updated By</MudTh>
                    <MudTh>Actions</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="RMA">@context.RmaNumber</MudTd>
                    <MudTd DataLabel="Status">
                        <MudChip Size="Size.Small" Color="@GetStatusColor(context.Status)" Variant="Variant.Filled">@context.Status</MudChip>
                    </MudTd>
                    <MudTd DataLabel="Reason">@context.Reason</MudTd>
                    <MudTd DataLabel="Credit">@(context.CreditAmount?.ToString("0.00") ?? "-")</MudTd>
                    <MudTd DataLabel="Updated By">@(context.UpdatedBy ?? context.CreatedBy)</MudTd>
                    <MudTd DataLabel="Actions">
                        <MudStack Row="true" Spacing="1">
                            @if (context.Status == "PendingReceipt")
                            {
                                <MudButton Variant="Variant.Outlined" Size="Size.Small" OnClick="() => ReceiveAsync(context.Id)">Receive</MudButton>
                            }
                            @if (context.Status is "Received" or "Inspected")
                            {
                                <MudButton Variant="Variant.Outlined" Color="Color.Success" Size="Size.Small" OnClick='() => InspectAsync(context.Id, "RESTOCK")'>Restock</MudButton>
                                <MudButton Variant="Variant.Outlined" Color="Color.Error" Size="Size.Small" OnClick='() => InspectAsync(context.Id, "SCRAP")'>Scrap</MudButton>
                            }
                        </MudStack>
                    </MudTd>
                </RowTemplate>
            </MudTable>
        }
    </MudPaper>
</div>

@code {
    private readonly List<RmaDto> _rows = [];
    private string _salesOrderIdInput = string.Empty;
    private int _itemId = 1;
    private decimal _qty = 1;
    private string _reason = "Damaged";
    private ApiException? _error;
    private bool _isBusy;

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        await ExecuteAsync(async () =>
        {
            var rows = await AdvancedClient.GetRmasAsync();
            _rows.Clear();
            _rows.AddRange(rows.OrderByDescending(x => x.CreatedAt));
        });
    }

    private async Task CreateAsync()
    {
        if (!Guid.TryParse(_salesOrderIdInput, out var salesOrderId))
        {
            ToastService.ShowError("SalesOrderId must be a valid GUID.");
            return;
        }

        await ExecuteAsync(async () =>
        {
            var payload = new RmaCreateDto(
                salesOrderId,
                _reason,
                [new RmaLineCreateDto(_itemId, _qty, _reason.ToUpperInvariant())]);

            await AdvancedClient.CreateRmaAsync(payload);
            ToastService.ShowSuccess("RMA created.");
            _salesOrderIdInput = string.Empty;
            await LoadAsync();
        });
    }

    private async Task ReceiveAsync(Guid id)
    {
        await ExecuteAsync(async () =>
        {
            await AdvancedClient.ReceiveRmaAsync(id);
            await LoadAsync();
        });
    }

    private async Task InspectAsync(Guid id, string disposition)
    {
        await ExecuteAsync(async () =>
        {
            await AdvancedClient.InspectRmaAsync(id, disposition, disposition == "RESTOCK" ? 0m : null);
            await LoadAsync();
        });
    }

    private async Task ExecuteAsync(Func<Task> action)
    {
        _isBusy = true;
        _error = null;

        try
        {
            await action();
        }
        catch (ApiException ex)
        {
            _error = ex;
            ToastService.ShowError(ex.UserMessage);
        }
        finally
        {
            _isBusy = false;
        }
    }

    private void DismissError()
    {
        _error = null;
    }

    private static Color GetStatusColor(string status) => status switch
    {
        "Restocked" => Color.Success,
        "Scrapped" => Color.Error,
        "Received" => Color.Info,
        "Inspected" => Color.Primary,
        _ => Color.Default
    };
}
