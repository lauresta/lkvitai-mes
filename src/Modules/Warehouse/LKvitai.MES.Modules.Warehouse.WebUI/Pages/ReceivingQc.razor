@page "/warehouse/inbound/qc"
@inject ReceivingClient ReceivingClient
@inject ToastService ToastService

<PageTitle>Receiving QC - LKvitai.MES</PageTitle>

<h1>Receiving QC Queue</h1>

@if (_apiError is not null)
{
    <SharedErrorAlert Message="@BuildErrorMessage(_apiError)"
                 TraceId="@_apiError.TraceId"
                 OnRetry="LoadAsync"
                 OnDismiss="DismissError" />
}

<div class="mud-surface shadow-sm mb-3">
    <div class="mud-surface-body">
        <div class="mud-grid-mrow g-2 align-items-end">
            <div class="mud-grid-col">
                <label class="form-label">Scan SKU / Lot</label>
                <input class="mud-input-base" @bind="_search" placeholder="FG-0001 or LOT-2026-01" />
            </div>
            <div class="mud-grid-col">
                <label class="form-label">Reason Code (for Fail)</label>
                <input class="mud-input-base" @bind="_reasonCode" placeholder="DAMAGED" />
            </div>
            <div class="mud-grid-col d-grid">
                <button class="mud-mbtn-base mud-mbtn-outline-secondary" @onclick="LoadAsync" disabled="@(_isLoading || _isSubmitting)">Refresh</button>
            </div>
        </div>
    </div>
</div>

<div class="mud-surface shadow-sm position-relative">
    @if (_isLoading || _isSubmitting)
    {
        <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-3" />
    }

    <div class="mud-surface-body">
        <div class="overflow-auto">
            <table class="mud-mtbl-base mud-mtbl-dense mtbl-hover align-middle">
                <thead>
                    <tr>
                        <th>SKU</th>
                        <th>Item</th>
                        <th>Lot</th>
                        <th>Qty</th>
                        <th>UoM</th>
                        <th>Inspector Notes</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (FilteredRows.Count == 0)
                    {
                        <tr>
                            <td colspan="7">
                                <EmptyState Title="No QC pending rows"
                                            Message="Receiving QC queue is empty for current filters."
                                            Icon="@Icons.Material.Filled.VerifiedUser"
                                            ActionLabel="Refresh"
                                            OnAction="LoadAsync" />
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var mrow in FilteredRows)
                        {
                            <tr>
                                <td>@mrow.ItemSku</td>
                                <td>@mrow.ItemName</td>
                                <td>@(mrow.LotNumber ?? "-")</td>
                                <td>@mrow.Qty.ToString("0.##")</td>
                                <td>@mrow.BaseUoM</td>
                                <td>
                                    <input class="mud-input-base minput-sm"
                                           value="@GetNotes(mrow)"
                                           @onchange="args => SetNotes(mrow, args.Value?.ToString())" />
                                </td>
                                <td class="d-flex gap-1">
                                    <button class="mud-mbtn-base mud-mbtn-sm mud-mbtn-success"
                                            @onclick="() => PassAsync(mrow)"
                                            disabled="@_isSubmitting">
                                        Pass
                                    </button>
                                    <button class="mud-mbtn-base mud-mbtn-sm mud-mbtn-danger"
                                            @onclick="() => FailAsync(mrow)"
                                            disabled="@_isSubmitting">
                                        Fail
                                    </button>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@code {
    private readonly List<QcPendingRowDto> _rows = [];
    private readonly Dictionary<string, string> _notesByKey = new(StringComparer.OrdinalIgnoreCase);
    private ApiException? _apiError;
    private bool _isLoading;
    private bool _isSubmitting;

    private string _search = string.Empty;
    private string _reasonCode = string.Empty;

    private IReadOnlyList<QcPendingRowDto> FilteredRows =>
        _rows.Where(MatchesSearch).ToList();

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _isLoading = true;
        _apiError = null;

        try
        {
            var rows = await ReceivingClient.GetPendingQcAsync();
            _rows.Clear();
            _rows.AddRange(rows);
        }
        catch (ApiException ex)
        {
            _apiError = ex;
            ToastService.ShowError(BuildErrorMessage(ex));
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task PassAsync(QcPendingRowDto mrow)
    {
        await SubmitQcAsync(mrow, isPass: true);
    }

    private async Task FailAsync(QcPendingRowDto mrow)
    {
        if (string.IsNullOrWhiteSpace(_reasonCode))
        {
            ToastService.ShowError("Reason code is required for QC fail.");
            return;
        }

        await SubmitQcAsync(mrow, isPass: false);
    }

    private async Task SubmitQcAsync(QcPendingRowDto mrow, bool isPass)
    {
        _isSubmitting = true;
        _apiError = null;

        try
        {
            var request = new QcActionRequestDto
            {
                ItemId = mrow.ItemId,
                LotId = mrow.LotId,
                Qty = mrow.Qty,
                ReasonCode = isPass ? null : _reasonCode.Trim(),
                InspectorNotes = GetNotes(mrow)
            };

            var result = isPass
                ? await ReceivingClient.PassQcAsync(request)
                : await ReceivingClient.FailQcAsync(request);

            ToastService.ShowSuccess($"QC {(isPass ? "pass" : "fail")} completed. Moved to {result.DestinationLocationCode}.");
            await LoadAsync();
        }
        catch (ApiException ex)
        {
            _apiError = ex;
            ToastService.ShowError(BuildErrorMessage(ex));
        }
        finally
        {
            _isSubmitting = false;
        }
    }

    private bool MatchesSearch(QcPendingRowDto mrow)
    {
        if (string.IsNullOrWhiteSpace(_search))
        {
            return true;
        }

        var filter = _search.Trim();
        return mrow.ItemSku.Contains(filter, StringComparison.OrdinalIgnoreCase)
               || mrow.ItemName.Contains(filter, StringComparison.OrdinalIgnoreCase)
               || (mrow.LotNumber?.Contains(filter, StringComparison.OrdinalIgnoreCase) ?? false);
    }

    private string BuildKey(QcPendingRowDto mrow)
    {
        return $"{mrow.ItemId}:{mrow.LotId?.ToString() ?? "-"}";
    }

    private string GetNotes(QcPendingRowDto mrow)
    {
        var key = BuildKey(mrow);
        return _notesByKey.TryGetValue(key, out var value) ? value : string.Empty;
    }

    private void SetNotes(QcPendingRowDto mrow, string? value)
    {
        var key = BuildKey(mrow);
        if (string.IsNullOrWhiteSpace(value))
        {
            _notesByKey.Remove(key);
            return;
        }

        _notesByKey[key] = value.Trim();
    }

    private void DismissError()
    {
        _apiError = null;
    }

    private static string BuildErrorMessage(ApiException ex)
    {
        if (!string.IsNullOrWhiteSpace(ex.UserMessage))
        {
            return ex.UserMessage;
        }

        return ex.ProblemDetails?.Detail
               ?? ex.ProblemDetails?.Title
               ?? "QC request failed.";
    }
}
