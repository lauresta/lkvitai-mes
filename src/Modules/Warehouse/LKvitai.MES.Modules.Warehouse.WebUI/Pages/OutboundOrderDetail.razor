@page "/warehouse/outbound/orders/{Id:guid}"
@inject OutboundClient OutboundClient
@inject NavigationManager NavigationManager
@inject ToastService ToastService
@using LKvitai.MES.Modules.Warehouse.WebUI.Infrastructure

<PageTitle>Outbound Order Detail - LKvitai.MES</PageTitle>

<div data-testid="outbound-order-detail-page">
    <MudText Typo="Typo.h5" Class="mb-3">Outbound Order Detail</MudText>

    @if (_apiError is not null)
    {
        <div data-testid="outbound-order-detail-error" class="mb-3">
            <ErrorBanner Message="@BuildErrorMessage(_apiError)"
                         TraceId="@_apiError.TraceId"
                         OnRetry="ReloadAsync"
                         OnDismiss="DismissError" />
        </div>
    }

    <MudPaper Class="pa-4 position-relative">
        <LoadingSpinner IsLoading="_isLoading" />

        @if (_order is null && !_isLoading)
        {
            <div data-testid="outbound-order-detail-empty">
                <MudText Typo="Typo.body2" Color="Color.Secondary">Order not found.</MudText>
            </div>
        }
        else if (_order is not null)
        {
            <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-3 flex-wrap">
                <div>
                    <MudText Typo="Typo.h6">@_order.OrderNumber</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">Customer: @(_order.CustomerName ?? "-")</MudText>
                </div>
                <MudStack Row="true" Spacing="1">
                    <MudButton Variant="Variant.Outlined" OnClick="BackToList">Back</MudButton>
                    @if (CanPack)
                    {
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="OpenPackingStation">Open Packing Station</MudButton>
                    }
                </MudStack>
            </MudStack>

            <MudGrid Spacing="2" Class="mb-3">
                <MudItem xs="12" md="3">
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Status</MudText>
                    <MudChip Color="@GetStatusColor(_order.Status)" Variant="Variant.Filled" Size="Size.Small">@_order.Status</MudChip>
                </MudItem>
                <MudItem xs="12" md="3">
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Order Date</MudText>
                    <MudText Typo="Typo.body2">@FormatDate(_order.OrderDate)</MudText>
                </MudItem>
                <MudItem xs="12" md="3">
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Requested Ship Date</MudText>
                    <MudText Typo="Typo.body2">@FormatDate(_order.RequestedShipDate)</MudText>
                </MudItem>
                <MudItem xs="12" md="3">
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Reservation Id</MudText>
                    <MudText Typo="Typo.body2">@_order.ReservationId</MudText>
                </MudItem>
                @if (_order.Shipment is not null)
                {
                    <MudItem xs="12">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Shipment</MudText>
                        <MudText Typo="Typo.body2">
                            @_order.Shipment.ShipmentNumber
                            @if (!string.IsNullOrWhiteSpace(_order.Shipment.TrackingNumber))
                            {
                                <span class="ml-2">Tracking: @_order.Shipment.TrackingNumber</span>
                            }
                        </MudText>
                    </MudItem>
                }
            </MudGrid>

            <MudTable T="OutboundOrderLineDto"
                      Items="_order.Lines"
                      Dense="true"
                      Hover="true"
                      Class="mb-3"
                      data-testid="outbound-order-detail-lines">
                <HeaderContent>
                    <MudTh>Item</MudTh>
                    <MudTh>Barcode</MudTh>
                    <MudTh>Qty</MudTh>
                    <MudTh>Picked</MudTh>
                    <MudTh>Shipped</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Item">
                        <MudText Typo="Typo.body2">@context.ItemSku</MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">@context.ItemName</MudText>
                    </MudTd>
                    <MudTd DataLabel="Barcode">@(context.PrimaryBarcode ?? "-")</MudTd>
                    <MudTd DataLabel="Qty">@context.Qty</MudTd>
                    <MudTd DataLabel="Picked">@context.PickedQty</MudTd>
                    <MudTd DataLabel="Shipped">@context.ShippedQty</MudTd>
                </RowTemplate>
            </MudTable>

            @if (_order.SalesOrderId.HasValue)
            {
                <MudPaper Class="pa-3" Outlined="true" data-testid="outbound-order-detail-form">
                    <MudText Typo="Typo.h6" Class="mb-2">Order Actions</MudText>

                    <MudStack Row="true" Spacing="1" Class="mb-2">
                        @if (CanRelease)
                        {
                            <MudButton Variant="Variant.Outlined" Color="Color.Primary" OnClick="ReleaseAsync" Disabled="@_isSubmitting">Release</MudButton>
                        }
                        @if (CanCancel)
                        {
                            <MudButton Variant="Variant.Outlined"
                                       Color="Color.Error"
                                       OnClick="CancelAsync"
                                       Disabled="@_isSubmitting"
                                       data-testid="outbound-order-detail-cancel">
                                Cancel
                            </MudButton>
                        }
                    </MudStack>

                    @if (CanCancel)
                    {
                        <MudTextField T="string"
                                      Label="Cancellation reason"
                                      @bind-Value="_cancelReason"
                                      Variant="Variant.Outlined"
                                      Dense="true"
                                      data-testid="outbound-order-detail-cancel-reason" />
                    }
                </MudPaper>
            }
        }
    </MudPaper>
</div>

@code {
    [Parameter]
    public Guid Id { get; set; }

    private OutboundOrderDetailDto? _order;
    private bool _isLoading;
    private bool _isSubmitting;
    private ApiException? _apiError;
    private string _cancelReason = "Customer requested cancellation";

    protected override async Task OnParametersSetAsync()
    {
        await ReloadAsync();
    }

    private async Task ReloadAsync()
    {
        _isLoading = true;
        _apiError = null;

        try
        {
            _order = await OutboundClient.GetOutboundOrderAsync(Id);
        }
        catch (ApiException ex)
        {
            _apiError = ex;
            _order = null;
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void DismissError()
    {
        _apiError = null;
    }

    private void BackToList()
    {
        NavigationManager.NavigateTo("/warehouse/outbound/orders");
    }

    private void OpenPackingStation()
    {
        NavigationManager.NavigateTo($"/warehouse/outbound/pack/{Id}");
    }

    private async Task ReleaseAsync()
    {
        if (_isSubmitting)
        {
            return;
        }

        if (_order?.SalesOrderId is null)
        {
            return;
        }

        _isSubmitting = true;

        try
        {
            await OutboundClient.ReleaseSalesOrderAsync(_order.SalesOrderId.Value);
            ToastService.ShowSuccess("Order released successfully.");
            await ReloadAsync();
        }
        catch (ApiException ex)
        {
            _apiError = ex;
            ToastService.ShowError(BuildErrorMessage(ex));
        }
        finally
        {
            _isSubmitting = false;
        }
    }

    private async Task CancelAsync()
    {
        if (_isSubmitting)
        {
            return;
        }

        if (_order?.SalesOrderId is null)
        {
            return;
        }

        if (string.IsNullOrWhiteSpace(_cancelReason))
        {
            ToastService.ShowError("Cancellation reason is required.");
            return;
        }

        _isSubmitting = true;

        try
        {
            await OutboundClient.CancelSalesOrderAsync(_order.SalesOrderId.Value, _cancelReason.Trim());
            ToastService.ShowSuccess("Order cancelled successfully.");
            await ReloadAsync();
        }
        catch (ApiException ex)
        {
            _apiError = ex;
            ToastService.ShowError(BuildErrorMessage(ex));
        }
        finally
        {
            _isSubmitting = false;
        }
    }

    private bool CanPack => _order is not null &&
                            string.Equals(_order.Status, "PICKED", StringComparison.OrdinalIgnoreCase);

    private bool CanRelease => _order is not null &&
                               _order.SalesOrderId.HasValue &&
                               string.Equals(_order.Status, "ALLOCATED", StringComparison.OrdinalIgnoreCase);

    private bool CanCancel => _order is not null &&
                              _order.SalesOrderId.HasValue &&
                              !string.Equals(_order.Status, "SHIPPED", StringComparison.OrdinalIgnoreCase) &&
                              !string.Equals(_order.Status, "DELIVERED", StringComparison.OrdinalIgnoreCase) &&
                              !string.Equals(_order.Status, "CANCELLED", StringComparison.OrdinalIgnoreCase);

    private static string FormatDate(DateTimeOffset? value)
        => value.HasValue ? value.Value.ToLocalTime().ToString("yyyy-MM-dd HH:mm") : "-";

    private static string BuildErrorMessage(ApiException ex)
        => !string.IsNullOrWhiteSpace(ex.UserMessage)
            ? ex.UserMessage
            : "Request failed.";

    private static Color GetStatusColor(string status)
        => status.ToUpperInvariant() switch
        {
            "ALLOCATED" => Color.Info,
            "PICKING" => Color.Primary,
            "PICKED" => Color.Default,
            "PACKED" => Color.Warning,
            "SHIPPED" => Color.Success,
            "DELIVERED" => Color.Success,
            "CANCELLED" => Color.Error,
            _ => Color.Default
        };
}
