@page "/reports/stock-movements"
@inject ReportsClient ReportsClient
@inject IJSRuntime JavaScript
@inject ToastService ToastService

<PageTitle>Stock Movements - LKvitai.MES</PageTitle>

<div data-testid="reports-stock-movements-page">
    <MudText Typo="Typo.h5" Class="mb-3">Stock Movement History</MudText>

    @if (_apiError is not null)
    {
        <div data-testid="reports-stock-movements-error">
            <SharedErrorAlert Message="@BuildErrorMessage(_apiError)"
                         TraceId="@_apiError.TraceId"
                         OnRetry="LoadAsync"
                         OnDismiss="DismissError" />
        </div>
    }

    <MudPaper Class="pa-4 mb-3">
        <MudGrid Spacing="2" AlignItems="AlignItems.End">
            <MudItem xs="12" md="2">
                <MudDatePicker Label="Start"
                               @bind-Date="_startDate"
                               DateFormat="yyyy-MM-dd"
                               Variant="Variant.Outlined"
                               Dense="true" />
            </MudItem>
            <MudItem xs="12" md="2">
                <MudDatePicker Label="End"
                               @bind-Date="_endDate"
                               DateFormat="yyyy-MM-dd"
                               Variant="Variant.Outlined"
                               Dense="true" />
            </MudItem>
            <MudItem xs="12" md="2">
                <MudNumericField T="int?"
                                 Label="Item Id"
                                 @bind-Value="_itemId"
                                 Variant="Variant.Outlined"
                                 Dense="true" />
            </MudItem>
            <MudItem xs="12" md="2">
                <MudNumericField T="int?"
                                 Label="Location Id"
                                 @bind-Value="_locationId"
                                 Variant="Variant.Outlined"
                                 Dense="true" />
            </MudItem>
            <MudItem xs="12" md="2">
                <MudTextField T="string"
                              Label="Operator"
                              @bind-Value="_operatorId"
                              Variant="Variant.Outlined"
                              Dense="true" />
            </MudItem>
            <MudItem xs="12" md="2">
                <MudSelect T="string"
                           Label="Movement Type"
                           @bind-Value="_movementType"
                           Variant="Variant.Outlined"
                           Dense="true">
                    <MudSelectItem Value="@string.Empty">All</MudSelectItem>
                    <MudSelectItem Value="@("Receive")">Receive</MudSelectItem>
                    <MudSelectItem Value="@("Transfer")">Transfer</MudSelectItem>
                    <MudSelectItem Value="@("Pick")">Pick</MudSelectItem>
                    <MudSelectItem Value="@("Adjust")">Adjust</MudSelectItem>
                    <MudSelectItem Value="@("Dispatch")">Dispatch</MudSelectItem>
                </MudSelect>
            </MudItem>
            <MudItem xs="12" md="2">
                <MudButton FullWidth="true"
                           Variant="Variant.Filled"
                           Color="Color.Primary"
                           Disabled="@_isLoading"
                           OnClick="ApplyFiltersAsync"
                           @attributes="ApplyButtonAttributes">
                    Apply
                </MudButton>
            </MudItem>
            <MudItem xs="12" md="2">
                <MudButton FullWidth="true"
                           Variant="Variant.Outlined"
                           Color="Color.Default"
                           Disabled="@_isLoading"
                           OnClick="ExportCsvAsync"
                           @attributes="ExportButtonAttributes">
                    CSV
                </MudButton>
            </MudItem>
        </MudGrid>
    </MudPaper>

    <MudPaper Class="pa-4 position-relative">
         (@_isLoading)
        {
            <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-3" />
        }

        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-2">
            <MudText Typo="Typo.subtitle2" data-testid="reports-stock-movements-total">Total: @_totalCount</MudText>
            <MudText Typo="Typo.caption" Class="mud-secondary-text" data-testid="reports-stock-movements-page-indicator">Page @_page of @TotalPages</MudText>
        </MudStack>

        <MudDataGrid T="StockMovementRowDto"
                     Items="_rows"
                     Dense="true"
                     Hover="true"
                     Loading="@_isLoading"
                     SortMode="SortMode.None"
                     Filterable="false"
                     @attributes="StockMovementsGridAttributes">
            <NoRecordsContent>
                <MudText Typo="Typo.body2" Class="mud-secondary-text">No stock movements found.</MudText>
            </NoRecordsContent>
            <Columns>
                <TemplateColumn Title="Timestamp">
                    <CellTemplate>
                        @context.Item.Timestamp.ToLocalTime().ToString("yyyy-MM-dd HH:mm")
                    </CellTemplate>
                </TemplateColumn>
                <PropertyColumn Property="x => x.MovementType" Title="Type" />
                <PropertyColumn Property="x => x.ItemSku" Title="SKU" />
                <TemplateColumn Title="From">
                    <CellTemplate>
                        @(context.Item.FromLocationCode ?? "-")
                    </CellTemplate>
                </TemplateColumn>
                <TemplateColumn Title="To">
                    <CellTemplate>
                        @(context.Item.ToLocationCode ?? "-")
                    </CellTemplate>
                </TemplateColumn>
                <TemplateColumn Title="Qty">
                    <CellTemplate>
                        @context.Item.Qty.ToString("0.##") @context.Item.BaseUoM
                    </CellTemplate>
                </TemplateColumn>
                <TemplateColumn Title="Operator">
                    <CellTemplate>
                        @(context.Item.Operator ?? "-")
                    </CellTemplate>
                </TemplateColumn>
                <TemplateColumn Title="Reason">
                    <CellTemplate>
                        @(context.Item.Reason ?? "-")
                    </CellTemplate>
                </TemplateColumn>
                <PropertyColumn Property="x => x.Reference" Title="Reference" />
            </Columns>
        </MudDataGrid>

        @if (_totalCount > 0)
        {
            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.FlexEnd" Class="mt-3" data-testid="reports-stock-movements-pager">
                <MudSelect T="int"
                           Label="Page size"
                           Value="_pageSize"
                           ValueChanged="OnPageSizeChangedAsync"
                           Variant="Variant.Outlined"
                           Dense="true"
                           Style="width: 120px;"
                           @attributes="PageSizeAttributes">
                    <MudSelectItem Value="25">25</MudSelectItem>
                    <MudSelectItem Value="50">50</MudSelectItem>
                    <MudSelectItem Value="100">100</MudSelectItem>
                </MudSelect>
                <MudPagination Count="@TotalPages"
                               Selected="@_page"
                               SelectedChanged="OnPageChangedAsync"
                               Variant="Variant.Outlined"
                               Color="Color.Primary"
                               Size="Size.Small"
                               Class="ml-2" />
            </MudStack>
        }
    </MudPaper>
</div>

@code {
    private readonly List<StockMovementRowDto> _rows = [];
    private ApiException? _apiError;
    private bool _isLoading;

    private DateTime? _startDate = DateTime.UtcNow.AddDays(-7);
    private DateTime? _endDate = DateTime.UtcNow;
    private int? _itemId;
    private int? _locationId;
    private string _operatorId = string.Empty;
    private string _movementType = string.Empty;
    private int _page = 1;
    private int _pageSize = 50;
    private int _totalCount;

    private static readonly Dictionary<string, object> StockMovementsGridAttributes = new()
    {
        ["data-testid"] = "reports-stock-movements-grid"
    };

    private static readonly Dictionary<string, object> ApplyButtonAttributes = new()
    {
        ["data-testid"] = "reports-stock-movements-apply"
    };

    private static readonly Dictionary<string, object> ExportButtonAttributes = new()
    {
        ["data-testid"] = "reports-stock-movements-export"
    };

    private static readonly Dictionary<string, object> PageSizeAttributes = new()
    {
        ["data-testid"] = "reports-stock-movements-page-size"
    };

    private int TotalPages => Math.Max(1, (int)Math.Ceiling(_totalCount / (double)Math.Max(1, _pageSize)));

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task ApplyFiltersAsync()
    {
        _page = 1;
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _isLoading = true;
        _apiError = null;

        try
        {
            var result = await ReportsClient.GetStockMovementsAsync(
                ParseDateOffset(_startDate, true),
                ParseDateOffset(_endDate, false),
                _itemId,
                _locationId,
                string.IsNullOrWhiteSpace(_operatorId) ? null : _operatorId,
                string.IsNullOrWhiteSpace(_movementType) ? null : _movementType,
                _page,
                _pageSize);

            _rows.Clear();
            _rows.AddRange(result.Movements);
            _totalCount = result.TotalCount;
        }
        catch (ApiException ex)
        {
            _apiError = ex;
            ToastService.ShowError(BuildErrorMessage(ex));
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task ExportCsvAsync()
    {
        try
        {
            var bytes = await ReportsClient.DownloadStockMovementsCsvAsync(
                ParseDateOffset(_startDate, true),
                ParseDateOffset(_endDate, false),
                _itemId,
                _locationId,
                string.IsNullOrWhiteSpace(_operatorId) ? null : _operatorId,
                string.IsNullOrWhiteSpace(_movementType) ? null : _movementType);

            await JavaScript.InvokeVoidAsync(
                "csvExport.downloadBytes",
                $"stock-movements-{DateTime.UtcNow:yyyyMMdd}.csv",
                "text/csv",
                Convert.ToBase64String(bytes));
        }
        catch (ApiException ex)
        {
            _apiError = ex;
            ToastService.ShowError(BuildErrorMessage(ex));
        }
    }

    private async Task OnPageChangedAsync(int page)
    {
        _page = Math.Max(1, page);
        await LoadAsync();
    }

    private async Task OnPageSizeChangedAsync(int size)
    {
        _pageSize = Math.Clamp(size, 1, 500);
        _page = 1;
        await LoadAsync();
    }

    private static DateTimeOffset? ParseDateOffset(DateTime? input, bool startOfDay)
    {
        if (!input.HasValue)
        {
            return null;
        }

        var date = input.Value.Date;
        var value = startOfDay
            ? new DateTimeOffset(date, TimeSpan.Zero)
            : new DateTimeOffset(date.AddDays(1).AddTicks(-1), TimeSpan.Zero);

        return value;
    }

    private void DismissError()
    {
        _apiError = null;
    }

    private static string BuildErrorMessage(ApiException ex)
    {
        if (!string.IsNullOrWhiteSpace(ex.UserMessage))
        {
            return ex.UserMessage;
        }

        return ex.ProblemDetails?.Detail
               ?? ex.ProblemDetails?.Title
               ?? "Stock movement report request failed.";
    }
}
