@page "/reservations"
@inject ReservationsClient ReservationsClient
@inject ToastService ToastService
@using System.Diagnostics

<PageTitle>Reservations - LKvitai.MES</PageTitle>

<div data-testid="reservations-page">
<h3>Reservations</h3>

@if (_apiError is not null)
{
    <SharedErrorAlert Message="@BuildErrorMessage(_apiError)"
                 TraceId="@_apiError.TraceId"
                 OnRetry="RetryAsync"
                 OnDismiss="DismissError" />
}

<div class="mud-surface shadow-sm position-relative">
     (@(_isLoading || _isSubmitting))
        {
            <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-3" />
        }

    <div class="mud-surface-body">
        <div class="mud-grid-mrow g-2 align-items-end mb-3">
            <div class="mud-grid-col">
                <label class="form-label">Status</label>
                <select class="mud-input-base" value="@_statusFilter" @onchange="OnStatusChangedAsync">
                    <option value="ALL">All</option>
                    <option value="ALLOCATED">ALLOCATED</option>
                    <option value="PICKING">PICKING</option>
                </select>
            </div>
            <div class="mud-grid-col">
                <button class="mud-mbtn-base mud-mbtn-outline-secondary" @onclick="ReloadAsync" disabled="@(_isLoading || _isSubmitting)">
                    Refresh
                </button>
            </div>
        </div>

        <MudDataGrid T="ReservationDto"
                     Items="@_reservations"
                     Dense="true"
                     Hover="true"
                     Loading="@(_isLoading || _isSubmitting)"
                     SortMode="SortMode.None"
                     Filterable="false"
                     RowClick="@(args => OpenDetails(args.Item))"
                     @attributes="GridAttributes">
            <NoRecordsContent>
                <MudText Typo="Typo.body2" Class="mud-secondary-text">No reservations found.</MudText>
            </NoRecordsContent>
            <Columns>
                <TemplateColumn Title="Reservation">
                    <CellTemplate>
                        <code>@ShortId(context.Item.ReservationId)</code>
                    </CellTemplate>
                </TemplateColumn>
                <PropertyColumn Property="x => x.Purpose" Title="Purpose" />
                <PropertyColumn Property="x => x.Priority" Title="Priority" />
                <PropertyColumn Property="x => x.Status" Title="Status" />
                <PropertyColumn Property="x => x.LockType" Title="Lock" />
                <TemplateColumn Title="Created">
                    <CellTemplate>
                        @context.Item.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")
                    </CellTemplate>
                </TemplateColumn>
                <TemplateColumn Title="Actions">
                    <CellTemplate>
                        <MudStack Row="true" Spacing="1">
                            @if (context.Item.Status == "ALLOCATED")
                            {
                                <MudButton Variant="Variant.Outlined"
                                           Size="Size.Small"
                                           Color="Color.Primary"
                                           Disabled="@_isSubmitting"
                                           OnClick="@(() => OpenStartPickingConfirmation(context.Item))">
                                    Start Picking
                                </MudButton>
                            }
                            @if (context.Item.Status == "PICKING")
                            {
                                <MudButton Variant="Variant.Outlined"
                                           Size="Size.Small"
                                           Color="Color.Primary"
                                           Disabled="@_isSubmitting"
                                           OnClick="@(() => OpenPickModal(context.Item))">
                                    Pick
                                </MudButton>
                            }
                        </MudStack>
                    </CellTemplate>
                </TemplateColumn>
            </Columns>
        </MudDataGrid>

        @if (_totalPages > 1)
        {
            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.FlexEnd" Class="mt-3" data-testid="reservations-pager">
                <MudSelect T="int"
                           Label="Page size"
                           Value="_pageSize"
                           ValueChanged="OnPageSizeChangedAsync"
                           Variant="Variant.Outlined"
                           Dense="true"
                           Style="width: 120px;"
                           @attributes="PageSizeAttributes">
                    <MudSelectItem Value="25">25</MudSelectItem>
                    <MudSelectItem Value="50">50</MudSelectItem>
                    <MudSelectItem Value="100">100</MudSelectItem>
                </MudSelect>
                <MudPagination Count="@_totalPages"
                               Selected="@_page"
                               SelectedChanged="OnPageChangedAsync"
                               Variant="Variant.Outlined"
                               Color="Color.Primary"
                               Size="Size.Small"
                               Class="ml-2" />
            </MudStack>
        }
    </div>
</div>

@if (_showDetailModal && _selectedReservation is not null)
{
    <div class="modal fade show d-block" tabindex="-1" role="dialog" aria-modal="true">
        <div class="modal-dialog modal-lg modal-dialog-scrollable" role="document">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Reservation @ShortId(_selectedReservation.ReservationId)</h5>
                    <button type="button" class="mud-mbtn-close" aria-label="Close" @onclick="CloseDetailModal"></button>
                </div>
                <div class="modal-body">
                    <dl class="mud-grid-mrow mb-3">
                        <dt class="mud-grid-col">Purpose</dt>
                        <dd class="mud-grid-col">@_selectedReservation.Purpose</dd>

                        <dt class="mud-grid-col">Priority</dt>
                        <dd class="mud-grid-col">@_selectedReservation.Priority</dd>

                        <dt class="mud-grid-col">Status</dt>
                        <dd class="mud-grid-col">@_selectedReservation.Status</dd>

                        <dt class="mud-grid-col">Lock</dt>
                        <dd class="mud-grid-col">@_selectedReservation.LockType</dd>
                    </dl>

                    <div class="overflow-auto">
                        <table class="mud-mtbl-base mud-mtbl-dense">
                            <thead>
                                <tr>
                                    <th>SKU</th>
                                    <th>Requested</th>
                                    <th>Allocated</th>
                                    <th>Warehouse</th>
                                    <th>Location</th>
                                    <th>Allocated HUs</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var line in _selectedReservation.Lines)
                                {
                                    <tr>
                                        <td>@line.SKU</td>
                                        <td>@line.RequestedQty</td>
                                        <td>@line.AllocatedQty</td>
                                        <td>@line.WarehouseId</td>
                                        <td>@line.Location</td>
                                        <td>
                                            @if (line.AllocatedHUs.Count == 0)
                                            {
                                                <span class="text-muted">-</span>
                                            }
                                            else
                                            {
                                                @string.Join(", ", line.AllocatedHUs.Select(hu => $"{hu.LPN} ({hu.HuId:N}, qty {hu.Qty})"))
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
                <div class="modal-footer">
                    @if (_selectedReservation.Status == "ALLOCATED")
                    {
                        <button type="button"
                                class="mud-mbtn-base mud-mbtn-primary"
                                @onclick="() => OpenStartPickingConfirmation(_selectedReservation)"
                                disabled="@_isSubmitting">
                            Start Picking
                        </button>
                    }
                    @if (_selectedReservation.Status == "PICKING")
                    {
                        <button type="button"
                                class="mud-mbtn-base mud-mbtn-primary"
                                @onclick="() => OpenPickModal(_selectedReservation)"
                                disabled="@_isSubmitting">
                            Pick
                        </button>
                    }
                    <button type="button" class="mud-mbtn-base mbtn-secondary" @onclick="CloseDetailModal">Close</button>
                </div>
            </div>
        </div>
    </div>
    <div class="modal-backdrop fade show"></div>
}

@if (_showPickModal && _pickReservation is not null)
{
    <div class="modal fade show d-block" tabindex="-1" role="dialog" aria-modal="true">
        <div class="modal-dialog modal-dialog-centered" role="document">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Pick Reservation @ShortId(_pickReservation.ReservationId)</h5>
                    <button type="button" class="mud-mbtn-close" aria-label="Close" @onclick="ClosePickModal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Line</label>
                        <select class="mud-input-base" value="@_selectedPickLineIndex" @onchange="OnPickLineChanged">
                            @for (var i = 0; i < _pickReservation.Lines.Count; i++)
                            {
                                var line = _pickReservation.Lines[i];
                                <option value="@i">@line.SKU | @line.Location | Allocated: @line.AllocatedQty</option>
                            }
                        </select>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Handling Unit</label>
                        <select class="mud-input-base" value="@_selectedPickHuId" @onchange="OnPickHuChanged">
                            @if (SelectedPickLine is not null)
                            {
                                @foreach (var hu in SelectedPickLine.AllocatedHUs)
                                {
                                    <option value="@hu.HuId">@hu.LPN (@hu.HuId:N) - Qty @hu.Qty</option>
                                }
                            }
                        </select>
                    </div>

                    <div class="mb-1">
                        <label class="form-label">Quantity</label>
                        <input type="number" min="0.01" step="0.01" class="mud-input-base" @bind="_pickQuantity" />
                    </div>
                    @if (!string.IsNullOrWhiteSpace(_pickValidationMessage))
                    {
                        <div class="text-danger small">@_pickValidationMessage</div>
                    }
                </div>
                <div class="modal-footer">
                    <button type="button" class="mud-mbtn-base mbtn-secondary" @onclick="ClosePickModal">Cancel</button>
                    <button type="button"
                            class="mud-mbtn-base mud-mbtn-primary"
                            @onclick="SubmitPickAsync"
                            disabled="@(_isSubmitting || !CanSubmitPick)">
                        Submit Pick
                    </button>
                </div>
            </div>
        </div>
    </div>
    <div class="modal-backdrop fade show"></div>
}

<SharedConfirmDialog Title="Start picking?"
               Message="Start picking this reservation now?"
               ConfirmText="Start"
               IsVisible="@_showStartPickingConfirm"
               OnConfirm="ConfirmStartPickingAsync"
               OnCancel="CancelStartPickingConfirm" />
</div>

@code {
    private IReadOnlyList<ReservationDto> _reservations = Array.Empty<ReservationDto>();
    private int _page = 1;
    private int _pageSize = 50;
    private int _totalCount;
    private string _statusFilter = "ALL";

    private bool _isLoading;
    private bool _isSubmitting;
    private ApiException? _apiError;

    private bool _showDetailModal;
    private ReservationDto? _selectedReservation;

    private bool _showStartPickingConfirm;
    private ReservationDto? _pendingStartPickingReservation;

    private bool _showPickModal;
    private ReservationDto? _pickReservation;
    private int _selectedPickLineIndex;
    private Guid _selectedPickHuId;
    private decimal _pickQuantity = 1m;
    private string? _pickValidationMessage;
    private static readonly Dictionary<string, object> GridAttributes = new() { ["data-testid"] = "reservations-grid" };
    private static readonly Dictionary<string, object> PageSizeAttributes = new() { ["data-testid"] = "reservations-page-size" };

    private int _totalPages => Math.Max(1, (int)Math.Ceiling(_totalCount / (double)Math.Max(1, _pageSize)));

    private ReservationLineDto? SelectedPickLine
    {
        get
        {
            if (_pickReservation is null || _pickReservation.Lines.Count == 0)
            {
                return null;
            }

            var index = Math.Clamp(_selectedPickLineIndex, 0, _pickReservation.Lines.Count - 1);
            return _pickReservation.Lines[index];
        }
    }

    private bool CanSubmitPick => SelectedPickLine is not null &&
                                  _selectedPickHuId != Guid.Empty &&
                                  _pickQuantity > 0m;

    protected override async Task OnInitializedAsync()
    {
        await LoadReservationsAsync();
    }

    private async Task LoadReservationsAsync()
    {
        _isLoading = true;
        _apiError = null;

        try
        {
            var status = _statusFilter == "ALL" ? null : _statusFilter;
            var result = await ReservationsClient.GetReservationsAsync(status, _page, _pageSize);
            _reservations = result.Items;
            _totalCount = result.TotalCount;
        }
        catch (ApiException ex)
        {
            _apiError = ex;
            _reservations = Array.Empty<ReservationDto>();
            _totalCount = 0;
        }
        catch (Exception ex)
        {
            _apiError = new ApiException(
                new ProblemDetailsModel
                {
                    Title = "Reservations request failed",
                    Detail = ex.Message,
                    Status = 500,
                    TraceId = Activity.Current?.Id
                },
                500);

            _reservations = Array.Empty<ReservationDto>();
            _totalCount = 0;
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task ReloadAsync() => await LoadReservationsAsync();

    private async Task RetryAsync() => await LoadReservationsAsync();

    private void DismissError() => _apiError = null;

    private async Task OnStatusChangedAsync(ChangeEventArgs args)
    {
        _statusFilter = args.Value?.ToString()?.ToUpperInvariant() switch
        {
            "ALLOCATED" => "ALLOCATED",
            "PICKING" => "PICKING",
            _ => "ALL"
        };

        _page = 1;
        await LoadReservationsAsync();
    }

    private async Task OnPageChangedAsync(int page)
    {
        _page = Math.Max(1, page);
        await LoadReservationsAsync();
    }

    private async Task OnPageSizeChangedAsync(int pageSize)
    {
        _pageSize = pageSize;
        _page = 1;
        await LoadReservationsAsync();
    }

    private Task OpenDetails(ReservationDto reservation)
    {
        _selectedReservation = reservation;
        _showDetailModal = true;
        return Task.CompletedTask;
    }

    private void CloseDetailModal()
    {
        _showDetailModal = false;
        _selectedReservation = null;
    }

    private void OpenStartPickingConfirmation(ReservationDto reservation)
    {
        _pendingStartPickingReservation = reservation;
        _showStartPickingConfirm = true;
    }

    private void CancelStartPickingConfirm()
    {
        _showStartPickingConfirm = false;
        _pendingStartPickingReservation = null;
    }

    private async Task ConfirmStartPickingAsync()
    {
        if (_pendingStartPickingReservation is null)
        {
            _showStartPickingConfirm = false;
            return;
        }

        _isSubmitting = true;
        _apiError = null;

        try
        {
            var response = await ReservationsClient.StartPickingAsync(_pendingStartPickingReservation.ReservationId);
            ToastService.ShowSuccess(response.Message);

            _showStartPickingConfirm = false;
            _pendingStartPickingReservation = null;
            _showDetailModal = false;
            _selectedReservation = null;

            await LoadReservationsAsync();
        }
        catch (ApiException ex)
        {
            _apiError = ex;
            ToastService.ShowError(BuildErrorMessage(ex));
        }
        finally
        {
            _isSubmitting = false;
        }
    }

    private void OpenPickModal(ReservationDto reservation)
    {
        _pickReservation = reservation;
        _selectedPickLineIndex = 0;
        _pickValidationMessage = null;
        _pickQuantity = 1m;

        var firstLine = reservation.Lines.FirstOrDefault();
        var firstHu = firstLine?.AllocatedHUs.FirstOrDefault();
        _selectedPickHuId = firstHu?.HuId ?? Guid.Empty;
        _showPickModal = true;
    }

    private void ClosePickModal()
    {
        _showPickModal = false;
        _pickReservation = null;
        _pickValidationMessage = null;
    }

    private void OnPickLineChanged(ChangeEventArgs args)
    {
        if (int.TryParse(args.Value?.ToString(), out var selected))
        {
            _selectedPickLineIndex = selected;
            var firstHu = SelectedPickLine?.AllocatedHUs.FirstOrDefault();
            _selectedPickHuId = firstHu?.HuId ?? Guid.Empty;
        }
    }

    private void OnPickHuChanged(ChangeEventArgs args)
    {
        if (Guid.TryParse(args.Value?.ToString(), out var huId))
        {
            _selectedPickHuId = huId;
        }
    }

    private async Task SubmitPickAsync()
    {
        _pickValidationMessage = null;

        if (_pickReservation is null || SelectedPickLine is null)
        {
            _pickValidationMessage = "Select a reservation line.";
            return;
        }

        if (_selectedPickHuId == Guid.Empty)
        {
            _pickValidationMessage = "Select a handling unit.";
            return;
        }

        if (_pickQuantity <= 0m)
        {
            _pickValidationMessage = "Quantity must be greater than zero.";
            return;
        }

        if (SelectedPickLine.AllocatedQty > 0m && _pickQuantity > SelectedPickLine.AllocatedQty)
        {
            _pickValidationMessage = $"Quantity exceeds allocated quantity {SelectedPickLine.AllocatedQty}.";
            return;
        }

        _isSubmitting = true;
        _apiError = null;

        try
        {
            var response = await ReservationsClient.PickAsync(_pickReservation.ReservationId, new PickRequestDto
            {
                ReservationId = _pickReservation.ReservationId,
                HuId = _selectedPickHuId,
                Sku = SelectedPickLine.SKU,
                Quantity = _pickQuantity
            });

            ToastService.ShowSuccess(response.Message);

            _showPickModal = false;
            _showDetailModal = false;
            _pickReservation = null;
            _selectedReservation = null;
            _pickValidationMessage = null;

            await LoadReservationsAsync();
        }
        catch (ApiException ex)
        {
            _apiError = ex;
            ToastService.ShowError(BuildErrorMessage(ex));
        }
        finally
        {
            _isSubmitting = false;
        }
    }

    private static string ShortId(Guid id) => id.ToString("N")[..8];

    private static string BuildErrorMessage(ApiException error)
    {
        if (error.ProblemDetails?.Errors is { Count: > 0 } fieldErrors)
        {
            var flattened = fieldErrors
                .SelectMany(entry => entry.Value.Select(message => $"{entry.Key}: {message}"));
            var details = string.Join("; ", flattened);
            return string.IsNullOrWhiteSpace(details) ? error.UserMessage : $"{error.UserMessage} {details}";
        }

        if (!string.IsNullOrWhiteSpace(error.ProblemDetails?.Detail))
        {
            return $"{error.UserMessage} {error.ProblemDetails.Detail}";
        }

        return error.UserMessage;
    }
}
