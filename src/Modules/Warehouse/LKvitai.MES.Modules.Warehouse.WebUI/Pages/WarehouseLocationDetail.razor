@page "/warehouse/locations/{Id:int}"

<PageTitle>Location Details</PageTitle>

<MudText Typo="Typo.h4">Location Details</MudText>
<MudText Typo="Typo.body2" Class="mud-secondary-text">Location ID: @Id</MudText>
<MudText Typo="Typo.body1" Class="mb-3">
    Manage location metadata in the admin location workspace.
</MudText>
<MudButton Variant="Variant.Outlined" Color="Color.Default" Href="/admin/locations">Open Admin Locations</MudButton>

@code {
    [Parameter]
    public int Id { get; set; }
}
