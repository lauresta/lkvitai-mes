@page "/warehouse/stock/location-balance"
@inject StockClient StockClient
@inject ToastService ToastService

<PageTitle>Location Balance - LKvitai.MES</PageTitle>

<div data-testid="stock-location-balance-page">
    <MudText Typo="Typo.h5" Class="mb-3">Location Balance</MudText>

    @if (_apiError is not null)
    {
        <ErrorBanner Message="@BuildErrorMessage(_apiError)"
                     TraceId="@_apiError.TraceId"
                     OnRetry="LoadAsync"
                     OnDismiss="@(() => _apiError = null)" />
    }

    <MudPaper Class="pa-4 mb-3">
        <MudGrid Spacing="2" AlignItems="AlignItems.End">
            <MudItem xs="12" md="3">
                <MudNumericField T="int?" Label="Location Id" @bind-Value="_locationId" Variant="Variant.Outlined" Dense="true" />
            </MudItem>
            <MudItem xs="12" md="3">
                <MudTextField T="string" Label="Status" @bind-Value="_status" Variant="Variant.Outlined" Dense="true" />
            </MudItem>
            <MudItem xs="12" md="3">
                <MudButton FullWidth="true" Variant="Variant.Filled" Color="Color.Primary" Disabled="@_isLoading" OnClick="ApplyFiltersAsync" @attributes="ApplyAttributes">Apply</MudButton>
            </MudItem>
            <MudItem xs="12" md="3">
                <MudButton FullWidth="true" Variant="Variant.Outlined" Color="Color.Default" Disabled="@_isLoading" OnClick="ResetFiltersAsync" @attributes="ResetAttributes">Reset</MudButton>
            </MudItem>
        </MudGrid>
    </MudPaper>

    <MudPaper Class="pa-4 position-relative">
         (_isLoading)
        {
            <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-3" />
        }

        <MudDataGrid T="LocationBalanceItemDto"
                     Items="_rows"
                     Dense="true"
                     Hover="true"
                     Loading="@_isLoading"
                     SortMode="SortMode.None"
                     Filterable="false"
                     @attributes="GridAttributes">
            <NoRecordsContent>
                <MudText Typo="Typo.body2" Class="mud-secondary-text">No rows found.</MudText>
            </NoRecordsContent>
            <Columns>
                <PropertyColumn Property="x => x.LocationCode" Title="Location" />
                <PropertyColumn Property="x => x.ItemCount" Title="Item Count" />
                <TemplateColumn Title="Total Weight">
                    <CellTemplate>
                        @context.Item.TotalWeight.ToString("0.###")
                    </CellTemplate>
                </TemplateColumn>
                <TemplateColumn Title="Total Volume">
                    <CellTemplate>
                        @context.Item.TotalVolume.ToString("0.###")
                    </CellTemplate>
                </TemplateColumn>
                <TemplateColumn Title="Max Weight">
                    <CellTemplate>
                        @(context.Item.MaxWeight?.ToString("0.###") ?? "-")
                    </CellTemplate>
                </TemplateColumn>
                <TemplateColumn Title="Max Volume">
                    <CellTemplate>
                        @(context.Item.MaxVolume?.ToString("0.###") ?? "-")
                    </CellTemplate>
                </TemplateColumn>
                <TemplateColumn Title="Utilization Weight">
                    <CellTemplate>
                        @FormatPercent(context.Item.UtilizationWeight)
                    </CellTemplate>
                </TemplateColumn>
                <TemplateColumn Title="Utilization Volume">
                    <CellTemplate>
                        @FormatPercent(context.Item.UtilizationVolume)
                    </CellTemplate>
                </TemplateColumn>
                <PropertyColumn Property="x => x.Status" Title="Status" />
            </Columns>
        </MudDataGrid>

        @if (_totalCount > 0)
        {
            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.FlexEnd" Class="mt-3" data-testid="stock-location-balance-pager">
                <MudSelect T="int"
                           Label="Page size"
                           Value="_pageSize"
                           ValueChanged="OnPageSizeChangedAsync"
                           Variant="Variant.Outlined"
                           Dense="true"
                           Style="width: 120px;"
                           @attributes="PageSizeAttributes">
                    <MudSelectItem Value="25">25</MudSelectItem>
                    <MudSelectItem Value="50">50</MudSelectItem>
                    <MudSelectItem Value="100">100</MudSelectItem>
                </MudSelect>
                <MudPagination Count="@TotalPages"
                               Selected="@_pageNumber"
                               SelectedChanged="OnPageChangedAsync"
                               Variant="Variant.Outlined"
                               Color="Color.Primary"
                               Size="Size.Small"
                               Class="ml-2" />
            </MudStack>
        }
    </MudPaper>
</div>

@code {
    private readonly List<LocationBalanceItemDto> _rows = [];
    private ApiException? _apiError;
    private bool _isLoading;
    private int? _locationId;
    private string? _status;
    private int _pageNumber = 1;
    private int _pageSize = 50;
    private int _totalCount;

    private static readonly Dictionary<string, object> GridAttributes = new() { ["data-testid"] = "stock-location-balance-grid" };
    private static readonly Dictionary<string, object> ApplyAttributes = new() { ["data-testid"] = "stock-location-balance-apply" };
    private static readonly Dictionary<string, object> ResetAttributes = new() { ["data-testid"] = "stock-location-balance-reset" };
    private static readonly Dictionary<string, object> PageSizeAttributes = new() { ["data-testid"] = "stock-location-balance-page-size" };

    private int TotalPages => Math.Max(1, (int)Math.Ceiling(_totalCount / (double)Math.Max(1, _pageSize)));

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task ApplyFiltersAsync()
    {
        _pageNumber = 1;
        await LoadAsync();
    }

    private async Task ResetFiltersAsync()
    {
        _locationId = null;
        _status = null;
        _pageNumber = 1;
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _isLoading = true;
        _apiError = null;

        try
        {
            var result = await StockClient.GetLocationBalanceAsync(_locationId, string.IsNullOrWhiteSpace(_status) ? null : _status, _pageNumber, _pageSize);
            _rows.Clear();
            _rows.AddRange(result.Items);
            _totalCount = result.TotalCount;
        }
        catch (ApiException ex)
        {
            _apiError = ex;
            ToastService.ShowError(BuildErrorMessage(ex));
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task OnPageChangedAsync(int page)
    {
        _pageNumber = Math.Max(1, page);
        await LoadAsync();
    }

    private async Task OnPageSizeChangedAsync(int size)
    {
        _pageSize = Math.Clamp(size, 1, 500);
        _pageNumber = 1;
        await LoadAsync();
    }

    private static string FormatPercent(decimal? value)
    {
        if (!value.HasValue)
        {
            return "-";
        }

        return $"{(value.Value * 100m):0.##}%";
    }

    private static string BuildErrorMessage(ApiException error)
    {
        if (!string.IsNullOrWhiteSpace(error.ProblemDetails?.Detail))
        {
            return $"{error.UserMessage} {error.ProblemDetails.Detail}";
        }

        return error.UserMessage;
    }
}
