@page "/warehouse/outbound/orders"
@implements IDisposable
@inject OutboundClient OutboundClient
@inject NavigationManager NavigationManager
@inject ToastService ToastService
@inject IJSRuntime JS
@using LKvitai.MES.Modules.Warehouse.WebUI.Infrastructure

<PageTitle>Outbound Orders - LKvitai.MES</PageTitle>

<div data-testid="outbound-orders-page">
    <MudText Typo="Typo.h5" Class="mb-3">Outbound Orders</MudText>

    @if (_apiError is not null)
    {
        <div data-testid="outbound-orders-error" class="mb-3">
            <ErrorBanner Message="@BuildErrorMessage(_apiError)"
                         TraceId="@_apiError.TraceId"
                         OnRetry="RetryAsync"
                         OnDismiss="DismissError" />
        </div>
    }

    <MudPaper Class="pa-4 position-relative">
        <LoadingSpinner IsLoading="_isLoading" />

        <MudGrid Spacing="2" AlignItems="AlignItems.End" Class="mb-3" data-testid="outbound-orders-filters">
            <MudItem xs="12" md="2">
                <MudSelect T="string"
                           Label="Status"
                           @bind-Value="_statusFilter"
                           Variant="Variant.Outlined"
                           Dense="true"
                           @attributes="StatusFilterAttributes">
                    <MudSelectItem T="string" Value="@string.Empty">All</MudSelectItem>
                    <MudSelectItem T="string" Value="@("ALLOCATED")">ALLOCATED</MudSelectItem>
                    <MudSelectItem T="string" Value="@("PICKING")">PICKING</MudSelectItem>
                    <MudSelectItem T="string" Value="@("PICKED")">PICKED</MudSelectItem>
                    <MudSelectItem T="string" Value="@("PACKED")">PACKED</MudSelectItem>
                    <MudSelectItem T="string" Value="@("SHIPPED")">SHIPPED</MudSelectItem>
                    <MudSelectItem T="string" Value="@("DELIVERED")">DELIVERED</MudSelectItem>
                    <MudSelectItem T="string" Value="@("CANCELLED")">CANCELLED</MudSelectItem>
                </MudSelect>
            </MudItem>

            <MudItem xs="12" md="3">
                <MudTextField T="string"
                              Label="Customer"
                              Placeholder="Customer name"
                              @bind-Value="_customerFilter"
                              Variant="Variant.Outlined"
                              Dense="true"
                              @attributes="CustomerFilterAttributes" />
            </MudItem>

            <MudItem xs="12" md="2">
                <MudDatePicker Label="Date from"
                               Date="@_dateFrom"
                               DateChanged="OnDateFromChanged"
                               Variant="Variant.Outlined"
                               PickerVariant="PickerVariant.Inline"
                               Dense="true"
                               @attributes="DateFromAttributes" />
            </MudItem>

            <MudItem xs="12" md="2">
                <MudDatePicker Label="Date to"
                               Date="@_dateTo"
                               DateChanged="OnDateToChanged"
                               Variant="Variant.Outlined"
                               PickerVariant="PickerVariant.Inline"
                               Dense="true"
                               @attributes="DateToAttributes" />
            </MudItem>

            <MudItem xs="12" md="3">
                <MudStack Row="true" Spacing="1" Class="flex-wrap">
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               OnClick="ApplyFiltersAsync"
                               Disabled="@_isLoading"
                               data-testid="outbound-orders-apply">
                        Apply
                    </MudButton>
                    <MudButton Variant="Variant.Outlined"
                               Color="Color.Default"
                               OnClick="ResetFiltersAsync"
                               Disabled="@_isLoading"
                               data-testid="outbound-orders-reset">
                        Reset
                    </MudButton>
                    <MudButton Variant="Variant.Outlined"
                               Color="Color.Default"
                               OnClick="RetryAsync"
                               Disabled="@_isLoading"
                               data-testid="outbound-orders-refresh">
                        Refresh
                    </MudButton>
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Success"
                               OnClick="OpenSalesOrderCreate"
                               data-testid="outbound-orders-create-sales">
                        + Sales Order
                    </MudButton>
                </MudStack>
            </MudItem>
        </MudGrid>

        <MudTable T="OutboundOrderSummaryDto"
                  Items="CurrentPageRows"
                  Dense="true"
                  Hover="true"
                  data-testid="outbound-orders-grid">
            <HeaderContent>
                <MudTh>
                    <MudCheckBox T="bool"
                                 Dense="true"
                                 Checked="@AreAllCurrentRowsSelected"
                                 CheckedChanged="ToggleSelectAllCurrentPageChecked" />
                </MudTh>
                <MudTh>Order Number</MudTh>
                <MudTh>Customer</MudTh>
                <MudTh>Status</MudTh>
                <MudTh>Items</MudTh>
                <MudTh>Requested Ship Date</MudTh>
                <MudTh>Actions</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Select">
                    <MudCheckBox T="bool"
                                 Dense="true"
                                 Checked="@_selectedOrderIds.Contains(context.Id)"
                                 CheckedChanged="value => ToggleOrderSelection(context.Id, value)" />
                </MudTd>
                <MudTd DataLabel="Order Number">
                    <MudLink Href="@($"/warehouse/outbound/orders/{context.Id}")">@context.OrderNumber</MudLink>
                </MudTd>
                <MudTd DataLabel="Customer">@(context.CustomerName ?? "-")</MudTd>
                <MudTd DataLabel="Status">
                    <MudChip Size="Size.Small" Color="@GetStatusColor(context.Status)">@context.Status</MudChip>
                </MudTd>
                <MudTd DataLabel="Items">@context.ItemCount</MudTd>
                <MudTd DataLabel="Requested Ship Date">@FormatDate(context.RequestedShipDate)</MudTd>
                <MudTd DataLabel="Actions">
                    <MudStack Row="true" Spacing="1" Class="flex-wrap">
                        <MudButton Variant="Variant.Outlined"
                                   Size="Size.Small"
                                   Color="Color.Primary"
                                   OnClick="() => OpenOrder(context.Id)">
                            View
                        </MudButton>
                        @if (string.Equals(context.Status, "PICKED", StringComparison.OrdinalIgnoreCase))
                        {
                            <MudButton Variant="Variant.Filled"
                                       Size="Size.Small"
                                       Color="Color.Primary"
                                       OnClick="() => OpenPacking(context.Id)">
                                Pack
                            </MudButton>
                        }
                    </MudStack>
                </MudTd>
            </RowTemplate>
            <NoRecordsContent>
                <MudText Typo="Typo.body2" Color="Color.Secondary">No outbound orders found.</MudText>
            </NoRecordsContent>
        </MudTable>

        @if (_selectedOrderIds.Count > 0)
        {
            <MudPaper Outlined="true" Class="pa-3 mt-3" data-testid="outbound-orders-selection-bar">
                <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="flex-wrap">
                    <MudText Typo="Typo.body2" Color="Color.Secondary">@_selectedOrderIds.Count order(s) selected</MudText>
                    <MudStack Row="true" Spacing="1" Class="flex-wrap">
                        <MudButton Variant="Variant.Outlined" Size="Size.Small" Color="Color.Error" OnClick="BulkCancelAsync" Disabled="@_isLoading">Bulk Cancel</MudButton>
                        <MudButton Variant="Variant.Outlined" Size="Size.Small" Color="Color.Default" OnClick="ExportSelectionCsvAsync">Export CSV</MudButton>
                        <MudButton Variant="Variant.Text" Size="Size.Small" Color="Color.Default" OnClick="ClearSelection">Clear</MudButton>
                    </MudStack>
                </MudStack>
            </MudPaper>
        }

        @if (TotalPages > 1)
        {
            <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mt-3" data-testid="outbound-orders-pager">
                <MudText Typo="Typo.body2" Color="Color.Secondary">Page @_page of @TotalPages</MudText>
                <MudPagination Count="@TotalPages"
                               Selected="@_page"
                               SelectedChanged="OnPageChangedAsync"
                               Variant="Variant.Outlined"
                               Color="Color.Primary"
                               Size="Size.Small" />
            </MudStack>
        }
    </MudPaper>
</div>

@code {
    private readonly List<OutboundOrderSummaryDto> _orders = [];
    private bool _isLoading;
    private ApiException? _apiError;
    private readonly HashSet<Guid> _selectedOrderIds = [];
    private string _statusFilter = string.Empty;
    private string _customerFilter = string.Empty;
    private DateTime? _dateFrom;
    private DateTime? _dateTo;
    private Timer? _pollTimer;
    private int _page = 1;
    private const int PageSize = 20;

    private static readonly Dictionary<string, object> StatusFilterAttributes = new() { ["data-testid"] = "outbound-orders-status" };
    private static readonly Dictionary<string, object> CustomerFilterAttributes = new() { ["data-testid"] = "outbound-orders-customer" };
    private static readonly Dictionary<string, object> DateFromAttributes = new() { ["data-testid"] = "outbound-orders-date-from" };
    private static readonly Dictionary<string, object> DateToAttributes = new() { ["data-testid"] = "outbound-orders-date-to" };

    protected override async Task OnInitializedAsync()
    {
        _pollTimer = new Timer(async _ => await InvokeAsync(PollAsync), null, TimeSpan.FromSeconds(30), TimeSpan.FromSeconds(30));
        await ReloadAsync();
    }

    public void Dispose()
    {
        _pollTimer?.Dispose();
    }

    private Task OnDateFromChanged(DateTime? value)
    {
        _dateFrom = value;
        return Task.CompletedTask;
    }

    private Task OnDateToChanged(DateTime? value)
    {
        _dateTo = value;
        return Task.CompletedTask;
    }

    private async Task PollAsync()
    {
        if (_isLoading)
        {
            return;
        }

        await ReloadAsync(showToastOnError: false);
    }

    private async Task ApplyFiltersAsync()
    {
        _page = 1;
        await ReloadAsync();
    }

    private async Task ResetFiltersAsync()
    {
        _statusFilter = string.Empty;
        _customerFilter = string.Empty;
        _dateFrom = null;
        _dateTo = null;
        _page = 1;
        await ReloadAsync();
    }

    private Task RetryAsync()
    {
        return ReloadAsync();
    }

    private async Task ReloadAsync(bool showToastOnError = true)
    {
        _isLoading = true;
        _apiError = null;

        try
        {
            var dateFrom = ParseDate(_dateFrom, startOfDay: true);
            var dateTo = ParseDate(_dateTo, startOfDay: false);

            var rows = await OutboundClient.GetOutboundOrderSummariesAsync(
                _statusFilter,
                _customerFilter,
                dateFrom,
                dateTo);

            _orders.Clear();
            _orders.AddRange(rows.OrderByDescending(x => x.OrderDate));
            _page = Math.Min(Math.Max(1, _page), TotalPages);
            _selectedOrderIds.RemoveWhere(x => _orders.All(order => order.Id != x));
        }
        catch (ApiException ex)
        {
            _apiError = ex;
            if (showToastOnError)
            {
                ToastService.ShowError(BuildErrorMessage(ex));
            }
        }
        catch (Exception ex)
        {
            _apiError = ToConnectivityApiException(ex);
            if (showToastOnError)
            {
                ToastService.ShowError(BuildErrorMessage(_apiError));
            }
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void DismissError()
    {
        _apiError = null;
    }

    private void OpenOrder(Guid orderId)
    {
        NavigationManager.NavigateTo($"/warehouse/outbound/orders/{orderId}");
    }

    private void OpenPacking(Guid orderId)
    {
        NavigationManager.NavigateTo($"/warehouse/outbound/pack/{orderId}");
    }

    private void OpenSalesOrderCreate()
    {
        NavigationManager.NavigateTo("/warehouse/sales/orders/create");
    }

    private bool AreAllCurrentRowsSelected =>
        CurrentPageRows.Any() && CurrentPageRows.All(x => _selectedOrderIds.Contains(x.Id));

    private Task ToggleSelectAllCurrentPageChecked(bool shouldSelect)
    {
        foreach (var order in CurrentPageRows)
        {
            if (shouldSelect)
            {
                _selectedOrderIds.Add(order.Id);
            }
            else
            {
                _selectedOrderIds.Remove(order.Id);
            }
        }

        return Task.CompletedTask;
    }

    private Task ToggleOrderSelection(Guid orderId, bool shouldSelect)
    {
        if (shouldSelect)
        {
            _selectedOrderIds.Add(orderId);
        }
        else
        {
            _selectedOrderIds.Remove(orderId);
        }

        return Task.CompletedTask;
    }

    private async Task BulkCancelAsync()
    {
        if (_selectedOrderIds.Count == 0)
        {
            return;
        }

        _isLoading = true;
        _apiError = null;

        try
        {
            var ids = _selectedOrderIds.ToArray();
            foreach (var id in ids)
            {
                await OutboundClient.CancelSalesOrderAsync(id, "Bulk cancel");
            }

            ToastService.ShowSuccess($"Cancelled {ids.Length} order(s).");
            _selectedOrderIds.Clear();
            await ReloadAsync();
        }
        catch (ApiException ex)
        {
            _apiError = ex;
            ToastService.ShowError(BuildErrorMessage(ex));
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task ExportSelectionCsvAsync()
    {
        var rows = _orders.Where(x => _selectedOrderIds.Contains(x.Id)).ToList();
        if (rows.Count == 0)
        {
            return;
        }

        var builder = new System.Text.StringBuilder();
        builder.AppendLine("OrderNumber,Customer,Status,ItemCount,RequestedShipDate");
        foreach (var row in rows)
        {
            builder.AppendLine(string.Join(',',
                EscapeCsv(row.OrderNumber),
                EscapeCsv(row.CustomerName ?? string.Empty),
                EscapeCsv(row.Status),
                row.ItemCount,
                EscapeCsv(FormatDate(row.RequestedShipDate))));
        }

        await JS.InvokeVoidAsync(
            "csvExport.download",
            $"outbound-orders-selected-{DateTime.UtcNow:yyyyMMddHHmmss}.csv",
            builder.ToString());
    }

    private void ClearSelection()
    {
        _selectedOrderIds.Clear();
    }

    private static DateTimeOffset? ParseDate(DateTime? value, bool startOfDay)
    {
        if (!value.HasValue)
        {
            return null;
        }

        var date = DateOnly.FromDateTime(value.Value);
        var time = startOfDay ? TimeOnly.MinValue : TimeOnly.MaxValue;
        return new DateTimeOffset(date.ToDateTime(time, DateTimeKind.Utc));
    }

    private static string FormatDate(DateTimeOffset? value)
        => value.HasValue ? value.Value.ToLocalTime().ToString("yyyy-MM-dd") : "-";

    private static string BuildErrorMessage(ApiException ex)
    {
        if (!string.IsNullOrWhiteSpace(ex.UserMessage))
        {
            return ex.UserMessage;
        }

        return ex.StatusCode switch
        {
            500 => "Failed to load orders. Please try again.",
            _ => "Failed to load orders."
        };
    }

    private static ApiException ToConnectivityApiException(Exception ex)
    {
        if (ex is ApiException apiException)
        {
            return apiException;
        }

        return new ApiException(
            new ProblemDetailsModel
            {
                Title = "Warehouse API is currently unavailable.",
                Detail = ex.Message,
                Status = 503,
                Type = "https://lkvitai.mes/problems/upstream-unavailable"
            },
            503);
    }

    private static string EscapeCsv(string value)
    {
        if (value.Contains(',') || value.Contains('"') || value.Contains('\n'))
        {
            var escaped = value.Replace("\"", "\"\"");
            return "\"" + escaped + "\"";
        }

        return value;
    }

    private IEnumerable<OutboundOrderSummaryDto> CurrentPageRows
        => _orders
            .Skip((_page - 1) * PageSize)
            .Take(PageSize);

    private int TotalPages => Math.Max(1, (int)Math.Ceiling(_orders.Count / (double)PageSize));

    private Task OnPageChangedAsync(int page)
    {
        _page = Math.Max(1, page);
        return Task.CompletedTask;
    }

    private static Color GetStatusColor(string status)
        => status.ToUpperInvariant() switch
        {
            "ALLOCATED" => Color.Info,
            "PICKING" => Color.Primary,
            "PICKED" => Color.Default,
            "PACKED" => Color.Warning,
            "SHIPPED" => Color.Success,
            "DELIVERED" => Color.Success,
            "CANCELLED" => Color.Error,
            _ => Color.Default
        };
}
