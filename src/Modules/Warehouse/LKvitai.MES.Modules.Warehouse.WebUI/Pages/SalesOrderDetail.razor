@page "/warehouse/sales/orders/{Id:guid}"
@inject SalesOrdersClient SalesOrdersClient
@inject NavigationManager NavigationManager
@inject ToastService ToastService

<PageTitle>Sales Order Detail - LKvitai.MES</PageTitle>

<div data-testid="sales-order-detail-page">
    <MudText Typo="Typo.h5" Class="mb-3">Sales Order Detail</MudText>

    @if (_apiError is not null)
    {
        <div data-testid="sales-order-detail-error" class="mb-3">
            <ErrorBanner Message="@BuildErrorMessage(_apiError)"
                         TraceId="@_apiError.TraceId"
                         OnRetry="ReloadAsync"
                         OnDismiss="DismissError" />
        </div>
    }

    <MudPaper Class="pa-4 position-relative">
         (_isLoading || _isBusy)
        {
            <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-3" />
        }

        @if (_order is null)
        {
            <div data-testid="sales-order-detail-empty">
                <EmptyState Title="Order not found"
                            Message="The sales order does not exist or is not accessible."
                            Icon="@Icons.Material.Filled.Description"
                            OnAction="BackToListAsync" />
            </div>
        }
        else
        {
            <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-3 flex-wrap">
                <div>
                    <MudText Typo="Typo.h6">@_order.OrderNumber</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">@_order.CustomerName</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Order date: @FormatDate(_order.OrderDate)</MudText>
                </div>
                <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                    <MudChip Color="@GetStatusColor(_order.Status)" Variant="Variant.Filled" Size="Size.Small">@_order.Status</MudChip>
                    <MudButton Variant="Variant.Outlined" Size="Size.Small" OnClick="BackToList">Back</MudButton>
                </MudStack>
            </MudStack>

            <MudGrid Spacing="2" Class="mb-3">
                <MudItem xs="12" md="4">
                    <MudPaper Class="pa-3" Outlined="true">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Requested delivery</MudText>
                        <MudText Typo="Typo.body2">@FormatDate(_order.RequestedDeliveryDate)</MudText>
                    </MudPaper>
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudPaper Class="pa-3" Outlined="true">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Reservation</MudText>
                        <MudText Typo="Typo.body2">@(_order.ReservationId?.ToString() ?? "-")</MudText>
                    </MudPaper>
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudPaper Class="pa-3" Outlined="true">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Outbound Order</MudText>
                        <MudText Typo="Typo.body2">@(_order.OutboundOrderId?.ToString() ?? "-")</MudText>
                    </MudPaper>
                </MudItem>
            </MudGrid>

            <MudStack Row="true" Spacing="1" Class="mb-3 flex-wrap" data-testid="sales-order-detail-actions">
                @if (CanSubmit)
                {
                    <MudButton Variant="Variant.Outlined" Color="Color.Primary" OnClick="SubmitAsync" Disabled="@_isBusy">Submit</MudButton>
                }
                @if (CanApprove)
                {
                    <MudButton Variant="Variant.Outlined" Color="Color.Info" OnClick="ApproveAsync" Disabled="@_isBusy">Approve</MudButton>
                }
                @if (CanAllocate)
                {
                    <MudButton Variant="Variant.Outlined" Color="Color.Primary" OnClick="AllocateAsync" Disabled="@_isBusy">Allocate</MudButton>
                }
                @if (CanRelease)
                {
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="ReleaseAsync" Disabled="@_isBusy">Release to Picking</MudButton>
                }
            </MudStack>

            @if (CanCancel)
            {
                <MudGrid Spacing="2" AlignItems="AlignItems.End" Class="mb-3" data-testid="sales-order-detail-form">
                    <MudItem xs="12" md="6">
                        <MudTextField T="string"
                                      Label="Cancel reason"
                                      @bind-Value="_cancelReason"
                                      MaxLength="250"
                                      Variant="Variant.Outlined"
                                      Dense="true"
                                      data-testid="sales-order-detail-cancel-reason" />
                    </MudItem>
                    <MudItem xs="12" md="3">
                        <MudButton Variant="Variant.Outlined"
                                   Color="Color.Error"
                                   OnClick="CancelAsync"
                                   Disabled="@_isBusy"
                                   data-testid="sales-order-detail-cancel">
                            Cancel Order
                        </MudButton>
                    </MudItem>
                </MudGrid>
            }

            <MudTable T="SalesOrderLineDto"
                      Items="_order.Lines"
                      Dense="true"
                      Hover="true"
                      data-testid="sales-order-detail-lines">
                <HeaderContent>
                    <MudTh>SKU</MudTh>
                    <MudTh>Description</MudTh>
                    <MudTh>Ordered</MudTh>
                    <MudTh>Allocated</MudTh>
                    <MudTh>Picked</MudTh>
                    <MudTh>Shipped</MudTh>
                    <MudTh>Price</MudTh>
                    <MudTh>Amount</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="SKU">@context.ItemSku</MudTd>
                    <MudTd DataLabel="Description">@context.ItemDescription</MudTd>
                    <MudTd DataLabel="Ordered">@context.OrderedQty.ToString("0.##")</MudTd>
                    <MudTd DataLabel="Allocated">@context.AllocatedQty.ToString("0.##")</MudTd>
                    <MudTd DataLabel="Picked">@context.PickedQty.ToString("0.##")</MudTd>
                    <MudTd DataLabel="Shipped">@context.ShippedQty.ToString("0.##")</MudTd>
                    <MudTd DataLabel="Price">@context.UnitPrice.ToString("0.00")</MudTd>
                    <MudTd DataLabel="Amount">@context.LineAmount.ToString("0.00")</MudTd>
                </RowTemplate>
                <FooterContent>
                    <MudTd ColSpan="7" Class="text-right"><strong>Total</strong></MudTd>
                    <MudTd><strong>@_order.TotalAmount.ToString("0.00")</strong></MudTd>
                </FooterContent>
            </MudTable>
        }
    </MudPaper>
</div>

@code {
    [Parameter]
    public Guid Id { get; set; }

    private SalesOrderDto? _order;
    private bool _isLoading;
    private bool _isBusy;
    private ApiException? _apiError;
    private string _cancelReason = "Cancelled by operator";

    private bool CanSubmit => string.Equals(_order?.Status, "DRAFT", StringComparison.OrdinalIgnoreCase);
    private bool CanApprove => string.Equals(_order?.Status, "PENDING_APPROVAL", StringComparison.OrdinalIgnoreCase);
    private bool CanAllocate => string.Equals(_order?.Status, "DRAFT", StringComparison.OrdinalIgnoreCase) ||
                                string.Equals(_order?.Status, "PENDING_STOCK", StringComparison.OrdinalIgnoreCase);
    private bool CanRelease => string.Equals(_order?.Status, "ALLOCATED", StringComparison.OrdinalIgnoreCase);
    private bool CanCancel => _order is not null &&
                              !string.Equals(_order.Status, "CANCELLED", StringComparison.OrdinalIgnoreCase) &&
                              !string.Equals(_order.Status, "SHIPPED", StringComparison.OrdinalIgnoreCase) &&
                              !string.Equals(_order.Status, "DELIVERED", StringComparison.OrdinalIgnoreCase) &&
                              !string.Equals(_order.Status, "INVOICED", StringComparison.OrdinalIgnoreCase);

    protected override async Task OnParametersSetAsync()
    {
        await ReloadAsync();
    }

    private async Task ReloadAsync()
    {
        _isLoading = true;
        _apiError = null;

        try
        {
            _order = await SalesOrdersClient.GetSalesOrderAsync(Id);
        }
        catch (ApiException ex)
        {
            _apiError = ex;
            ToastService.ShowError(BuildErrorMessage(ex));
            _order = null;
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task SubmitAsync()
    {
        await ExecuteActionAsync(() => SalesOrdersClient.SubmitSalesOrderAsync(Id), "Sales order submitted.");
    }

    private async Task ApproveAsync()
    {
        await ExecuteActionAsync(() => SalesOrdersClient.ApproveSalesOrderAsync(Id), "Sales order approved.");
    }

    private async Task AllocateAsync()
    {
        _isBusy = true;
        _apiError = null;

        try
        {
            var result = await SalesOrdersClient.AllocateSalesOrderAsync(Id);
            var message = result.ReservationId.HasValue
                ? $"Sales order allocated. Reservation: {result.ReservationId.Value}"
                : "Sales order allocated.";
            ToastService.ShowSuccess(message);
            await ReloadAsync();
        }
        catch (ApiException ex)
        {
            _apiError = ex;
            ToastService.ShowError(BuildErrorMessage(ex));
        }
        finally
        {
            _isBusy = false;
        }
    }

    private async Task ReleaseAsync()
    {
        await ExecuteActionAsync(() => SalesOrdersClient.ReleaseSalesOrderAsync(Id), "Sales order released to picking.");
    }

    private async Task CancelAsync()
    {
        if (string.IsNullOrWhiteSpace(_cancelReason))
        {
            ToastService.ShowError("Cancel reason is required.");
            return;
        }

        await ExecuteActionAsync(() => SalesOrdersClient.CancelSalesOrderAsync(Id, _cancelReason.Trim()), "Sales order cancelled.");
    }

    private async Task ExecuteActionAsync(Func<Task<SalesOrderDto>> action, string successMessage)
    {
        _isBusy = true;
        _apiError = null;

        try
        {
            await action();
            ToastService.ShowSuccess(successMessage);
            await ReloadAsync();
        }
        catch (ApiException ex)
        {
            _apiError = ex;
            ToastService.ShowError(BuildErrorMessage(ex));
        }
        finally
        {
            _isBusy = false;
        }
    }

    private void DismissError()
    {
        _apiError = null;
    }

    private void BackToList()
    {
        NavigationManager.NavigateTo("/warehouse/sales/orders");
    }

    private Task BackToListAsync()
    {
        BackToList();
        return Task.CompletedTask;
    }

    private static string FormatDate(DateTime? value)
    {
        return value?.ToString("yyyy-MM-dd HH:mm") ?? "-";
    }

    private static Color GetStatusColor(string status) => status.ToUpperInvariant() switch
    {
        "DRAFT" => Color.Default,
        "PENDING_APPROVAL" => Color.Warning,
        "ALLOCATED" => Color.Info,
        "PENDING_STOCK" => Color.Warning,
        "PICKING" => Color.Primary,
        "PACKED" => Color.Primary,
        "SHIPPED" => Color.Success,
        "DELIVERED" => Color.Success,
        "INVOICED" => Color.Dark,
        "CANCELLED" => Color.Error,
        _ => Color.Default
    };

    private static string BuildErrorMessage(ApiException ex)
    {
        if (!string.IsNullOrWhiteSpace(ex.UserMessage))
        {
            return ex.UserMessage;
        }

        return ex.ProblemDetails?.Detail
               ?? ex.ProblemDetails?.Title
               ?? "Sales order request failed.";
    }
}
