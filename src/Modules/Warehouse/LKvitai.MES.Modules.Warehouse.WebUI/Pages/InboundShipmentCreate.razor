@page "/inbound/shipments/create"
@page "/inbound/shipments/{Id:int}/edit"
@using System.Globalization
@inject ReceivingClient ReceivingClient
@inject MasterDataAdminClient MasterDataAdminClient
@inject NavigationManager NavigationManager
@inject ToastService ToastService

<PageTitle>@(IsEditMode ? $"Edit ISH-{Id} - Cikada.MES" : "Create Inbound Shipment - Cikada.MES")</PageTitle>

<h1>@(IsEditMode ? $"Edit Inbound Shipment ISH-{Id}" : "Create Inbound Shipment")</h1>

@if (_apiError is not null)
{
    <ErrorBanner Message="@BuildErrorMessage(_apiError)"
                 TraceId="@_apiError.TraceId"
                 OnRetry="@(IsEditMode ? LoadShipmentForEditAsync : LoadLookupDataAsync)"
                 OnDismiss="DismissError" />
}

<MudPaper Class="panel ish-create position-relative" Elevation="0" Outlined="true">
    <LoadingSpinner IsLoading="_isLoading || _isSubmitting" />

    <div class="panel__head">
        <div class="panel__title">Shipment Details</div>
        <div class="panel__actions">
            <MudButton Size="Size.Small" Variant="Variant.Outlined" Color="Color.Default" OnClick="BackToList">Back</MudButton>
        </div>
    </div>

    <div class="ish-create__body">
        <div class="ish-create__header-grid">
            <div class="lk-form-field">
                <span class="lk-form-field__label">Reference Number</span>
                <div class="lk-form-field__control">
                    <MudTextField T="string" Variant="Variant.Text" @bind-Value="_referenceNumber" Required="true" />
                </div>
            </div>
            <div class="lk-form-field">
                <span class="lk-form-field__label">Supplier</span>
                <div class="lk-form-field__control">
                    <MudAutocomplete T="AdminSupplierDto"
                                      Variant="Variant.Text"
                                      @bind-Value="_supplier"
                                      SearchFunc="SearchSuppliersAsync"
                                      ToStringFunc="@(s => s is null ? string.Empty : $"{s.Code} - {s.Name}")"
                                      CoerceText="true"
                                      ResetValueOnEmptyText="true"
                                      Required="true" />
                </div>
            </div>
            <div class="lk-form-field">
                <span class="lk-form-field__label">Expected Date</span>
                <div class="lk-form-field__control">
                    <MudDatePicker Variant="Variant.Text" DateFormat="yyyy-MM-dd" @bind-Date="_expectedDate" />
                </div>
            </div>
            <div class="lk-form-field">
                <span class="lk-form-field__label">Invoice Number</span>
                <div class="lk-form-field__control">
                    <MudTextField T="string" Variant="Variant.Text" @bind-Value="_invoiceNumber" Placeholder="Optional" />
                </div>
            </div>
            <div class="lk-form-field">
                <span class="lk-form-field__label">Invoice Date</span>
                <div class="lk-form-field__control">
                    <MudDatePicker Variant="Variant.Text" DateFormat="yyyy-MM-dd" @bind-Date="_invoiceDate" />
                </div>
            </div>
        </div>

        <div class="ish-create__section-head">
            <div class="ish-create__section-title">
                Lines
                <small>Service items (Transport, Delivery...) fold into Additional Costs below instead of holding stock.</small>
            </div>
            <MudButton Size="Size.Small" Variant="Variant.Outlined" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" OnClick="AddLine" Disabled="@_isSubmitting">Add Line</MudButton>
        </div>

        <MudTable Items="@_lines" Dense="true" Hover="true" Class="lk-grid ish-create__grid">
            <HeaderContent>
                <MudTh>Item</MudTh>
                <MudTh>Qty</MudTh>
                <MudTh>Invoice unit price</MudTh>
                <MudTh>Ccy</MudTh>
                <MudTh>Actual unit price</MudTh>
                <MudTh></MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Item" Style="min-width: 240px;">
                    <div class="ish-create__item-cell">
                        <div class="lk-field--inline">
                            <MudAutocomplete T="AdminItemDto"
                                              Variant="Variant.Text"
                                              Value="@context.Item"
                                              ValueChanged="@(v => OnLineItemChanged(context, v))"
                                              SearchFunc="SearchItemsAsync"
                                              ToStringFunc="@(i => i is null ? string.Empty : $"{i.InternalSKU} - {i.Name}")"
                                              CoerceText="true"
                                              ResetValueOnEmptyText="true"
                                              Placeholder="Select item" />
                        </div>
                        @if (context.Item?.IsService == true)
                        {
                            <span class="chip chip--reserved ish-create__service-chip">Service - @(context.Item.CostType ?? "Other")</span>
                        }
                    </div>
                </MudTd>
                <MudTd DataLabel="Qty" Style="width: 90px;">
                    <div class="lk-field--inline">
                        <MudNumericField T="decimal" Variant="Variant.Text" Culture="NumberCulture" Min="0.001m" @bind-Value="context.ExpectedQty" />
                    </div>
                </MudTd>
                <MudTd DataLabel="Invoice unit price" Style="width: 130px;">
                    <div class="lk-field--inline">
                        <MudNumericField T="decimal?" Variant="Variant.Text" Culture="NumberCulture" Min="0m" Format="0.####" @bind-Value="context.UnitPrice" />
                    </div>
                </MudTd>
                <MudTd DataLabel="Ccy" Style="width: 76px;">
                    <div class="lk-field--inline">
                        <MudTextField T="string" Variant="Variant.Text" MaxLength="3" @bind-Value="context.Currency" />
                    </div>
                </MudTd>
                <MudTd DataLabel="Actual unit price" Style="width: 120px;" Class="is-num">
                    @if (context.Item?.IsService == true)
                    {
                        <span class="text-muted">-</span>
                    }
                    else
                    {
                        <span class="mono">@FormatMoney(ComputeActualUnitPrice(context))</span>
                    }
                </MudTd>
                <MudTd Style="width: 40px;">
                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small" Disabled="@(_isSubmitting || _lines.Count == 1)" OnClick="@(() => RemoveLine(context))" />
                </MudTd>
            </RowTemplate>
            <NoRecordsContent>
                <EmptyState Title="No lines" Message="Add at least one item line." IconCss="bi bi-list-ul" OnAction="AddLineAsync" />
            </NoRecordsContent>
        </MudTable>

        <div class="ish-create__section-head">
            <div class="ish-create__section-title">
                Additional costs
                <small>Freight/duty/insurance/other, distributed across Stock lines by value at receiving time.</small>
            </div>
            <MudButton Size="Size.Small" Variant="Variant.Outlined" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" OnClick="AddAdditionalCost" Disabled="@_isSubmitting">Add Cost</MudButton>
        </div>

        @if (_duplicateCostTypeWarning is not null)
        {
            <div class="lk-state lk-state--warn ish-create__warning">@_duplicateCostTypeWarning</div>
        }

        <MudTable Items="@_additionalCosts" Dense="true" Hover="true" Class="lk-grid ish-create__grid">
            <HeaderContent>
                <MudTh>Type</MudTh>
                <MudTh>Amount</MudTh>
                <MudTh>Ccy</MudTh>
                <MudTh></MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Type" Style="min-width: 180px;">
                    <div class="lk-field--inline">
                        <MudAutocomplete T="string"
                                          Variant="Variant.Text"
                                          @bind-Value="context.CostType"
                                          SearchFunc="SearchCostTypesAsync"
                                          CoerceText="true"
                                          CoerceValue="true" />
                    </div>
                </MudTd>
                <MudTd DataLabel="Amount" Style="width: 140px;">
                    <div class="lk-field--inline">
                        <MudNumericField T="decimal" Variant="Variant.Text" Culture="NumberCulture" Min="0m" Format="0.00" Adornment="Adornment.End" AdornmentText="€" @bind-Value="context.Amount" />
                    </div>
                </MudTd>
                <MudTd DataLabel="Ccy" Style="width: 76px;">
                    <div class="lk-field--inline">
                        <MudTextField T="string" Variant="Variant.Text" MaxLength="3" @bind-Value="context.Currency" />
                    </div>
                </MudTd>
                <MudTd Style="width: 40px;">
                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small" Disabled="@_isSubmitting" OnClick="@(() => RemoveAdditionalCost(context))" />
                </MudTd>
            </RowTemplate>
        </MudTable>

        <div class="ish-create__totals">
            <div class="ish-create__totals-item">
                <span class="ish-create__totals-label">Total Qty (Stock)</span>
                <span class="ish-create__totals-value">@TotalStockQty.ToString("0.###", NumberCulture)</span>
            </div>
            <div class="ish-create__totals-item">
                <span class="ish-create__totals-label">Total Invoice Value</span>
                <span class="ish-create__totals-value">@FormatMoney(TotalInvoiceValue)</span>
            </div>
            <div class="ish-create__totals-item">
                <span class="ish-create__totals-label">Total Additional Costs</span>
                <span class="ish-create__totals-value">@FormatMoney(TotalAdditionalCostPool)</span>
            </div>
            <div class="ish-create__totals-item">
                <span class="ish-create__totals-label">Total Actual Value</span>
                <span class="ish-create__totals-value">@FormatMoney(TotalActualValue)</span>
            </div>
            <div class="ish-create__totals-item">
                <span class="ish-create__totals-label">Avg Invoice Price</span>
                <span class="ish-create__totals-value">@FormatMoney(AverageInvoiceUnitPrice)</span>
            </div>
            <div class="ish-create__totals-item">
                <span class="ish-create__totals-label">Avg Actual Price</span>
                <span class="ish-create__totals-value">@FormatMoney(AverageActualUnitPrice)</span>
            </div>
        </div>

        <div class="ish-create__footer">
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SubmitAsync" Disabled="@_isSubmitting">@(IsEditMode ? "Save Changes" : "Create Shipment")</MudButton>
        </div>
    </div>
</MudPaper>

@code {
    private static readonly string[] CostTypePresets = ["Freight", "Duty", "Insurance", "VAT", "Other"];

    // Lithuanian formatting: comma decimal separator, matches the convention already
    // used for money elsewhere in the app (see Dashboard.razor's lt-LT price formatting).
    private static readonly CultureInfo NumberCulture = CultureInfo.GetCultureInfo("lt-LT");

    [Parameter]
    public int? Id { get; set; }

    private bool IsEditMode => Id.HasValue;

    private readonly List<InboundLineModel> _lines = [];
    private readonly List<AdditionalCostModel> _additionalCosts = [];

    private bool _isLoading;
    private bool _isSubmitting;
    private ApiException? _apiError;
    private string? _duplicateCostTypeWarning;

    private string _referenceNumber = $"IN-{DateTime.UtcNow:yyyyMMdd-HHmmss}";
    private AdminSupplierDto? _supplier;
    private DateTime? _expectedDate;
    private string? _invoiceNumber;
    private DateTime? _invoiceDate;

    protected override async Task OnInitializedAsync()
    {
        if (IsEditMode)
        {
            await LoadShipmentForEditAsync();
        }
        else
        {
            _lines.Add(new InboundLineModel());
            foreach (var costType in CostTypePresets.Where(x => x != "Other"))
            {
                _additionalCosts.Add(new AdditionalCostModel { CostType = costType });
            }

            await LoadLookupDataAsync();
        }
    }

    private async Task LoadLookupDataAsync()
    {
        _isLoading = true;
        _apiError = null;

        try
        {
            // Warm the supplier/item autocompletes are server-searched on demand; nothing to
            // preload here beyond validating the API is reachable.
            await MasterDataAdminClient.GetSuppliersAsync(null, 1, 1);
        }
        catch (ApiException ex)
        {
            _apiError = ex;
            ToastService.ShowError(BuildErrorMessage(ex));
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task LoadShipmentForEditAsync()
    {
        if (Id is not { } shipmentId)
        {
            return;
        }

        _isLoading = true;
        _apiError = null;

        try
        {
            var shipment = await ReceivingClient.GetShipmentByIdAsync(shipmentId);

            if (!string.Equals(shipment.Status, "Draft", StringComparison.OrdinalIgnoreCase))
            {
                ToastService.ShowError(
                    $"ISH-{shipment.Id} has status '{shipment.Status}' and can no longer be edited - " +
                    "receiving has already started against it.");
                NavigationManager.NavigateTo($"/warehouse/inbound/shipments/{shipment.Id}");
                return;
            }

            _referenceNumber = shipment.ReferenceNumber;
            _expectedDate = shipment.ExpectedDate?.ToDateTime(TimeOnly.MinValue);
            _invoiceNumber = shipment.InvoiceNumber;
            _invoiceDate = shipment.InvoiceDate?.ToDateTime(TimeOnly.MinValue);

            // The detail response carries the supplier's display name but not its Code
            // (needed by the Supplier autocomplete's ToStringFunc), so look the full
            // record up by searching on that name rather than round-tripping a
            // dedicated by-id endpoint that doesn't exist yet.
            _supplier = (await SearchSuppliersAsync(shipment.SupplierName))
                .FirstOrDefault(x => x.Id == shipment.SupplierId)
                ?? new AdminSupplierDto { Id = shipment.SupplierId, Name = shipment.SupplierName };

            _lines.Clear();
            foreach (var line in shipment.Lines)
            {
                _lines.Add(new InboundLineModel
                {
                    Item = new AdminItemDto
                    {
                        Id = line.ItemId,
                        InternalSKU = line.ItemSku,
                        Name = line.ItemName,
                        BaseUoM = line.BaseUoM,
                        RequiresLotTracking = line.RequiresLotTracking,
                        RequiresQC = line.RequiresQC,
                        ItemType = line.ItemType,
                        CostType = line.CostType
                    },
                    ExpectedQty = line.ExpectedQty,
                    UnitPrice = line.UnitPrice,
                    Currency = line.Currency ?? "EUR"
                });
            }

            if (_lines.Count == 0)
            {
                _lines.Add(new InboundLineModel());
            }

            _additionalCosts.Clear();
            foreach (var cost in shipment.AdditionalCosts)
            {
                _additionalCosts.Add(new AdditionalCostModel
                {
                    CostType = cost.CostType,
                    Amount = cost.Amount,
                    Currency = cost.Currency
                });
            }

            if (_additionalCosts.Count == 0)
            {
                foreach (var costType in CostTypePresets.Where(x => x != "Other"))
                {
                    _additionalCosts.Add(new AdditionalCostModel { CostType = costType });
                }
            }

            RefreshDuplicateCostTypeWarning();
        }
        catch (ApiException ex)
        {
            _apiError = ex;
            ToastService.ShowError(BuildErrorMessage(ex));
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task<IEnumerable<AdminSupplierDto>> SearchSuppliersAsync(string value)
    {
        try
        {
            var result = await MasterDataAdminClient.GetSuppliersAsync(value, 1, 20);
            return result.Items;
        }
        catch (ApiException)
        {
            return Array.Empty<AdminSupplierDto>();
        }
    }

    private async Task<IEnumerable<AdminItemDto>> SearchItemsAsync(string value)
    {
        try
        {
            var result = await MasterDataAdminClient.GetItemsAsync(value, null, "Active", 1, 20);
            return result.Items;
        }
        catch (ApiException)
        {
            return Array.Empty<AdminItemDto>();
        }
    }

    private static Task<IEnumerable<string>> SearchCostTypesAsync(string value)
    {
        IEnumerable<string> results = string.IsNullOrWhiteSpace(value)
            ? CostTypePresets
            : CostTypePresets
                .Where(x => x.Contains(value, StringComparison.OrdinalIgnoreCase))
                .Append(value.Trim())
                .Distinct(StringComparer.OrdinalIgnoreCase);

        return Task.FromResult(results);
    }

    private void OnLineItemChanged(InboundLineModel line, AdminItemDto? item)
    {
        line.Item = item;
        RefreshDuplicateCostTypeWarning();
    }

    private void AddLine() => _lines.Add(new InboundLineModel());

    private Task AddLineAsync()
    {
        AddLine();
        return Task.CompletedTask;
    }

    private void RemoveLine(InboundLineModel line)
    {
        if (_lines.Count == 1)
        {
            return;
        }

        _lines.Remove(line);
        RefreshDuplicateCostTypeWarning();
    }

    private void AddAdditionalCost() => _additionalCosts.Add(new AdditionalCostModel { CostType = "Other" });

    private void RemoveAdditionalCost(AdditionalCostModel cost)
    {
        _additionalCosts.Remove(cost);
        RefreshDuplicateCostTypeWarning();
    }

    private void RefreshDuplicateCostTypeWarning()
    {
        var serviceCostTypes = _lines
            .Where(x => x.Item?.IsService == true)
            .Select(x => NormalizeCostType(x.Item!.CostType))
            .ToHashSet(StringComparer.OrdinalIgnoreCase);

        var manualDuplicates = _additionalCosts
            .Where(x => x.Amount > 0m)
            .Select(x => NormalizeCostType(x.CostType))
            .Where(x => serviceCostTypes.Contains(x))
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .ToList();

        _duplicateCostTypeWarning = manualDuplicates.Count == 0
            ? null
            : $"A manual additional cost row shares a cost type ({string.Join(", ", manualDuplicates)}) with a Service line on this shipment - check this isn't double-counting the same invoice amount.";
    }

    private static string NormalizeCostType(string? value)
        => string.IsNullOrWhiteSpace(value) ? "Other" : value.Trim();

    // --- Live totals / landed-cost preview (mirrors ReceivingController.UpdateItemValuationForReceiptAsync) ---

    private IEnumerable<InboundLineModel> StockLines => _lines.Where(x => x.Item is null || !x.Item.IsService);
    private IEnumerable<InboundLineModel> ServiceLines => _lines.Where(x => x.Item?.IsService == true);

    private decimal TotalStockQty => StockLines.Sum(x => x.ExpectedQty);

    private decimal TotalInvoiceValue => _lines.Sum(x => x.ExpectedQty * (x.UnitPrice ?? 0m));

    private decimal TotalStockExpectedValue => StockLines.Sum(x => x.ExpectedQty * (x.UnitPrice ?? 0m));

    private decimal TotalAdditionalCostPool
        => _additionalCosts.Sum(x => x.Amount) + ServiceLines.Sum(x => x.ExpectedQty * (x.UnitPrice ?? 0m));

    private decimal TotalActualValue => TotalStockExpectedValue + TotalAdditionalCostPool;

    private decimal AverageInvoiceUnitPrice => TotalStockQty > 0m ? TotalStockExpectedValue / TotalStockQty : 0m;

    private decimal AverageActualUnitPrice => TotalStockQty > 0m ? TotalActualValue / TotalStockQty : 0m;

    private decimal ComputeActualUnitPrice(InboundLineModel line)
    {
        var unitPrice = line.UnitPrice ?? 0m;
        var totalPool = TotalAdditionalCostPool;
        var totalStockValue = TotalStockExpectedValue;

        if (totalPool <= 0m || totalStockValue <= 0m || line.ExpectedQty <= 0m)
        {
            return unitPrice;
        }

        var lineValue = line.ExpectedQty * unitPrice;
        var lineShare = totalPool * lineValue / totalStockValue;
        return unitPrice + (lineShare / line.ExpectedQty);
    }

    private static string FormatMoney(decimal value) => value.ToString("0.00", NumberCulture);

    private async Task SubmitAsync()
    {
        if (string.IsNullOrWhiteSpace(_referenceNumber))
        {
            ToastService.ShowError("Reference number is required.");
            return;
        }

        if (_supplier is null)
        {
            ToastService.ShowError("Supplier is required.");
            return;
        }

        var lines = BuildLineRequests();
        if (lines.Count == 0)
        {
            ToastService.ShowError("Add at least one valid line.");
            return;
        }

        var request = new CreateInboundShipmentRequestDto
        {
            ReferenceNumber = _referenceNumber.Trim(),
            SupplierId = _supplier.Id,
            Type = "PO",
            ExpectedDate = _expectedDate.HasValue ? DateOnly.FromDateTime(_expectedDate.Value.Date) : null,
            InvoiceNumber = string.IsNullOrWhiteSpace(_invoiceNumber) ? null : _invoiceNumber.Trim(),
            InvoiceDate = _invoiceDate.HasValue ? DateOnly.FromDateTime(_invoiceDate.Value.Date) : null,
            Lines = lines,
            AdditionalCosts = BuildAdditionalCostRequests()
        };

        _isSubmitting = true;
        _apiError = null;

        try
        {
            if (IsEditMode && Id is { } shipmentId)
            {
                var updated = await ReceivingClient.UpdateShipmentAsync(shipmentId, request);
                ToastService.ShowSuccess($"Inbound shipment ISH-{updated.Id} updated.");
                NavigationManager.NavigateTo($"/warehouse/inbound/shipments/{updated.Id}");
            }
            else
            {
                var created = await ReceivingClient.CreateShipmentAsync(request);
                ToastService.ShowSuccess($"Inbound shipment ISH-{created.Id} created.");
                NavigationManager.NavigateTo($"/warehouse/inbound/shipments/{created.Id}");
            }
        }
        catch (ApiException ex)
        {
            _apiError = ex;
            ToastService.ShowError(BuildErrorMessage(ex));
        }
        finally
        {
            _isSubmitting = false;
        }
    }

    private List<CreateInboundShipmentLineRequestDto> BuildLineRequests()
    {
        return _lines
            .Where(x => x.Item is not null && x.ExpectedQty > 0m)
            .Select(x => new CreateInboundShipmentLineRequestDto
            {
                ItemId = x.Item!.Id,
                ExpectedQty = x.ExpectedQty,
                UnitPrice = x.UnitPrice,
                Currency = string.IsNullOrWhiteSpace(x.Currency) ? null : x.Currency.Trim()
            })
            .ToList();
    }

    private List<CreateAdditionalCostRequestDto> BuildAdditionalCostRequests()
    {
        return _additionalCosts
            .Where(x => x.Amount > 0m)
            .Select(x => new CreateAdditionalCostRequestDto
            {
                CostType = string.IsNullOrWhiteSpace(x.CostType) ? "Other" : x.CostType.Trim(),
                Amount = x.Amount,
                Currency = string.IsNullOrWhiteSpace(x.Currency) ? null : x.Currency.Trim()
            })
            .ToList();
    }

    private void BackToList()
    {
        NavigationManager.NavigateTo(IsEditMode
            ? $"/warehouse/inbound/shipments/{Id}"
            : "/warehouse/inbound/shipments");
    }

    private void DismissError()
    {
        _apiError = null;
    }

    private static string BuildErrorMessage(ApiException ex)
    {
        if (!string.IsNullOrWhiteSpace(ex.UserMessage))
        {
            return ex.UserMessage;
        }

        return ex.ProblemDetails?.Detail
               ?? ex.ProblemDetails?.Title
               ?? "Inbound shipment request failed.";
    }

    private sealed class InboundLineModel
    {
        public AdminItemDto? Item { get; set; }
        public decimal ExpectedQty { get; set; } = 1m;
        public decimal? UnitPrice { get; set; }
        public string? Currency { get; set; } = "EUR";
    }

    private sealed class AdditionalCostModel
    {
        public string CostType { get; set; } = "Other";
        public decimal Amount { get; set; }
        public string? Currency { get; set; } = "EUR";
    }
}
