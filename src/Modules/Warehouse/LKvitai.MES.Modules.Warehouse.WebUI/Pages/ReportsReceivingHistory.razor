@page "/reports/receiving-history"
@inject ReportsClient ReportsClient
@inject IJSRuntime JavaScript
@inject ToastService ToastService

<PageTitle>Receiving History - LKvitai.MES</PageTitle>

<div data-testid="reports-receiving-history-page">
    <MudText Typo="Typo.h5" Class="mb-3">Receiving History Report</MudText>

    @if (_apiError is not null)
    {
        <ErrorBanner Message="@BuildErrorMessage(_apiError)"
                     TraceId="@_apiError.TraceId"
                     OnRetry="LoadAsync"
                     OnDismiss="@(() => _apiError = null)" />
    }

    <MudPaper Class="pa-4 mb-3">
        <MudGrid Spacing="2">
            <MudItem xs="12" md="2">
                <MudNumericField T="int?" Label="Supplier Id" @bind-Value="_supplierId" Variant="Variant.Outlined" Dense="true" />
            </MudItem>
            <MudItem xs="12" md="3">
                <MudSelect T="string" Label="Status" @bind-Value="_status" Variant="Variant.Outlined" Dense="true">
                    <MudSelectItem Value="@string.Empty">All</MudSelectItem>
                    <MudSelectItem Value="@("Draft")">Draft</MudSelectItem>
                    <MudSelectItem Value="@("Partial")">Partial</MudSelectItem>
                    <MudSelectItem Value="@("Complete")">Complete</MudSelectItem>
                </MudSelect>
            </MudItem>
            <MudItem xs="12" md="3">
                <MudDatePicker Label="Expected From" @bind-Date="_dateFrom" DateFormat="yyyy-MM-dd" Variant="Variant.Outlined" />
            </MudItem>
            <MudItem xs="12" md="3">
                <MudDatePicker Label="Expected To" @bind-Date="_dateTo" DateFormat="yyyy-MM-dd" Variant="Variant.Outlined" />
            </MudItem>
            <MudItem xs="12" md="1">
                <MudButton FullWidth="true" Variant="Variant.Filled" Color="Color.Primary" OnClick="ApplyFiltersAsync">Apply</MudButton>
            </MudItem>
            <MudItem xs="12" md="2">
                <MudButton FullWidth="true" Variant="Variant.Outlined" Color="Color.Default" OnClick="ExportCsvAsync">Export CSV</MudButton>
            </MudItem>
        </MudGrid>
    </MudPaper>

    <MudPaper Class="pa-4 position-relative">
        <LoadingSpinner IsLoading="@_isLoading" />

        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-2">
            <MudText Typo="Typo.subtitle2">Total: @_totalCount</MudText>
            <MudText Typo="Typo.caption" Class="mud-secondary-text">Page @_pageNumber of @TotalPages</MudText>
        </MudStack>

        <MudDataGrid T="ReceivingHistoryRowDto"
                     Items="_items"
                     Dense="true"
                     Hover="true"
                     Loading="@_isLoading"
                     SortMode="SortMode.None"
                     Filterable="false"
                     @attributes="ReceivingHistoryGridAttributes">
            <NoRecordsContent>
                <MudText Typo="Typo.body2" Class="mud-secondary-text">No rows found.</MudText>
            </NoRecordsContent>
            <Columns>
                <PropertyColumn Property="x => x.Id" Title="Shipment Id" />
                <PropertyColumn Property="x => x.ReferenceNumber" Title="Reference" />
                <PropertyColumn Property="x => x.SupplierName" Title="Supplier" />
                <TemplateColumn Title="Expected">
                    <CellTemplate>
                        @context.Item.ExpectedDate?.ToString("yyyy-MM-dd")
                    </CellTemplate>
                </TemplateColumn>
                <PropertyColumn Property="x => x.Status" Title="Status" />
                <PropertyColumn Property="x => x.TotalExpectedQty" Title="Expected Qty" />
                <PropertyColumn Property="x => x.TotalReceivedQty" Title="Received Qty" />
            </Columns>
        </MudDataGrid>

        @if (_totalCount > 0)
        {
            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.FlexEnd" Class="mt-3">
                <MudSelect T="int"
                           Label="Page size"
                           Value="_pageSize"
                           ValueChanged="OnPageSizeChangedAsync"
                           Variant="Variant.Outlined"
                           Dense="true"
                           Style="width: 120px;">
                    <MudSelectItem Value="25">25</MudSelectItem>
                    <MudSelectItem Value="50">50</MudSelectItem>
                    <MudSelectItem Value="100">100</MudSelectItem>
                </MudSelect>
                <MudPagination Count="@TotalPages"
                               Selected="@_pageNumber"
                               SelectedChanged="OnPageChangedAsync"
                               Variant="Variant.Outlined"
                               Color="Color.Primary"
                               Size="Size.Small"
                               Class="ml-2" />
            </MudStack>
        }
    </MudPaper>
</div>

@code {
    private readonly List<ReceivingHistoryRowDto> _items = [];
    private ApiException? _apiError;
    private bool _isLoading;
    private int _pageNumber = 1;
    private int _pageSize = 50;
    private int _totalCount;

    private int? _supplierId;
    private string _status = string.Empty;
    private DateTime? _dateFrom;
    private DateTime? _dateTo;

    private static readonly Dictionary<string, object> ReceivingHistoryGridAttributes =
        new() { ["data-testid"] = "reports-receiving-history-grid" };

    private int TotalPages => Math.Max(1, (int)Math.Ceiling(_totalCount / (double)Math.Max(1, _pageSize)));

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task ApplyFiltersAsync()
    {
        _pageNumber = 1;
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _isLoading = true;
        _apiError = null;

        try
        {
            var dateFrom = ParseDate(_dateFrom);
            var dateTo = ParseDate(_dateTo);

            var response = await ReportsClient.GetReceivingHistoryAsync(
                _supplierId,
                string.IsNullOrWhiteSpace(_status) ? null : _status,
                dateFrom,
                dateTo,
                _pageNumber,
                _pageSize);

            _items.Clear();
            _items.AddRange(response.Items);
            _totalCount = response.TotalCount;
        }
        catch (ApiException ex)
        {
            _apiError = ex;
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task OnPageChangedAsync(int page)
    {
        _pageNumber = Math.Max(1, page);
        await LoadAsync();
    }

    private async Task OnPageSizeChangedAsync(int size)
    {
        _pageSize = Math.Clamp(size, 1, 1000);
        _pageNumber = 1;
        await LoadAsync();
    }

    private async Task ExportCsvAsync()
    {
        try
        {
            var bytes = await ReportsClient.DownloadReceivingHistoryCsvAsync(
                _supplierId,
                string.IsNullOrWhiteSpace(_status) ? null : _status,
                ParseDate(_dateFrom),
                ParseDate(_dateTo));

            await JavaScript.InvokeVoidAsync(
                "csvExport.downloadBytes",
                "receiving-history-report.csv",
                "text/csv",
                Convert.ToBase64String(bytes));
        }
        catch (ApiException ex)
        {
            _apiError = ex;
            ToastService.ShowError(BuildErrorMessage(ex));
        }
    }

    private static DateOnly? ParseDate(DateTime? value)
    {
        return value.HasValue
            ? DateOnly.FromDateTime(value.Value.Date)
            : null;
    }

    private static string BuildErrorMessage(ApiException error)
    {
        if (!string.IsNullOrWhiteSpace(error.ProblemDetails?.Detail))
        {
            return $"{error.UserMessage} {error.ProblemDetails.Detail}";
        }

        return error.UserMessage;
    }
}
