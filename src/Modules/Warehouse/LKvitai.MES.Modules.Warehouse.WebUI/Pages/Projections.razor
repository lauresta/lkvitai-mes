@page "/projections"
@inject ProjectionsClient ProjectionsClient
@inject ToastService ToastService
@inject IJSRuntime JavaScript
@using System.Diagnostics

<PageTitle>Projections - LKvitai.MES</PageTitle>

<div data-testid="projections-page">
    <MudText Typo="Typo.h5" Class="mb-3">Projections</MudText>

    @if (_apiError is not null)
    {
        <div data-testid="projections-error" class="mb-3">
            <ErrorBanner Message="@BuildErrorMessage(_apiError)"
                         TraceId="@_apiError.TraceId"
                         OnRetry="RetryAsync"
                         OnDismiss="DismissError" />
        </div>

        <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined" Dense="true" Class="mb-3">
            <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                <MudText Typo="Typo.body2">@BuildFriendlyHint(_apiError, _lastFailedOperation)</MudText>
                <MudButton Variant="Variant.Text" Size="Size.Small" OnClick="CopyErrorAsync">Copy Error</MudButton>
            </MudStack>
        </MudAlert>
    }

    <MudPaper Class="pa-4 mb-3" data-testid="projections-lag-grid">
        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-3">
            <MudText Typo="Typo.h6">Projection Lag</MudText>
            <MudButton Variant="Variant.Outlined" Size="Size.Small" OnClick="RefreshLagFromToolbarAsync">Refresh</MudButton>
        </MudStack>

        @if (_projectionLag.Count == 0)
        {
            <MudText Typo="Typo.body2" Color="Color.Secondary">No projection lag data available.</MudText>
        }
        else
        {
            <MudTable T="ProjectionLagStatusDto" Items="_projectionLag" Dense="true" Hover="true">
                <HeaderContent>
                    <MudTh>Projection</MudTh>
                    <MudTh>Status</MudTh>
                    <MudTh>Lag (s)</MudTh>
                    <MudTh>Lag (events)</MudTh>
                    <MudTh>Last Updated</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Projection">@context.ProjectionName</MudTd>
                    <MudTd DataLabel="Status">@context.Status</MudTd>
                    <MudTd DataLabel="Lag (s)">@(context.LagSeconds?.ToString("0.##") ?? "-")</MudTd>
                    <MudTd DataLabel="Lag (events)">@(context.LagEvents?.ToString() ?? "-")</MudTd>
                    <MudTd DataLabel="Last Updated">
                        @if (context.LastUpdated.HasValue)
                        {
                            @context.LastUpdated.Value.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss")
                            <span class="ml-2"><StaleBadge LagSeconds="@context.LagSeconds" LastUpdated="@context.LastUpdated.Value.UtcDateTime" /></span>
                        }
                        else
                        {
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Unknown</MudText>
                        }
                    </MudTd>
                </RowTemplate>
            </MudTable>
        }
    </MudPaper>

    <MudPaper Class="pa-4 mb-3" data-testid="projections-form">
        <MudText Typo="Typo.h6" Class="mb-2">Rebuild / Verify</MudText>

        <MudSelect T="string"
                   Label="Projection"
                   Value="@_selectedProjection"
                   ValueChanged="OnProjectionChanged"
                   Variant="Variant.Outlined"
                   Dense="true"
                   Class="mb-3">
            @foreach (var projection in _projections)
            {
                <MudSelectItem T="string" Value="@projection">@projection</MudSelectItem>
            }
        </MudSelect>

        <MudStack Row="true" Spacing="1" Class="mb-3">
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="OpenRebuildConfirmation" Disabled="@_isBusy">
                Rebuild
            </MudButton>
            <MudButton Variant="Variant.Outlined" Color="Color.Primary" OnClick="VerifyAsync" Disabled="@_isBusy">
                Verify
            </MudButton>
        </MudStack>

        @if (_rebuildResult is not null)
        {
            var success = _rebuildResult.ChecksumMatch && _rebuildResult.Swapped;
            <MudAlert Severity="@(success ? Severity.Success : Severity.Error)" Variant="Variant.Outlined" Dense="true" Class="mb-3">
                <MudText Typo="Typo.subtitle2">Rebuild Result</MudText>
                <MudText Typo="Typo.body2">Projection: @_rebuildResult.ProjectionName</MudText>
                <MudText Typo="Typo.body2">Events Processed: @_rebuildResult.EventsProcessed</MudText>
                <MudText Typo="Typo.body2">Checksum Match: @_rebuildResult.ChecksumMatch</MudText>
                <MudText Typo="Typo.body2">Swapped: @_rebuildResult.Swapped</MudText>
                <MudText Typo="Typo.body2">Duration: @_rebuildResult.Duration</MudText>
            </MudAlert>
        }

        @if (_verifyResult is not null)
        {
            <MudAlert Severity="@(_verifyResult.ChecksumMatch ? Severity.Success : Severity.Error)" Variant="Variant.Outlined" Dense="true">
                <strong>Verify:</strong> ChecksumMatch=@_verifyResult.ChecksumMatch,
                ProductionRows=@_verifyResult.ProductionRowCount,
                ShadowRows=@_verifyResult.ShadowRowCount
            </MudAlert>
        }
    </MudPaper>

    <MudPaper Class="pa-4">
        <MudText Typo="Typo.h6" Class="mb-2">Runbook</MudText>
        <MudText Typo="Typo.body2" Class="mb-2">Use this quick checklist before and after projection rebuilds.</MudText>
        <ol class="mb-2">
            <li>Check lag table above and confirm projection status.</li>
            <li>Run `Verify` first; use `Rebuild` only when mismatch or corruption is confirmed.</li>
            <li>After rebuild, verify `ChecksumMatch=true` and lag returns to healthy.</li>
            <li>Capture traceId for failed operations and share with support.</li>
        </ol>
        <MudLink Href="docs/master-data/master-data-06-ops-runbook-projections.md" Target="_blank" Rel="noopener noreferrer">
            Open Projection Runbook
        </MudLink>
    </MudPaper>
</div>

<ConfirmDialog Title="Rebuild projection?"
               Message="Are you sure? This will rebuild the projection from scratch."
               ConfirmText="Rebuild"
               IsVisible="@_showRebuildConfirm"
               OnConfirm="ConfirmRebuildAsync"
               OnCancel="CancelRebuildConfirm" />

@code {
    private static readonly string[] _projections =
    [
        "LocationBalance",
        "AvailableStock",
        "OutboundOrderSummary",
        "ShipmentSummary",
        "DispatchHistory",
        "OnHandValue",
        "InboundShipmentSummary"
    ];

    private string _selectedProjection = "LocationBalance";
    private bool _isBusy;
    private bool _showRebuildConfirm;
    private ApiException? _apiError;
    private FailedOperation _lastFailedOperation = FailedOperation.RefreshLag;
    private RebuildResultDto? _rebuildResult;
    private VerifyResultDto? _verifyResult;
    private List<ProjectionLagStatusDto> _projectionLag = [];

    protected override async Task OnInitializedAsync()
    {
        await RefreshLagAsync(clearErrorOnSuccess: true);
    }

    private Task OnProjectionChanged(string projection)
    {
        _selectedProjection = string.IsNullOrWhiteSpace(projection) ? "LocationBalance" : projection;
        return Task.CompletedTask;
    }

    private void OpenRebuildConfirmation()
    {
        _showRebuildConfirm = true;
    }

    private void CancelRebuildConfirm()
    {
        _showRebuildConfirm = false;
    }

    private async Task ConfirmRebuildAsync()
    {
        _showRebuildConfirm = false;
        _isBusy = true;
        _apiError = null;

        try
        {
            _rebuildResult = await ProjectionsClient.RebuildAsync(_selectedProjection);
            _verifyResult = null;

            if (_rebuildResult.ChecksumMatch && _rebuildResult.Swapped)
            {
                ToastService.ShowSuccess($"Rebuild completed for {_selectedProjection}.");
            }
            else
            {
                ToastService.ShowWarning($"Rebuild finished with mismatch for {_selectedProjection}.");
            }
        }
        catch (ApiException ex)
        {
            _apiError = ex;
            _lastFailedOperation = FailedOperation.Rebuild;
            ToastService.ShowError(BuildErrorMessage(ex));
        }
        catch (Exception ex)
        {
            _apiError = new ApiException(
                new ProblemDetailsModel
                {
                    Title = "Projection rebuild failed",
                    Detail = ex.Message,
                    Status = 500,
                    TraceId = Activity.Current?.Id
                },
                500);
            _lastFailedOperation = FailedOperation.Rebuild;
            ToastService.ShowError(_apiError.UserMessage);
        }
        finally
        {
            _isBusy = false;
            await RefreshLagAsync();
        }
    }

    private async Task VerifyAsync()
    {
        _isBusy = true;
        _apiError = null;

        try
        {
            _verifyResult = await ProjectionsClient.VerifyAsync(_selectedProjection);
            if (_verifyResult.ChecksumMatch)
            {
                ToastService.ShowSuccess($"Verify succeeded for {_selectedProjection}.");
            }
            else
            {
                ToastService.ShowWarning($"Verify mismatch for {_selectedProjection}.");
            }
        }
        catch (ApiException ex)
        {
            _apiError = ex;
            _lastFailedOperation = FailedOperation.Verify;
            ToastService.ShowError(BuildErrorMessage(ex));
        }
        catch (Exception ex)
        {
            _apiError = new ApiException(
                new ProblemDetailsModel
                {
                    Title = "Projection verify failed",
                    Detail = ex.Message,
                    Status = 500,
                    TraceId = Activity.Current?.Id
                },
                500);
            _lastFailedOperation = FailedOperation.Verify;
            ToastService.ShowError(_apiError.UserMessage);
        }
        finally
        {
            _isBusy = false;
            await RefreshLagAsync();
        }
    }

    private async Task RefreshLagFromToolbarAsync()
    {
        await RefreshLagAsync(clearErrorOnSuccess: true);
    }

    private async Task RefreshLagAsync(bool clearErrorOnSuccess = false)
    {
        try
        {
            var rows = await ProjectionsClient.GetProjectionLagAsync();
            _projectionLag = rows.ToList();

            if (clearErrorOnSuccess && _lastFailedOperation == FailedOperation.RefreshLag)
            {
                _apiError = null;
            }
        }
        catch (ApiException ex)
        {
            _apiError = ex;
            _lastFailedOperation = FailedOperation.RefreshLag;
        }
    }

    private async Task RetryAsync()
    {
        switch (_lastFailedOperation)
        {
            case FailedOperation.Rebuild:
                await ConfirmRebuildAsync();
                return;
            case FailedOperation.Verify:
                await VerifyAsync();
                return;
            default:
                await RefreshLagAsync(clearErrorOnSuccess: true);
                return;
        }
    }

    private async Task CopyErrorAsync()
    {
        if (_apiError is null)
        {
            return;
        }

        var payload = $"traceId={_apiError.TraceId}; message={BuildErrorMessage(_apiError)}";
        await JavaScript.InvokeVoidAsync("navigator.clipboard.writeText", payload);
        ToastService.ShowSuccess("Error details copied.");
    }

    private void DismissError() => _apiError = null;

    private static string BuildFriendlyHint(ApiException error, FailedOperation operation)
    {
        if (operation == FailedOperation.RefreshLag)
        {
            return "Projection lag status could not be refreshed. Retry and check health endpoint availability.";
        }

        var text = BuildErrorMessage(error);
        if (text.Contains("not implemented", StringComparison.OrdinalIgnoreCase) ||
            text.Contains("not supported", StringComparison.OrdinalIgnoreCase))
        {
            return "Selected projection is not supported for rebuild. Choose one of the supported projections in the selector.";
        }

        if (text.Contains("42P01", StringComparison.OrdinalIgnoreCase) ||
            text.Contains("schema", StringComparison.OrdinalIgnoreCase) ||
            text.Contains("shadow", StringComparison.OrdinalIgnoreCase))
        {
            return "Projection rebuild failed due to database schema mismatch. Run shadow cleanup and schema validation, then retry.";
        }

        return "Projection operation failed. Use the runbook below and copy the error details for investigation.";
    }

    private static string BuildErrorMessage(ApiException error)
    {
        if (error.ProblemDetails?.Errors is { Count: > 0 } fieldErrors)
        {
            var flattened = fieldErrors
                .SelectMany(entry => entry.Value.Select(message => $"{entry.Key}: {message}"));
            var details = string.Join("; ", flattened);
            return string.IsNullOrWhiteSpace(details) ? error.UserMessage : $"{error.UserMessage} {details}";
        }

        if (!string.IsNullOrWhiteSpace(error.ProblemDetails?.Detail))
        {
            return $"{error.UserMessage} {error.ProblemDetails.Detail}";
        }

        return error.UserMessage;
    }

    private enum FailedOperation
    {
        RefreshLag,
        Rebuild,
        Verify
    }
}
