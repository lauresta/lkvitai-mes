@page "/reports/dispatch-history"
@inject ReportsClient ReportsClient
@inject IJSRuntime JavaScript
@inject ToastService ToastService

<PageTitle>Dispatch History - LKvitai.MES</PageTitle>

<div data-testid="reports-dispatch-history-page">
    <MudText Typo="Typo.h5" Class="mb-3">Dispatch History Report</MudText>

    @if (_apiError is not null)
    {
        <div data-testid="reports-dispatch-history-error">
            <ErrorBanner Message="@BuildErrorMessage(_apiError)"
                         TraceId="@_apiError.TraceId"
                         OnRetry="LoadAsync"
                         OnDismiss="DismissError" />
        </div>
    }

    <MudPaper Class="pa-4 mb-3">
        <MudGrid Spacing="2" AlignItems="AlignItems.End">
            <MudItem xs="12" md="2">
                <MudDatePicker Label="Date From"
                               @bind-Date="_from"
                               DateFormat="yyyy-MM-dd"
                               Variant="Variant.Outlined"
                               Dense="true" />
            </MudItem>
            <MudItem xs="12" md="2">
                <MudDatePicker Label="Date To"
                               @bind-Date="_to"
                               DateFormat="yyyy-MM-dd"
                               Variant="Variant.Outlined"
                               Dense="true" />
            </MudItem>
            <MudItem xs="12" md="3">
                <MudTextField T="string"
                              Label="Carrier"
                              Placeholder="FedEx"
                              @bind-Value="_carrier"
                              Variant="Variant.Outlined"
                              Dense="true" />
            </MudItem>
            <MudItem xs="12" md="5">
                <MudStack Row="true" Spacing="1">
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               Disabled="@_isLoading"
                               OnClick="ApplyFiltersAsync"
                               @attributes="ApplyButtonAttributes">
                        Apply
                    </MudButton>
                    <MudButton Variant="Variant.Outlined"
                               Color="Color.Default"
                               Disabled="@_isLoading"
                               OnClick="ResetFiltersAsync"
                               @attributes="ResetButtonAttributes">
                        Reset
                    </MudButton>
                    <MudButton Variant="Variant.Outlined"
                               Color="Color.Default"
                               Disabled="@_isLoading"
                               OnClick="LoadAsync"
                               @attributes="RefreshButtonAttributes">
                        Refresh
                    </MudButton>
                    <MudSpacer />
                    <MudButton Variant="Variant.Outlined"
                               Color="Color.Success"
                               Disabled="@_isLoading"
                               OnClick="ExportCsvAsync"
                               @attributes="ExportButtonAttributes">
                        Export CSV
                    </MudButton>
                </MudStack>
            </MudItem>
        </MudGrid>
    </MudPaper>

    @if (_summary is not null)
    {
        <MudGrid Spacing="2" Class="mb-3" data-testid="reports-dispatch-history-summary">
            <MudItem xs="12" md="4">
                <MudPaper Class="pa-4 h-100" Outlined="true">
                    <MudText Typo="Typo.caption" Class="mud-secondary-text">Total Shipments</MudText>
                    <MudText Typo="Typo.h4">@_summary.TotalShipments</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" md="4">
                <MudPaper Class="pa-4 h-100" Outlined="true">
                    <MudText Typo="Typo.caption" Class="mud-secondary-text">Total Orders</MudText>
                    <MudText Typo="Typo.h4">@_summary.TotalOrders</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" md="4">
                <MudPaper Class="pa-4 h-100" Outlined="true">
                    <MudText Typo="Typo.caption" Class="mud-secondary-text">On-Time Delivery</MudText>
                    <MudText Typo="Typo.h4">@_summary.OnTimeDeliveryPercent.ToString("0.0")%</MudText>
                </MudPaper>
            </MudItem>
        </MudGrid>
    }

    <MudPaper Class="pa-4 position-relative">
         (@_isLoading)
        {
            <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-3" />
        }

        <MudDataGrid T="DispatchHistoryReportRowDto"
                     Items="_rows"
                     Dense="true"
                     Hover="true"
                     Loading="@_isLoading"
                     SortMode="SortMode.None"
                     Filterable="false"
                     @attributes="DispatchHistoryGridAttributes">
            <NoRecordsContent>
                <MudText Typo="Typo.body2" Class="mud-secondary-text">No dispatch history rows found.</MudText>
            </NoRecordsContent>
            <Columns>
                <PropertyColumn Property="x => x.ShipmentNumber" Title="Shipment" />
                <PropertyColumn Property="x => x.OrderNumber" Title="Order" />
                <TemplateColumn Title="Customer">
                    <CellTemplate>
                        @(context.Item.CustomerName ?? "-")
                    </CellTemplate>
                </TemplateColumn>
                <PropertyColumn Property="x => x.Carrier" Title="Carrier" />
                <TemplateColumn Title="Tracking">
                    <CellTemplate>
                        @(context.Item.TrackingNumber ?? "-")
                    </CellTemplate>
                </TemplateColumn>
                <TemplateColumn Title="Dispatch Date">
                    <CellTemplate>
                        @context.Item.DispatchDate.ToLocalTime().ToString("yyyy-MM-dd HH:mm")
                    </CellTemplate>
                </TemplateColumn>
                <TemplateColumn Title="Delivery Date">
                    <CellTemplate>
                        @(context.Item.DeliveryDate?.ToLocalTime().ToString("yyyy-MM-dd HH:mm") ?? "-")
                    </CellTemplate>
                </TemplateColumn>
                <TemplateColumn Title="Status">
                    <CellTemplate>
                        <MudChip T="string"
                                 Size="Size.Small"
                                 Variant="Variant.Filled"
                                 Color="@GetStatusColor(context.Item.Status)">
                            @context.Item.Status
                        </MudChip>
                    </CellTemplate>
                </TemplateColumn>
            </Columns>
        </MudDataGrid>

        @if (_totalCount > 0)
        {
            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.FlexEnd" Class="mt-3" data-testid="reports-dispatch-history-pager">
                <MudSelect T="int"
                           Label="Page size"
                           Value="_pageSize"
                           ValueChanged="OnPageSizeChangedAsync"
                           Variant="Variant.Outlined"
                           Dense="true"
                           Style="width: 120px;"
                           @attributes="PageSizeAttributes">
                    <MudSelectItem Value="25">25</MudSelectItem>
                    <MudSelectItem Value="50">50</MudSelectItem>
                    <MudSelectItem Value="100">100</MudSelectItem>
                </MudSelect>
                <MudPagination Count="@TotalPages"
                               Selected="@_page"
                               SelectedChanged="OnPageChangedAsync"
                               Variant="Variant.Outlined"
                               Color="Color.Primary"
                               Size="Size.Small"
                               Class="ml-2" />
            </MudStack>
        }
    </MudPaper>
</div>

@code {
    private readonly List<DispatchHistoryReportRowDto> _rows = [];
    private DispatchHistorySummaryDto? _summary;
    private ApiException? _apiError;
    private bool _isLoading;

    private DateTime? _from;
    private DateTime? _to;
    private string _carrier = string.Empty;
    private int _page = 1;
    private int _pageSize = 50;
    private int _totalCount;

    private static readonly Dictionary<string, object> DispatchHistoryGridAttributes = new()
    {
        ["data-testid"] = "reports-dispatch-history-grid"
    };

    private static readonly Dictionary<string, object> ApplyButtonAttributes = new()
    {
        ["data-testid"] = "reports-dispatch-history-apply"
    };

    private static readonly Dictionary<string, object> ResetButtonAttributes = new()
    {
        ["data-testid"] = "reports-dispatch-history-reset"
    };

    private static readonly Dictionary<string, object> RefreshButtonAttributes = new()
    {
        ["data-testid"] = "reports-dispatch-history-refresh"
    };

    private static readonly Dictionary<string, object> ExportButtonAttributes = new()
    {
        ["data-testid"] = "reports-dispatch-history-export"
    };

    private static readonly Dictionary<string, object> PageSizeAttributes = new()
    {
        ["data-testid"] = "reports-dispatch-history-page-size"
    };

    private int TotalPages => Math.Max(1, (int)Math.Ceiling(_totalCount / (double)Math.Max(1, _pageSize)));

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task ApplyFiltersAsync()
    {
        _page = 1;
        await LoadAsync();
    }

    private async Task ResetFiltersAsync()
    {
        _from = null;
        _to = null;
        _carrier = string.Empty;
        _page = 1;
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _isLoading = true;
        _apiError = null;

        try
        {
            var result = await ReportsClient.GetDispatchHistoryAsync(
                ParseDate(_from),
                ParseDate(_to),
                string.IsNullOrWhiteSpace(_carrier) ? null : _carrier,
                _page,
                _pageSize);

            _rows.Clear();
            _rows.AddRange(result.Shipments);
            _summary = result.Summary;
            _totalCount = result.TotalCount;
        }
        catch (ApiException ex)
        {
            _apiError = ex;
            ToastService.ShowError(BuildErrorMessage(ex));
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task ExportCsvAsync()
    {
        try
        {
            var bytes = await ReportsClient.DownloadDispatchHistoryCsvAsync(
                ParseDate(_from),
                ParseDate(_to),
                string.IsNullOrWhiteSpace(_carrier) ? null : _carrier);

            await JavaScript.InvokeVoidAsync(
                "csvExport.downloadBytes",
                $"dispatch-history-{DateTime.UtcNow:yyyyMMdd}.csv",
                "text/csv",
                Convert.ToBase64String(bytes));
        }
        catch (ApiException ex)
        {
            _apiError = ex;
            ToastService.ShowError(BuildErrorMessage(ex));
        }
    }

    private async Task OnPageChangedAsync(int page)
    {
        _page = Math.Max(1, page);
        await LoadAsync();
    }

    private async Task OnPageSizeChangedAsync(int size)
    {
        _pageSize = Math.Clamp(size, 1, 500);
        _page = 1;
        await LoadAsync();
    }

    private static DateOnly? ParseDate(DateTime? value)
    {
        return value.HasValue ? DateOnly.FromDateTime(value.Value.Date) : null;
    }

    private static Color GetStatusColor(string status)
    {
        return status.ToUpperInvariant() switch
        {
            "DISPATCHED" => Color.Primary,
            "DELIVERED" => Color.Success,
            _ => Color.Default
        };
    }

    private void DismissError()
    {
        _apiError = null;
    }

    private static string BuildErrorMessage(ApiException ex)
    {
        if (!string.IsNullOrWhiteSpace(ex.UserMessage))
        {
            return ex.UserMessage;
        }

        return ex.ProblemDetails?.Detail
               ?? ex.ProblemDetails?.Title
               ?? "Dispatch history request failed.";
    }
}
