@page "/orders/{Number}"
@inject SalesApiClient Api
@inject PersistentComponentState ApplicationState
@implements IDisposable

<PageTitle>@Number &middot; Sales</PageTitle>

<main class="main">

    @* ── Page head ─────────────────────────────────────────────── *@
    <div class="page-head">
        <div>
            <div class="eyebrow mono">Sales &middot; Orders</div>
            <h1>Order details</h1>
        </div>
        <div class="page-actions">
            <a class="btn btn--ghost" href="./">&#8592; Back to orders</a>
        </div>
    </div>

    @if (_loadFailed)
    {
        <section class="panel" role="alert">
            <div class="panel__head" style="background:var(--danger-bg);color:var(--danger-fg)">
                <div>
                    <strong>Sales API unreachable.</strong>
                    <span>Could not load <span class="mono">@Number</span>.</span>
                </div>
                <button class="btn btn--ghost" type="button" @onclick="ReloadAsync">Retry</button>
            </div>
        </section>
    }
    else if (_order is null && _loadCompleted)
    {
        <section class="panel">
            <div class="panel__head">
                <div>
                    <strong>Order not found.</strong>
                    <span>No order matches <span class="mono">@Number</span>.</span>
                </div>
                <a class="btn btn--ghost" href="./">Back to orders</a>
            </div>
        </section>
    }
    else if (_order is not null)
    {
        var o = _order;

        <section class="panel details" aria-labelledby="details-title">
            <nav class="details__breadcrumb" aria-label="Breadcrumb">
                <a href="./">Home</a><span>/</span>
                <a href="./">Orders</a><span>/</span>
                <strong>@o.Number</strong>
            </nav>
            <header class="details__title">
                <div>
                    <span class="details__id mono">@o.Number</span>
                    <h2 id="details-title">@o.Customer</h2>
                    <div class="details__sub">
                        <span><b>Date:</b> @OrderFormat.Date(o.Date)</span>
                        <span><b>Address:</b> @o.Address</span>
                        <span><b>Store:</b> @o.Store</span>
                        <span><b>Status:</b> <span class="chip @OrderFormat.StatusChip(o.StatusCode) chip--sm">@o.Status</span></span>
                    </div>
                    @if (o.Operator is not null)
                    {
                        <div class="details__op">Operator: @o.Operator.Name &middot; @OrderFormat.DateTime(o.Operator.At)</div>
                    }
                </div>
                <div class="details__title__actions">
                    <button class="btn btn--ghost" type="button">Print</button>
                    <button class="btn" type="button">Email customer</button>
                    <button class="btn btn--primary" type="button">Open in PoS</button>
                </div>
            </header>

            @* Items *@
            <div class="details__section">
                <div class="section-label">
                    Items
                    <span class="section-label__count">@o.ItemGroups.Count products &middot; @o.ItemGroups.Sum(g => g.Lines.Count) line items</span>
                </div>
                <div class="table-wrap is-mobile-hidden">
                    <table class="lk-table">
                        <thead>
                            <tr>
                                <th style="width:24px">#</th>
                                <th>Item</th>
                                <th>Side</th>
                                <th>Color</th>
                                <th class="is-num">Width</th>
                                <th class="is-num">Height</th>
                                <th>Notes</th>
                                <th class="is-num">Q-ty</th>
                                <th class="is-num">Price</th>
                                <th class="is-num">Amount</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var grp in o.ItemGroups)
                            {
                                <tr class="group-row"><td colspan="10">@grp.Label</td></tr>
                                @foreach (var line in grp.Lines)
                                {
                                    <tr class="@(line.IsAccessory ? "acc-row" : "")">
                                        <td class="mono">@line.Num</td>
                                        <td>@(line.IsAccessory ? "↳ " + line.Name : line.Name)</td>
                                        <td>@line.Side</td>
                                        <td>@line.Color</td>
                                        <td class="is-num mono">@OrderFormat.Dimension(line.Width)</td>
                                        <td class="is-num mono">@OrderFormat.Dimension(line.Height)</td>
                                        <td>@line.Notes</td>
                                        <td class="is-money">@OrderFormat.Quantity(line.Qty)</td>
                                        <td class="is-money">@OrderFormat.Money(line.Price)</td>
                                        <td class="is-money">@OrderFormat.Money(line.Amount)</td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
                <div class="mobile-cards">
                    @foreach (var grp in o.ItemGroups)
                    {
                        @foreach (var line in grp.Lines.Where(l => !l.IsAccessory))
                        {
                            <article class="mobile-card">
                                <div class="mobile-card__top">
                                    <span class="mobile-card__id">@line.Num. @line.Name</span>
                                    <span class="chip chip--entered chip--sm">x@OrderFormat.Quantity(line.Qty)</span>
                                </div>
                                <div class="mobile-card__meta">
                                    <span>@line.Side &middot; @line.Color</span>
                                    <span>@OrderFormat.Dimension(line.Width) &times; @OrderFormat.Dimension(line.Height)</span>
                                    <span>Amount <b>@OrderFormat.Money(line.Amount)</b></span>
                                </div>
                            </article>
                        }
                    }
                </div>
            </div>

            @* Amounts *@
            <div class="details__section">
                <div class="section-label">Amounts <span class="section-label__count">all values incl. VAT</span></div>
                <div class="amounts">
                    @foreach (var card in o.Amounts)
                    {
                        <div class="amount-card @OrderFormat.AmountModifier(card.Kind)">
                            <span class="amount-card__label">@card.Label</span>
                            <span class="amount-card__value">@OrderFormat.AmountValue(card)</span>
                        </div>
                    }
                </div>
            </div>

            @* Employees *@
            <div class="details__section">
                <div class="section-label">Employees <span class="section-label__count">@o.Employees.Count assignments</span></div>
                <div class="table-wrap is-mobile-hidden">
                    <table class="lk-table">
                        <thead>
                            <tr>
                                <th>Duty</th>
                                <th>Employee</th>
                                <th>Service date</th>
                                <th>Acquaintance date</th>
                                <th class="is-num">Order q-ty</th>
                                <th class="is-num">Item q-ty</th>
                                <th class="is-num">Amount</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var e in o.Employees)
                            {
                                <tr>
                                    <td><span class="duty @OrderFormat.DutyClass(e.DutyCode)">@e.DutyLabel</span></td>
                                    <td><div class="emp-name"><span class="emp-avatar">@e.Initials</span>@e.Name</div></td>
                                    <td class="mono">@OrderFormat.Date(e.ServiceDate)</td>
                                    <td class="mono">@OrderFormat.Date(e.AcquaintanceDate)</td>
                                    <td class="is-num mono">@OrderFormat.Integer(e.OrderQty)</td>
                                    <td class="is-num mono">@OrderFormat.Integer(e.ItemQty)</td>
                                    <td class="is-money">@OrderFormat.Money(e.Amount)</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </section>
    }

</main>

@code {
    [Parameter] public string Number { get; set; } = "";

    private OrderDetailsDto? _order;
    private bool             _loadFailed;
    private bool             _loadCompleted;
    private string?          _hydratedFromNumber;
    private PersistingComponentStateSubscription _persistingSub;

    private string PersistKey => $"sales.order.details.{Number}";

    protected override void OnInitialized()
    {
        // Persist the just-fetched details so the interactive (post-hydration)
        // pass can rehydrate without a second HTTP roundtrip — kills the
        // brief "blank → re-render" flash users see when entering the page.
        _persistingSub = ApplicationState.RegisterOnPersisting(() =>
        {
            if (_order is not null)
            {
                ApplicationState.PersistAsJson(PersistKey, _order);
            }
            return Task.CompletedTask;
        });
    }

    protected override async Task OnParametersSetAsync()
    {
        // Skip the second fetch if the prerender side persisted us a payload
        // for this exact order number. Tracked by _hydratedFromNumber so we
        // still refetch when the user navigates to a different /orders/{Number}.
        //
        // try/catch ensures a malformed/incompatible persist payload never
        // kills the circuit (filters and buttons would silently stop working).
        try
        {
            if (_hydratedFromNumber != Number &&
                ApplicationState.TryTakeFromJson<OrderDetailsDto>(PersistKey, out var persisted) &&
                persisted is not null)
            {
                _order = persisted;
                _loadFailed = false;
                _loadCompleted = true;
                _hydratedFromNumber = Number;
                return;
            }
        }
        catch
        {
            // fall through to a fresh fetch
        }

        _order = null;
        _loadFailed = false;
        _loadCompleted = false;
        await ReloadAsync();
    }

    private async Task ReloadAsync()
    {
        try
        {
            var result = await Api.GetOrderDetailsAsync(Number, CancellationToken.None);
            switch (result.Outcome)
            {
                case SalesApiOutcome.Ok:
                    _order = result.Value;
                    _loadFailed = false;
                    break;
                case SalesApiOutcome.NotFound:
                    _order = null;
                    _loadFailed = false;
                    break;
                default: // Failed
                    _order = null;
                    _loadFailed = true;
                    break;
            }
        }
        catch
        {
            _order = null;
            _loadFailed = true;
        }
        finally
        {
            _loadCompleted = true;
            _hydratedFromNumber = Number;
            StateHasChanged();
        }
    }

    public void Dispose() => _persistingSub.Dispose();
}
