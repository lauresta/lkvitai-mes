    private static readonly string[] AllStatuses = ["Ivestas", "Patvirtintas", "Gaminamas", "Pagamintas", "Filialui", "Atiduotas", "Sustabdytas"];
    private static readonly string[] AllStores    = ["Vilnius", "Kaunas", "Klaipeda", "Siauliai", "Panevezys"];

    // ── Detail sample data (for KVT-240518-018, UAB Audenis Projektai) ──
    private static readonly IReadOnlyList<ItemGroup> SampleItems =
    [
        new("1. Roller blind Audinys R120",
