@page "/"

<PageTitle>Sales · Orders</PageTitle>

<main class="main">

    @* ── Page head ─────────────────────────────────────────────── *@
    <div class="page-head">
        <div>
            <div class="eyebrow mono">Sales &middot; Orders</div>
            <h1>Orders</h1>
            <p>Compact operational Sales Orders. Click an order number to open details in a new tab.</p>
        </div>
        <div class="page-actions">
            <button class="btn btn--ghost" type="button">Export</button>
            <button class="btn btn--primary" type="button">+ New order</button>
        </div>
    </div>

    @* ── Orders list panel ─────────────────────────────────────── *@
    <section class="panel orders-list" aria-labelledby="orders-list-title">
        <div class="panel__head">
            <div>
                <h2 id="orders-list-title">Recent, unpaid and unfinished orders</h2>
                <span>Server-side search will include hidden product text from legacy ProductsSearch.</span>
            </div>
            <span class="mono">Compact &middot; 100 rows/page &middot; sorted by Date desc</span>
        </div>

        <div class="toolbar">
            <label class="field field--search">
                <span class="key-hint" aria-hidden="true">/</span>
                <input type="search" value="@_search" aria-label="Search orders"
                       @oninput="OnSearch" placeholder="Search orders" />
            </label>

            <LkSelect Label="Status" Value="@_statusFilter" Options="@StatusOptions"
                      ValueChanged="@(v => { _statusFilter = v; ApplyFilters(); })" />

            <LkSelect Label="Store" Value="@_storeFilter" Options="@StoreOptions"
                      ValueChanged="@(v => { _storeFilter = v; ApplyFilters(); })" />

            <LkSelect Label="Date" Value="@_dateFilter" Options="@DateOptions"
                      ValueChanged="@(v => _dateFilter = v)" />

            <label class="field" style="cursor:pointer;padding-right:8px;gap:7px"
                   title="Show only orders with outstanding debt"
                   @onclick="ToggleDebt">
                <span class="checkbox @(_hasDebtFilter ? "is-checked" : "")" aria-hidden="true"></span>
                <span style="font-size:12px;color:var(--n-700)">Has debt</span>
            </label>

            <div class="spacer"></div>

            <nav class="pagination" aria-label="Pagination top">
                <button type="button" disabled>&#8249; Prev</button>
                <button type="button" class="is-active">1</button>
                <button type="button">2</button>
                <button type="button">3</button>
                <button type="button">Next &#8250;</button>
            </nav>
        </div>

        @* Desktop table *@
        <div class="table-wrap is-mobile-hidden">
            <table class="lk-table">
                <thead>
                    <tr>
                        <th style="width:32px"><span class="checkbox" aria-label="Select all"></span></th>
                        <th>Number <span class="sort">&#9660;</span></th>
                        <th>Date <span class="sort">&#9660;</span></th>
                        <th class="is-num">Price</th>
                        <th class="is-num">Debt</th>
                        <th>Customer</th>
                        <th style="width:24px" title="Flags"></th>
                        <th>Status</th>
                        <th>Store</th>
                        <th>Address</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var o in _filtered)
                    {
                        <tr class="@(o.Id == _selectedId ? "is-selected" : "")"
                            @onclick="@(() => _selectedId = o.Id)"
                            style="cursor:pointer">
                            <td><span class="checkbox @(o.Id == _selectedId ? "is-checked" : "")" aria-hidden="true"></span></td>
                            <td>
                                <a class="order-link"
                                   href="/orders/@o.Number"
                                   target="_blank"
                                   title="Open @o.Number in new tab"
                                   @onclick:stopPropagation>@o.Number<span class="order-link__open">&#8599;</span></a>
                            </td>
                            <td class="mono">@o.Date</td>
                            <td class="is-money">@o.Price</td>
                            <td class="is-money @o.DebtClass">@o.Debt</td>
                            <td><span class="cust">@o.Customer</span></td>
                            <td>
                                <span class="cust__flags">
                                    @if (o.HasDebt) { <span class="cust__flag cust__flag--debt" title="Has debt">&#8364;</span> }
                                    @if (o.IsVip)   { <span class="cust__flag cust__flag--vip"  title="VIP customer">&#9733;</span> }
                                    @if (o.HasNote) { <span class="cust__flag cust__flag--note" title="Has note">!</span> }
                                </span>
                            </td>
                            <td><span class="chip @o.StatusChip">@o.Status</span></td>
                            <td>@o.Store</td>
                            <td>@o.Address</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @* Mobile cards *@
        <div class="mobile-cards" aria-label="Mobile orders">
            @foreach (var o in _filtered)
            {
                <article class="mobile-card @(o.Id == _selectedId ? "is-selected" : "")"
                         @onclick="@(() => _selectedId = o.Id)">
                    <div class="mobile-card__top">
                        <a class="mobile-card__id order-link"
                           href="/orders/@o.Number"
                           target="_blank"
                           @onclick:stopPropagation>@o.Number &#8599;</a>
                        <span class="chip @o.StatusChip">@o.Status</span>
                    </div>
                    <div class="mobile-card__cust">@o.Customer</div>
                    <div class="mobile-card__meta">
                        <span>@o.Date</span>
                        <span>@o.Store</span>
                        @if (o.HasDebt)
                        {
                            <span>Debt <b class="danger">@o.Debt</b></span>
                        }
                        else
                        {
                            <span>Debt <b>@o.Debt</b></span>
                        }
                    </div>
                </article>
            }
        </div>

        <div class="table-foot">
            <span>Showing <strong>1&#8211;@_filtered.Count</strong> of <strong>284</strong> entries</span>
            <nav class="pagination" aria-label="Pagination bottom">
                <button type="button" disabled>&#8249; Prev</button>
                <button type="button" class="is-active">1</button>
                <button type="button">2</button>
                <button type="button">3</button>
                <button type="button">Next &#8250;</button>
            </nav>
        </div>
    </section>

</main>

