        new(3, "KVT-240516-102", "2026-04-27", "2 330,00 \u20ac", "2 330,00 \u20ac", "is-debt-overdue", "MB Namai Sau",                true,  true,  false, "Ivestas",      "chip--entered",    "Klaipeda",  "Taikos pr. 52, Klaipeda"),
        new(4, "KVT-240516-076", "2026-04-26", "392,80 \u20ac",   "0,00 \u20ac",     "is-debt-zero",    "Rasa Butkute",                false, false, false, "Pagamintas",   "chip--made",       "Vilnius",   "Kalvariju g. 125, Vilnius"),
        new(5, "KVT-240515-031", "2026-04-25", "924,10 \u20ac",   "124,10 \u20ac",   "is-debt-pos",     "UAB Siaures Apartamentai",    false, false, true,  "Filialui",     "chip--shipped",    "Panevezys", "Respublikos g. 39, Panevezys"),
        new(6, "KVT-240514-009", "2026-04-24", "1 096,00 \u20ac", "0,00 \u20ac",     "is-debt-zero",    "Darius Vaitkus",              false, false, false, "Atiduotas",    "chip--delivered",  "Siauliai",  "Tilzes g. 109, Siauliai"),
        new(7, "KVT-240513-088", "2026-04-22", "615,70 \u20ac",   "615,70 \u20ac",   "is-debt-overdue", "UAB Interjero Linija",        true,  false, false, "Sustabdytas",  "chip--paused",     "Vilnius",   "Konstitucijos pr. 12, Vilnius"),
