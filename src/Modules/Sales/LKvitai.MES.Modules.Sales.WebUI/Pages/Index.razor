@page "/"
@inject SalesApiClient Api
@implements IAsyncDisposable

<PageTitle>Sales · Orders</PageTitle>

<main class="main">

    @* ── Page head ─────────────────────────────────────────────── *@
    <div class="page-head">
        <div>
            <div class="eyebrow mono">Sales &middot; Orders</div>
            <h1>Orders</h1>
            <p>Compact operational Sales Orders. Click an order number to open details in a new tab.</p>
        </div>
        <div class="page-actions">
            <button class="btn btn--ghost" type="button">Export</button>
            <button class="btn btn--primary" type="button">+ New order</button>
        </div>
    </div>

    @* ── Orders list panel ─────────────────────────────────────── *@
    <section class="panel orders-list" aria-labelledby="orders-list-title">
        <div class="panel__head">
            <div>
                <h2 id="orders-list-title">Recent, unpaid and unfinished orders</h2>
                <span>Search matches order number, customer, address, and the hidden ProductsSearch text aggregated from item lines.</span>
            </div>
            <span class="mono">Compact &middot; @_pageSize rows/page &middot; sorted by Date desc</span>
        </div>

        <div class="toolbar">
            <label class="field field--search">
                <span class="key-hint" aria-hidden="true">/</span>
                <input type="search" value="@_search" aria-label="Search orders"
                       @oninput="OnSearch" placeholder="Search orders" />
            </label>

            <LkSelect Label="Status" Value="@_statusFilter" Options="@StatusOptions"
                      ValueChanged="OnStatusChanged" />

            <LkSelect Label="Store" Value="@_storeFilter" Options="@StoreOptions"
                      ValueChanged="OnStoreChanged" />

            @* Date filter is intentionally disabled in S-1 — the legacy "30d / month / ytd"
               presets need real range semantics that arrive in S-2 (handoff R-7). Showing
               it greyed out preserves the toolbar layout without lying about behavior. *@
            <LkSelect Label="Date" Value="@_dateFilter" Options="@DateOptions"
                      Disabled="true"
                      Title="Date range filter activates in S-2"
                      ValueChanged="@(_ => Task.CompletedTask)" />

            <label class="field" style="cursor:pointer;padding-right:8px;gap:7px"
                   title="Show only orders with outstanding debt"
                   @onclick="ToggleDebt">
                <span class="checkbox @(_hasDebtFilter ? "is-checked" : "")" aria-hidden="true"></span>
                <span style="font-size:12px;color:var(--n-700)">Has debt</span>
            </label>

            <div class="spacer"></div>

            @RenderPagination("Pagination top")
        </div>

        @if (_loadFailed)
        {
            <div class="panel__head" role="alert" style="border-top:1px solid var(--n-150);background:var(--danger-bg);color:var(--danger-fg)">
                <div>
                    <strong>Sales API unreachable.</strong>
                    <span>Try again or reload the page.</span>
                </div>
                <button class="btn btn--ghost" type="button" @onclick="ReloadAsync">Retry</button>
            </div>
        }

        @* Desktop table *@
        <div class="table-wrap is-mobile-hidden">
            <table class="lk-table">
                <thead>
                    <tr>
                        <th style="width:32px"><span class="checkbox" aria-label="Select all"></span></th>
                        <th>Number</th>
                        <th>Date <span class="sort" title="Sorted descending">&#9660;</span></th>
                        <th class="is-num">Price</th>
                        <th class="is-num">Debt</th>
                        <th>Customer</th>
                        <th style="width:24px" title="Flags"></th>
                        <th>Status</th>
                        <th>Store</th>
                        <th>Address</th>
                    </tr>
                </thead>
                <tbody>
                    @if (_orders.Count == 0 && !_loadFailed)
                    {
                        <tr>
                            <td colspan="10" style="text-align:center;color:var(--n-500);padding:24px 12px">
                                No orders match these filters.
                            </td>
                        </tr>
                    }
                    @foreach (var o in _orders)
                    {
                        <tr class="@(o.Id == _selectedId ? "is-selected" : "")"
                            @onclick="@(() => _selectedId = o.Id)"
                            style="cursor:pointer">
                            <td><span class="checkbox @(o.Id == _selectedId ? "is-checked" : "")" aria-hidden="true"></span></td>
                            <td>
                                <a class="order-link"
                                   href="orders/@o.Number"
                                   target="_blank"
                                   title="Open @o.Number in new tab"
                                   @onclick:stopPropagation>@o.Number<span class="order-link__open">&#8599;</span></a>
                            </td>
                            <td class="mono">@OrderFormat.Date(o.Date)</td>
                            <td class="is-money">@OrderFormat.Money(o.Price)</td>
                            <td class="is-money @OrderFormat.DebtClass(o.Debt, o.IsOverdue)">@OrderFormat.Money(o.Debt)</td>
                            <td><span class="cust">@o.Customer</span></td>
                            <td>
                                <span class="cust__flags">
                                    @if (o.HasDebt) { <span class="cust__flag cust__flag--debt" title="Has debt">&#8364;</span> }
                                    @if (o.IsVip)   { <span class="cust__flag cust__flag--vip"  title="VIP customer">&#9733;</span> }
                                    @if (o.HasNote) { <span class="cust__flag cust__flag--note" title="Has note">!</span> }
                                </span>
                            </td>
                            <td><span class="chip @OrderFormat.StatusChip(o.StatusCode)">@o.Status</span></td>
                            <td>@o.Store</td>
                            <td>@o.Address</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @* Mobile cards *@
        <div class="mobile-cards" aria-label="Mobile orders">
            @if (_orders.Count == 0 && !_loadFailed)
            {
                <article class="mobile-card">
                    <div class="mobile-card__cust" style="color:var(--n-500)">No orders match these filters.</div>
                </article>
            }
            @foreach (var o in _orders)
            {
                <article class="mobile-card @(o.Id == _selectedId ? "is-selected" : "")"
                         @onclick="@(() => _selectedId = o.Id)">
                    <div class="mobile-card__top">
                        <a class="mobile-card__id order-link"
                           href="orders/@o.Number"
                           target="_blank"
                           @onclick:stopPropagation>@o.Number &#8599;</a>
                        <span class="chip @OrderFormat.StatusChip(o.StatusCode)">@o.Status</span>
                    </div>
                    <div class="mobile-card__cust">@o.Customer</div>
                    <div class="mobile-card__meta">
                        <span>@OrderFormat.Date(o.Date)</span>
                        <span>@o.Store</span>
                        @if (o.IsOverdue || (o.HasDebt && o.Debt > 0))
                        {
                            <span>Debt <b class="danger">@OrderFormat.Money(o.Debt)</b></span>
                        }
                        else
                        {
                            <span>Debt <b>@OrderFormat.Money(o.Debt)</b></span>
                        }
                    </div>
                </article>
            }
        </div>

        <div class="table-foot">
            <span>
                Showing <strong>@OrderFormat.Integer(_from)&#8211;@OrderFormat.Integer(_to)</strong>
                of <strong>@OrderFormat.Integer(_total)</strong> entries
            </span>
            @RenderPagination("Pagination bottom")
        </div>
    </section>

</main>

@code {
    private const int PageSize = 100;

    private static readonly IReadOnlyList<SelectOption> StatusOptions =
    [
        new("",             "All statuses"),
        new("Įvestas",      "Įvestas"),
        new("Patvirtintas", "Patvirtintas"),
        new("Gaminamas",    "Gaminamas"),
        new("Pagamintas",   "Pagamintas"),
        new("Filialui",     "Filialui"),
        new("Atiduotas",    "Atiduotas"),
        new("Sustabdytas",  "Sustabdytas"),
    ];

    private static readonly IReadOnlyList<SelectOption> StoreOptions =
    [
        new("",          "All stores"),
        new("Vilnius",   "Vilnius"),
        new("Kaunas",    "Kaunas"),
        new("Klaipėda",  "Klaipėda"),
        new("Šiauliai",  "Šiauliai"),
        new("Panevėžys", "Panevėžys"),
    ];

    // Disabled in S-1 — kept so the visual control stays aligned with the toolbar grid.
    private static readonly IReadOnlyList<SelectOption> DateOptions =
    [
        new("30d",   "Last 30 days"),
        new("month", "This month"),
        new("ytd",   "YTD"),
    ];

    private List<OrderSummaryDto> _orders       = new();
    private int                   _total;
    private int                   _page         = 1;
    private readonly int          _pageSize     = PageSize;
    private string                _search       = "";
    private string                _statusFilter = "";
    private string                _storeFilter  = "";
    private string                _dateFilter   = "30d";
    private bool                  _hasDebtFilter;
    private int?                  _selectedId;
    private bool                  _loadFailed;
    private CancellationTokenSource? _searchCts;

    private int _totalPages => Math.Max(1, (int)Math.Ceiling(_total / (double)_pageSize));
    private int _from       => _total == 0 ? 0 : ((_page - 1) * _pageSize) + 1;
    private int _to         => Math.Min(_page * _pageSize, _total);

    protected override async Task OnInitializedAsync()
    {
        await ReloadAsync();
    }

    private async Task OnSearch(ChangeEventArgs e)
    {
        _search = e.Value?.ToString() ?? "";

        if (_searchCts is not null)
        {
            await _searchCts.CancelAsync();
            _searchCts.Dispose();
        }
        _searchCts = new CancellationTokenSource();
        var token = _searchCts.Token;

        try
        {
            await Task.Delay(200, token);
            _page = 1; // any filter change resets to page 1 to avoid landing on an empty page
            await ReloadAsync();
        }
        catch (TaskCanceledException) { /* superseded by a newer keystroke */ }
    }

    public async ValueTask DisposeAsync()
    {
        if (_searchCts is not null)
        {
            await _searchCts.CancelAsync();
            _searchCts.Dispose();
            _searchCts = null;
        }
    }

    private async Task OnStatusChanged(string value)
    {
        _statusFilter = value;
        _page = 1;
        await ReloadAsync();
    }

    private async Task OnStoreChanged(string value)
    {
        _storeFilter = value;
        _page = 1;
        await ReloadAsync();
    }

    private async Task ToggleDebt()
    {
        _hasDebtFilter = !_hasDebtFilter;
        _page = 1;
        await ReloadAsync();
    }

    private async Task GoToPage(int page)
    {
        if (page < 1 || page > _totalPages || page == _page) return;
        _page = page;
        await ReloadAsync();
    }

    private Task GoPrev() => GoToPage(_page - 1);
    private Task GoNext() => GoToPage(_page + 1);

    /// <summary>
    /// Returns the page numbers to render as buttons. For up to 7 pages we show
    /// them all; for larger totals we show a windowed view with ellipsis (-1)
    /// markers so the toolbar never overflows.
    /// </summary>
    private IReadOnlyList<int> PageButtons()
    {
        if (_totalPages <= 7)
        {
            return Enumerable.Range(1, _totalPages).ToList();
        }

        var pages = new List<int> { 1 };
        var start = Math.Max(2, _page - 2);
        var end   = Math.Min(_totalPages - 1, _page + 2);

        if (start > 2)               pages.Add(-1);
        for (var i = start; i <= end; i++) pages.Add(i);
        if (end < _totalPages - 1)   pages.Add(-1);

        pages.Add(_totalPages);
        return pages;
    }

    private RenderFragment RenderPagination(string ariaLabel) => @<text>
        <nav class="pagination" aria-label="@ariaLabel">
            <button type="button" disabled="@(_page <= 1)" @onclick="GoPrev">&#8249; Prev</button>
            @foreach (var p in PageButtons())
            {
                if (p < 0)
                {
                    <span class="pagination__ellipsis" aria-hidden="true">…</span>
                }
                else
                {
                    var pageValue = p;
                    <button type="button"
                            class="@(pageValue == _page ? "is-active" : "")"
                            disabled="@(pageValue == _page)"
                            @onclick="@(() => GoToPage(pageValue))">@pageValue</button>
                }
            }
            <button type="button" disabled="@(_page >= _totalPages)" @onclick="GoNext">Next &#8250;</button>
        </nav>
    </text>;

    private async Task ReloadAsync()
    {
        var query = new OrdersQueryParams
        {
            Search   = string.IsNullOrWhiteSpace(_search) ? null : _search,
            Status   = string.IsNullOrEmpty(_statusFilter) ? null : _statusFilter,
            Store    = string.IsNullOrEmpty(_storeFilter)  ? null : _storeFilter,
            Date     = null, // S-1: date preset is disabled in the UI; never sent to API
            HasDebt  = _hasDebtFilter,
            Page     = _page,
            PageSize = _pageSize,
        };

        var result = await Api.GetOrdersAsync(query, CancellationToken.None);
        if (result is null)
        {
            _loadFailed = true;
            _orders = new List<OrderSummaryDto>();
            _total = 0;
        }
        else
        {
            _loadFailed = false;
            _orders = result.Items.ToList();
            _total = result.Total;

            // Defensive: if a filter or smaller pageSize collapsed the result set
            // and we landed past the last page, snap back to a valid page and refetch.
            if (_orders.Count == 0 && _total > 0 && _page > _totalPages)
            {
                _page = _totalPages;
                await ReloadAsync();
                return;
            }
        }

        StateHasChanged();
    }
}
