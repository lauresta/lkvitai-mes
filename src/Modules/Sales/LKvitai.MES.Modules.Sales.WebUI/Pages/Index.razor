    // ── Filter & selection state ──────────────────────────────────
    private List<OrderRow> _filtered = AllOrders.ToList();
    private string    _search       = "";
    private string    _statusFilter = "";
    private string    _storeFilter  = "";
    private string    _dateFilter   = "30d";
    private bool      _hasDebtFilter;
    private int?      _selectedId   = 1;
    private OrderRow? _selected     = AllOrders[0];

    private void OnSearch(ChangeEventArgs e)
    {
        _search = e.Value?.ToString() ?? "";
        ApplyFilters();
    }

    private void ApplyFilters()
    {
        _filtered = AllOrders
            .Where(o => string.IsNullOrWhiteSpace(_search) ||
                o.Number.Contains(_search, StringComparison.OrdinalIgnoreCase) ||
                o.Customer.Contains(_search, StringComparison.OrdinalIgnoreCase) ||
                o.Address.Contains(_search, StringComparison.OrdinalIgnoreCase))
            .Where(o => string.IsNullOrEmpty(_statusFilter) || o.Status == _statusFilter)
            .Where(o => string.IsNullOrEmpty(_storeFilter)  || o.Store  == _storeFilter)
            .Where(o => !_hasDebtFilter || o.HasDebt)
            .ToList();
    }

    private void SelectOrder(OrderRow order)
    {
        _selectedId = order.Id;
        _selected   = order;
    }

    private void ToggleDebt()
    {
        _hasDebtFilter = !_hasDebtFilter;
        ApplyFilters();
    }
}
