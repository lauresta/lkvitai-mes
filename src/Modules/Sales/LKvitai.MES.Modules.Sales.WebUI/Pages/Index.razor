@page "/"

<PageTitle>Sales · Orders</PageTitle>

<main class="main">

    @* Page head *@
    <div class="page-head">
        <div class="page-head__text">
            <p class="page-head__eyebrow">Sales</p>
            <h1 class="page-head__title">Orders</h1>
        </div>
        <div class="page-head__actions">
            <button class="btn btn-ghost">Export</button>
            <button class="btn btn-primary">+ New order</button>
        </div>
    </div>

    @* Orders list panel *@
    <div class="panel orders-list">
        <div class="panel__head">
            <span class="panel__title">Orders list</span>
            <span class="panel__meta">@_filtered.Count orders</span>
        </div>

        <div class="toolbar">
            <div class="field field--search">
                <input type="text"
                       placeholder="Search… (/)"
                       value="@_search"
                       @oninput="OnSearch" />
            </div>
            <div class="field">
                <select @bind="_statusFilter" @bind:after="ApplyFilters">
                    <option value="">All statuses</option>
                    @foreach (var s in AllStatuses)
                    {
                        <option value="@s">@s</option>
                    }
                </select>
            </div>
            <div class="field">
                <select @bind="_storeFilter" @bind:after="ApplyFilters">
                    <option value="">All stores</option>
                    @foreach (var s in AllStores)
                    {
                        <option value="@s">@s</option>
                    }
                </select>
            </div>
            <label class="filter-toggle">
                <input type="checkbox" @bind="_hasDebtFilter" @bind:after="ApplyFilters" />
                <span>Has debt</span>
            </label>
            <div class="toolbar__spacer"></div>
            <span class="panel__meta">@_filtered.Count of @AllOrders.Count</span>
        </div>

        @* Desktop grid *@
        <OrdersGrid Orders="@_filtered"
                    SelectedId="@_selectedId"
                    OnRowClick="@SelectOrder" />

        @* Mobile cards *@
        <div class="mobile-cards">
            @foreach (var o in _filtered)
            {
                <div class="mobile-card @(o.Id == _selectedId ? "is-selected" : "")"
                     @onclick="@(() => SelectOrder(o))">
                    <div class="mobile-card__top">
                        <span class="mobile-card__number">@o.Number</span>
                        <span class="chip @MobileStatusChip(o.Status)">@o.Status</span>
                    </div>
                    <div class="mobile-card__customer">@o.Customer</div>
                    <div class="mobile-card__meta">
                        <span>@o.Date.ToString("yyyy-MM-dd")</span>
                        <span>@o.Store</span>
                        @if (o.Debt > 0)
                        {
                            <span class="mobile-card__debt">@o.Debt.ToString("N2", CultureInfo.InvariantCulture) € skola</span>
                        }
                    </div>
                </div>
            }
        </div>

        <div class="table-foot">
            Showing @_filtered.Count of @AllOrders.Count orders
        </div>
    </div>

    @* Detail panel (shown when a row is selected) *@
    @if (_selectedOrder is not null)
    {
        <OrderDetailPanel Order="@_selectedOrder" />
    }

</main>

