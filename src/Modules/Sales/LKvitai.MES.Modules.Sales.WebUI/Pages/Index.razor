@page "/"

<PageTitle>Sales · Orders</PageTitle>

<main class="main">

    @* ── Page head ─────────────────────────────────────────────── *@
    <div class="page-head">
        <div>
            <div class="eyebrow mono">Sales &middot; Orders</div>
            <h1>Orders list and order details</h1>
            <p>Compact operational Sales Orders. The list is dense by default; selected row drives the details panel below.</p>
        </div>
        <div class="page-actions">
            <button class="btn btn--ghost" type="button">Export</button>
            <button class="btn btn--primary" type="button">+ New order</button>
        </div>
    </div>

    @* ── Orders list panel ─────────────────────────────────────── *@
    <section class="panel orders-list" aria-labelledby="orders-list-title">
        <div class="panel__head">
            <div>
                <h2 id="orders-list-title">Recent, unpaid and unfinished orders</h2>
                <span>Server-side search will include hidden product text from legacy ProductsSearch.</span>
            </div>
            <span class="mono">Compact &middot; 100 rows/page &middot; sorted by Date desc</span>
        </div>

        <div class="toolbar">
            <label class="field field--search">
                <span class="key-hint" aria-hidden="true">/</span>
                <input type="search" value="@_search" aria-label="Search orders"
                       @oninput="OnSearch" placeholder="Search orders" />
            </label>

            <LkSelect Label="Status" Value="@_statusFilter" Options="@StatusOptions"
                      ValueChanged="@(v => { _statusFilter = v; ApplyFilters(); })" />

            <LkSelect Label="Store" Value="@_storeFilter" Options="@StoreOptions"
                      ValueChanged="@(v => { _storeFilter = v; ApplyFilters(); })" />

            <LkSelect Label="Date" Value="@_dateFilter" Options="@DateOptions"
                      ValueChanged="@(v => _dateFilter = v)" />

            <label class="field" style="cursor:pointer;padding-right:8px;gap:7px"
                   title="Show only orders with outstanding debt"
                   @onclick="ToggleDebt">
                <span class="checkbox @(_hasDebtFilter ? "is-checked" : "")" aria-hidden="true"></span>
                <span style="font-size:12px;color:var(--n-700)">Has debt</span>
            </label>

            <div class="spacer"></div>

            <nav class="pagination" aria-label="Pagination top">
                <button type="button" disabled>&#8249; Prev</button>
                <button type="button" class="is-active">1</button>
                <button type="button">2</button>
                <button type="button">3</button>
                <button type="button">Next &#8250;</button>
            </nav>
        </div>

        @* Desktop table *@
        <div class="table-wrap is-mobile-hidden">
            <table class="lk-table">
                <thead>
                    <tr>
                        <th style="width:32px"><span class="checkbox" aria-label="Select all"></span></th>
                        <th>Number <span class="sort">&#9660;</span></th>
                        <th>Date <span class="sort">&#9660;</span></th>
                        <th class="is-num">Price</th>
                        <th class="is-num">Debt</th>
                        <th>Customer</th>
                        <th style="width:24px" title="Flags"></th>
                        <th>Status</th>
                        <th>Store</th>
                        <th>Address</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var o in _filtered)
                    {
                        <tr class="@(o.Id == _selectedId ? "is-selected" : "")"
                            @onclick="@(() => SelectOrder(o))"
                            style="cursor:pointer">
                            <td><span class="checkbox @(o.Id == _selectedId ? "is-checked" : "")" aria-hidden="true"></span></td>
                            <td>
                                <a class="order-link"
                                   href="/orders/@o.Number"
                                   target="_blank"
                                   title="Open @o.Number in new tab"
                                   @onclick:stopPropagation>@o.Number<span class="order-link__open">&#8599;</span></a>
                            </td>
                            <td class="mono">@o.Date</td>
                            <td class="is-money">@o.Price</td>
                            <td class="is-money @o.DebtClass">@o.Debt</td>
                            <td><span class="cust">@o.Customer</span></td>
                            <td>
                                <span class="cust__flags">
                                    @if (o.HasDebt) { <span class="cust__flag cust__flag--debt" title="Has debt">&#8364;</span> }
                                    @if (o.IsVip)   { <span class="cust__flag cust__flag--vip"  title="VIP customer">&#9733;</span> }
                                    @if (o.HasNote) { <span class="cust__flag cust__flag--note" title="Has note">!</span> }
                                </span>
                            </td>
                            <td><span class="chip @o.StatusChip">@o.Status</span></td>
                            <td>@o.Store</td>
                            <td>@o.Address</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @* Mobile cards *@
        <div class="mobile-cards" aria-label="Mobile orders">
            @foreach (var o in _filtered)
            {
                <article class="mobile-card @(o.Id == _selectedId ? "is-selected" : "")"
                         @onclick="@(() => SelectOrder(o))">
                    <div class="mobile-card__top">
                        <span class="mobile-card__id">@o.Number</span>
                        <span class="chip @o.StatusChip">@o.Status</span>
                    </div>
                    <div class="mobile-card__cust">@o.Customer</div>
                    <div class="mobile-card__meta">
                        <span>@o.Date</span>
                        <span>@o.Store</span>
                        @if (o.HasDebt)
                        {
                            <span>Debt <b class="danger">@o.Debt</b></span>
                        }
                        else
                        {
                            <span>Debt <b>@o.Debt</b></span>
                        }
                    </div>
                </article>
            }
        </div>

        <div class="table-foot">
            <span>Showing <strong>1&#8211;@_filtered.Count</strong> of <strong>284</strong> entries</span>
            <nav class="pagination" aria-label="Pagination bottom">
                <button type="button" disabled>&#8249; Prev</button>
                <button type="button" class="is-active">1</button>
                <button type="button">2</button>
                <button type="button">3</button>
                <button type="button">Next &#8250;</button>
            </nav>
        </div>
    </section>

    @* ── Order details panel ───────────────────────────────────── *@
    @if (_selected is not null)
    {
        <section id="order-details" class="panel details" aria-labelledby="details-title">
            <nav class="details__breadcrumb" aria-label="Breadcrumb">
                <a href="#">Home</a><span>/</span>
                <a href="#">Orders</a><span>/</span>
                <strong>@_selected.Number</strong>
            </nav>
            <header class="details__title">
                <div>
                    <span class="details__id mono">@_selected.Number</span>
                    <h2 id="details-title">@_selected.Customer</h2>
                    <div class="details__sub">
                        <span><b>Date:</b> @_selected.Date</span>
                        <span><b>Address:</b> @_selected.Address</span>
                        <span><b>Store:</b> @_selected.Store</span>
                        <span><b>Status:</b> <span class="chip @_selected.StatusChip chip--sm">@_selected.Status</span></span>
                    </div>
                    <div class="details__op">Operator: R&#363;ta Markevi&#269;ien&#279; &middot; 2026-04-29 09:42:17</div>
                </div>
                <div class="details__title__actions">
                    <button class="btn btn--ghost" type="button">Print</button>
                    <button class="btn" type="button">Email customer</button>
                    <button class="btn btn--primary" type="button">Open in PoS</button>
                </div>
            </header>

            @* Items *@
            <div class="details__section">
                <div class="section-label">Items <span class="section-label__count">3 products &middot; 4 line items</span></div>
                <div class="table-wrap is-mobile-hidden">
                    <table class="lk-table">
                        <thead>
                            <tr>
                                <th style="width:24px">#</th>
                                <th>Item</th>
                                <th>Side</th>
                                <th>Color</th>
                                <th class="is-num">Width</th>
                                <th class="is-num">Height</th>
                                <th>Notes</th>
                                <th class="is-num">Q-ty</th>
                                <th class="is-num">Price</th>
                                <th class="is-num">Amount</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var grp in SampleItems)
                            {
                                <tr class="group-row"><td colspan="10">@grp.Label</td></tr>
                                @foreach (var line in grp.Lines)
                                {
                                    <tr class="@(line.IsAcc ? "acc-row" : "")">
                                        <td class="mono">@line.Num</td>
                                        <td>@line.Name</td>
                                        <td>@line.Side</td>
                                        <td>@line.Color</td>
                                        <td class="is-num mono">@line.Width</td>
                                        <td class="is-num mono">@line.Height</td>
                                        <td>@line.Notes</td>
                                        <td class="is-money">@line.Qty</td>
                                        <td class="is-money">@line.Price</td>
                                        <td class="is-money">@line.Amount</td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
                <div class="mobile-cards">
                    @foreach (var grp in SampleItems)
                    {
                        @foreach (var line in grp.Lines.Where(l => !l.IsAcc))
                        {
                            <article class="mobile-card">
                                <div class="mobile-card__top">
                                    <span class="mobile-card__id">@line.Num. @line.Name</span>
                                    <span class="chip chip--entered chip--sm">x@line.Qty</span>
                                </div>
                                <div class="mobile-card__meta">
                                    <span>@line.Side &middot; @line.Color</span>
                                    <span>@line.Width &times; @line.Height</span>
                                    <span>Amount <b>@line.Amount</b></span>
                                </div>
                            </article>
                        }
                    }
                </div>
            </div>

            @* Amounts *@
            <div class="details__section">
                <div class="section-label">Amounts <span class="section-label__count">all values incl. VAT</span></div>
                <div class="amounts">
                    @foreach (var card in SampleAmounts)
                    {
                        <div class="amount-card @card.Modifier">
                            <span class="amount-card__label">@card.Label</span>
                            <span class="amount-card__value">@card.Value</span>
                        </div>
                    }
                </div>
            </div>

            @* Employees *@
            <div class="details__section">
                <div class="section-label">Employees <span class="section-label__count">3 assignments</span></div>
                <div class="table-wrap is-mobile-hidden">
                    <table class="lk-table">
                        <thead>
                            <tr>
                                <th>Duty</th>
                                <th>Employee</th>
                                <th>Service date</th>
                                <th>Acquaintance date</th>
                                <th class="is-num">Order q-ty</th>
                                <th class="is-num">Item q-ty</th>
                                <th class="is-num">Amount</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var e in SampleEmployees)
                            {
                                <tr>
                                    <td><span class="duty @e.DutyClass">@e.DutyLabel</span></td>
                                    <td><div class="emp-name"><span class="emp-avatar">@e.Initials</span>@e.Name</div></td>
                                    <td class="mono">@e.ServiceDate</td>
                                    <td class="mono">@e.AcqDate</td>
                                    <td class="is-num mono">@e.OrderQty</td>
                                    <td class="is-num mono">@e.ItemQty</td>
                                    <td class="is-money">@e.Amount</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </section>
    }

</main>

