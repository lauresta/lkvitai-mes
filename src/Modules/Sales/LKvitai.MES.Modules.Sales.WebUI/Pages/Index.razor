            new("1", "Roller blind Audinys R120", "Left",   "White",    "1 250,00", "1 710,00", "Bedroom window",      "2,00", "148,00", "296,00"),
            new("",  "Metal chain 100 cm",        "",       "",         "",         "",         "",                    "2,00", "8,00",   "16,00",  IsAcc: true),
        ]),
        new("2. Day-night blind DN45",
        [
            new("2", "Day-night blind DN45",      "Right",  "Graphite", "980,00",   "1 420,00", "Kitchen",             "1,00", "210,00", "210,00"),
        ]),
        new("3. Vertical blinds V78",
        [
            new("3", "Vertical blinds V78",       "Center", "Sand",     "2 420,00", "2 360,00", "Office, split controls", "1,00", "960,00", "960,00"),
        ]),
    ];

    private static readonly IReadOnlyList<AmountCard> SampleAmounts =
    [
        new("Defined",        "1 482,00 \u20ac"),
        new("Calculated",     "1 540,00 \u20ac"),
        new("Discount",       "5,00 %"),
        new("After discount", "1 482,00 \u20ac", "amount-card--total"),
        new("Paid",           "1 000,00 \u20ac", "amount-card--paid"),
        new("Debt",           "482,00 \u20ac",   "amount-card--debt"),
    ];

    private static readonly IReadOnlyList<EmployeeLine> SampleEmployees =
    [
        new("RM", "Ruta Markeviciene",  "duty--sales", "Sales consultant", "2026-04-29", "2026-04-29", "1", "4", "1 482,00"),
        new("MJ", "Mantas Jankauskas",  "duty--prod",  "Production",       "2026-04-30", "2026-04-30", "1", "3", "1 210,00"),
        new("TV", "Tomas Varnas",       "duty--inst",  "Installation",     "2026-05-03", "2026-05-03", "1", "4", "272,00"),
    ];

    // ── Filter & selection state ──────────────────────────────────
    private List<OrderRow> _filtered = AllOrders.ToList();
    private string  _search      = "";
    private string  _statusFilter = "";
    private string  _storeFilter  = "";
    private bool    _hasDebtFilter;
    private int?    _selectedId   = 1;
    private OrderRow? _selected   = AllOrders[0];

    private void OnSearch(ChangeEventArgs e)
    {
        _search = e.Value?.ToString() ?? "";
        ApplyFilters();
    }

    private void ApplyFilters()
    {
        _filtered = AllOrders
            .Where(o => string.IsNullOrWhiteSpace(_search) ||
                o.Number.Contains(_search, StringComparison.OrdinalIgnoreCase) ||
                o.Customer.Contains(_search, StringComparison.OrdinalIgnoreCase) ||
                o.Address.Contains(_search, StringComparison.OrdinalIgnoreCase))
            .Where(o => string.IsNullOrEmpty(_statusFilter) || o.Status == _statusFilter)
            .Where(o => string.IsNullOrEmpty(_storeFilter)  || o.Store  == _storeFilter)
            .Where(o => !_hasDebtFilter || o.HasDebt)
            .ToList();
    }

    private void SelectOrder(OrderRow order)
    {
        _selectedId = order.Id;
        _selected   = order;
    }

    private void ToggleDebt()
    {
        _hasDebtFilter = !_hasDebtFilter;
        ApplyFilters();
    }
}
