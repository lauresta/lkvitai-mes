        new(8,  "KVT-2024-0884", new DateOnly(2024, 3,  7), 7250.00m, 1200.00m, "OCI Lithuania UAB",     "Patvirtintas","Kaunas",    "Jonavos g. 60, Kaunas",       true,  false, true),
        new(9,  "KVT-2024-0883", new DateOnly(2024, 3,  6),  430.00m,    0.00m, "Marija Stankevičiūtė", "Atiduotas",   "Panevėžys", "Respublikos g. 28, Panevėžys",false, false, false),
        new(10, "KVT-2024-0882", new DateOnly(2024, 3,  5), 2100.00m,    0.00m, "Textilės namai UAB",    "Gaminamas",   "Vilnius",   "Verkių g. 29, Vilnius",       false, false, true),
    ];

    private static readonly string[] AllStatuses =
        ["Įvestas", "Patvirtintas", "Gaminamas", "Pagamintas", "Filialui", "Atiduotas", "Sustabdytas"];

    private static readonly string[] AllStores =
        ["Vilnius", "Kaunas", "Klaipėda", "Šiauliai", "Panevėžys"];

    // ── Filter state ────────────────────────────────────────────────────────
    private List<OrderRow> _filtered = AllOrders.ToList();
    private string _search = "";
    private string _statusFilter = "";
    private string _storeFilter = "";
    private bool _hasDebtFilter;

    // ── Selection state ─────────────────────────────────────────────────────
    private long? _selectedId;
    private OrderRow? _selectedOrder;

    // ── Filtering ───────────────────────────────────────────────────────────
    private void OnSearch(ChangeEventArgs e)
    {
        _search = e.Value?.ToString() ?? "";
        ApplyFilters();
    }

    private void ApplyFilters()
    {
        _filtered = AllOrders
            .Where(o => string.IsNullOrWhiteSpace(_search) ||
                o.Number.Contains(_search, StringComparison.OrdinalIgnoreCase) ||
                o.Customer.Contains(_search, StringComparison.OrdinalIgnoreCase) ||
                o.Address.Contains(_search, StringComparison.OrdinalIgnoreCase))
            .Where(o => string.IsNullOrEmpty(_statusFilter) || o.Status == _statusFilter)
            .Where(o => string.IsNullOrEmpty(_storeFilter) || o.Store == _storeFilter)
            .Where(o => !_hasDebtFilter || o.Debt > 0)
            .ToList();
    }

    private void SelectOrder(OrderRow order)
    {
        _selectedId = order.Id;
        _selectedOrder = order;
    }

    private static string MobileStatusChip(string status) => status switch
    {
        "Įvestas"      => "chip--entered",
        "Patvirtintas" => "chip--approved",
        "Gaminamas"    => "chip--inprogress",
        "Pagamintas"   => "chip--made",
        "Filialui"     => "chip--shipped",
        "Atiduotas"    => "chip--delivered",
        "Sustabdytas"  => "chip--paused",
        _              => "chip--entered"
    };
}
