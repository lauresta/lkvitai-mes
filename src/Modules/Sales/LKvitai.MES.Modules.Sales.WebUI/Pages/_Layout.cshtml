@using Microsoft.AspNetCore.Components.Web
@namespace LKvitai.MES.Modules.Sales.WebUI.Pages
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@inject Microsoft.Extensions.Configuration.IConfiguration Configuration

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="~/" />
    <link href="_content/MudBlazor/MudBlazor.min.css" rel="stylesheet" asp-append-version="true" />
    @* asp-append-version=true emits a content-hash query string (?v=...) so
       Cloudflare and the browser cache the CSS by hash instead of by name —
       a redeploy of the same URL with new content reaches the user instantly,
       not in 4 hours when max-age expires. *@
    @* portal-tokens.css MUST load BEFORE portal-shell.css. See the long-form
       rationale in Portal/Pages/_Layout.cshtml; in short, this file owns
       --dark / --dark-2 / --dark-line / --n-* / --accent-* and replaces the
       per-module copy that used to live in Sales/wwwroot/css/tokens.css.
       Module-local overrides (e.g. orders.css component classes) still load
       AFTER portal-shell.css and may consume any token defined here. *@
    <link href="_content/LKvitai.MES.BuildingBlocks.WebUI/css/portal-tokens.css" rel="stylesheet" asp-append-version="true" />
    <link href="_content/LKvitai.MES.BuildingBlocks.WebUI/css/portal-shell.css" rel="stylesheet" asp-append-version="true" />
    <link href="css/orders.css" rel="stylesheet" asp-append-version="true" />
    <link rel="icon" type="image/png" sizes="32x32" href="_content/LKvitai.MES.BuildingBlocks.WebUI/brand/favicon-32.png" asp-append-version="true" />
    <link rel="icon" type="image/png" sizes="16x16" href="_content/LKvitai.MES.BuildingBlocks.WebUI/brand/favicon-16.png" asp-append-version="true" />
    <link rel="apple-touch-icon" sizes="180x180" href="_content/LKvitai.MES.BuildingBlocks.WebUI/brand/icon-180.png" asp-append-version="true" />
    <link rel="manifest" href="_content/LKvitai.MES.BuildingBlocks.WebUI/brand/site.webmanifest" asp-append-version="true" />
    <meta name="theme-color" content="#2f8f8b" />
    <title>Cikada.MES · Sales</title>
    <component type="typeof(HeadOutlet)" render-mode="ServerPrerendered" />
@{
    var clarityProjectId = Configuration["Clarity:ProjectId"];
    string? clarityUserLabel = null;
    if (!string.IsNullOrWhiteSpace(clarityProjectId) && User?.Identity?.IsAuthenticated == true)
    {
        // Test env runs everyone through one shared "admin" login today - label
        // those sessions explicitly rather than pretending they're anonymous.
        // Once real per-person accounts exist, this naturally becomes their
        // actual username (denis, jonas, petras, ...).
        clarityUserLabel = string.Equals(User.Identity!.Name, "admin", StringComparison.OrdinalIgnoreCase)
            ? "admin-sesija"
            : User.Identity!.Name;
    }
}
@if (!string.IsNullOrWhiteSpace(clarityProjectId))
{
    <script type="text/javascript">
        (function(c,l,a,r,i,t,y){
            c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};
            t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;
            y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);
        })(window, document, "clarity", "script", @Html.Raw(System.Text.Json.JsonSerializer.Serialize(clarityProjectId)));
        @if (clarityUserLabel is not null)
        {
            @Html.Raw($"clarity(\"identify\", {System.Text.Json.JsonSerializer.Serialize(clarityUserLabel)});")
        }
    </script>
}
</head>
<body>
    @RenderBody()

    <div id="blazor-error-ui">
        An unhandled error has occurred.
        <a href="" class="reload">Reload</a>
        <a class="dismiss">🗙</a>
    </div>

    @* Required for PersistentComponentState to actually transfer state from the
       prerender pass to the interactive (post-SignalR) pass. Without this tag
       the RegisterOnPersisting callbacks fire on the server but the serialized
       payload is never written into the page, so TryTakeFromJson on the client
       always returns false and OnInitializedAsync re-fetches data — visible
       as a flash between the prerendered grid and the re-rendered grid.

       Pairs with two other guards in this module that together prevent the
       circuit-on-startup death we saw on mes-test:
         * Program.cs bumps SignalR's MaximumReceiveMessageSize to 256 KB so the
           hydration message isn't truncated on connect.
         * Pages/Index.razor persists a slim `PersistedOrderRow` (no
           ProductsSearch) to keep the payload comfortably under that cap. *@
    <persist-component-state />

    <script src="_framework/blazor.server.js" asp-append-version="true"></script>
    <script src="_content/MudBlazor/MudBlazor.min.js" asp-append-version="true"></script>
</body>
</html>
