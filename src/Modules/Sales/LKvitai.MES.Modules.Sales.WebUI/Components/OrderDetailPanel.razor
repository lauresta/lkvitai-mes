@* OrderDetailPanel — orchestrates detail sections. Hardcoded sample data in S-0; replaced in S-1. *@

<div class="panel details">
    <OrderDetailHeader Order="@Order" />
    <div class="section-head">Items</div>
    <OrderItemsTable Items="@_sampleItems" />
    <div class="section-head">Amounts</div>
    <OrderAmountsGrid Amounts="@_sampleAmounts" />
    <div class="section-head">Employees</div>
    <OrderEmployeesTable Employees="@_sampleEmployees" />
</div>

@code {
    [Parameter] public OrderRow Order { get; set; } = default!;

    private static readonly List<OrderItemLine> _sampleItems =
    [
        new("Horizontalios žaliuzės PVC 25mm", "Kairė", "Pilka", "1200×1400", null,          4, 125.00m,  500.00m, false),
        new("Montavimo laikiklis",              null,    null,    null,         null,          8,   4.50m,   36.00m, true),
        new("Ritininės užuolaidos",             null,    "Balta", "800×1600",  "Atspalvis 04",6,  89.00m,  534.00m, false),
        new("Grandinėlės svoris",               null,    null,    null,         null,          6,   1.20m,    7.20m, true),
        new("Spaustukas",                       null,    null,    null,         null,         12,   0.80m,    9.60m, true),
    ];

    private static readonly List<OrderAmountCard> _sampleAmounts =
    [
        new("Apibrėžta suma",    "2 840,00 €", ""),
        new("Apskaičiuota suma", "2 840,00 €", ""),
        new("Nuolaida",          "0,00 €",     ""),
        new("Po nuolaidos",      "2 840,00 €", "amount-card--total"),
        new("Sumokėta",          "2 840,00 €", "amount-card--paid"),
        new("Skola",             "0,00 €",     "amount-card--debt"),
    ];

    private static readonly List<OrderEmployeeLine> _sampleEmployees =
    [
        new("TB", "Tomas Bernotas",  "Pardavėjas",  "duty--sales",   "2024-03-10", 284.00m),
        new("AJ", "Algis Jankūnas",  "Meistras",    "duty--prod",    "2024-03-12", 426.00m),
