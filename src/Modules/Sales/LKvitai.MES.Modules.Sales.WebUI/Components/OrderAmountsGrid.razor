@* OrderAmountsGrid — 6-card responsive amounts grid *@

<div class="amounts-grid">
    @foreach (var card in Amounts)
    {
        <div class="amount-card @card.CssModifier">
            <div class="amount-card__label">@card.Label</div>
            <div class="amount-card__value">@card.Value</div>
        </div>
    }
</div>

@code {
    [Parameter] public IReadOnlyList<OrderAmountCard> Amounts { get; set; } = [];
}
