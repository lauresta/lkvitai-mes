@* OrdersGrid — dense MudDataGrid with local sample records. ServerData wired in S-1. *@

<MudDataGrid T="OrderRow"
             Items="@Orders"
             Dense="true"
             FixedHeader="true"
             Height="400px"
             Hover="true"
             Class="lk-grid"
             RowClassFunc="@GetRowClass"
             RowClick="@OnRowClicked">
    <Columns>

        <TemplateColumn Title=""
                        HeaderStyle="width:36px;padding:0 6px"
                        CellStyle="width:36px;padding:0 0 0 10px"
                        Sortable="false">
            <CellTemplate>
                <input type="checkbox" class="row-check" />
            </CellTemplate>
        </TemplateColumn>

        <TemplateColumn Title="Number"
                        HeaderStyle="width:140px"
                        CellStyle="width:140px"
                        SortBy="@(x => x.Number)">
            <CellTemplate>
                <span class="order-link mono">@context.Item.Number ↗</span>
            </CellTemplate>
        </TemplateColumn>

        <TemplateColumn Title="Date"
                        HeaderStyle="width:95px"
                        CellStyle="width:95px"
                        SortBy="@(x => x.Date)">
            <CellTemplate>
                <span class="mono tabular">@context.Item.Date.ToString("yyyy-MM-dd")</span>
            </CellTemplate>
        </TemplateColumn>

        <TemplateColumn Title="Price"
                        HeaderStyle="width:105px;text-align:right"
                        CellStyle="width:105px;text-align:right"
                        SortBy="@(x => x.Price)">
            <CellTemplate>
                <span class="mono tabular">@context.Item.Price.ToString("N2", CultureInfo.InvariantCulture) €</span>
            </CellTemplate>
        </TemplateColumn>

        <TemplateColumn Title="Debt"
                        HeaderStyle="width:105px;text-align:right"
                        CellStyle="width:105px;text-align:right"
                        SortBy="@(x => x.Debt)">
            <CellTemplate>
                <span class="mono tabular @DebtClass(context.Item)">@context.Item.Debt.ToString("N2", CultureInfo.InvariantCulture) €</span>
            </CellTemplate>
        </TemplateColumn>

        <TemplateColumn Title="Customer" SortBy="@(x => x.Customer)">
            <CellTemplate>
                <span class="customer-name">@context.Item.Customer</span>
            </CellTemplate>
        </TemplateColumn>

        <TemplateColumn Title=""
                        HeaderStyle="width:44px"
                        CellStyle="width:44px"
                        Sortable="false">
            <CellTemplate>
                <span class="flags">
                    @if (context.Item.HasDebt) { <span class="cust__flag cust__flag--debt" title="Has debt">€</span> }
                    @if (context.Item.IsVip)   { <span class="cust__flag cust__flag--vip"  title="VIP">★</span> }
                    @if (context.Item.HasNote) { <span class="cust__flag cust__flag--note" title="Internal note">!</span> }
                </span>
            </CellTemplate>
        </TemplateColumn>

        <TemplateColumn Title="Status"
                        HeaderStyle="width:130px"
                        CellStyle="width:130px"
                        SortBy="@(x => x.Status)">
            <CellTemplate>
                <span class="chip @StatusChipClass(context.Item.Status)">@context.Item.Status</span>
            </CellTemplate>
        </TemplateColumn>

        <TemplateColumn Title="Store"
                        HeaderStyle="width:90px"
                        CellStyle="width:90px"
                        SortBy="@(x => x.Store)">
            <CellTemplate>
                <span>@context.Item.Store</span>
            </CellTemplate>
        </TemplateColumn>

        <TemplateColumn Title="Address" SortBy="@(x => x.Address)">
            <CellTemplate>
                <span class="address-cell">@context.Item.Address</span>
            </CellTemplate>
        </TemplateColumn>

    </Columns>
</MudDataGrid>

@code {
    [Parameter] public IReadOnlyList<OrderRow> Orders { get; set; } = [];
    [Parameter] public long? SelectedId { get; set; }
    [Parameter] public EventCallback<OrderRow> OnRowClick { get; set; }

    private string GetRowClass(OrderRow row, int _) =>
        row.Id == SelectedId ? "is-selected" : string.Empty;

    private void OnRowClicked(DataGridRowClickEventArgs<OrderRow> args) =>
        OnRowClick.InvokeAsync(args.Item);

    private static string StatusChipClass(string status) => status switch
    {
        "Įvestas"      => "chip--entered",
        "Patvirtintas" => "chip--approved",
        "Gaminamas"    => "chip--inprogress",
        "Pagamintas"   => "chip--made",
        "Filialui"     => "chip--shipped",
        "Atiduotas"    => "chip--delivered",
        "Sustabdytas"  => "chip--paused",
        _              => "chip--entered"
    };

    private static string DebtClass(OrderRow row) =>
        row.Debt == 0 ? "debt-zero" : "debt-overdue";
}
