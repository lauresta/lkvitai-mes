@* OrderEmployeesTable — employees with duty dots and avatars *@

<table class="emp-table">
    <thead>
        <tr>
            <th>Employee</th>
            <th>Duty</th>
            <th>Service date</th>
            <th style="text-align:right">Amount</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var emp in Employees)
        {
            <tr class="@emp.DutyClass">
                <td>
                    <span class="emp-avatar">
                        <span class="emp-avatar__initials">@emp.Initials</span>
                        @emp.FullName
                    </span>
                </td>
                <td>
                    <span class="duty-dot"></span>@emp.Duty
                </td>
                <td class="mono">@emp.ServiceDate</td>
                <td style="text-align:right" class="mono tabular">@emp.Amount.ToString("N2", CultureInfo.InvariantCulture) €</td>
            </tr>
        }
    </tbody>
</table>

@code {
    [Parameter] public IReadOnlyList<OrderEmployeeLine> Employees { get; set; } = [];
}
