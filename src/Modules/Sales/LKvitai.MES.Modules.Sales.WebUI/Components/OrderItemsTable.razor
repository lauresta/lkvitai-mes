@* OrderItemsTable — product group rows + accessory rows *@

<table class="items-table">
    <thead>
        <tr>
            <th style="width:40%">Item</th>
            <th>Side</th>
            <th>Color</th>
            <th>Size</th>
            <th>Notes</th>
            <th style="text-align:right">Qty</th>
            <th style="text-align:right">Price</th>
            <th style="text-align:right">Amount</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Items)
        {
            <tr class="@(item.IsAccessory ? "acc-row" : "group-row")">
                <td>
                    @if (item.IsAccessory)
                    {
                        <span class="acc-prefix">↳</span>
                    }
                    @item.Title
                </td>
                <td>@(item.Side ?? "—")</td>
                <td>@(item.Color ?? "—")</td>
                <td class="mono">@(item.WidthHeight ?? "—")</td>
                <td>@(item.Notes ?? "")</td>
                <td style="text-align:right" class="mono tabular">@item.Quantity</td>
                <td style="text-align:right" class="mono tabular">@item.Price.ToString("N2", CultureInfo.InvariantCulture) €</td>
                <td style="text-align:right" class="mono tabular">@item.Amount.ToString("N2", CultureInfo.InvariantCulture) €</td>
            </tr>
        }
    </tbody>
</table>

@code {
    [Parameter] public IReadOnlyList<OrderItemLine> Items { get; set; } = [];
}
