@inherits LayoutComponentBase
@inject AuthenticationStateProvider AuthStateProvider
@using System.Security.Claims

<MudThemeProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<AuthorizeView>
    <Authorized>
        <div class="app-shell">
            <div class="test-strip test-strip--dev">
                <div class="test-strip__main">
                    <span class="icon-warning"></span>
                    <span>Development environment</span>
                    <span class="test-strip__note">· sample data only in S-0</span>
                </div>
                <span class="test-strip__host">sales-webui · dev</span>
            </div>

            <header class="topbar">
                <div class="brand">
                    <div class="brand__mark">MES</div>
                    <div>
                        <div class="brand__name">LKvitai<span>.MES</span></div>
                        <div class="brand__tagline">Sales · Orders</div>
                    </div>
                </div>
                <div class="topbar__separator"></div>
                <div class="topbar__spacer"></div>
                <div class="user-block">
                    <div class="user-block__avatar">@_initials</div>
                    <div>
                        <div class="user-block__name">@_username</div>
                        <div class="user-block__role">Sales</div>
                    </div>
                </div>
            </header>

            @Body
        </div>
    </Authorized>
    <NotAuthorized>
        <RedirectToLogin />
    </NotAuthorized>
</AuthorizeView>

@code {
    private string _username = "";
    private string _initials = "";

    protected override async Task OnInitializedAsync()
    {
        var state = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = state.User;
        var name = user.FindFirstValue(ClaimTypes.Name) ?? user.Identity?.Name ?? "User";
        _username = name;
        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        _initials = parts.Length >= 2
            ? $"{parts[0][0]}{parts[1][0]}"
            : parts.Length == 1 ? $"{parts[0][0]}" : "U";
        _initials = _initials.ToUpper();
    }
}
