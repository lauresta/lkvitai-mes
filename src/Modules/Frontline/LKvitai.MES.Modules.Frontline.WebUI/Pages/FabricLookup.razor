@* FabricLookup — mobile-first single-fabric lookup screen.

   UX baseline: docs/ux/fabric-availability-static-preview.html (mobile panels)
   + Variant A handover: on desktop the mobile UI is rendered inside a 390 px
   phone frame, with an operational sidebar (recent checks, QR to open on
   phone) on the right.

   F-1: payload comes from FrontlineApiClient.GetFabricCardAsync over
   /api/frontline/fabric/{code} (StubFabricQueryService in F-1, SQL adapter in
   F-2). Recent-checks list stays in-memory per-circuit until F-2 wires the
   Frontline_FabricLastChecked table. *@

@page "/"
@page "/fabric"
@page "/fabric/lookup"
@inject FrontlineApiClient Api

<PageTitle>Frontline · Fabric availability</PageTitle>

<main class="fa-main">

    <div class="fa-page-head">
        <div>
            <div class="fa-eyebrow mono">Frontline · Fabric availability</div>
            <h1>Fabric availability</h1>
            <p>
                Mobile-first lookup for the sales floor. Optimised for phone use —
                use the desktop low-stock list for purchasing and ops.
            </p>
        </div>
    </div>

    <div class="lookup-shell">

        @* The phone-frame column. On mobile (< 980px) this collapses to
           full-width and drops the rounded phone-screen visual. *@
        <div>
            <div class="lookup-frame__label" role="note">
                Optimised for phone use. For live fabric checks on the shop floor,
                open this page on a phone or scan the QR on the right.
            </div>

            <div class="fa-app">
                <FaHeader CurrentMode="lookup" />

                <div class="fa-content">

                    <form class="mobile-search" @onsubmit="@RunCheckAsync" @onsubmit:preventDefault>
                        <label class="mobile-search__input">
                            <svg class="icon-svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                                <circle cx="11" cy="11" r="6.5" />
                                <path d="M21 21l-4.3-4.3" />
                            </svg>
                            <span class="sr-only">Fabric code</span>
                            <input type="text"
                                   placeholder="Enter fabric code…"
                                   autocomplete="off"
                                   value="@_code"
                                   @oninput="OnCodeInput" />
                        </label>
                        <button class="btn-primary" type="submit" disabled="@_busy">
                            @(_busy ? "…" : "Check")
                        </button>
                    </form>

                    @if (_apiError)
                    {
                        <div class="status-block status-block--out" role="alert" style="margin-top:12px">
                            <div class="status-block__icon">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <path d="M12 8v5" />
                                    <circle cx="12" cy="16.5" r="1" fill="currentColor" />
                                    <path d="M12 3l9.5 17H2.5L12 3z" />
                                </svg>
                            </div>
                            <div class="status-block__main">
                                <div class="status-block__primary">Frontline API unreachable</div>
                                <div class="status-block__sub">Try again in a moment, or check the API container.</div>
                            </div>
                        </div>
                    }
                    else if (_notFound && !string.IsNullOrWhiteSpace(_lastQuery))
                    {
                        <div class="status-block status-block--disc" role="status" style="margin-top:12px">
                            <div class="status-block__icon">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <path d="M6 6l12 12M6 18L18 6" />
                                </svg>
                            </div>
                            <div class="status-block__main">
                                <div class="status-block__primary">Fabric '@_lastQuery' not found</div>
                                <div class="status-block__sub">Check the code or scan again.</div>
                            </div>
                        </div>
                    }
                    else if (_result is null)
                    {
                        <section class="empty-card">
                            <div>
                                <div class="empty-illustration">
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                                        <circle cx="11" cy="11" r="6.5" />
                                        <path d="M21 21l-4.3-4.3" />
                                    </svg>
                                </div>
                                <h3>Check availability</h3>
                                <p>Enter a fabric code to see stock, expected delivery and alternatives.</p>
                            </div>
                        </section>

                        @if (_recent.Count > 0)
                        {
                            <div class="fa-section-label">
                                Recent <span class="fa-section-label__count">last @_recent.Count</span>
                            </div>
                            <div class="recent-list">
                                @foreach (var r in _recent)
                                {
                                    var captured = r;
                                    <button class="recent-row"
                                            type="button"
                                            @onclick="@(() => RestoreRecentAsync(captured))">
                                        <span class="recent-row__code">@r.Code</span>
                                        <span class="recent-row__meta">
                                            <span class="mono">@r.WidthMm mm</span>
                                            <span class="chip @StatusChipClass(r.Status) chip--sm">@RecentChipLabel(r)</span>
                                        </span>
                                    </button>
                                }
                            </div>
                        }
                    }
                    else
                    {
                        var widths = _result.Widths;
                        var selected = widths.FirstOrDefault(w => w.WidthMm == _selectedWidth) ?? widths[0];

                        <article class="fabric-card" aria-live="polite">
                            <div class="fabric-hero" role="img" aria-label="@($"{_result.Code} fabric photo")">
                                @if (_result.DiscountPercent is { } d)
                                {
                                    <span class="fabric-hero__ribbon">−@d % · CAMPAIGN</span>
                                }
                            </div>

                            <div class="fabric-body">
                                <div class="fabric-id">
                                    <span class="fabric-id__code">@_result.Code</span>
                                    <span class="fabric-id__width">· @selected.WidthMm mm</span>
                                </div>
                                <p class="fabric-name">@_result.Name</p>

                                <div class="widths-label">Width</div>
                                <div class="widths" role="radiogroup" aria-label="Width">
                                    @foreach (var w in widths)
                                    {
                                        var captured = w;
                                        <button class="width-chip @(w.WidthMm == selected.WidthMm ? "is-active" : "")"
                                                type="button"
                                                aria-pressed="@(w.WidthMm == selected.WidthMm)"
                                                @onclick="@(() => _selectedWidth = captured.WidthMm)">
                                            @w.WidthMm
                                            <span class="width-chip__qty @QtyPillClass(w.Status)">@FormatMeters(w.StockMeters)</span>
                                        </button>
                                    }
                                </div>

                                <div class="status-block @StatusBlockClass(selected.Status)" role="status">
                                    <div class="status-block__icon">
                                        @StatusIcon(selected.Status)
                                    </div>
                                    <div class="status-block__main">
                                        <div class="status-block__primary">
                                            @StatusHeadline(selected.Status) ·
                                            <span class="status-block__qty">@FormatMeters(selected.StockMeters)</span>
                                        </div>
                                        @if (selected.ExpectedDate is not null || selected.IncomingMeters is not null)
                                        {
                                            <div class="status-block__sub">
                                                @if (selected.ExpectedDate is { } d2)
                                                {
                                                    <text>Next delivery <b>@d2.ToString("yyyy-MM-dd")</b></text>
                                                }
                                                @if (selected.IncomingMeters is { } im)
                                                {
                                                    @if (selected.ExpectedDate is not null) { <text> · </text> }
                                                    <span class="chip chip--incoming chip--sm">+ @im m incoming</span>
                                                }
                                            </div>
                                        }
                                    </div>
                                </div>

                                @if (!string.IsNullOrWhiteSpace(_result.Notes))
                                {
                                    <p class="notes">@_result.Notes</p>
                                }

                                <div class="reserve-row">
                                    <button class="btn-secondary"
                                            type="button"
                                            disabled
                                            title="Reserve workflow lands in a later phase">
                                        Reserve <span class="pill">SOON</span>
                                    </button>
                                </div>

                                @if (_result.Alternatives.Count > 0)
                                {
                                    <div class="alt-section">
                                        <div class="alt-head">
                                            <span class="alt-head__label">Alternatives</span>
                                            <span class="alt-head__hint">swipe →</span>
                                        </div>
                                        <div class="alt-scroll">
                                            @foreach (var alt in _result.Alternatives)
                                            {
                                                var captured = alt;
                                                <button class="alt-card"
                                                        type="button"
                                                        @onclick="@(() => OpenAlternativeAsync(captured))">
                                                    <div class="alt-img @AltImgClass(captured.Code)"></div>
                                                    <div class="alt-body">
                                                        <div class="alt-body__code">@alt.Code · @alt.WidthMm</div>
                                                        <div class="alt-body__row">
                                                            <span class="chip @StatusChipClass(alt.Status) chip--sm">
                                                                @FormatMeters(alt.StockMeters)
                                                            </span>
                                                            <span>
                                                                @(alt.ExpectedDate?.ToString("MM-dd") ?? "ready")
                                                            </span>
                                                        </div>
                                                    </div>
                                                </button>
                                            }
                                        </div>
                                    </div>
                                }
                            </div>
                        </article>
                    }

                </div>
            </div>
        </div>

        @* Operational sidebar — visible on desktop only (≥ 980 px), hidden
           via .lookup-shell__sidebar default in fabric.css. *@
        <aside class="lookup-shell__sidebar lookup-sidebar" aria-label="Lookup sidebar">
            <section class="panel">
                <div class="panel__head">
                    <h3>Open on phone</h3>
                    <p>Scan to continue this lookup on the sales-floor handset.</p>
                </div>
                <div class="qr-block">
                    <div class="qr-placeholder" aria-hidden="true"></div>
                    <p class="qr-block__caption">QR will deep-link to this fabric on the mobile lookup once F-2 ships.</p>
                </div>
            </section>

            <section class="panel">
                <div class="panel__head">
                    <h3>Recent checks</h3>
                    <p>Tap to restore the last lookup.</p>
                </div>
                <div class="panel__body">
                    @if (_recent.Count == 0)
                    {
                        <p class="qr-block__caption" style="margin:0">No recent lookups yet.</p>
                    }
                    else
                    {
                        <div class="last-checked-list">
                            @foreach (var r in _recent)
                            {
                                var captured = r;
                                <button class="last-checked-item"
                                        type="button"
                                        style="all:unset; cursor:pointer; display:flex; flex-direction:column; gap:2px; padding:8px 10px; border-left:2px solid var(--n-200); background:var(--n-25)"
                                        @onclick="@(() => RestoreRecentAsync(captured))">
                                    <span class="last-checked-item__code">@r.Code <span class="dim mono">· @r.WidthMm mm</span></span>
                                    <span class="last-checked-item__meta">
                                        <span class="chip @StatusChipClass(r.Status) chip--sm">@RecentChipLabel(r)</span>
                                    </span>
                                </button>
                            }
                        </div>
                    }
                </div>
            </section>
        </aside>

    </div>

</main>

@code {
    /// <summary>Per-circuit recent-check entry. F-2 will replace this with
    /// rows persisted in <c>Frontline_FabricLastChecked</c> so the same list
    /// shows up on every device the operator opens.</summary>
    private sealed record RecentCheck(string Code, int WidthMm, FabricAvailabilityStatus Status, int? StockMeters);

    private string _code = "";
    private string _lastQuery = "";
    private FabricCardDto? _result;
    private int _selectedWidth;
    private bool _busy;
    private bool _apiError;
    private bool _notFound;
    private readonly List<RecentCheck> _recent = new();

    private void OnCodeInput(ChangeEventArgs e) => _code = e.Value?.ToString() ?? "";

    private async Task RunCheckAsync()
    {
        if (string.IsNullOrWhiteSpace(_code))
        {
            _result = null;
            _notFound = false;
            _apiError = false;
            return;
        }

        await LoadAsync(_code, width: null).ConfigureAwait(true);
    }

    private async Task RestoreRecentAsync(RecentCheck r)
    {
        _code = r.Code;
        await LoadAsync(r.Code, r.WidthMm).ConfigureAwait(true);
    }

    private async Task OpenAlternativeAsync(FabricAlternativeDto alt)
    {
        _code = alt.Code;
        await LoadAsync(alt.Code, alt.WidthMm).ConfigureAwait(true);
    }

    private async Task LoadAsync(string code, int? width)
    {
        _busy = true;
        _apiError = false;
        _notFound = false;
        _lastQuery = code.Trim().ToUpperInvariant();
        StateHasChanged();

        try
        {
            var fetched = await Api.GetFabricCardAsync(_lastQuery, width, CancellationToken.None)
                .ConfigureAwait(true);

            switch (fetched.Outcome)
            {
                case FrontlineApiOutcome.Ok when fetched.Value is { Widths.Count: > 0 } card:
                    _result = card;
                    _selectedWidth = card.SelectedWidthMm
                        ?? card.Widths.OrderBy(w => w.WidthMm).First().WidthMm;
                    PushRecent(card, _selectedWidth);
                    break;
                case FrontlineApiOutcome.NotFound:
                    _result = null;
                    _notFound = true;
                    break;
                default:
                    _result = null;
                    _apiError = true;
                    break;
            }
        }
        finally
        {
            _busy = false;
        }
    }

    private void PushRecent(FabricCardDto card, int widthMm)
    {
        var row = card.Widths.FirstOrDefault(w => w.WidthMm == widthMm) ?? card.Widths[0];
        _recent.RemoveAll(r => r.Code == card.Code && r.WidthMm == row.WidthMm);
        _recent.Insert(0, new RecentCheck(card.Code, row.WidthMm, row.Status, row.StockMeters));
        if (_recent.Count > 5)
        {
            _recent.RemoveRange(5, _recent.Count - 5);
        }
    }

    /* ── Display helpers ───────────────────────────────────────── */
    private static string StatusChipClass(FabricAvailabilityStatus s) => s switch
    {
        FabricAvailabilityStatus.Enough       => "chip--ok",
        FabricAvailabilityStatus.Low          => "chip--low",
        FabricAvailabilityStatus.None         => "chip--out",
        FabricAvailabilityStatus.Discontinued => "chip--disc",
        _ => "chip--disc",
    };

    private static string StatusBlockClass(FabricAvailabilityStatus s) => s switch
    {
        FabricAvailabilityStatus.Enough       => "status-block--ok",
        FabricAvailabilityStatus.Low          => "status-block--low",
        FabricAvailabilityStatus.None         => "status-block--out",
        FabricAvailabilityStatus.Discontinued => "status-block--disc",
        _ => "status-block--disc",
    };

    private static string QtyPillClass(FabricAvailabilityStatus s) => s switch
    {
        FabricAvailabilityStatus.Enough => "is-ok",
        FabricAvailabilityStatus.Low    => "is-low",
        FabricAvailabilityStatus.None   => "is-out",
        _ => "",
    };

    private static string StatusHeadline(FabricAvailabilityStatus s) => s switch
    {
        FabricAvailabilityStatus.Enough       => "In stock",
        FabricAvailabilityStatus.Low          => "Low stock",
        FabricAvailabilityStatus.None         => "Out of stock",
        FabricAvailabilityStatus.Discontinued => "Discontinued",
        _ => "Unknown",
    };

    private static string FormatMeters(int? meters) => meters is { } m ? $"{m} m" : "—";

    private static string RecentChipLabel(RecentCheck r) => r.Status switch
    {
        FabricAvailabilityStatus.Enough       => $"OK · {r.StockMeters ?? 0} m",
        FabricAvailabilityStatus.Low          => $"Low · {r.StockMeters ?? 0} m",
        FabricAvailabilityStatus.None         => "Out",
        FabricAvailabilityStatus.Discontinued => "Disc",
        _ => "—",
    };

    private static string AltImgClass(string code)
    {
        var hash = (uint)code.GetHashCode() & 0x3;
        return hash switch
        {
            0 => "",
            1 => "alt-img--blue",
            2 => "alt-img--green",
            _ => "alt-img--red",
        };
    }

    private RenderFragment StatusIcon(FabricAvailabilityStatus s) => @<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        @if (s == FabricAvailabilityStatus.Enough)
        {
            <path d="M5 12l5 5L20 7" />
        }
        else if (s == FabricAvailabilityStatus.Discontinued)
        {
            <path d="M6 6l12 12M6 18L18 6" />
        }
        else
        {
            <path d="M12 8v5" />
            <circle cx="12" cy="16.5" r="1" fill="currentColor" />
            <path d="M12 3l9.5 17H2.5L12 3z" />
        }
    </svg>;
}
