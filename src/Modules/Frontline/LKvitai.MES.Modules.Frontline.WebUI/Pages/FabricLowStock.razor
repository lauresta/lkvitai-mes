@* FabricLowStock — desktop low-stock list for purchasing/ops.

   UX baseline: docs/ux/fabric-availability-static-preview.html (.desktop-panel).
   F-1: rows come from FrontlineApiClient.GetLowStockAsync over
   /api/frontline/fabric/low-stock. The toolbar still drives client-side
   filtering only (server-side filter / sort / paging arrives in F-3 with
   MudDataGrid ServerData and a real low-stock proc derived from the legacy
   web_RemainsAll view).

   Columns (per fabric-availability-codex-rules.md §5):
     Photo · Code · Name · Width · Available (+progress) · Status · ETA
     · Incoming · Alternatives · Last checked · Actions *@

@page "/fabric/low-stock"
@inject FrontlineApiClient Api

<PageTitle>Frontline · Fabric availability · Low stock</PageTitle>

<main class="fa-main">

    <div class="fa-page-head">
        <div>
            <div class="fa-eyebrow mono">Frontline · Fabric availability</div>
            <h1>Low-stock materials</h1>
            <p>
                All fabrics under the selected threshold. Use this list for
                purchasing and operational decisions; for a single live check on
                the sales floor switch to <a class="fabric-link" href="fabric">Lookup</a>.
            </p>
        </div>
        <ModeSwitcher CurrentMode="low-stock" />
    </div>

    <section class="fa-panel" aria-labelledby="ls-title">
        <div class="fa-panel__head">
            <div>
                <h2 id="ls-title">Low-stock materials</h2>
                <p>Server-side filter, sort and paging once F-3 lands. F-1 uses the stub data source.</p>
            </div>
            <span class="mono" style="color:var(--n-500); font-size:11.5px">
                @(_apiError
                    ? "Frontline API unreachable"
                    : $"F-1 · {_rows.Count} rows from /api/frontline/fabric/low-stock")
            </span>
        </div>

        <div class="metrics" role="group" aria-label="Low-stock summary">
            <div class="metric metric--low">
                <span class="metric__label">Below threshold</span>
                <strong class="metric__value">@_metricBelow</strong>
                <span class="metric__delta">low + out + discontinued</span>
            </div>
            <div class="metric metric--out">
                <span class="metric__label">Out of stock</span>
                <strong class="metric__value">@_metricOut</strong>
                <span class="metric__delta">@_metricOutNoEta with no ETA</span>
            </div>
            <div class="metric">
                <span class="metric__label">Expected this week</span>
                <strong class="metric__value">@_metricExpected</strong>
                <span class="metric__delta">@_metricIncoming m incoming</span>
            </div>
            <div class="metric">
                <span class="metric__label">Discontinued</span>
                <strong class="metric__value">@_metricDisc</strong>
                <span class="metric__delta">need replacement</span>
            </div>
        </div>

        <div class="fa-toolbar">
            <label class="field field--search">
                <svg class="field__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <circle cx="11" cy="11" r="6.5" />
                    <path d="M21 21l-4.3-4.3" />
                </svg>
                <input type="search"
                       value="@_search"
                       placeholder="Search code, name, supplier…"
                       @oninput="@(e => _search = e.Value?.ToString() ?? "")" />
                <span class="kbd">/</span>
            </label>

            <LkSelect Label="Threshold"
                      ExtraClass="threshold-field"
                      Value="@_threshold"
                      Options="@ThresholdOptions"
                      ValueChanged="@(v => _threshold = v)" />

            <LkSelect Label="Status"
                      Value="@_statusFilter"
                      Options="@StatusOptions"
                      ValueChanged="@(v => _statusFilter = v)" />

            <LkSelect Label="Width"
                      Value="@_widthFilter"
                      Options="@WidthOptions"
                      ValueChanged="@(v => _widthFilter = v)" />

            <LkSelect Label="Supplier"
                      Value="@_supplierFilter"
                      Options="@SupplierOptions"
                      ValueChanged="@(v => _supplierFilter = v)" />

            <div style="flex:1"></div>

            <button class="btn-xs" type="button" title="Refresh data" @onclick="ReloadAsync" disabled="@_busy">
                @(_busy ? "…" : "↻ Refresh")
            </button>

            <nav class="pagination" aria-label="Pagination">
                <button type="button" disabled>‹</button>
                <button type="button" class="is-active">1</button>
                <button type="button" disabled>›</button>
            </nav>
        </div>

        <div class="fa-table-wrap">
            <table class="lk-table">
                <thead>
                    <tr>
                        <th style="width:48px"></th>
                        <th>Code</th>
                        <th>Name</th>
                        <th>Width</th>
                        <th class="is-num">Available</th>
                        <th>Status</th>
                        <th>Expected</th>
                        <th class="is-num">Incoming</th>
                        <th>Alternatives</th>
                        <th>Last checked</th>
                        <th style="width:1%"></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var r in FilteredRows())
                    {
                        <tr>
                            <td><span class="row-thumb @ThumbClass(r.Code)"></span></td>
                            <td><a class="fabric-link" href="@($"fabric?code={r.Code}")">@r.Code</a></td>
                            <td><span class="fabric-name-cell">@r.Name</span></td>
                            <td class="mono">@r.WidthMm mm</td>
                            <td class="is-meters @MeterStatusClass(r.Status)">
                                <span class="meters-bar">
                                    <span class="meters-bar__num">@r.AvailableMeters m</span>
                                    <span class="meters-bar__track">
                                        <span class="meters-bar__fill @MeterFillClass(r.Status)"
                                              style="width:@(MetersBarPct(r))%"></span>
                                    </span>
                                </span>
                            </td>
                            <td><span class="chip @StatusChipClass(r.Status)">@StatusLabel(r.Status)</span></td>
                            <td class="mono @(r.ExpectedDate is null ? "dim" : "")">
                                @(r.ExpectedDate?.ToString("yyyy-MM-dd") ?? "—")
                            </td>
                            <td class="is-num mono @(r.IncomingMeters is null ? "dim" : "")">
                                @(r.IncomingMeters is { } m ? $"{m} m" : "—")
                            </td>
                            <td class="alts-cell">
                                @if (r.AlternativeCodes.Count == 0)
                                {
                                    <text>—</text>
                                }
                                else
                                {
                                    @for (var i = 0; i < r.AlternativeCodes.Count; i++)
                                    {
                                        if (i > 0) { <text>, </text> }
                                        <a href="@($"fabric?code={r.AlternativeCodes[i]}")">@r.AlternativeCodes[i]</a>
                                    }
                                }
                            </td>
                            <td class="last-checked-cell mono">@FormatLastChecked(r.LastChecked)</td>
                            <td>
                                <div class="actions">
                                    <a class="btn-xs btn-xs--primary" href="@($"fabric?code={r.Code}")">Open</a>
                                    @if (r.CanReplace)
                                    {
                                        <button class="btn-xs" type="button" title="Find a replacement fabric">Replace</button>
                                    }
                                    else if (r.CanNotify)
                                    {
                                        <button class="btn-xs" type="button" title="Notify when stock arrives">Notify</button>
                                    }
                                    else if (r.CanReserve)
                                    {
                                        <button class="btn-xs" type="button" title="Reserve from current stock">Reserve</button>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                    @if (_apiError)
                    {
                        <tr>
                            <td colspan="11" style="text-align:center; color:var(--danger-fg); padding:24px 12px">
                                Frontline API unreachable. Try Refresh in a moment.
                            </td>
                        </tr>
                    }
                    else if (_initialised && !FilteredRows().Any())
                    {
                        <tr>
                            <td colspan="11" style="text-align:center; color:var(--n-500); padding:24px 12px">
                                No fabrics match the current filters.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="fa-table-foot">
            <span>Showing <strong>1–@FilteredRows().Count()</strong> of <strong>@_rows.Count</strong> rows</span>
            <span class="mono" style="opacity:.7">F-1 stub · server paging arrives in F-3</span>
        </div>
    </section>

</main>

@code {
    private static readonly IReadOnlyList<SelectOption> ThresholdOptions =
    [
        new("",    "Any (all)"),
        new("10",  "≤ 10 m"),
        new("25",  "≤ 25 m"),
        new("50",  "≤ 50 m"),
        new("0",   "Out of stock only"),
    ];

    private static readonly IReadOnlyList<SelectOption> StatusOptions =
    [
        new("",     "All low"),
        new("low",  "Low"),
        new("out",  "Out"),
        new("disc", "Discontinued"),
    ];

    private static readonly IReadOnlyList<SelectOption> WidthOptions =
    [
        new("",     "All widths"),
        new("1600", "1600 mm"),
        new("1800", "1800 mm"),
        new("2000", "2000 mm"),
        new("2500", "2500 mm"),
    ];

    private static readonly IReadOnlyList<SelectOption> SupplierOptions =
    [
        new("",       "All suppliers"),
        new("Decora", "Decora"),
        new("Vali",   "Vali"),
        new("Marla",  "Marla"),
    ];

    private string _search          = "";
    private string _threshold       = "";
    private string _statusFilter    = "";
    private string _widthFilter     = "";
    private string _supplierFilter  = "";

    private List<FabricLowStockDto> _rows = new();
    private bool _busy;
    private bool _apiError;
    private bool _initialised;

    private int _metricBelow;
    private int _metricOut;
    private int _metricOutNoEta;
    private int _metricExpected;
    private int _metricIncoming;
    private int _metricDisc;

    protected override async Task OnInitializedAsync()
    {
        await ReloadAsync().ConfigureAwait(true);
    }

    private async Task ReloadAsync()
    {
        _busy = true;
        _apiError = false;
        StateHasChanged();

        try
        {
            // F-1: fetch a single page of every row (stub returns ≤ 6 today).
            // F-3 will switch to MudDataGrid ServerData and push these
            // filters into FabricLowStockQueryParams instead of filtering in-memory.
            var page = await Api
                .GetLowStockAsync(new FabricLowStockQueryParams { Page = 1, PageSize = 200 }, CancellationToken.None)
                .ConfigureAwait(true);

            if (page is null)
            {
                _apiError = true;
                _rows = new();
            }
            else
            {
                _rows = page.Items.ToList();
                RecomputeMetrics();
            }

            _initialised = true;
        }
        finally
        {
            _busy = false;
        }
    }

    private void RecomputeMetrics()
    {
        var weekFromNow = DateOnly.FromDateTime(DateTime.UtcNow.Date.AddDays(7));
        _metricBelow = _rows.Count;
        _metricOut = _rows.Count(r => r.Status == FabricAvailabilityStatus.None);
        _metricOutNoEta = _rows.Count(r => r.Status == FabricAvailabilityStatus.None && r.ExpectedDate is null);
        _metricExpected = _rows.Count(r => r.ExpectedDate is { } d && d <= weekFromNow);
        _metricIncoming = _rows.Sum(r => r.IncomingMeters ?? 0);
        _metricDisc = _rows.Count(r => r.Status == FabricAvailabilityStatus.Discontinued);
    }

    private IEnumerable<FabricLowStockDto> FilteredRows()
    {
        IEnumerable<FabricLowStockDto> q = _rows;

        if (!string.IsNullOrWhiteSpace(_search))
        {
            var needle = _search.Trim();
            q = q.Where(r =>
                r.Code.Contains(needle, StringComparison.OrdinalIgnoreCase) ||
                r.Name.Contains(needle, StringComparison.OrdinalIgnoreCase) ||
                (r.Supplier?.Contains(needle, StringComparison.OrdinalIgnoreCase) ?? false) ||
                r.AlternativeCodes.Any(a => a.Contains(needle, StringComparison.OrdinalIgnoreCase)));
        }

        q = _statusFilter switch
        {
            "low"  => q.Where(r => r.Status == FabricAvailabilityStatus.Low),
            "out"  => q.Where(r => r.Status == FabricAvailabilityStatus.None),
            "disc" => q.Where(r => r.Status == FabricAvailabilityStatus.Discontinued),
            _      => q,
        };

        if (_threshold == "0")
        {
            q = q.Where(r => r.Status == FabricAvailabilityStatus.None);
        }
        else if (int.TryParse(_threshold, out var t))
        {
            q = q.Where(r =>
                r.AvailableMeters <= t ||
                r.Status is FabricAvailabilityStatus.Discontinued or FabricAvailabilityStatus.None);
        }

        if (!string.IsNullOrEmpty(_widthFilter) && int.TryParse(_widthFilter, out var w))
        {
            q = q.Where(r => r.WidthMm == w);
        }

        if (!string.IsNullOrEmpty(_supplierFilter))
        {
            q = q.Where(r =>
                string.Equals(r.Supplier, _supplierFilter, StringComparison.OrdinalIgnoreCase));
        }

        return q;
    }

    private static int MetersBarPct(FabricLowStockDto r)
    {
        if (r.Status == FabricAvailabilityStatus.None) return 0;
        if (r.ThresholdMeters <= 0) return 0;
        var pct = (int)Math.Round(100.0 * r.AvailableMeters / r.ThresholdMeters);
        return Math.Clamp(pct, 0, 100);
    }

    private static string MeterStatusClass(FabricAvailabilityStatus s) => s switch
    {
        FabricAvailabilityStatus.Enough       => "is-ok",
        FabricAvailabilityStatus.Low          => "is-low",
        FabricAvailabilityStatus.None         => "is-out",
        FabricAvailabilityStatus.Discontinued => "is-disc",
        _ => "",
    };

    private static string MeterFillClass(FabricAvailabilityStatus s) => s switch
    {
        FabricAvailabilityStatus.Low          => "is-low",
        FabricAvailabilityStatus.None         => "is-out",
        FabricAvailabilityStatus.Discontinued => "is-disc",
        _ => "",
    };

    private static string StatusChipClass(FabricAvailabilityStatus s) => s switch
    {
        FabricAvailabilityStatus.Enough       => "chip--ok",
        FabricAvailabilityStatus.Low          => "chip--low",
        FabricAvailabilityStatus.None         => "chip--out",
        FabricAvailabilityStatus.Discontinued => "chip--disc",
        _ => "chip--disc",
    };

    private static string StatusLabel(FabricAvailabilityStatus s) => s switch
    {
        FabricAvailabilityStatus.Enough       => "OK",
        FabricAvailabilityStatus.Low          => "Low",
        FabricAvailabilityStatus.None         => "Out",
        FabricAvailabilityStatus.Discontinued => "Discontinued",
        _ => "Unknown",
    };

    private static string ThumbClass(string code) => ((uint)code.GetHashCode() & 0x3) switch
    {
        0 => "",
        1 => "row-thumb--blue",
        2 => "row-thumb--green",
        _ => "row-thumb--red",
    };

    private static string FormatLastChecked(DateTimeOffset? value)
    {
        if (value is null) return "—";
        var v = value.Value;
        var today = DateTime.UtcNow.Date;
        if (v.UtcDateTime.Date == today) return $"today {v.UtcDateTime:HH:mm}";
        if (v.UtcDateTime.Date == today.AddDays(-1)) return $"yesterday {v.UtcDateTime:HH:mm}";
        return v.UtcDateTime.ToString("yyyy-MM-dd");
    }
}
