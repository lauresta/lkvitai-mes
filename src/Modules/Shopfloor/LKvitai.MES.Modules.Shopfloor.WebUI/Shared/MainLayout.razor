@inherits LayoutComponentBase
@inject IJSRuntime JS

<MudThemeProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<PortalAuthenticatedShell>
    <ChildContent>
        <MudLayout Class="lk sf-shell">
            <MudDrawer Class="@($"sidebar {(_collapsed ? "is-collapsed" : "")}")"
                       Variant="DrawerVariant.Persistent"
                       Width="@(_collapsed ? "52px" : "240px")"
                       Elevation="0"
                       @bind-Open="_drawerOpen">

                <div class="sidebar__head">
                    <span class="sidebar__module">
                        <i class="bi bi-tools"></i>
                        @if (!_collapsed)
                        {
                            <span>Shopfloor</span>
                        }
                    </span>
                    <button class="sidebar__collapse"
                            type="button"
                            @onclick="ToggleCollapse"
                            title="@(_collapsed ? "Expand sidebar []]" : "Collapse sidebar [[]")">
                        <i class="bi @(_collapsed ? "bi-chevron-double-right" : "bi-chevron-double-left")"></i>
                    </button>
                </div>

                <NavMenu Collapsed="_collapsed" />

                @if (!_collapsed)
                {
                    <div class="sidebar__footer">
                        <span>Loaded <span class="mono">@_initTime</span></span>
                    </div>
                }
            </MudDrawer>

            <MudMainContent>
                <main class="sf-main">
                    @Body
                </main>
            </MudMainContent>
        </MudLayout>
    </ChildContent>
    <NotAuthorizedContent>
        <RedirectToLogin />
    </NotAuthorizedContent>
</PortalAuthenticatedShell>

@code {
    private bool _drawerOpen = true;
    private bool _collapsed;
    private string _initTime = "";

    private const string CollapseStorageKey = "lkvitai.shopfloor.sidebar.collapsed";

    protected override void OnInitialized()
    {
        _initTime = DateTime.Now.ToString("HH:mm:ss");
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
            return;

        try
        {
            var val = await JS.InvokeAsync<string?>("localStorage.getItem", CollapseStorageKey);
            if (val == "true")
            {
                _collapsed = true;
                StateHasChanged();
            }
        }
        catch
        {
            // localStorage is not available during the prerender pass.
        }
    }

    private async Task ToggleCollapse()
    {
        _collapsed = !_collapsed;

        try
        {
            await JS.InvokeVoidAsync("localStorage.setItem", CollapseStorageKey, _collapsed ? "true" : "false");
        }
        catch
        {
            // Ignore browsers that block localStorage.
        }
    }
}
