@page "/"
@using System.Net.Http.Json
@inject IHttpClientFactory HttpClientFactory

<PageTitle>Scanning · Hello</PageTitle>

<MudStack Spacing="4">
    <MudText Typo="Typo.h3">Hello from Scanning.</MudText>

    <MudText Typo="Typo.body1" Class="mud-text-secondary">
        This is a scaffolded module. There is no business logic yet. Scanning is the
        cross-cutting mobile barcode-lookup surface and is intentionally public for now.
        Once the shared role model is in place this will switch to the portal auth scheme
        and require a scanner identity.
    </MudText>

    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
        <MudChip T="string" Color="Color.Default" Icon="@Icons.Material.Filled.PersonOff">
            anonymous
        </MudChip>
    </MudStack>

    <MudDivider />

    <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.NetworkPing"
                   OnClick="PingApi"
                   Disabled="_isPinging">
            @(_isPinging ? "Pinging…" : "Ping API")
        </MudButton>
        <MudText Typo="Typo.caption" Class="mud-text-secondary">
            Calls <code>GET /api/scan/ping</code> on the Scanning API container.
        </MudText>
    </MudStack>

    @if (_lastResult is not null)
    {
        if (_lastResult.IsSuccess)
        {
            <MudAlert Severity="Severity.Success">
                <div>
                    <strong>@_lastResult.ModuleName</strong> responded at
                    <code>@_lastResult.Timestamp</code>.
                </div>
            </MudAlert>
        }
        else
        {
            <MudAlert Severity="Severity.Error">
                Ping failed: @_lastResult.ErrorMessage
            </MudAlert>
        }
    }
</MudStack>

@code {
    private bool _isPinging;
    private PingResultView? _lastResult;

    private async Task PingApi()
    {
        _isPinging = true;
        _lastResult = null;

        try
        {
            var client = HttpClientFactory.CreateClient("ScanningApi");
            var response = await client.GetAsync("/api/scan/ping");

            if (!response.IsSuccessStatusCode)
            {
                _lastResult = PingResultView.Failure(
                    $"{(int)response.StatusCode} {response.ReasonPhrase}");
                return;
            }

            var payload = await response.Content.ReadFromJsonAsync<PingPayload>();
            _lastResult = payload is null
                ? PingResultView.Failure("Empty response body.")
                : PingResultView.Success(payload.Module, payload.Now);
        }
        catch (Exception ex)
        {
            _lastResult = PingResultView.Failure(ex.Message);
        }
        finally
        {
            _isPinging = false;
        }
    }

    private sealed record PingPayload(string Module, string Now);

    private sealed record PingResultView(bool IsSuccess, string? ModuleName, string? Timestamp, string? ErrorMessage)
    {
        public static PingResultView Success(string moduleName, string timestamp) =>
            new(true, moduleName, timestamp, null);

        public static PingResultView Failure(string errorMessage) =>
            new(false, null, null, errorMessage);
    }
}
