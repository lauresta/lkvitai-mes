@*
    Inline SVG icon set ported 1:1 from the legacy script.js icons map.
    Kept as a Razor component (instead of <img> sprites) so each icon
    inherits currentColor from the module-card hover/scaffold/planned
    states without an extra fetch — same trade-off the static page made.

    Issue #93 wires the icon key from the API-backed module list. The
    render contract here stays string-keyed for stability so an API
    rename never breaks the dashboard outright (unknown keys render an
    empty <svg/> placeholder rather than throw).
*@

<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor"
     stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    @((MarkupString)PathFor(Key))
</svg>

@code {
    [Parameter, EditorRequired] public string Key { get; set; } = string.Empty;

    private static string PathFor(string key) => key switch
