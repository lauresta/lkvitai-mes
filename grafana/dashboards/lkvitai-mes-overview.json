{
  "id": null,
  "uid": "lkvitai-mes-overview",
  "title": "LKvitai MES Overview",
  "description": "Warehouse Management System - SLA, Cache, DB Connections, Capacity",
  "tags": ["lkvitai", "mes", "warehouse"],
  "refresh": "30s",
  "schemaVersion": 39,
  "version": 1,
  "timezone": "browser",
  "time": { "from": "now-24h", "to": "now" },
  "fiscalYearStartMonth": 0,
  "liveNow": false,
  "templating": {
    "list": [
      {
        "name": "job",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(up{job=~\"lkvitai-mes.*\"}, job)",
        "current": { "text": "lkvitai-mes-test", "value": "lkvitai-mes-test" },
        "refresh": 1,
        "sort": 1,
        "includeAll": false,
        "multi": false
      }
    ]
  },
  "panels": [
    {
      "type": "row",
      "title": "SLA",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100
    },
    {
      "id": 1,
      "type": "stat",
      "title": "Uptime",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sla_uptime_percentage{job=\"$job\"}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 99 },
              { "color": "green", "value": 99.9 }
            ]
          },
          "mappings": []
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value_and_name"
      },
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 1 }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "API Response p95",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sla_api_response_time_p95{job=\"$job\"}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "decimals": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 200 },
              { "color": "red", "value": 500 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "value_and_name"
      },
      "gridPos": { "h": 5, "w": 6, "x": 6, "y": 1 }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Projection Lag",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sla_projection_lag_seconds{job=\"$job\"}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "value_and_name"
      },
      "gridPos": { "h": 5, "w": 6, "x": 12, "y": 1 }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Order Fulfillment",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sla_order_fulfillment_rate{job=\"$job\"} * 100"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 90 },
              { "color": "green", "value": 95 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value_and_name"
      },
      "gridPos": { "h": 5, "w": 6, "x": 18, "y": 1 }
    },
    {
      "type": "row",
      "title": "Cache",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 6 },
      "id": 101
    },
    {
      "id": 5,
      "type": "gauge",
      "title": "Cache Hit Rate",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "cache_hit_rate{job=\"$job\"} * 100"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 1,
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "green", "value": 80 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "gridPos": { "h": 7, "w": 5, "x": 0, "y": 7 }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Cache Hits / Misses",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "cache_hit_total{job=\"$job\"}",
          "legendFormat": "Hits"
        },
        {
          "refId": "B",
          "expr": "cache_miss_total{job=\"$job\"}",
          "legendFormat": "Misses"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 20,
            "pointSize": 5,
            "showPoints": "auto"
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Hits" },
            "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "Misses" },
            "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }]
          }
        ]
      },
      "gridPos": { "h": 7, "w": 8, "x": 5, "y": 7 }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Cache Latency",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "cache_latency_ms{job=\"$job\"}",
          "legendFormat": "Latency"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "decimals": 2,
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 15,
            "gradientMode": "scheme"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 20 }
            ]
          },
          "color": { "mode": "continuous-GrYlRd" }
        }
      },
      "gridPos": { "h": 7, "w": 7, "x": 13, "y": 7 }
    },
    {
      "id": 8,
      "type": "stat",
      "title": "Cache Size",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "cache_size{job=\"$job\"}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "value_and_name"
      },
      "gridPos": { "h": 7, "w": 4, "x": 20, "y": 7 }
    },
    {
      "type": "row",
      "title": "PostgreSQL Connection Pool",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "id": 102
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Active / Idle Connections",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "npgsql_connection_active{job=\"$job\"}",
          "legendFormat": "Active"
        },
        {
          "refId": "B",
          "expr": "npgsql_connection_idle{job=\"$job\"}",
          "legendFormat": "Idle"
        },
        {
          "refId": "C",
          "expr": "npgsql_connection_pool_max{job=\"$job\"}",
          "legendFormat": "Pool Max"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 20,
            "pointSize": 5,
            "showPoints": "auto"
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Active" },
            "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "Idle" },
            "properties": [{ "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "Pool Max" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } },
              { "id": "custom.lineStyle", "value": { "fill": "dash", "dash": [10, 10] } },
              { "id": "custom.fillOpacity", "value": 0 }
            ]
          }
        ]
      },
      "gridPos": { "h": 7, "w": 8, "x": 0, "y": 15 }
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Connection Wait Time",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "npgsql_connection_wait_ms{job=\"$job\"}",
          "legendFormat": "Wait"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "decimals": 1,
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 15,
            "gradientMode": "scheme"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "red", "value": 200 }
            ]
          },
          "color": { "mode": "continuous-GrYlRd" }
        }
      },
      "gridPos": { "h": 7, "w": 8, "x": 8, "y": 15 }
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Connection Errors",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "npgsql_connection_errors_total{job=\"$job\"}",
          "legendFormat": "Errors"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 80
          },
          "color": { "fixedColor": "red", "mode": "fixed" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        }
      },
      "gridPos": { "h": 7, "w": 4, "x": 16, "y": 15 }
    },
    {
      "id": 12,
      "type": "gauge",
      "title": "Pool Utilization",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "(npgsql_connection_active{job=\"$job\"} / npgsql_connection_pool_max{job=\"$job\"}) * 100"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 0,
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 60 },
              { "color": "red", "value": 85 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "gridPos": { "h": 7, "w": 4, "x": 20, "y": 15 }
    },
    {
      "type": "row",
      "title": "Capacity",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 22 },
      "id": 103
    },
    {
      "id": 13,
      "type": "stat",
      "title": "Database Size",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "capacity_database_size_gb{job=\"$job\"}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "decgbytes",
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "red", "value": 120 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "value_and_name"
      },
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 23 }
    },
    {
      "id": 14,
      "type": "stat",
      "title": "Events (daily)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "capacity_event_count{job=\"$job\"}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "value_and_name"
      },
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 23 }
    },
    {
      "id": 15,
      "type": "timeseries",
      "title": "API Requests / Hour",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "capacity_api_request_volume_per_hour{job=\"$job\"}",
          "legendFormat": "req/h"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "decimals": 0,
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 25,
            "gradientMode": "opacity"
          },
          "color": { "fixedColor": "purple", "mode": "fixed" }
        }
      },
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 23 }
    },
    {
      "id": 16,
      "type": "gauge",
      "title": "Location Utilization",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "capacity_location_utilization_percent{job=\"$job\"}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 0,
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
